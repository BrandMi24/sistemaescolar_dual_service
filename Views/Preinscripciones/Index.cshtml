@using ControlEscolar.Enums
@model IEnumerable<ControlEscolar.Models.Preinscripcion>

@{
    ViewData["Title"] = "Lista de Preinscripciones";
}

<div class="main-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Lista de Preinscripciones</h2>
        <a asp-action="Create" class="btn btn-primary">Nueva Preinscripción</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Nombre</th>
                    <th>Carrera</th>
                    <th>Contacto</th>
                    <th>Estado</th>
                    <th>Promedio</th>
                    <th>Estatus</th>
                    <th>Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nombre @item.ApellidoPaterno @item.ApellidoMaterno</td>
                        <td>
                            <div class="fw-semibold">@item.CarreraSolicitada</div>
                            @if (!string.IsNullOrWhiteSpace(item.OpcionEducativa))
                            {
                                <small class="text-muted">Opción: @item.OpcionEducativa</small>
                            }
                        </td>
                        <td>
                            <div>@item.Email</div>
                            <small class="text-muted">@item.Telefono</small>
                        </td>
                        <td>@item.Estado</td>
                        <td>@(item.Promedio?.ToString("0.00") ?? "-")</td>
                        <td>
                            @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "StatusValue", item.EstadoPreinscripcion.ToString() }, { "StatusType", "preinscripcion" } })
                        </td>
                        <td>@item.FechaPreinscripcion.ToString("dd/MM/yyyy")</td>
                        <td class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
