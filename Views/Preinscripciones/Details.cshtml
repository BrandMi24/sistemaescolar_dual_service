@using ControlEscolar.Enums
@model ControlEscolar.Models.Preinscripcion

@{
    ViewData["Title"] = "Comprobante de Preinscripción";
}

<div class="main-container">
    <div class="page-header">
        <h1>Comprobante de Preinscripción</h1>
        <p>Folio: @(Model.academiccontrol_preinscription_folio ?? Model.academiccontrol_preinscription_ID.ToString())</p>
    </div>

    <div class="form-container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "StatusValue", Model.academiccontrol_preinscription_state }, { "StatusType", "preinscripcion" } })
            <small class="text-muted">Registrado el @Model.academiccontrol_preinscription_registrationDate.ToString("dd/MM/yyyy HH:mm")</small>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Datos personales</h3>
            <dl class="row">
                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_personaldata_name
                    @Model.academiccontrol_preinscription_personaldata_paternalSurname
                    @Model.academiccontrol_preinscription_personaldata_maternalSurname
                </dd>

                <dt class="col-sm-4">CURP</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_personaldata_CURP</dd>

                <dt class="col-sm-4">Fecha de nacimiento</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_personaldata_birthDate.ToString("dd/MM/yyyy") (@Model.Edad años)
                </dd>

                <dt class="col-sm-4">Sexo</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_personaldata_gender</dd>

                <dt class="col-sm-4">Estado civil</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_personaldata_maritalStatus</dd>
            </dl>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Contacto y domicilio</h3>
            <dl class="row">
                <dt class="col-sm-4">Correo</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_personaldata_email</dd>

                <dt class="col-sm-4">Teléfonos</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_personaldata_phone
                    <br /><small class="text-muted">Emergencia (Tutor): @Model.academiccontrol_preinscription_tutor_phone</small>
                </dd>

                <dt class="col-sm-4">Dirección</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_address_street #@Model.academiccontrol_preinscription_address_exteriorNumber, @Model.academiccontrol_preinscription_address_neighborhood<br />
                    @Model.academiccontrol_preinscription_address_municipality, @Model.academiccontrol_preinscription_address_state C.P. @Model.academiccontrol_preinscription_address_zipCode
                </dd>
            </dl>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Salud y otros</h3>
            <dl class="row">
                <dt class="col-sm-4">Institución médica</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_health_medicalService</dd>

                <dt class="col-sm-4">Comunidad indígena</dt>
                <dd class="col-sm-8">
                    @(Model.academiccontrol_preinscription_health_indigenousCommunity ? "Sí" : "No")
                    @if (!string.IsNullOrWhiteSpace(Model.academiccontrol_preinscription_health_indigenousCommunityDescription))
                    {
                        <span> - @Model.academiccontrol_preinscription_health_indigenousCommunityDescription</span>
                    }
                </dd>

                <dt class="col-sm-4">Discapacidad</dt>
                <dd class="col-sm-8">
                    @(Model.academiccontrol_preinscription_health_hasDisability
                                        ? Model.academiccontrol_preinscription_health_disabilityDescription
                                        : "Ninguna")
                </dd>

                <dt class="col-sm-4">¿Tiene hijos?</dt>
                <dd class="col-sm-8">@(Model.academiccontrol_preinscription_health_hasChildren ? "Sí" : "No")</dd>

                <dt class="col-sm-4">Cómo se enteró</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_diffusionMedia</dd>

                <dt class="col-sm-4">Comentarios</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_health_comments</dd>
            </dl>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Académicos y carrera</h3>
            <dl class="row">
                <dt class="col-sm-4">Escuela de egreso</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_academic_originSchool
                    (@Model.academiccontrol_preinscription_academic_schoolMunicipality, @Model.academiccontrol_preinscription_academic_schoolState)
                </dd>

                <dt class="col-sm-4">Promedio</dt>
                <dd class="col-sm-8">@(Model.academiccontrol_preinscription_average?.ToString("0.00") ?? "0.00")</dd>

                <dt class="col-sm-4">Periodo de secundaria</dt>
                <dd class="col-sm-8">
                    @Model.academiccontrol_preinscription_academic_startDate?.ToString("dd/MM/yyyy") -
                    @Model.academiccontrol_preinscription_academic_endDate?.ToString("dd/MM/yyyy")
                </dd>

                <dt class="col-sm-4">Carrera solicitada</dt>
                <dd class="col-sm-8">@Model.academiccontrol_preinscription_careerRequested</dd>
            </dl>
        </div>

        <div class="d-flex justify-content-between mt-4">
            @* <a asp-controller="Preinscripciones" asp-action="Index" class="btn btn-secondary">Volver al listado</a> *@
            @* <a asp-action="Edit" asp-route-id="@Model.academiccontrol_preinscription_ID" class="btn btn-warning">Editar</a> *@
        </div>
    </div>
</div>