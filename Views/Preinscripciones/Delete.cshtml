@model ControlEscolar.Models.Preinscripcion

@{
    ViewData["Title"] = "Eliminar Preinscripción";
}

<div class="main-container">
    <div class="form-container">
        <h2>Confirmar eliminación</h2>
        <p class="text-muted">Esta acción eliminará el preregistro y sus archivos cargados.</p>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Folio:</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">Nombre:</dt>
            <dd class="col-sm-9">@Model.Nombre @Model.ApellidoPaterno @Model.ApellidoMaterno</dd>

            <dt class="col-sm-3">Carrera:</dt>
            <dd class="col-sm-9">@Model.CarreraSolicitada</dd>

            <dt class="col-sm-3">Correo:</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger">Eliminar</button>
            </div>
        </form>
    </div>
</div>
