@using ControlEscolar.Helpers
@model ControlEscolar.Models.Preinscripcion

@{
    ViewData["Title"] = "Nueva Preinscripción";
    Layout = "_Layout";
}

<div class="wizard-wrapper pt-5 mb-5">
    <div class="container">

        <div class="stepper mx-auto mb-5" id="pre-stepper" style="max-width: 800px;">
            <div class="step-badge active" data-step="1">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">1</span></span>
                <span class="step-label txt-title fw-bold text-xs">Aspirante</span>
            </div>
            <div class="step-badge" data-step="2">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">2</span></span>
                <span class="step-label txt-title fw-bold text-xs">Domicilio y Tutor</span>
            </div>
            <div class="step-badge" data-step="3">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">3</span></span>
                <span class="step-label txt-title fw-bold text-xs">Salud</span>
            </div>
            <div class="step-badge" data-step="4">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">4</span></span>
                <span class="step-label txt-title fw-bold text-xs">Secundaria</span>
            </div>
        </div>

        <div class="form-container bg-surface rounded-4 shadow-sm border-theme p-4 p-md-5">
            <form asp-action="Create" enctype="multipart/form-data" id="preinscripcionForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-error-100 txt-error border-error rounded-3"></div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger bg-error-100 txt-error border-error rounded-3 mb-4">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @TempData["ErrorMessage"]
                    </div>
                }

                <div class="wizard-step active" data-step="1">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Datos del Aspirante</h3>
                    <p class="txt-body mb-4 small">Escriba exactamente como aparece en el acta de nacimiento.</p>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Nombre" class="form-label txt-body text-xs fw-bold tracking-wide">NOMBRE(S) *</label>
                            <input asp-for="Nombre" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre del alumno" />
                            <span asp-validation-for="Nombre" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApellidoPaterno" class="form-label txt-body text-xs fw-bold tracking-wide">APELLIDO PATERNO *</label>
                            <input asp-for="ApellidoPaterno" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Apellido paterno" />
                            <span asp-validation-for="ApellidoPaterno" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ApellidoMaterno" class="form-label txt-body text-xs fw-bold tracking-wide">APELLIDO MATERNO</label>
                            <input asp-for="ApellidoMaterno" class="form-control bg-app border-theme txt-title fw-bold" placeholder="Apellido materno" />
                            <span asp-validation-for="ApellidoMaterno" class="txt-error text-xs fw-bold"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="CURP" class="form-label txt-body text-xs fw-bold tracking-wide">CURP *</label>
                            <input asp-for="CURP" class="form-control bg-app border-theme txt-title fw-bold text-uppercase" maxlength="18" required placeholder="XXXXYYYYZZZZ0000AA" />
                            <span asp-validation-for="CURP" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FechaNacimiento" class="form-label txt-body text-xs fw-bold tracking-wide">FECHA DE NACIMIENTO *</label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control bg-app border-theme txt-title fw-bold date-quick" required />
                            <span asp-validation-for="FechaNacimiento" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Sexo" class="form-label txt-body text-xs fw-bold tracking-wide">SEXO *</label>
                            <select asp-for="Sexo" class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Seleccione</option>
                                @foreach (var s in CatalogosHelper.Sexos)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                            <span asp-validation-for="Sexo" class="txt-error text-xs fw-bold"></span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <label asp-for="EstadoCivil" class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO CIVIL</label>
                            <select asp-for="EstadoCivil" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Soltero(a)</option>
                                @foreach (var ec in CatalogosHelper.EstadosCiviles)
                                {
                                    <option value="@ec">@ec</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Email" class="form-label txt-body text-xs fw-bold tracking-wide">CORREO ELECTRÓNICO (PERSONAL O TUTOR) *</label>
                            <input asp-for="Email" type="email" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="correo@ejemplo.com" />
                            <span asp-validation-for="Email" class="txt-error text-xs fw-bold"></span>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-step="2">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Domicilio y Tutor</h3>
                    <p class="txt-body mb-4 small">Información de residencia y datos del padre de familia o responsable legal.</p>

                    <div class="row g-4 mb-4">
                        <div class="col-md-3">
                            <label asp-for="CodigoPostal" class="form-label txt-body text-xs fw-bold tracking-wide">CÓDIGO POSTAL</label>
                            <input asp-for="CodigoPostal" class="form-control bg-app border-theme txt-title fw-bold" placeholder="5 dígitos" maxlength="5" />
                            <span asp-validation-for="CodigoPostal" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Estado" class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO *</label>
                            <select asp-for="Estado" class="form-select bg-app border-theme txt-title fw-bold" data-estado data-municipio-target="Municipio" data-current-value="@Model?.Estado">
                                <option value="">Selecciona un estado</option>
                            </select>
                            <span asp-validation-for="Estado" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Municipio" class="form-label txt-body text-xs fw-bold tracking-wide">MUNICIPIO *</label>
                            <select asp-for="Municipio" class="form-select bg-app border-theme txt-title fw-bold" data-municipio="Municipio" data-current-value="@Model?.Municipio">
                                <option value="">Seleccione un municipio</option>
                            </select>
                            <span asp-validation-for="Municipio" class="txt-error text-xs fw-bold"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label asp-for="Colonia" class="form-label txt-body text-xs fw-bold tracking-wide">COLONIA *</label>
                            <input asp-for="Colonia" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Colonia" />
                            <span asp-validation-for="Colonia" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-5">
                            <label asp-for="Calle" class="form-label txt-body text-xs fw-bold tracking-wide">CALLE *</label>
                            <input asp-for="Calle" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre de la calle" />
                            <span asp-validation-for="Calle" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="NumeroExterior" class="form-label txt-body text-xs fw-bold tracking-wide">NÚMERO *</label>
                            <input asp-for="NumeroExterior" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Ej. 123" />
                            <span asp-validation-for="NumeroExterior" class="txt-error text-xs fw-bold"></span>
                        </div>
                    </div>

                    <div class="col-12 mt-5 mb-3">
                        <h6 class="fw-bold txt-primary-dark border-bottom border-theme pb-2">Datos del Padre, Madre o Tutor</h6>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">NOMBRE COMPLETO DEL TUTOR *</label>
                            <input name="TutorNombre" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre completo del responsable" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">PARENTESCO *</label>
                            <select name="Parentesco" class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Seleccione</option>
                                <option value="Padre">Padre</option>
                                <option value="Madre">Madre</option>
                                <option value="Familiar">Familiar</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">TELÉFONO *</label>
                            <input name="TelefonoEmergencia" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="10 dígitos" />
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-step="3">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Salud y otros datos</h3>

                    <div class="row g-4 mb-4 mt-2">
                        <div class="col-md-6">
                            <label asp-for="ServicioMedico" class="form-label txt-body text-xs fw-bold tracking-wide">INSTITUCIÓN MÉDICA</label>
                            <select asp-for="ServicioMedico" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Ninguna / No sabe</option>
                                @foreach (var sm in CatalogosHelper.ServiciosMedicos)
                                {
                                    <option value="@sm">@sm</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DiscapacidadDescripcion" class="form-label txt-body text-xs fw-bold tracking-wide">¿DISCAPACIDAD O TRASTORNO?</label>
                            <select asp-for="DiscapacidadDescripcion" class="form-select bg-app border-theme txt-title fw-bold" id="discapacidadSelect">
                                @foreach (var d in CatalogosHelper.Discapacidades)
                                {
                                    <option value="@d">@d</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿PERTENECE A COMUNIDAD INDÍGENA? *</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input form-check-custom" type="radio" name="ComunidadIndigena" value="true" id="comIndSi" required>
                                    <label class="form-check-label fw-bold txt-title" for="comIndSi">Sí</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input form-check-custom" type="radio" name="ComunidadIndigena" value="false" id="comIndNo" checked data-toggle-target="#comunidadDescripcionGroup" data-toggle-value="true">
                                    <label class="form-check-label fw-bold txt-title" for="comIndNo">No</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6" id="comunidadDescripcionGroup" style="display:none;">
                            <label asp-for="ComunidadIndigenaDescripcion" class="form-label txt-body text-xs fw-bold tracking-wide">¿CUÁL?</label>
                            <input asp-for="ComunidadIndigenaDescripcion" class="form-control bg-app border-theme txt-title fw-bold" placeholder="Huichol, etc." />
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Comentarios" class="form-label txt-body text-xs fw-bold tracking-wide">ALERGIAS O COMENTARIOS MÉDICOS ADICIONALES</label>
                            <textarea asp-for="Comentarios" class="form-control bg-app border-theme txt-title fw-bold" rows="3" placeholder="Información que la escuela deba saber para el cuidado del alumno..."></textarea>
                        </div>
                    </div>
                </div>

                <div class="wizard-step" data-step="4">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Datos Académicos (Secundaria)</h3>
                    <p class="txt-body mb-4 small">Información sobre la escuela de donde egresa el aspirante.</p>

                    <div class="row g-4 mb-4 mt-1">
                        <div class="col-md-6">
                            <label asp-for="EscuelaProcedencia" class="form-label txt-body text-xs fw-bold tracking-wide">SECUNDARIA DE PROCEDENCIA *</label>
                            <input asp-for="EscuelaProcedencia" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre de la secundaria" />
                            <span asp-validation-for="EscuelaProcedencia" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="EstadoEscuela" class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO *</label>
                            <select asp-for="EstadoEscuela" class="form-select bg-app border-theme txt-title fw-bold" data-estado data-municipio-target="MunicipioEscuela" data-current-value="@Model?.EstadoEscuela">
                                <option value="">Seleccione</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MunicipioEscuela" class="form-label txt-body text-xs fw-bold tracking-wide">MUNICIPIO *</label>
                            <select asp-for="MunicipioEscuela" class="form-select bg-app border-theme txt-title fw-bold" data-municipio="MunicipioEscuela" data-current-value="@Model?.MunicipioEscuela">
                                <option value="">Seleccione un municipio</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CLAVE DE CENTRO DE TRABAJO (CCT)</label>
                            <input name="CCT" class="form-control bg-app border-theme txt-title fw-bold text-uppercase" placeholder="EJ. 28DES0000X" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="InicioBachillerato" class="form-label txt-body text-xs fw-bold tracking-wide">INICIO SECUNDARIA</label>
                            <input asp-for="InicioBachillerato" type="date" class="form-control bg-app border-theme txt-title fw-bold date-quick" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FinBachillerato" class="form-label txt-body text-xs fw-bold tracking-wide">EGRESO SECUNDARIA</label>
                            <input asp-for="FinBachillerato" type="date" class="form-control bg-app border-theme txt-title fw-bold date-quick" />
                        </div>
                    </div>

                    <div class="col-12 mt-5 mb-3">
                        <h6 class="fw-bold txt-primary-dark border-bottom border-theme pb-2">Solicitud de Ingreso a Preparatoria</h6>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label asp-for="CarreraSolicitada" class="form-label txt-body text-xs fw-bold tracking-wide">ESPECIALIDAD SOLICITADA *</label>
                            <select asp-for="CarreraSolicitada" class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Selecciona una opción</option>
                                @foreach (var c in CatalogosHelper.Carreras)
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                            <span asp-validation-for="CarreraSolicitada" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Promedio" class="form-label txt-body text-xs fw-bold tracking-wide">PROMEDIO FINAL *</label>
                            <input asp-for="Promedio" type="number" step="0.01" min="0" max="10" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Ej. 8.5" />
                            <span asp-validation-for="Promedio" class="txt-error text-xs fw-bold"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MedioDifusion" class="form-label txt-body text-xs fw-bold tracking-wide">¿CÓMO SE ENTERÓ?</label>
                            <select asp-for="MedioDifusion" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Seleccione</option>
                                @foreach (var md in CatalogosHelper.MediosDifusion)
                                {
                                    <option value="@md">@md</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top border-theme">
                    <button type="button" class="btn btn-ghost-sep px-4" id="prevStep" disabled>
                        <i class="bi bi-arrow-left me-2"></i> Anterior
                    </button>
                    <div class="d-flex gap-3">
                        <button type="button" class="btn btn-primary-sep px-5" id="nextStep">
                            Siguiente <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                        @* <button type="submit" class="btn btn-primary-sep px-5 d-none" id="submitBtn" style="background-color: var(--success-700);">
                            <i class="bi bi-check2-circle me-2"></i> Enviar Solicitud
                        </button> *@
                        <button type="button" class="btn btn-primary-sep px-5 d-none" id="submitBtn" style="background-color: var(--success-700);">
                            <i class="bi bi-check2-circle me-2"></i> Enviar Solicitud
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="text-center mt-5 txt-body pb-4 fw-bold text-xxs tracking-wide opacity-50">
            SISTEMA INTEGRAL ESCOLAR © 2026 - TODOS LOS DERECHOS RESERVADOS
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            const nextBtn = document.getElementById('nextStep');
            const prevBtn = document.getElementById('prevStep');
            const submitBtn = document.getElementById('submitBtn');
            const steps = document.querySelectorAll('.wizard-step');
            const stepBadges = document.querySelectorAll('.step-badge');

            let currentStep = 1;
            const totalSteps = steps.length;

            function updateUI() {
                steps.forEach((step) => {
                    if (parseInt(step.getAttribute('data-step')) === currentStep) {
                        step.classList.add('active');
                    } else {
                        step.classList.remove('active');
                    }
                });

                stepBadges.forEach((badge, index) => {
                    const stepNum = index + 1;
                    badge.classList.remove('active', 'completed');
                    const numSpan = badge.querySelector('.step-num');
                    const icon = badge.querySelector('.completed-icon');

                    if (stepNum < currentStep) {
                        badge.classList.add('completed');
                        if (numSpan) numSpan.classList.add('d-none');
                        if (icon) icon.classList.remove('d-none');
                    } else if (stepNum === currentStep) {
                        badge.classList.add('active');
                        if (numSpan) numSpan.classList.remove('d-none');
                        if (icon) icon.classList.add('d-none');
                    } else {
                        if (numSpan) numSpan.classList.remove('d-none');
                        if (icon) icon.classList.add('d-none');
                    }
                });

                if(prevBtn) prevBtn.disabled = (currentStep === 1);

                if (currentStep === totalSteps) {
                    if(nextBtn) nextBtn.classList.add('d-none');
                    if(submitBtn) submitBtn.classList.remove('d-none');
                } else {
                    if(nextBtn) nextBtn.classList.remove('d-none');
                    if(submitBtn) submitBtn.classList.add('d-none');
                }
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', () => {
                    if (currentStep < totalSteps) {
                        currentStep++;
                        updateUI();
                    }
                });
            }

            if (prevBtn) {
                prevBtn.addEventListener('click', () => {
                    if (currentStep > 1) {
                        currentStep--;
                        updateUI();
                    }
                });
            }

            updateUI();


        const CreateUrl = '@Url.Content("~/Preinscripciones/Create")';

                    document.getElementById('submitBtn').addEventListener('click', async function () {
            const form = document.getElementById('preinscripcionForm');
            const formData = new FormData(form);

            try {
                const response = await fetch(CreateUrl, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    const contentType = response.headers.get('Content-Type');

                    if (contentType && contentType.includes('application/pdf')) {
                        // Es un PDF, descargarlo
                        const blob = await response.blob();
                        const url = window.URL.createObjectURL(blob);
                        const a = document.createElement('a');

                        // Obtener nombre del archivo del header
                        const disposition = response.headers.get('Content-Disposition');
                        let fileName = 'FichaPreinscripcion.pdf';
                        if (disposition) {
                            const match = disposition.match(/filename="?([^"]+)"?/);
                            if (match) fileName = match[1];
                        }

                        a.href = url;
                        a.download = fileName;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        window.URL.revokeObjectURL(url);

                                const folio = response.headers.get('X-Folio');
        const detailsUrl = response.headers.get('X-Details-Url');

        // Guardar mensaje en sessionStorage para mostrarlo en la siguiente página
        sessionStorage.setItem('successMessage', `Preinscripción registrada exitosamente. Su folio es: ${folio}`);

        // Redirigir a Details
        window.location.href = detailsUrl;

                    } else if (response.redirected) {
                        window.location.href = response.url;
                    } else {
                        window.location.href = response.url;
                    }
                } else {
                    console.error('Error en el servidor:', response.status);
                }
            } catch (error) {
                console.error('Error al enviar:', error);
            }
        });
        });
    </script>
}

