@using ControlEscolar.Helpers
@model ControlEscolar.Models.Preinscripcion

@{
    ViewData["Title"] = "Nueva Preinscripción";
    Layout = "_Layout";
}

<div class="wizard-wrapper pt-5 mb-5">
    <div class="container">

        <div class="stepper mx-auto mb-5" id="pre-stepper" style="max-width: 800px;">
            <div class="step-badge active" data-step="1">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">1</span></span>
                <span class="step-label txt-title fw-bold text-xs">Aspirante</span>
            </div>
            <div class="step-badge" data-step="2">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">2</span></span>
                <span class="step-label txt-title fw-bold text-xs">Domicilio y Tutor</span>
            </div>
            <div class="step-badge" data-step="3">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">3</span></span>
                <span class="step-label txt-title fw-bold text-xs">Salud</span>
            </div>
            <div class="step-badge" data-step="4">
                <span class="step-number"><i class="bi bi-check-lg completed-icon d-none"></i><span class="step-num">4</span></span>
                <span class="step-label txt-title fw-bold text-xs">Secundaria</span>
            </div>
        </div>

        <div class="form-container bg-surface rounded-4 shadow-sm border-theme p-4 p-md-5">
            <form asp-action="Create" enctype="multipart/form-data" id="preinscripcionForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-error-100 txt-error border-error rounded-3"></div>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger bg-error-100 txt-error border-error rounded-3 mb-4">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @TempData["ErrorMessage"]
                    </div>
                }

                @* PASO 1: DATOS DEL ASPIRANTE *@
                <div class="wizard-step active" data-step="1">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Datos del Aspirante</h3>
                    <p class="txt-body mb-4 small">Escriba exactamente como aparece en el acta de nacimiento.</p>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">NOMBRE(S) *</label>
                            <input name="academiccontrol_preinscription_personaldata_name" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre del alumno" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">APELLIDO PATERNO *</label>
                            <input name="academiccontrol_preinscription_personaldata_paternalSurname" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Apellido paterno" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">APELLIDO MATERNO</label>
                            <input name="academiccontrol_preinscription_personaldata_maternalSurname" class="form-control bg-app border-theme txt-title fw-bold" placeholder="Apellido materno" />
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CURP *</label>
                            <input name="academiccontrol_preinscription_personaldata_CURP" class="form-control bg-app border-theme txt-title fw-bold text-uppercase" maxlength="18" required placeholder="XXXXYYYYZZZZ0000AA" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">FECHA DE NACIMIENTO *</label>
                            @{
                                var maxFechaNac = DateTime.Today.AddYears(-15).ToString("yyyy-MM-dd");
                                var minFechaNac = DateTime.Today.AddYears(-70).ToString("yyyy-MM-dd");
                            }
                            <input name="academiccontrol_preinscription_personaldata_birthDate"
                                   type="date"
                                   class="form-control bg-app border-theme txt-title fw-bold date-quick"
                                   required
                                   min="@minFechaNac"
                                   max="@maxFechaNac"
                                   title="El aspirante debe tener entre 15 y 70 años de edad" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">SEXO *</label>
                            <select name="academiccontrol_preinscription_personaldata_gender" class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Seleccione</option>
                                @foreach (var s in CatalogosHelper.Sexos)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO CIVIL</label>
                            <select name="academiccontrol_preinscription_personaldata_maritalStatus" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Soltero(a)</option>
                                @foreach (var ec in CatalogosHelper.EstadosCiviles)
                                {
                                    <option value="@ec">@ec</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CORREO ELECTRÓNICO *</label>
                            <input name="academiccontrol_preinscription_personaldata_email" type="email" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="correo@ejemplo.com" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">TELÉFONO PERSONAL</label>
                            <input name="academiccontrol_preinscription_personaldata_phone" class="form-control bg-app border-theme txt-title fw-bold" placeholder="10 dígitos" />
                        </div>
                    </div>
                </div>

                @* PASO 2: DOMICILIO Y TUTOR *@
                <div class="wizard-step" data-step="2">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Domicilio y Tutor</h3>
                    <p class="txt-body mb-4 small">Información de residencia y datos del padre de familia o responsable legal.</p>

                    <div class="row g-4 mb-4">
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CÓDIGO POSTAL</label>
                            <input name="academiccontrol_preinscription_address_zipCode" class="form-control bg-app border-theme txt-title fw-bold" placeholder="5 dígitos" maxlength="5" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO *</label>
                            <select name="academiccontrol_preinscription_address_state" class="form-select bg-app border-theme txt-title fw-bold" data-estado data-municipio-target="Municipio">
                                <option value="">Selecciona un estado</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">MUNICIPIO *</label>
                            <select name="academiccontrol_preinscription_address_municipality" id="Municipio" class="form-select bg-app border-theme txt-title fw-bold" data-municipio="Municipio">
                                <option value="">Seleccione un municipio</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">COLONIA *</label>
                            <input name="academiccontrol_preinscription_address_neighborhood" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Colonia" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CALLE *</label>
                            <input name="academiccontrol_preinscription_address_street" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre de la calle" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">NÚMERO *</label>
                            <input name="academiccontrol_preinscription_address_exteriorNumber" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Ej. 123" />
                        </div>
                    </div>

                    <div class="col-12 mt-5 mb-3">
                        <h6 class="fw-bold txt-primary-dark border-bottom border-theme pb-2">Datos del Padre, Madre o Tutor</h6>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">NOMBRE COMPLETO DEL TUTOR *</label>
                            <input name="academiccontrol_preinscription_tutor_fullName" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre completo del responsable" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">PARENTESCO *</label>
                            <select name="academiccontrol_preinscription_tutor_relationship" class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Seleccione</option>
                                <option value="Padre">Padre</option>
                                <option value="Madre">Madre</option>
                                <option value="Familiar">Familiar</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">TELÉFONO *</label>
                            <input name="academiccontrol_preinscription_tutor_phone" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="10 dígitos" />
                        </div>
                    </div>
                </div>

                @* PASO 3: SALUD Y OTROS DATOS *@
                <div class="wizard-step" data-step="3">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Salud y otros datos</h3>

                    <div class="row g-4 mb-4 mt-2">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">INSTITUCIÓN MÉDICA</label>
                            <select name="academiccontrol_preinscription_health_medicalService" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Ninguna / No sabe</option>
                                @foreach (var sm in CatalogosHelper.ServiciosMedicos)
                                {
                                    <option value="@sm">@sm</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿DISCAPACIDAD O TRASTORNO?</label>
                            <select name="academiccontrol_preinscription_health_disabilityDescription" class="form-select bg-app border-theme txt-title fw-bold" id="discapacidadSelect">
                                @foreach (var d in CatalogosHelper.Discapacidades)
                                {
                                    <option value="@d">@d</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿TIENE HIJOS? *</label>
                            <div class="d-flex gap-3 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="academiccontrol_preinscription_health_hasChildren" value="true" id="hijosSi">
                                    <label class="form-check-label fw-bold txt-title" for="hijosSi">Sí</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="academiccontrol_preinscription_health_hasChildren" value="false" id="hijosNo" checked>
                                    <label class="form-check-label fw-bold txt-title" for="hijosNo">No</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿PERTENECE A COMUNIDAD INDÍGENA? *</label>
                            <div class="d-flex gap-4 mt-2">
                                <div class="form-check">
                                    <input class="form-check-input form-check-custom" type="radio" name="academiccontrol_preinscription_health_indigenousCommunity" value="true" id="comIndSi" required>
                                    <label class="form-check-label fw-bold txt-title" for="comIndSi">Sí</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input form-check-custom" type="radio" name="academiccontrol_preinscription_health_indigenousCommunity" value="false" id="comIndNo" checked>
                                    <label class="form-check-label fw-bold txt-title" for="comIndNo">No</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6" id="comunidadDescripcionGroup" style="display:none;">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿CUÁL?</label>
                            <input name="academiccontrol_preinscription_health_indigenousCommunityDescription" class="form-control bg-app border-theme txt-title fw-bold" placeholder="Especifique comunidad" />
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">ALERGIAS O COMENTARIOS MÉDICOS ADICIONALES</label>
                            <textarea name="academiccontrol_preinscription_health_comments" class="form-control bg-app border-theme txt-title fw-bold" rows="3" placeholder="Información relevante para el cuidado del alumno..."></textarea>
                        </div>
                    </div>
                </div>

                @* PASO 4: DATOS ACADÉMICOS *@
                <div class="wizard-step" data-step="4">
                    <h3 class="fw-bold mb-1 txt-primary-dark">Datos Académicos (Secundaria)</h3>
                    <p class="txt-body mb-4 small">Información sobre la escuela de donde egresa el aspirante.</p>

                    <div class="row g-4 mb-4 mt-1">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">SECUNDARIA DE PROCEDENCIA *</label>
                            <input name="academiccontrol_preinscription_academic_originSchool" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Nombre de la secundaria" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO ESCUELA *</label>
                            <select name="academiccontrol_preinscription_academic_schoolState" class="form-select bg-app border-theme txt-title fw-bold" data-estado data-municipio-target="MunicipioEscuela">
                                <option value="">Seleccione</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">MUNICIPIO ESCUELA *</label>
                            <select name="academiccontrol_preinscription_academic_schoolMunicipality" id="MunicipioEscuela" class="form-select bg-app border-theme txt-title fw-bold" data-municipio="MunicipioEscuela">
                                <option value="">Seleccione</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">CLAVE DE CENTRO DE TRABAJO (CCT)</label>
                            <input name="academiccontrol_preinscription_academic_CCT" class="form-control bg-app border-theme txt-title fw-bold text-uppercase" placeholder="EJ. 28DES0000X" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">INICIO SECUNDARIA</label>
                            <input id="startDateSecundaria"
                                   name="academiccontrol_preinscription_academic_startDate"
                                   type="date"
                                   class="form-control bg-app border-theme txt-title fw-bold date-quick" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">EGRESO SECUNDARIA</label>
                            <input id="endDateSecundaria"
                                   name="academiccontrol_preinscription_academic_endDate"
                                   type="date"
                                   class="form-control bg-app border-theme txt-title fw-bold date-quick"
                                   title="Debe ser exactamente 3 años después del inicio" />
                        </div>
                    </div>

                    <div class="col-12 mt-5 mb-3">
                        <h6 class="fw-bold txt-primary-dark border-bottom border-theme pb-2">Solicitud de Ingreso a Preparatoria</h6>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">ESPECIALIDAD SOLICITADA *</label>
                            @{
                                var carrerasDisponibles = ViewBag.CarrerasDisponibles as List<string> ?? new List<string>();
                            }
                            <select name="academiccontrol_preinscription_careerRequested"
                                    class="form-select bg-app border-theme txt-title fw-bold" required>
                                <option value="">Selecciona una opción</option>
                                @if (!carrerasDisponibles.Any())
                                {
                                    <option disabled value="">No hay carreras disponibles en este momento</option>
                                }
                                else
                                {
                                    foreach (var c in carrerasDisponibles)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                }
                            </select>
                           
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">PROMEDIO FINAL *</label>
                            <input name="academiccontrol_preinscription_average" type="number" step="0.01" min="0" max="10" class="form-control bg-app border-theme txt-title fw-bold" required placeholder="Ej. 8.5" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label txt-body text-xs fw-bold tracking-wide">¿CÓMO SE ENTERÓ?</label>
                            <select name="academiccontrol_preinscription_diffusionMedia" class="form-select bg-app border-theme txt-title fw-bold">
                                <option value="">Seleccione</option>
                                @foreach (var md in CatalogosHelper.MediosDifusion)
                                {
                                    <option value="@md">@md</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                @* NAVEGACIÓN *@
                <div class="d-flex justify-content-between align-items-center mt-5 pt-4 border-top border-theme">
                    <button type="button" class="btn btn-ghost-sep px-4" id="prevStep" disabled>
                        <i class="bi bi-arrow-left me-2"></i> Anterior
                    </button>
                    <div class="d-flex gap-3">
                        <button type="button" class="btn btn-primary-sep px-5" id="nextStep">
                            Siguiente <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                        <button type="button" class="btn btn-primary-sep px-5 d-none" id="submitBtn" style="background-color: var(--success-700);">
                            <i class="bi bi-check2-circle me-2"></i> Enviar Solicitud
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="text-center mt-5 txt-body pb-4 fw-bold text-xxs tracking-wide opacity-50">
            SISTEMA INTEGRAL ESCOLAR © 2026 - TODOS LOS DERECHOS RESERVADOS
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nextBtn = document.getElementById('nextStep');
            const prevBtn = document.getElementById('prevStep');
            const submitBtn = document.getElementById('submitBtn');
            const steps = document.querySelectorAll('.wizard-step');
            const stepBadges = document.querySelectorAll('.step-badge');
            let currentStep = 1;
            const totalSteps = steps.length;

            function updateUI() {
                steps.forEach(s => s.classList.toggle('active', parseInt(s.dataset.step) === currentStep));
                stepBadges.forEach((badge, idx) => {
                    const sNum = idx + 1;
                    badge.classList.toggle('active', sNum === currentStep);
                    badge.classList.toggle('completed', sNum < currentStep);
                });
                prevBtn.disabled = currentStep === 1;
                nextBtn.classList.toggle('d-none', currentStep === totalSteps);
                submitBtn.classList.toggle('d-none', currentStep !== totalSteps);
            }

            nextBtn.addEventListener('click', () => { if (currentStep < totalSteps) { currentStep++; updateUI(); } });
            prevBtn.addEventListener('click', () => { if (currentStep > 1) { currentStep--; updateUI(); } });

            // Lógica para mostrar/ocultar descripción de comunidad indígena
            document.getElementsByName('academiccontrol_preinscription_health_indigenousCommunity').forEach(radio => {
                radio.addEventListener('change', (e) => {
                    document.getElementById('comunidadDescripcionGroup').style.display = (e.target.value === 'true') ? 'block' : 'none';
                });
            });

            // ── Intervalo de secundaria: ajuste dinámico de min/max en fecha de egreso ──
            const startSecInput = document.getElementById('startDateSecundaria');
            const endSecInput   = document.getElementById('endDateSecundaria');

            function actualizarLimitesEgreso() {
                const startVal = startSecInput.value;
                if (!startVal) {
                    endSecInput.min = '';
                    endSecInput.max = '';
                    return;
                }
                const start = new Date(startVal + 'T00:00:00'); // evitar offset de zona horaria
                const minEnd = new Date(start);
                minEnd.setFullYear(minEnd.getFullYear() + 3);
                minEnd.setDate(minEnd.getDate() - 30);
                const maxEnd = new Date(start);
                maxEnd.setFullYear(maxEnd.getFullYear() + 3);
                maxEnd.setDate(maxEnd.getDate() + 30);
                endSecInput.min = minEnd.toISOString().split('T')[0];
                endSecInput.max = maxEnd.toISOString().split('T')[0];
                // Si ya tenía un valor fuera del nuevo rango, limpiarlo
                if (endSecInput.value && (endSecInput.value < endSecInput.min || endSecInput.value > endSecInput.max)) {
                    endSecInput.value = '';
                }
            }

            startSecInput.addEventListener('change', actualizarLimitesEgreso);

            // Submit con manejo de PDF y redirección
            submitBtn.addEventListener('click', async function () {
                const form = document.getElementById('preinscripcionForm');
                const formData = new FormData(form);

                // ── Validación cliente: intervalo de secundaria ───────────────────────────
                const startRaw = formData.get('academiccontrol_preinscription_academic_startDate');
                const endRaw   = formData.get('academiccontrol_preinscription_academic_endDate');

                if (startRaw && endRaw) {
                    const startD = new Date(startRaw + 'T00:00:00');
                    const endD   = new Date(endRaw   + 'T00:00:00');
                    const diffDias = (endD - startD) / (1000 * 60 * 60 * 24);

                    if (endD <= startD) {
                        alert('⚠️ La fecha de egreso de secundaria debe ser posterior a la de inicio.');
                        return;
                    }
                    if (diffDias < 1065 || diffDias > 1125) {
                        alert('⚠️ El intervalo entre inicio y egreso de secundaria debe ser de exactamente 3 años.');
                        return;
                    }
                }
                // ─────────────────────────────────────────────────────────────────────────

                const actionUrl = '@Url.Action("Create", "Preinscripciones")';

                try {
                    const response = await fetch(actionUrl, {
                        method: 'POST',
                        body: formData,
                        headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                    });

                    if (response.ok) {
                        const contentType = response.headers.get('Content-Type');
                        if (contentType && contentType.includes('application/pdf')) {
                            const blob = await response.blob();
                            const url = window.URL.createObjectURL(blob);
                            const a = document.createElement('a');
                            a.href = url;
                            a.download = 'FichaPreinscripcion.pdf';
                            a.click();
                            window.location.href = response.headers.get('X-Details-Url') || '/';
                        } else {
                            window.location.href = response.url;
                        }
                    }
                } catch (error) { console.error('Error al enviar:', error); }
            });
        });
    </script>
}