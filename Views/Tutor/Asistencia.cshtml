@{
    ViewData["Title"] = "Control de Asistencia: 7º A";
    Layout = "_LayoutTutor";
}

<div class="d-flex flex-column gap-4" style="min-height: 82vh;">

    <div class="bg-surface p-4 rounded-4 border border-light shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1" style="max-width: 850px;">
            
            <div class="d-flex align-items-center gap-2">
                <span class="text-secondary fw-bold text-xxs tracking-widest text-uppercase">Fecha:</span>
                <input type="date" id="dateFilter" class="form-control border-0 bg-app py-2 px-3 text-xs fw-bold txt-title rounded-3" value="@DateTime.Now.ToString("yyyy-MM-dd")">
            </div>

            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
                <input type="text" id="searchInput" class="form-control border-0 bg-app py-2 ps-5 text-sm fw-medium" placeholder="Buscar por matrícula o nombre...">
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-sm bg-app text-secondary border-0 py-2 px-3 rounded-3" title="Imprimir reporte">
                <i class="bi bi-printer"></i>
            </button>
            <button class="btn-primary-sep border-0 py-2 px-4 text-xs fw-bold tracking-widest shadow-sm" onclick="alert('Asistencia guardada en el sistema.')">
                 GUARDAR LISTA
            </button>
        </div>
    </div>

    <div class="bg-surface p-0 rounded-4 border border-light shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
        <div class="table-responsive flex-grow-1">
            <table class="table table-borderless align-middle mb-0">
                <thead class="bg-app sticky-top" style="z-index: 5;">
                    <tr>
                        <th class="py-3 px-4 text-xxs fw-bold text-uppercase tracking-wider" width="15%">Matrícula</th>
                        <th class="py-3 text-xxs fw-bold text-uppercase tracking-wider" width="40%">Alumno</th>
                        <th class="py-3 text-center text-xxs fw-bold text-uppercase tracking-wider" width="45%">Estado de Asistencia</th>
                    </tr>
                </thead>
                <tbody id="attendanceTableBody">
                    
                    <tr class="border-bottom border-light hover-bg-app data-row">
                        <td class="px-4 py-3">
                            <div class="txt-primary-dark fw-bold text-xs search-target">26001504</div>
                        </td>
                        <td class="search-target">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-sm bg-accent-light txt-primary-dark fw-bold rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:35px; height:35px; font-size: 0.75rem;">
                                    RC
                                </div>
                                <div>
                                    <div class="txt-title fw-bold text-xs text-uppercase mb-0">Roberto Carlos Perez Cadena</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-4">
                            <div class="btn-group w-100 shadow-none border border-light rounded-3 overflow-hidden bg-app">
                                <input type="radio" class="btn-check" name="att_1" id="p1" checked>
                                <label class="btn btn-outline-success border-0 py-2 fw-bold text-xxs tracking-tighter" for="p1">PRESENTE</label>
                                
                                <input type="radio" class="btn-check" name="att_1" id="f1">
                                <label class="btn btn-outline-danger border-0 py-2 fw-bold text-xxs tracking-tighter" for="f1">FALTA</label>
                                
                                <input type="radio" class="btn-check" name="att_1" id="r1">
                                <label class="btn btn-outline-warning border-0 py-2 fw-bold text-xxs tracking-tighter" for="r1">RETARDO</label>
                            </div>
                        </td>
                    </tr>

                    <tr class="border-bottom border-light hover-bg-app data-row">
                        <td class="px-4 py-3">
                            <div class="txt-primary-dark fw-bold text-xs search-target">26001892</div>
                        </td>
                        <td class="search-target">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-sm bg-light text-secondary fw-bold rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:35px; height:35px; font-size: 0.75rem;">
                                    MA
                                </div>
                                <div>
                                    <div class="txt-title fw-bold text-xs text-uppercase mb-0">Miguel Ángel Torres</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-4">
                            <div class="btn-group w-100 shadow-none border border-light rounded-3 overflow-hidden bg-app">
                                <input type="radio" class="btn-check" name="att_2" id="p2">
                                <label class="btn btn-outline-success border-0 py-2 fw-bold text-xxs tracking-tighter" for="p2">PRESENTE</label>
                                
                                <input type="radio" class="btn-check" name="att_2" id="f2" checked>
                                <label class="btn btn-outline-danger border-0 py-2 fw-bold text-xxs tracking-tighter" for="f2">FALTA</label>
                                
                                <input type="radio" class="btn-check" name="att_2" id="r2">
                                <label class="btn btn-outline-warning border-0 py-2 fw-bold text-xxs tracking-tighter" for="r2">RETARDO</label>
                            </div>
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold" style="font-size: 0.65rem;">MOSTRAR:</span>
                <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs" style="width: 70px; cursor: pointer;">
                    <option value="5" selected>5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                </select>
                <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
            </div>

            <nav aria-label="Navegación de asistencia">
                <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    /* Personalización de los botones de asistencia para que se vean más limpios */
    .btn-check:checked + .btn-outline-success { background-color: #E1F7E7 !important; color: #15803D !important; box-shadow: none; }
    .btn-check:checked + .btn-outline-danger { background-color: #FEE2E2 !important; color: #B91C1C !important; box-shadow: none; }
    .btn-check:checked + .btn-outline-warning { background-color: #FEF3C7 !important; color: #92400E !important; box-shadow: none; }
    
    .btn-outline-success, .btn-outline-danger, .btn-outline-warning { color: #6B7280; }
    
    .hover-bg-app:hover { background-color: var(--bg-app); transition: background 0.2s ease; }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;

            function updateTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let rowsPerPage = parseInt($('#rowsPerPage').val());
                let filteredRows = [];

                $('.data-row').each(function () {
                    let text = $(this).find('.search-target').text().toLowerCase();
                    if (text.indexOf(searchTerm) > -1) {
                        filteredRows.push($(this));
                    }
                    $(this).hide();
                });

                let totalRecords = filteredRows.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                if (currentPage > totalPages) currentPage = totalPages;

                let startIndex = (currentPage - 1) * rowsPerPage;
                let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);

                for (let i = startIndex; i < endIndex; i++) {
                    filteredRows[i].show();
                }

                $('#tableInfo').text(totalRecords === 0 ? '0 REGISTROS' : `${startIndex + 1} - ${endIndex} DE ${totalRecords}`);
                renderPagination(totalPages);
            }

            function renderPagination(totalPages) {
                let html = '';
                
                html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage - 1}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>`;

                for (let i = 1; i <= totalPages; i++) {
                    let btnClass = (i === currentPage)
                        ? 'bg-primary-dark text-white shadow-sm'
                        : 'bg-app txt-title hover-bg-light';

                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link border-0 ${btnClass} rounded-2 mx-1 fw-bold text-xxs px-3" href="#" data-page="${i}">${i}</a>
                    </li>`;
                }

                html += `<li class="page-item ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage + 1}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>`;

                $('#paginationControls').html(html);
            }

            $('#searchInput, #rowsPerPage').on('input change', function() {
                currentPage = 1;
                updateTable();
            });

            $('#paginationControls').on('click', '.page-link', function(e) {
                e.preventDefault();
                let page = parseInt($(this).data('page'));
                if (page && !$(this).parent().hasClass('disabled')) {
                    currentPage = page;
                    updateTable();
                }
            });

            updateTable();
        });
    </script>
}