@{
    ViewData["Title"] = "Gestión de Expedientes y Entrevistas";
    Layout = "_LayoutTutor";
}

<div class="d-flex flex-column gap-4" style="min-height: 82vh;">

    <div class="bg-surface p-4 rounded-4 border border-light shadow-sm d-flex flex-column gap-3">
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
            
            <div class="position-relative flex-grow-1" style="max-width: 600px;">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
                <input type="text" id="alumnoSearch" class="form-control border-0 bg-app py-2 ps-5 text-sm fw-medium" placeholder="Buscar por nombre o matrícula...">
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <select id="filterEntrevista" class="form-select border-0 bg-app txt-title fw-bold text-xs" style="width: auto; min-width: 180px;">
                    <option value="todos">TODAS LAS ENTREVISTAS</option>
                    <option value="completa">COMPLETAS</option>
                    <option value="pendiente">PENDIENTES</option>
                </select>

                <select id="filterAcademico" class="form-select border-0 bg-app txt-title fw-bold text-xs" style="width: auto; min-width: 180px;">
                    <option value="todos">TODOS LOS NIVELES</option>
                    <option value="regular">REGULARES</option>
                    <option value="riesgo">EN RIESGO</option>
                </select>
            </div>
        </div>

        <div class="border-top border-light pt-2 mt-1">
            <span class="text-secondary fw-bold text-uppercase tracking-widest" style="font-size: 0.65rem;">
                MOSTRANDO <span id="visibleCount" class="txt-primary-dark">3</span> ALUMNOS EN EL GRUPO 7º A
            </span>
        </div>
    </div>

    <div class="row g-4" id="alumnosGrid">
        
        <div class="col-12 col-md-6 col-xxl-4 alumno-card-wrapper" data-entrevista="completa" data-academico="regular">
            <div class="bg-white p-4 rounded-4 border border-light shadow-sm transition-all h-100 border-top border-4" style="border-top-color: var(--primary-900) !important;">
                <div class="d-flex flex-column align-items-center text-center mb-4">
                    
                    <div class="user-initial-avatar mb-3 shadow-sm" style="width: 60px; height: 60px; font-size: 1.5rem; background-color: var(--accent-100); color: var(--primary-900);">
                        RC
                    </div>

                    <h6 class="txt-title fw-bold mb-1 text-uppercase alumno-nombre">Roberto Carlos Perez Cadena</h6>
                    <div class="text-secondary fw-bold text-xxs mb-3 tracking-widest text-uppercase">
                        MATRÍCULA: <span class="alumno-matricula">26001504</span>
                    </div>

                    <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold status-aceptado">ENTREVISTA COMPLETA</span>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn-primary-sep border-0 py-2 text-xxs fw-bold tracking-widest shadow-sm" onclick="verEntrevista('26001504')">
                        VER ENTREVISTA
                    </button>
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm bg-app text-secondary border-0 flex-grow-1 py-2 rounded-3" onclick="verSeguimiento('26001504')" title="Bitácora">
                            <i class="bi bi-journal-text"></i>
                        </button>
                        <button class="btn btn-sm bg-app text-secondary border-0 flex-grow-1 py-2 rounded-3" data-bs-toggle="modal" data-bs-target="#modalEditar" title="Editar">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        
                        <div class="dropdown flex-grow-1">
                            <button class="btn btn-sm bg-app text-secondary border-0 w-100 py-2 rounded-3" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu border-light shadow-sm text-xxs p-2">
                                <li><a class="dropdown-item fw-bold text-uppercase py-2" href="#">Cambiar Grupo</a></li>
                                <li><a class="dropdown-item fw-bold text-uppercase py-2 text-danger" href="#">Tramitar Baja</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item fw-bold text-uppercase py-2 text-danger" href="#">Remover del Grupo</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xxl-4 alumno-card-wrapper" data-entrevista="pendiente" data-academico="riesgo">
            <div class="bg-white p-4 rounded-4 border border-light shadow-sm transition-all h-100 border-top border-4" style="border-top-color: var(--error-700) !important;">
                <div class="d-flex flex-column align-items-center text-center mb-4">
                    
                    <div class="user-initial-avatar mb-3 shadow-sm" style="width: 60px; height: 60px; font-size: 1.5rem; background-color: var(--error-100); color: var(--error-700);">
                        MA
                    </div>

                    <h6 class="txt-title fw-bold mb-1 text-uppercase alumno-nombre">Miguel Ángel Torres</h6>
                    <div class="text-secondary fw-bold text-xxs mb-3 tracking-widest text-uppercase">
                        MATRÍCULA: <span class="alumno-matricula">26001892</span>
                    </div>

                    <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold bg-app text-secondary border">ENTREVISTA PENDIENTE</span>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-sm bg-app text-dark fw-bold border-0 py-2 text-xxs tracking-widest" onclick="verEntrevista('26001892')">
                        REALIZAR ENTREVISTA
                    </button>
                    
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm bg-app text-secondary border-0 flex-grow-1 py-2 rounded-3" onclick="verSeguimiento('26001892')">
                            <i class="bi bi-journal-text"></i>
                        </button>
                        <button class="btn btn-sm bg-app text-secondary border-0 flex-grow-1 py-2 rounded-3" data-bs-toggle="modal" data-bs-target="#modalEditar">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        <button class="btn btn-sm bg-app text-secondary border-0 flex-grow-1 py-2 rounded-3">
                            <i class="bi bi-three-dots"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header border-bottom border-light p-4">
                <h6 class="modal-title txt-title fw-bold text-uppercase tracking-widest">Editar Datos del Alumno</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-xxs fw-bold text-secondary text-uppercase mb-2 d-block">Nombre(s)</label>
                        <input type="text" class="form-control border-0 bg-app py-2 text-xs fw-bold txt-title" value="Roberto Carlos">
                    </div>
                    <div class="col-md-6">
                        <label class="text-xxs fw-bold text-secondary text-uppercase mb-2 d-block">Apellidos</label>
                        <input type="text" class="form-control border-0 bg-app py-2 text-xs fw-bold txt-title" value="Perez Cadena">
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top border-light p-3">
                <button class="btn-primary-sep border-0 px-4 py-2 text-xxs fw-bold tracking-widest shadow-sm" onclick="ejecutarAccion('Datos actualizados correctamente')">
                    GUARDAR CAMBIOS
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function applyFilters() {
                var search = $("#alumnoSearch").val().toLowerCase();
                var ent = $("#filterEntrevista").val();
                var acad = $("#filterAcademico").val();
                var count = 0;

                $(".alumno-card-wrapper").each(function() {
                    var $card = $(this);
                    var txt = $card.find(".alumno-nombre").text().toLowerCase() + $card.find(".alumno-matricula").text().toLowerCase();
                    
                    var match = txt.indexOf(search) > -1 &&
                                (ent === "todos" || $card.data("entrevista") === ent) &&
                                (acad === "todos" || $card.data("academico") === acad);
                    
                    if (match) {
                        $card.show();
                        count++;
                    } else {
                        $card.hide();
                    }
                });
                $("#visibleCount").text(count);
            }

            $("#alumnoSearch").on("input", applyFilters);
            $("#filterEntrevista, #filterAcademico").on("change", applyFilters);
            
            applyFilters();
        });

        function verEntrevista(m) { alert("Visualizando expediente de entrevista: " + m); }
        function verSeguimiento(m) { location.href = '@Url.Action("Seguimiento", "Tutor")?m=' + m; }
        function ejecutarAccion(msg) { alert(msg); $('.modal').modal('hide'); }
    </script>
}