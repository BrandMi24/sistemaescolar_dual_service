@{
    ViewData["Title"] = "Gestión de Expedientes y Entrevistas";
    Layout = "_LayoutTutor";
}

<div class="d-flex flex-column gap-4">
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column gap-3">
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
            <div class="position-relative search-wrapper flex-grow-1" style="max-width: 600px;">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" id="alumnoSearch" class="form-control search-input-custom" placeholder="Buscar por nombre o matrícula...">
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <select id="filterEntrevista" class="form-select bg-app border-theme txt-title fw-bold text-xs" style="width: auto; cursor: pointer;">
                    <option value="todos">Todas las Entrevistas</option>
                    <option value="completa">Completas</option>
                    <option value="pendiente">Pendientes</option>
                </select>
                <select id="filterAcademico" class="form-select bg-app border-theme txt-title fw-bold text-xs" style="width: auto; cursor: pointer;">
                    <option value="todos">Todos los Niveles</option>
                    <option value="regular">Regulares</option>
                    <option value="riesgo">En Riesgo</option>
                </select>
            </div>
        </div>
        <div class="txt-body text-xs fw-bold border-top border-theme pt-2 mt-1">
            <i class="bi bi-info-circle me-1"></i> Mostrando <span id="visibleCount" class="txt-title">3</span> alumnos en el grupo 7º A
        </div>
    </div>

    <div class="row g-4" id="alumnosGrid">
        <div class="col-12 col-md-6 col-xxl-4 alumno-card-wrapper" data-entrevista="completa" data-academico="regular">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm hover-shadow-md transition-all h-100 border-top border-4" style="border-top-color: var(--primary-900) !important;">
                <div class="d-flex flex-column align-items-center text-center mb-4">
                    <div class="avatar-container mb-3 position-relative">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Roberto" class="avatar-xl-img rounded-circle shadow-sm">
                        <div class="status-indicator bg-success"></div>
                    </div>
                    <h5 class="txt-title fw-bold mb-1 alumno-nombre">Roberto Carlos Perez Cadena</h5>
                    <div class="txt-body text-xs mb-3"><i class="bi bi-hash"></i> <span class="alumno-matricula">26001504</span></div>
                    <span class="badge status-aceptado text-xxs px-2 py-1">Entrevista Completa</span>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn btn-primary-sep btn-sm py-2 shadow-sm" onclick="verEntrevista('26001504')">Ver Entrevista</button>
                    <div class="d-flex gap-2">
                        <button class="btn btn-ghost-sep btn-sm flex-grow-1 py-2" onclick="verSeguimiento('26001504')"><i class="bi bi-journal-text"></i></button>
                        <button class="btn btn-ghost-sep btn-sm flex-grow-1 py-2" data-bs-toggle="modal" data-bs-target="#modalEditar"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-ghost-sep btn-sm flex-grow-1 py-2" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                        <ul class="dropdown-menu border-theme shadow-sm text-xs">
                            <li><a class="dropdown-item fw-bold" href="#" data-bs-toggle="modal" data-bs-target="#modalCambiarGrupo">Cambiar Grupo</a></li>
                            <li><a class="dropdown-item fw-bold text-danger" href="#" data-bs-toggle="modal" data-bs-target="#modalBaja">Tramitar Baja</a></li>
                            <li><hr class="dropdown-divider border-theme"></li>
                            <li><a class="dropdown-item fw-bold text-danger" href="#" onclick="removerAlumno('26001504')">Remover del Grupo</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditar" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content border-theme rounded-4 shadow-lg"><div class="modal-header border-bottom border-theme p-4"><h5 class="modal-title txt-title fw-bold">Editar Alumno</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body p-4"><div class="row g-3"><div class="col-md-6"><label class="form-label text-xs fw-bold">NOMBRE</label><input type="text" class="form-control bg-app border-theme" value="Roberto Carlos"></div><div class="col-md-6"><label class="form-label text-xs fw-bold">APELLIDOS</label><input type="text" class="form-control bg-app border-theme" value="Perez Cadena"></div></div></div><div class="modal-footer"><button class="btn btn-primary-sep px-4" onclick="ejecutarAccion('Actualizado')">Guardar</button></div></div></div></div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function applyFilters() {
                var search = $("#alumnoSearch").val().toLowerCase();
                var ent = $("#filterEntrevista").val();
                var acad = $("#filterAcademico").val();
                var count = 0;
                $(".alumno-card-wrapper").each(function() {
                    var $card = $(this);
                    var txt = $card.find(".alumno-nombre").text().toLowerCase() + $card.find(".alumno-matricula").text().toLowerCase();
                    var match = txt.indexOf(search) > -1 && (ent === "todos" || $card.data("entrevista") === ent) && (acad === "todos" || $card.data("academico") === acad);
                    if (match) { $card.show(); count++; } else { $card.hide(); }
                });
                $("#visibleCount").text(count);
            }
            $("#alumnoSearch").on("keyup", applyFilters);
            $("#filterEntrevista, #filterAcademico").on("change", applyFilters);
        });
        function verEntrevista(m) { alert("Entrevista: " + m); }
        function verSeguimiento(m) { location.href = '@Url.Action("Seguimiento", "Tutor")?m=' + m; }
        function ejecutarAccion(msg) { alert(msg); $('.modal').modal('hide'); }
    </script>
}