@model ControlEscolar.ViewModels.OperationalTracking.TutorSeguimientoViewModel
@{
    ViewData["Title"] = "Bitácora de Seguimiento";
    Layout = "_LayoutTutor";
}

<div class="tutor-split-layout">

    <aside class="tutor-sticky-nav">
        <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm text-center">
            <div class="avatar-container mb-3 position-relative">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=@(Model.StudentName.Replace(" ", ""))" class="avatar-xl-img rounded-circle shadow-sm" style="width: 120px; height: 120px;">
                <div class="status-indicator bg-success"></div>
            </div>
            <h5 class="txt-title fw-bold mb-1">@Model.StudentName</h5>
            <p class="txt-body text-xs mb-3 fw-bold">Matrícula: @Model.Matricula</p>

            <div class="d-flex flex-column gap-2 border-top border-theme pt-3">
                <div class="d-flex justify-content-between text-xxs fw-bold tracking-wide">
                    <span class="txt-body">CARRERA:</span>
                    <span class="txt-title">@Model.CareerCode</span>
                </div>
                <div class="d-flex justify-content-between text-xxs fw-bold tracking-wide">
                    <span class="txt-body">GRUPO:</span>
                    <span class="txt-title">@Model.GroupCode</span>
                </div>
                <div class="d-flex justify-content-between text-xxs fw-bold tracking-wide">
                    <span class="txt-body">HORAS:</span>
                    <span class="txt-success-700">@Model.ApprovedHours / @Model.RequiredHours</span>
                </div>
                <div class="d-flex justify-content-between text-xxs fw-bold tracking-wide">
                    <span class="txt-body">ESTADO:</span>
                    <span class="txt-title">@Model.StatusCode</span>
                </div>
            </div>

            <button class="btn btn-primary-sep w-100 mt-4 d-flex align-items-center justify-content-center gap-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalNuevaNota">
                <i class="bi bi-plus-circle-fill"></i> Nueva Nota
            </button>
        </div>

        <a href="@Url.Action("Entrevista", "Tutor")" class="btn btn-ghost-sep w-100 mt-3 text-xs fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Volver a Expedientes
        </a>
    </aside>

    <main class="d-flex flex-column gap-3">

        <div class="bg-surface p-3 rounded-4 border-theme d-flex justify-content-between align-items-center">
            <h6 class="txt-title fw-bold mb-0">Historial Cronológico</h6>
            <div class="position-relative search-wrapper" style="width: 250px;">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" class="form-control form-control-sm search-input-custom" placeholder="Filtrar notas...">
            </div>
        </div>

        <div class="tutor-timeline pt-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert bg-success-100 border border-success-700 text-success-700 rounded-3 alert-dismissible fade show shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert bg-error-100 border border-error border-opacity-25 txt-error rounded-3 alert-dismissible fade show shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.AssignmentId.HasValue)
            {
                <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm">
                    <p class="txt-body mb-0">No hay estudiantes asignados a tu perfil de tutor/docente.</p>
                </div>
            }
            else if (Model.TimelineDocuments.Count == 0)
            {
                <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm">
                    <p class="txt-body mb-0">No hay documentos registrados en esta asignación.</p>
                </div>
            }
            else
            {
                foreach (var doc in Model.TimelineDocuments)
                {
                    var isRejected = doc.StatusCode == "REJECTED";
                    <div class="tutor-timeline-item">
                        <div class="tutor-timeline-dot" style="border-color: @(isRejected ? "var(--error-700)" : "var(--primary-900)");"></div>
                        <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm hover-shadow-md transition-all">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="badge @(isRejected ? "bg-error-100 txt-error border border-error border-opacity-25" : "status-aceptado") text-xxs px-2 py-1 mb-2">@doc.StatusCode</span>
                                    <h6 class="txt-title fw-bold mb-0">@doc.Title</h6>
                                </div>
                                <span class="txt-body text-xxs fw-bold tracking-wide">@doc.UploadDate.ToString("dd MMMM, yyyy")</span>
                            </div>
                            <p class="txt-body text-sm">@(string.IsNullOrWhiteSpace(doc.Notes) ? "Sin observaciones del alumno." : doc.Notes)</p>
                            <div class="border-top border-theme pt-2 mt-2 d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <span class="txt-body text-xxs">Tipo: <strong>@doc.DocumentType</strong></span>
                                <div class="d-flex gap-2">
                                    @if (!string.IsNullOrWhiteSpace(doc.FilePath))
                                    {
                                        <a href="@Url.Action("DownloadOperationalDocument", "Tutor", new { documentId = doc.Id })" class="btn btn-sm btn-ghost-sep">Descargar</a>
                                    }
                                    <form method="post" action="@Url.Action("ApproveDocument", "Tutor")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <button type="submit" class="btn btn-sm btn-primary-sep">Aprobar</button>
                                    </form>
                                    <form method="post" action="@Url.Action("RejectDocument", "Tutor")">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="documentId" value="@doc.Id" />
                                        <input type="hidden" name="comments" value="Requiere correcciones" />
                                        <button type="submit" class="btn btn-sm btn-ghost-sep">Rechazar</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm mt-3">
                    <div class="d-flex flex-column flex-md-row gap-2 align-items-md-center justify-content-between">
                        <div class="txt-body text-sm">Aprobación de horas y cierre de proceso</div>
                        <div class="d-flex gap-2 flex-wrap">
                            <form method="post" action="@Url.Action("ApproveHours", "Tutor")" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
                                <input type="number" name="approvedHours" class="form-control form-control-sm" step="0.5" min="0" placeholder="Horas aprobadas" required style="max-width: 150px;" />
                                <button type="submit" class="btn btn-sm btn-primary-sep">Guardar Horas</button>
                            </form>
                            <form method="post" action="@Url.Action("FinalApproval", "Tutor")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="assignmentId" value="@Model.AssignmentId" />
                                <button type="submit" class="btn btn-sm btn-ghost-sep">Aprobación Final</button>
                            </form>
                        </div>
                    </div>
                </div>
            }

        </div>

    </main>
</div>

<div class="modal fade" id="modalNuevaNota" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-theme rounded-4 shadow-lg">
            <div class="modal-header border-bottom border-theme p-4">
                <h5 class="modal-title txt-title fw-bold">Nueva Nota de Seguimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label txt-body text-xs fw-bold">CATEGORÍA</label>
                        <select class="form-select bg-app border-theme fw-bold">
                            <option>Académico</option>
                            <option>Conductual</option>
                            <option>Médico / Psicológico</option>
                            <option>Personal</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label txt-body text-xs fw-bold">ASUNTO</label>
                        <input type="text" class="form-control bg-app border-theme" placeholder="Ej. Reporte de entrevista">
                    </div>
                    <div class="col-12">
                        <label class="form-label txt-body text-xs fw-bold">DESCRIPCIÓN DETALLADA</label>
                        <textarea class="form-control bg-app border-theme text-sm" rows="4" placeholder="Escribe aquí los detalles de la nota..."></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top border-theme p-3">
                <button type="button" class="btn btn-ghost-sep px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary-sep px-4" onclick="location.reload()">Guardar Nota</button>
            </div>
        </div>
    </div>
</div>