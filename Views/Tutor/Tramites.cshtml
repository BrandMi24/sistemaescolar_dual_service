function agregarCampo() {
    $('#contenedorRequisitos').append(`
        <div class="input-group mb-2 req-row">
            <input type="text" class="form-control req-nombre" placeholder="Nombre del requisito">
            <button class="btn btn-outline-secondary btn-foto" type="button" data-es-foto="false" onclick="marcarComoFoto(this)">
                <i class="bi bi-camera"></i>
            </button>
            <button class="btn btn-outline-danger" type="button" onclick="$(this).parent().remove()">
                <i class="bi bi-trash"></i>
            </button>
        </div>`);
}

function marcarComoFoto(btn) {
    const $row = $(btn).closest('.req-row');
    const $input = $row.find('.req-nombre');
    const esFoto = $(btn).data('es-foto') === true;

    if (!esFoto) {
        // ACTIVAR MODO FOTO:
        // Solo bloqueamos y añadimos la marca, manteniendo el nombre original
        $(btn).removeClass('btn-outline-secondary').addClass('btn-primary text-white');
        $(btn).data('es-foto', true);
        
        let nombreOriginal = $input.val().trim();
        // Si estaba vacío, ponemos algo por defecto, si tenía texto, le agregamos la marca
        let nombreMarcado = (nombreOriginal === "") ? "Fotografía" : nombreOriginal;
        
        // Agregamos la marca solo si no la tiene ya
        if (!nombreMarcado.includes("(FOTO)")) {
            nombreMarcado += " (FOTO)";
        }
        
        $input.val(nombreMarcado);
        $input.prop('disabled', true);
        $input.addClass('bg-light text-muted fw-bold');
    } else {
        // DESACTIVAR MODO FOTO:
        // Quitamos la marca y desbloqueamos
        $(btn).removeClass('btn-primary text-white').addClass('btn-outline-secondary');
        $(btn).data('es-foto', false);
        
        let nombreActual = $input.val();
        let nombreLimpio = nombreActual.replace(" (FOTO)", "").trim();
        
        $input.val(nombreLimpio);
        $input.prop('disabled', false);
        $input.removeClass('bg-light text-muted fw-bold');
        $input.focus();
    }
}

