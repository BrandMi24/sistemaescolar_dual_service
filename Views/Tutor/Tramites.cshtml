function cargarEdicion(id, nombre) {
    const contenedor = $('#contenedorAccion');
    contenedor.html(`
        <input type="hidden" id="editId" value="${id}">
        <label class="text-xs fw-bold text-muted">NOMBRE DEL TRÁMITE</label>
        <input type="text" id="editNombre" class="form-control mb-3" value="${nombre}">
        <label class="text-xs fw-bold text-muted">REQUISITOS ACTUALES</label>
        <div id="editRequisitos" class="mb-3"></div>
        <button class="btn btn-sm btn-outline-primary mb-2" onclick="agregarCampoEdit()">+ Agregar Requisito</button>
        <button class="btn btn-success w-100 mt-2" onclick="guardarEdicion()">GUARDAR CAMBIOS</button>
    `);

    // Hacemos el fetch para traer los requisitos que ya tiene ese trámite
    fetch(`/Tramites/ObtenerRequisitosJson?id=${id}`)
    .then(r => r.json())
    .then(requisitos => {
        requisitos.forEach(req => {
            agregarCampoEdit(req.nombre_documento);
        });
    });
}

// Función auxiliar para agregar campos en el modo edición
function agregarCampoEdit(valor = "") {
    const esFoto = valor.toLowerCase().includes('(foto)');
    // Si es foto, definimos las clases iniciales para que el botón se vea activo
    const btnClase = esFoto ? 'btn-primary text-white' : 'btn-outline-secondary';
    $('#editRequisitos').append(`
        <div class="input-group mb-2 req-row">
            <input type="text" class="form-control req-nombre" value="${valor}" placeholder="Nombre del requisito">
            <button class="btn btn-outline-secondary btn-foto" type="button" data-es-foto="${valor.toLowerCase().includes('(foto)')}" onclick="marcarComoFoto(this)">
                <i class="bi bi-camera"></i>
            </button>
            <button class="btn btn-outline-danger" type="button" onclick="$(this).parent().remove()">
                <i class="bi bi-trash"></i>
            </button>
        </div>`);
}
function guardarEdicion() {
    if ($('#editRequisitos .req-row').length === 0) {
        Swal.fire('Error', 'Debes agregar al menos un requisito.', 'warning');
        return;
    }
    // VALIDACIÓN: El nombre no debe estar vacío
    if ($('#editNombre').val().trim() === "") {
        Swal.fire('Error', 'El nombre del trámite es obligatorio.', 'warning');
        return;
    }
    const data = {
        id: parseInt($('#editId').val()), // Asegúrate que el hidden tiene este ID
        nombre: $('#editNombre').val(),
        listaRequisitos: []
    };

    $('#editRequisitos .req-row').each(function() {
        // Obtenemos el valor del input
        let nombreReq = $(this).find('.req-nombre').val();
        
        if (nombreReq && nombreReq.trim() !== "") {
            // Empujamos un objeto con la propiedad "nombre" (tal como espera el DTO)
            data.listaRequisitos.push({ nombre: nombreReq });
        }
    });

    fetch('/Tramites/GuardarEdicion', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data) // Esto envía el objeto al [FromBody] del controlador
    })
    .then(r => r.json())
    .then(data => {
        if(data.success) {
            Swal.fire('¡Éxito!', 'Trámite actualizado correctamente.', 'success')
                .then(() => window.location.reload());
        } else {
            Swal.fire('Error', data.message || 'No se pudo guardar.', 'error');
        }
    });
}

// Lógica de eliminación
function eliminarTramite(id) {
    Swal.fire({
        title: '¿Estás seguro?',
        text: "Esta acción no se puede deshacer.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Sí, eliminar'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch(`/Tramites/EliminarTramite?id=${id}`, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    Swal.fire('Eliminado', '', 'success').then(() => window.location.reload());
                } else {
                    // AQUÍ MOSTRAMOS EL MENSAJE QUE VIENE DEL CONTROLADOR
                    Swal.fire('Error', data.message, 'error');
                }
            });
        }
    });
}
