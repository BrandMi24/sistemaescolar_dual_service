@model IEnumerable<ControlEscolar.Models.DetalleSolicitudViewModel>
@{
    ViewData["Title"] = "Revisión de Trámites";
    Layout = "_LayoutTutor";
}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="row g-4">
    <div class="col-12">
        <div class="bg-white p-4 rounded-4 shadow-sm border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="btn-group shadow-sm" role="group">
                <button type="button" onclick="filtrarPorEstatusDataTable('Todos', this)" class="btn btn-outline-secondary btn-sm px-4">Todos</button>
                <button type="button" onclick="filtrarPorEstatusDataTable('Pendiente', this)" class="btn btn-outline-warning btn-sm px-4 active fw-bold">Pendientes</button>
                <button type="button" onclick="filtrarPorEstatusDataTable('Aprobado', this)" class="btn btn-outline-success btn-sm px-4">Aprobados</button>
                <button type="button" onclick="filtrarPorEstatusDataTable('Rechazado', this)" class="btn btn-outline-danger btn-sm px-4">Rechazados</button>
            </div>

            <div class="d-flex align-items-center gap-3">
                <div id="containerLength"></div>
                <div class="input-group shadow-sm" style="max-width: 300px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="txtBusqueda" class="form-control border-start-0 text-sm" placeholder="Buscar alumno, folio...">
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="bg-white p-0 rounded-4 shadow-sm border-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-sm" id="tablaTutor">
                    <thead class="bg-light text-muted border-bottom">
                        <tr>
                            <th class="py-3 px-4 fw-bold text-xs text-center">FOLIO / FECHA</th>
                            <th class="py-3 fw-bold text-xs">ALUMNO</th>
                            <th class="py-3 fw-bold text-xs text-center">GRUPO</th>
                            <th class="py-3 fw-bold text-xs">TRÁMITE</th>
                            <th class="py-3 fw-bold text-xs text-center">ESTADO</th>
                            <th class="py-3 px-4 fw-bold text-xs text-center">ACCIÓN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr class="border-bottom hover-bg-light transition-all">
                                    <td class="px-4 py-3 text-center">
                                        <span class="text-primary fw-bold text-sm d-block">#@item.Id</span>
                                        <span class="text-muted text-xs">@item.Fecha.ToString("dd/MM/yyyy")</span>
                                    </td>
                                    <td>
                                        <span class="text-dark fw-bold d-block">@item.Nombre</span>
                                        <span class="text-muted text-xs">Mat: @item.Matricula</span>
                                    </td>
                                    <td class="text-center text-dark fw-bold">@item.Grado° "@item.Grupo"</td>
                                    <td><span class="text-dark fw-bold text-xs">@item.Tipo</span></td>
                                    <td class="text-center">
                                        @{
                                            var badgeClass = item.Estatus == "Pendiente" ? "border-warning text-warning" :
                                                             item.Estatus == "Rechazado" ? "border-danger text-danger" : "border-success text-success";
                                        }
                                        <span class="badge bg-white border shadow-sm rounded-pill px-3 py-1 @badgeClass">
                                            @item.Estatus.ToUpper()
                                        </span>
                                    </td>
                                    <td class="text-center px-4">
                                        <button type="button" class="btn btn-sm btn-dark rounded-pill px-4 fw-bold shadow-sm btn-revisar"
                                                data-id="@item.Id" data-idtramite="@item.IdTramite" data-nombre="@item.Nombre"
                                                data-matricula="@item.Matricula" data-grado="@item.Grado" data-grupo="@item.Grupo"
                                                data-tipo="@item.Tipo" data-archivopath="@item.ArchivoPath" data-estatus="@item.Estatus">
                                            Revisar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="revisarModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <form asp-action="ActualizarEstatus" method="post">
                
                <div class="modal-header bg-dark text-white p-4 border-0">
                    <div class="w-100">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="modal-title fw-bold">
                                Expediente: <span id="modalNombreAlumno" class="text-info"></span>
                                <small class="ms-2 opacity-75 text-xs" id="modalMatriculaAlumno"></small>
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="mt-2 text-xs opacity-75 fw-bold tracking-wide">
                            <span id="modalTipoTramite" class="me-3"></span>
                            <span id="modalGradoGrupoHist"></span>
                        </div>
                    </div>
                </div>

                <div class="modal-body p-0">
                    <div class="d-flex flex-column flex-md-row" style="height: 65vh; min-height: 500px;">
                        
                        <div class="bg-light border-end d-flex flex-column" style="width: 350px;">
                            <div class="p-3 border-bottom bg-white d-flex justify-content-between align-items-center shadow-sm z-1">
                                <h6 class="fw-bold mb-0 text-xs tracking-widest text-muted">REQUISITOS DEL TRÁMITE</h6>
                                <span id="contadorProgreso" class="badge rounded-pill bg-secondary shadow-sm">0/0</span>
                            </div>
                            <div id="listaDocumentos" class="flex-grow-1 overflow-auto p-3">
                            </div>
                        </div>

                        <div class="flex-grow-1 bg-white d-flex flex-column">
                            <div class="bg-secondary bg-opacity-10 border-bottom p-2 d-flex justify-content-between align-items-center shadow-sm z-1">
                                <span class="text-sm fw-bold px-2 text-dark" id="nombreDocActivo">Seleccione un archivo de la lista</span>
                                <a id="btnLinkIndividual" href="#" download class="btn btn-sm btn-outline-dark py-1 px-3 fw-bold rounded-pill" style="display:none; font-size: 0.75rem;">
                                    <i class="bi bi-download me-1"></i> Descargar
                                </a>
                            </div>
                            <div id="pdfContainer" class="flex-grow-1 bg-light d-flex align-items-center justify-content-center">
                                <div class="text-center text-muted opacity-50">
                                    <i class="bi bi-file-earmark-pdf mb-3" style="font-size: 5rem;"></i>
                                    <p class="text-sm fw-bold">Vista previa del documento</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light p-3 border-top">
                    <div class="row w-100 align-items-center g-3">
                        
                        <div class="col-md-3 text-start">
                            <button type="button" id="btnDescargaCarpeta" class="btn btn-outline-secondary btn-sm rounded-pill fw-bold w-100">
                                <i class="bi bi-file-earmark-zip me-1"></i> Exportar ZIP
                            </button>
                        </div>
                        
                        <div class="col-md-5" id="contenedorObservacionesFooter" style="display:none;">
                            <textarea name="observaciones" id="modalObservacionesFooter" class="form-control form-control-sm border-warning shadow-sm rounded-3" rows="2" placeholder="Describa aquí el motivo del rechazo (Obligatorio)..." oninput="validarTextoRechazo()"></textarea>
                        </div>

                        <div class="col-md-5 text-center text-muted text-sm fw-bold" id="mensajeTramiteCerradoFooter" style="display:none;">
                            <i class="bi bi-lock-fill me-1"></i> Este trámite ya fue dictaminado.
                        </div>

                        <div class="col-md-4 text-end" id="accionesPendientesFooter" style="display:none;">
                            <button type="button" id="btnRechazarFooter" onclick="confirmarDictamen('Rechazado')" class="btn btn-danger btn-sm px-4 rounded-pill fw-bold shadow-sm disabled" disabled>RECHAZAR</button>
                            <button type="button" id="btnAceptarFooter" onclick="confirmarDictamen('Aprobado')" class="btn btn-success btn-sm px-4 rounded-pill fw-bold shadow-sm disabled ms-2" disabled>APROBAR</button>
                        </div>

                    </div>
                    <input type="hidden" name="id" id="inputSolicitudId" />
                    <input type="hidden" name="estatus" id="inputEstatus" />
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <script>
        let matriculaActiva = "";

        $(document).ready(function () {
        // Inicializar DataTable
        const table = $('#tablaTutor').DataTable({
        language: { url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
        order: [[0, 'desc']],
        dom: "rt<'d-flex justify-content-between align-items-center mt-3 text-muted text-sm'ip>"
        });

        // Por defecto, mostrar solo "Pendientes"
        table.column(4).search('^Pendiente$', true, false).draw();

        // Buscador personalizado
        $('#txtBusqueda').on('keyup', function () { table.search(this.value).draw(); });
        });

        // Función para los botones de Filtro (Todos, Pendientes, Aprobados...)
        function filtrarPorEstatusDataTable(estatus, boton) {
        document.querySelectorAll('.btn-group .btn').forEach(x => {
        x.classList.remove('active', 'fw-bold');
        });
        boton.classList.add('active', 'fw-bold');

        const table = $('#tablaTutor').DataTable();
        if (estatus === 'Todos') {
        table.column(4).search('').draw();
        } else {
        table.column(4).search('^' + estatus + '$', true, false).draw();
        }
        }

        // Lógica al hacer clic en "Revisar"
        document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-revisar');
        if (btn) {
        const data = btn.dataset;
        matriculaActiva = data.matricula;

        // Llenar encabezado del modal
        document.getElementById('modalNombreAlumno').innerText = data.nombre;
        document.getElementById('modalMatriculaAlumno').innerText = `(${data.matricula})`;
        document.getElementById('modalTipoTramite').innerText = `Trámite: ${data.tipo}`;
        document.getElementById('modalGradoGrupoHist').innerText = `Grupo: ${data.grado}° "${data.grupo}"`;
        document.getElementById('inputSolicitudId').value = data.id;
                
        const txtObservaciones = document.getElementById('modalObservacionesFooter');
        txtObservaciones.value = data.observaciones || "";

        // Configurar Descarga ZIP
        document.getElementById('btnDescargaCarpeta').onclick = () => {
        window.location.href = `/Tramites/DescargarCarpeta?idSolicitud=${data.id}&matricula=${data.matricula}&tipo=${data.tipo}`;
        };

        // Lógica de Estatus General
        const estatus = data.estatus.toLowerCase();
        const divAcciones = document.getElementById('accionesPendientesFooter');
        const contenedorObs = document.getElementById('contenedorObservacionesFooter');
        const mensajeCerrado = document.getElementById('mensajeTramiteCerradoFooter');

        if (estatus === "pendiente") {
        divAcciones.style.display = "block";
        contenedorObs.style.display = "block";
        mensajeCerrado.style.display = "none";
        txtObservaciones.readOnly = false;
        validarTextoRechazo();
        } else {
        divAcciones.style.display = "none";
        contenedorObs.style.display = "none";
        mensajeCerrado.style.display = "block";
        txtObservaciones.readOnly = true;
        }

        // Resetear Visor
        document.getElementById('pdfContainer').innerHTML = `<div class="text-center text-muted opacity-50"><i class="bi bi-file-earmark-pdf mb-3" style="font-size: 5rem;"></i><p class="text-sm fw-bold">Vista previa del documento</p></div>`;
        document.getElementById('nombreDocActivo').innerText = "Seleccione un archivo de la lista";
        document.getElementById('btnLinkIndividual').style.display = "none";

        // Cargar Documentos (Fetch)
        const listaDoc = document.getElementById('listaDocumentos');
        listaDoc.innerHTML = '<div class="text-center p-4"><div class="spinner-border spinner-border-sm"></div></div>';

        fetch(`/Tramites/ObtenerDetalleRequisitos?idSolicitud=${data.id}`)
        .then(r => r.json())
        .then(requisitos => {
        listaDoc.innerHTML = "";
        requisitos.forEach(req => {
        let colorClase = "border-light";
        let checkIcon = "bi-circle";
        let checkColor = "text-muted";

        if (req.estatus === "Aprobado") { colorClase = "border-success"; checkIcon = "bi-check-circle-fill"; checkColor = "text-success"; }
        if (req.estatus === "Rechazado") { colorClase = "border-danger"; checkIcon = "bi-x-circle-fill"; checkColor = "text-danger"; }

        // Render de la tarjeta del documento
        const html = `
        <div class="bg-white border rounded-3 p-3 mb-2 shadow-sm border-start border-4 ${colorClase}">
        <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="fw-bold text-dark text-xs text-truncate cursor-pointer" style="max-width: 80%; cursor:pointer;"
        onclick="manejadorCargarVisor('${data.archivopath}', '${req.nombreArchivoFisico}', ${req.esFotografia}, '${req.nombreRequisito}', ${req.idRequisito}, ${data.id})">
        <i class="bi bi-file-pdf me-1"></i> ${req.nombreRequisito}
        </span>
        <i class="bi ${checkIcon} ${checkColor}" style="font-size: 1rem;"></i>
        </div>
        ${estatus === "pendiente" ? `
        <div class="d-flex gap-2 justify-content-end mt-2 border-top pt-2">
        <button type="button" class="btn btn-outline-danger btn-sm text-xs py-1 px-3 rounded-pill" onclick="confirmarEstatusIndividual(${data.id}, ${req.idRequisito}, 'Rechazado', this)">Mal</button>
        <button type="button" class="btn btn-outline-success btn-sm text-xs py-1 px-3 rounded-pill" onclick="confirmarEstatusIndividual(${data.id}, ${req.idRequisito}, 'Aprobado', this)">Correcto</button>
        </div>` : ''}
        </div>`;
        listaDoc.insertAdjacentHTML('beforeend', html);
        });
        validarAprobacionTotal();
        });

        new bootstrap.Modal(document.getElementById('revisarModal')).show();
        }
        });

        // Cargar Visor PDF
        function manejadorCargarVisor(folder, archivo, esFoto, nombre, idReq, idSol) {
        const container = document.getElementById('pdfContainer');
        const btnDescarga = document.getElementById('btnLinkIndividual');
        document.getElementById('nombreDocActivo').innerHTML = `<i class="bi bi-file-earmark-pdf me-2"></i> ${nombre}`;

        if (archivo && archivo !== "null" && archivo !== "" && !esFoto) {
        let pathParts = folder.replace(/\\/g, '/');
        if (!pathParts.includes('/Carpetas_ZIP/')) pathParts = pathParts.replace('Carpetas_ZIP', '/Carpetas_ZIP/');
        const urlVisor = `/uploads/tramites/${pathParts}/${archivo}`.replace(/\/+/g, '/');
                
        container.innerHTML = `<div class="w-100 h-100 d-flex justify-content-center align-items-center"><div class="spinner-border"></div></div>`;
                
        setTimeout(() => {
        container.innerHTML = `<iframe src="${urlVisor}?v=${new Date().getTime()}#toolbar=1" style="width:100%; height:100%; border:none;"></iframe>`;
        }, 300);

        btnDescarga.style.display = "inline-flex";
        btnDescarga.href = `/Tramites/DescargarArchivoIndividual?idSolicitud=${idSol}&idRequisito=${idReq}&matricula=${encodeURIComponent(matriculaActiva)}`;
        } else {
        container.innerHTML = `<div class="text-center text-muted opacity-50 p-5"><i class="bi ${esFoto ? 'bi-camera' : 'bi-file-earmark-x'} mb-3" style="font-size: 4rem;"></i><h5>${esFoto ? 'Requisito Físico' : 'El alumno no subió este archivo'}</h5></div>`;
        btnDescarga.style.display = "none";
        }
        }

        // Aprobar/Rechazar Documento Individual (Fetch)
        function confirmarEstatusIndividual(idSolicitud, idReq, nuevoEstatus, btn) {
        fetch('/Tramites/ActualizarEstatusDocumento', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idSolicitud: parseInt(idSolicitud), idRequisito: parseInt(idReq), estatus: nuevoEstatus })
        }).then(res => {
        if (res.ok) {
        const card = btn.closest('.bg-white');
        const icon = card.querySelector('.bi-circle, .bi-check-circle-fill, .bi-x-circle-fill');
                    
        card.classList.remove('border-light', 'border-success', 'border-danger');
        icon.classList.remove('bi-circle', 'bi-check-circle-fill', 'bi-x-circle-fill', 'text-muted', 'text-success', 'text-danger');

        if(nuevoEstatus === 'Aprobado') {
        card.classList.add('border-success');
        icon.classList.add('bi-check-circle-fill', 'text-success');
        } else {
        card.classList.add('border-danger');
        icon.classList.add('bi-x-circle-fill', 'text-danger');
        }
                    
        Swal.fire({ toast: true, position: 'top-end', showConfirmButton: false, timer: 1000, icon: 'success', title: `Marcado como ${nuevoEstatus}` });
        validarAprobacionTotal();
        }
        });
        }

        // Validación Final
        function validarAprobacionTotal() {
        const listaDoc = document.getElementById('listaDocumentos');
        const total = listaDoc.children.length;
        const aprobados = listaDoc.querySelectorAll('.border-success').length;
        const btnAceptar = document.getElementById('btnAceptarFooter');
            
        document.getElementById('contadorProgreso').innerText = `${aprobados}/${total}`;
        document.getElementById('contadorProgreso').className = aprobados === total ? "badge rounded-pill bg-success shadow-sm" : "badge rounded-pill bg-secondary shadow-sm";

        if (total > 0 && aprobados === total) {
        btnAceptar.disabled = false;
        btnAceptar.classList.remove('disabled');
        } else {
        btnAceptar.disabled = true;
        btnAceptar.classList.add('disabled');
        }
        }

        function validarTextoRechazo() {
        const txt = document.getElementById('modalObservacionesFooter').value.trim();
        const btnRechazar = document.getElementById('btnRechazarFooter');
        if (txt.length > 0) {
        btnRechazar.disabled = false;
        btnRechazar.classList.remove('disabled');
        } else {
        btnRechazar.disabled = true;
        btnRechazar.classList.add('disabled');
        }
        }

        // Dictamen Final Trámite
        function confirmarDictamen(v) {
        const esAprobacion = (v === 'Aprobado');
        if (!esAprobacion && document.getElementById('modalObservacionesFooter').value.trim().length < 5) {
        Swal.fire({ icon: 'warning', title: 'Faltan observaciones', text: 'Detalla el motivo del rechazo.' });
        return;
        }

        Swal.fire({
        title: esAprobacion ? '¿Aprobar Trámite?' : '¿Rechazar Trámite?',
        text: esAprobacion ? "Se notificará al alumno." : "El alumno deberá corregir los documentos.",
        icon: esAprobacion ? 'success' : 'warning',
        showCancelButton: true,
        confirmButtonColor: esAprobacion ? '#198754' : '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, confirmar',
        cancelButtonText: 'Cancelar'
        }).then((result) => {
        if (result.isConfirmed) {
        document.getElementById('inputEstatus').value = v;
        document.querySelector('#revisarModal form').submit();
        }
        });
        }
    </script>
}