@model IEnumerable<ControlEscolar.Models.VisitaPsicologica>
@{
    ViewData["Title"] = "Directorio de Salud Mental";
    Layout = "_LayoutSalud";
}

<div class="d-flex flex-column gap-4 fade-in">

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column gap-3">

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="position-relative flex-grow-1" style="max-width: 480px;">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 18px; transform: translateY(-50%);"></i>
                <input type="text" id="searchInput" class="form-control ps-5"
                       placeholder="Buscar por nombre o matrícula..."
                       style="height: 48px; border-radius: 8px; background-color: var(--app-bg); border: 1px solid var(--border-color); box-shadow: none;">
            </div>

            <a asp-action="Register" class="btn-primary-sep d-flex align-items-center justify-content-center gap-2 text-decoration-none shadow-sm" style="height: 48px; border-radius: 8px;">
                <i class="bi bi-plus-lg"></i>
                <span class="fw-bold">Nueva Sesión</span>
            </a>
        </div>

        <div class="d-flex flex-column flex-md-row align-items-md-center gap-3 flex-wrap">

            <div class="d-flex align-items-center gap-2 flex-wrap">
                <i class="bi bi-calendar-range text-muted fs-5"></i>
                <span class="txt-body text-xs fw-bold text-nowrap">Filtrar por fecha:</span>
                <input type="date" id="fechaInicio" class="form-control form-control-sm border-theme"
                       style="width: 155px; border-radius: 8px; background-color: var(--app-bg);"
                       title="Fecha inicio">
                <span class="txt-body text-xs fw-bold">—</span>
                <input type="date" id="fechaFin" class="form-control form-control-sm border-theme"
                       style="width: 155px; border-radius: 8px; background-color: var(--app-bg);"
                       title="Fecha fin">
                <button id="btnLimpiarFechas" class="btn btn-sm btn-outline-secondary" style="border-radius: 8px;" title="Limpiar filtro de fechas">
                    <i class="bi bi-x-circle"></i>
                </button>
            </div>

            <div class="vr d-none d-md-block" style="height: 32px;"></div>

            <button id="btnSort" class="btn btn-sm d-flex align-items-center gap-2 fw-bold px-3"
                    style="height: 36px; border-radius: 8px; border: 1.5px solid var(--border-color); background-color: var(--app-bg);"
                    title="Ordenar alfabéticamente">
                <i class="bi bi-sort-alpha-down" id="sortIcon"></i>
                <span id="sortLabel">A → Z</span>
            </button>

            <button id="btnExportarExcel" class="btn btn-sm d-flex align-items-center gap-2 fw-bold px-3"
                    style="height: 36px; border-radius: 8px; border: 1.5px solid #198754; color: #198754; background-color: #f0fff4;"
                    title="Exportar a Excel con el rango de fechas seleccionado">
                <i class="bi bi-file-earmark-excel-fill"></i>
                <span>Exportar Excel</span>
            </button>
        </div>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden d-flex flex-column">
        <div class="table-responsive bg-surface" style="min-height: 450px;">
            <table class="table align-middle mb-0" id="psicoTable" style="min-width: 900px;">
                <thead class="admin-table-header bg-app">
                    <tr class="text-uppercase" style="font-size: 0.75rem;">
                        <th class="py-4 px-4 text-muted fw-bold">Paciente</th>
                        <th class="py-4 text-center text-muted fw-bold">Matrícula</th>
                        <th class="py-4 text-muted fw-bold">Programa / Carrera</th>
                        <th class="py-4 text-center text-muted fw-bold">Estado</th>
                        <th class="py-4 text-end px-4 text-muted fw-bold">Acciones</th>
                    </tr>
                </thead>
                <tbody id="psicoBody">
                    @foreach (var p in Model)
                    {
                        var estado = "seguimiento";
                        <tr class="border-bottom border-theme data-row"
                            data-estado="@estado"
                            data-nombre="@p.NombreCompleto?.ToLower()"
                            data-fecha="@p.FechaVisita.ToString("yyyy-MM-dd")">
                            <td class="px-4 py-3 search-target">
                                <div class="txt-title fw-bold fs-6">@p.NombreCompleto</div>
                                <div class="text-muted text-xxs mt-1">
                                    Última sesión: @p.FechaVisita.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-app text-secondary border border-light px-3 py-2 text-xxs fw-bold" style="font-family: monospace; letter-spacing: 1px;">
                                    @p.Matricula
                                </span>
                            </td>
                            <td>
                                <div class="text-xxs fw-bold text-secondary text-uppercase tracking-tight">@p.Carrera</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold border @estadoClase">
                                    @estadoTexto
                                </span>
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="History" asp-route-id="@p.Matricula" 
                                       class="btn btn-sm border-0 bg-primary-100 txt-primary-dark rounded-2 py-1 px-2" 
                                       title="Ver Expediente">
                                        <i class="bi bi-folder2-open fs-6"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem;">Mostrar:</span>
                <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs shadow-none" style="width: 70px; cursor: pointer;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                </select>
                <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
            </div>

            <nav aria-label="Navegación">
                <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: transparent !important;
    }

    .page-link-custom:hover {
        background-color: #e2e8f0 !important;
        color: #1a2b6b !important;
    }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900) !important; /* Usando tu variable de verde/oscuro */
        border-color: var(--primary-900) !important;
        color: #ffffff !important;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .page-link-custom {
        border-radius: 4px !important;
        color: #333;
        border: 1px solid #ccc;
        background-color: #fff;
        padding: 5px 12px;
        font-weight: bold;
    }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900) !important;
        border-color: var(--primary-900) !important;
        color: white !important;
    }

    #btnSort:hover {
        background-color: #e9ecef !important;
    }

    #btnExportarExcel:hover {
        background-color: #d1e7dd !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;
            let sortDir = 'asc';
            const $tbody = $('#psicoTable tbody');

            // ── Ordenar filas en el DOM ──────────────────────────────────────
            function sortRows(dir) {
                const rows = $tbody.find('tr.data-row').get();
                rows.sort(function (a, b) {
                    const na = $(a).data('nombre') || '';
                    const nb = $(b).data('nombre') || '';
                    return dir === 'asc' ? na.localeCompare(nb, 'es') : nb.localeCompare(na, 'es');
                });
                $.each(rows, function (_, row) { $tbody.append(row); });
            }

            // ── Filtrar y paginar ────────────────────────────────────────────
            function updateTable() {
                const searchTerm  = $('#searchInput').val().toLowerCase();
                const fechaInicio = $('#fechaInicio').val();
                const fechaFin    = $('#fechaFin').val();
                const rowsPerPage = parseInt($('#rowsPerPage').val());
                const filteredRows = [];

                $('.data-row').each(function () {
                    const text     = $(this).find('.search-target').text().toLowerCase();
                    const mat      = $(this).find('.badge').first().text().toLowerCase();
                    const fechaRow = $(this).data('fecha');

                    const matchSearch = !searchTerm || text.includes(searchTerm) || mat.includes(searchTerm);
                    const matchDesde  = !fechaInicio || fechaRow >= fechaInicio;
                    const matchHasta  = !fechaFin   || fechaRow <= fechaFin;

                    if (matchSearch && matchDesde && matchHasta) {
                        filteredRows.push($(this));
                    }
                    $(this).hide();
                });

                const total  = filteredRows.length;
                const pages  = Math.ceil(total / rowsPerPage) || 1;
                if (currentPage > pages) currentPage = pages;
                const start  = (currentPage - 1) * rowsPerPage;
                const end    = Math.min(start + rowsPerPage, total);

                for (let i = startIndex; i < endIndex; i++) {
                    filteredRows[i].show();
                }

                $('#tableInfo').text(
                    total === 0 ? 'Sin registros' : `Mostrando ${start + 1} a ${end} de ${total}`
                );
                renderPagination(pages);
            }

            function renderPagination(totalPages) {
                let html = `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                              <a class="page-link page-link-custom" href="#" data-page="${currentPage - 1}">
                                <i class="bi bi-chevron-left"></i></a></li>`;
                for (let i = 1; i <= totalPages; i++) {
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                               <a class="page-link page-link-custom" href="#" data-page="${i}">${i}</a></li>`;
                }
                html += `<li class="page-item ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}">
                           <a class="page-link page-link-custom" href="#" data-page="${currentPage + 1}">
                             <i class="bi bi-chevron-right"></i></a></li>`;
                $('#paginationControls').html(html);
            }

            // ── Eventos ──────────────────────────────────────────────────────
            $('#searchInput, #rowsPerPage, #fechaInicio, #fechaFin').on('input change', function () {
                currentPage = 1;
                updateTable();
            });

            $('#btnLimpiarFechas').on('click', function () {
                $('#fechaInicio, #fechaFin').val('');
                currentPage = 1;
                updateTable();
            });

            $('#paginationControls').on('click', '.page-link', function (e) {
                e.preventDefault();
                let page = parseInt($(this).data('page'));
                if (page && !$(this).parent().hasClass('disabled')) {
                    currentPage = page;
                    updateTable();
                }
            });

            // ── Botón ordenar A-Z / Z-A ──────────────────────────────────────
            $('#btnSort').on('click', function () {
                if (sortDir === 'asc') {
                    sortDir = 'desc';
                    $('#sortIcon').removeClass('bi-sort-alpha-down').addClass('bi-sort-alpha-down-alt');
                    $('#sortLabel').text('Z → A');
                } else {
                    sortDir = 'asc';
                    $('#sortIcon').removeClass('bi-sort-alpha-down-alt').addClass('bi-sort-alpha-down');
                    $('#sortLabel').text('A → Z');
                }
                sortRows(sortDir);
                currentPage = 1;
                updateTable();
            });

            // ── Botón exportar Excel ─────────────────────────────────────────
            $('#btnExportarExcel').on('click', function () {
                const fi = $('#fechaInicio').val();
                const ff = $('#fechaFin').val();
                let url = '@Url.Action("ExportarExcel", "VisitaPsicologica")';
                const params = [];
                if (fi) params.push('fechaInicio=' + fi);
                if (ff) params.push('fechaFin=' + ff);
                if (params.length) url += '?' + params.join('&');
                window.location.href = url;
            });

            // Init
            sortRows(sortDir);
            updateTable();
        });
    </script>
}
