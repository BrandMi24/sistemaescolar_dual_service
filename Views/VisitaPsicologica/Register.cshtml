@model ControlEscolar.Models.VisitaPsicologica
@{
    ViewData["Title"] = "Nueva Sesión Psicológica";
    Layout = "_LayoutSalud";
}

<div class="row g-4 align-items-start mx-auto fade-in" style="max-width: 1200px;">
    
    <div class="col-12 col-lg-4 col-xl-3 position-lg-sticky" style="top: 20px;">
        <div class="bg-white p-4 rounded-4 shadow-sm border border-light d-flex flex-column gap-4">
            
            <div class="text-center pb-3 border-bottom border-light">
                <div class="icon-purple rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 shadow-sm" style="width: 60px; height: 60px;">
                    <i class="bi bi-person-heart fs-2"></i>
                </div>
                <h6 class="fw-bold mb-1 text-dark">Nueva Sesión</h6>
                <p class="text-muted text-xs mb-0">Atención Psicológica</p>
                
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-xs fw-bold text-muted">Progreso</span>
                        <span id="progressText" class="text-xs fw-bold text-dark">50%</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 6px; background-color: #f1f5f9;">
                        <div id="progressBar" class="progress-bar" role="progressbar" style="width: 50%; background-color: var(--primary-900);"></div>
                    </div>
                </div>
            </div>

            <ul class="nav flex-column nav-pills-custom" id="psicoTabs" role="tablist">
                <li class="nav-item mb-2" role="presentation">
                    <button class="nav-link w-100 active d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso1" type="button" onclick="updateProgress(50)">
                        <div class="d-flex align-items-center">
                            <div class="icon-blue rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                <i class="bi bi-person-badge fs-6"></i>
                            </div>
                            <span>1. Identificación</span>
                        </div>
                        <i class="bi bi-check-circle-fill text-success text-xs d-none" id="icon-step1"></i>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso2" type="button" onclick="updateProgress(100)">
                        <div class="d-flex align-items-center">
                            <div class="icon-red rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                <i class="bi bi-chat-square-text fs-6"></i>
                            </div>
                            <span>2. Entrevista Clínica</span>
                        </div>
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-12 col-lg-8 col-xl-9">
        <form asp-action="Register" method="post" id="formRegistro">
            <div class="tab-content bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light">
                
                <div class="tab-pane fade show active" id="paso1" role="tabpanel">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h4 class="fw-bold text-dark mb-1">1. Datos del Paciente</h4>
                        <p class="text-muted text-sm mb-0">Información básica para el expediente de salud mental.</p>
                    </div>

                    <div class="bg-light p-4 rounded-4 border border-light mb-4">
                        <h6 class="fw-bold text-dark text-sm mb-3">
                            <span class="icon-blue p-1 rounded-2 me-2"><i class="bi bi-search"></i></span> 
                            Búsqueda en Sistema
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Matrícula</label>
                                <input asp-for="Matricula" class="form-control custom-input fw-bold" id="Matricula" placeholder="Ingrese matrícula..." />
                                <span asp-validation-for="Matricula" class="text-danger text-xs"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Edad</label>
                                <input asp-for="Edad" class="form-control custom-input bg-white fw-bold" id="Edad" type="number" placeholder="Años" />
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark text-sm mb-3">
                        <span class="icon-cyan p-1 rounded-2 me-2"><i class="bi bi-person-lines-fill"></i></span> 
                        Información Personal (Auto-completado)
                    </h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label-custom">Nombre Completo</label>
                            <input asp-for="NombreCompleto" class="form-control custom-input bg-light" id="NombreCompleto" readonly />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label-custom">Carrera / Programa Educativo</label>
                            <input asp-for="Carrera" class="form-control custom-input bg-light" id="Carrera" readonly />
                        </div>
                    </div>

                    <div class="mt-4 text-end border-top pt-4">
                        <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm rounded-3" onclick="showTab('#paso2', 100)">
                            Siguiente Paso <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="tab-pane fade" id="paso2" role="tabpanel">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h4 class="fw-bold text-dark mb-1">2. Entrevista Clínica</h4>
                        <p class="text-muted text-sm mb-0">Registro confidencial de antecedentes y motivo de consulta.</p>
                    </div>

                    <div class="row g-4 mb-4">
                        
                        <div class="col-12">
                            <label class="form-label-custom mb-2">Motivo de la Consulta Actual *</label>
                            <textarea asp-for="MotivoConsulta" class="form-control custom-input" rows="4" placeholder="Describa la situación por la que acude el estudiante..." required></textarea>
                        </div>

                        <div class="col-12 mt-4 border-top pt-4">
                            <h6 class="fw-bold text-dark text-sm mb-3">Antecedentes Psicológicos/Psiquiátricos</h6>
                            
                            <div class="bg-light p-4 rounded-4 border border-light mb-3">
                                <div class="form-check form-switch mb-3">
                                    <input asp-for="TerapiaPrevia" class="form-check-input" type="checkbox" id="checkTerapia" onchange="toggleTerapia()">
                                    <label class="form-check-label text-xs fw-bold text-dark ms-2" for="checkTerapia">¿Ha tenido terapia psicológica previa?</label>
                                </div>
                                <div id="campoTerapiaAnterior" class="d-none">
                                    <label class="form-label-custom mb-2">Motivo de Terapia Anterior</label>
                                    <input asp-for="MotivoConsultaPrevia" class="form-control custom-input" placeholder="Breve descripción (Opcional)..." />
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="bg-light p-4 rounded-4 border border-light">
                                <label class="form-label-custom mb-2">Medicación Psiquiátrica Actual</label>
                                <input asp-for="MedicacionPsiquiatrica" class="form-control custom-input" placeholder="Nombre de medicamentos o 'Ninguna'..." />
                            </div>
                        </div>

                    </div>

                    <div class="mt-4 d-flex justify-content-between border-top pt-4">
                        <button type="button" class="btn btn-outline-secondary fw-bold px-4 shadow-sm rounded-3" onclick="showTab('#paso1', 50)">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="submit" class="btn btn-dark px-5 fw-bold shadow-sm rounded-3">
                            Guardar Sesión <i class="bi bi-save ms-2"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<style>
    /* Forzar estilo oscuro en los tabs */
    .nav-pills-custom .nav-link {
        color: #495057;
        font-weight: 600;
        border-radius: 8px;
        padding: 12px 16px;
        transition: all 0.2s;
    }
    .nav-pills-custom .nav-link:hover {
        background-color: #f8f9fa; 
    }
    .nav-pills-custom .nav-link.active {
        background-color: #212529 !important; 
        color: #ffffff !important;
    }
</style>

@section Scripts {
    <script>
        function showTab(target, progress) {
            // Mostrar la pestaña
            const triggerEl = document.querySelector(`button[data-bs-target="${target}"]`);
            bootstrap.Tab.getOrCreateInstance(triggerEl).show();
            
            // Actualizar progreso
            updateProgress(progress);
            
            // Mostrar palomita verde si se avanzó al paso 2
            if(progress === 100) {
                document.getElementById('icon-step1').classList.remove('d-none');
            }

            window.scrollTo(0, 0);
        }

        function updateProgress(value) {
            document.getElementById('progressBar').style.width = value + '%';
            document.getElementById('progressText').innerText = value + '%';
        }

        // Lógica para mostrar/ocultar el campo de motivo anterior
        function toggleTerapia() {
            const check = document.getElementById('checkTerapia');
            const contenedor = document.getElementById('campoTerapiaAnterior');
            if (check.checked) {
                contenedor.classList.remove('d-none');
            } else {
                contenedor.classList.add('d-none');
                document.getElementById('MotivoConsultaPrevia').value = "";
            }
        }

        // Lógica de Autocompletado y Cálculo de Edad (Idéntico a tu script original)
        document.addEventListener("DOMContentLoaded", function () {
            const inputMatricula = document.getElementById('Matricula');

            inputMatricula.addEventListener('blur', function () {
                const matricula = this.value.trim();

                if (matricula) {
                    fetch(`/VisitaPsicologica/ObtenerDatosAlumno?matricula=${matricula}`)
                        .then(response => {
                            if (!response.ok) {
                                throw new Error("No encontrado");
                            }
                            return response.json();
                        })
                        .then(data => {
                            document.getElementById('NombreCompleto').value = data.nombreCompleto;
                            document.getElementById('Carrera').value = data.carrera;

                            if (data.fechaNacimiento) {
                                const fecha = new Date(data.fechaNacimiento);
                                const hoy = new Date();
                                let edad = hoy.getFullYear() - fecha.getFullYear();
                                const m = hoy.getMonth() - fecha.getMonth();

                                if (m < 0 || (m === 0 && hoy.getDate() < fecha.getDate())) {
                                    edad--;
                                }

                                document.querySelector('[name="Edad"]').value = edad;
                            }
                        })
                        .catch(error => {
                            console.log("Alumno no encontrado o error:", error);
                            // Limpiar si no se encuentra
                            document.getElementById('NombreCompleto').value = '';
                            document.getElementById('Carrera').value = '';
                        });
                }
            });
        });
    </script>
}