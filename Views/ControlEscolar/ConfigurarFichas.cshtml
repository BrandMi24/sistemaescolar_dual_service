@using ControlEscolar.Helpers
@model ControlEscolar.Models.ConfiguracionViewModel

@{
    ViewData["Title"] = "Control Escolar — Configuración";
    Layout = "_LayoutControlEscolar";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 text-sm fw-bold" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 text-sm fw-bold" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-card-white shadow-sm mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
        <div>
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">
                <i class="bi bi-ticket-detailed me-2"></i>Configuración de Fichas por Carrera
            </h6>
            <p class="text-xxs text-muted mt-1 mb-0">Define el límite de preinscripciones por carrera y periodo</p>
        </div>
        <button type="button" class="btn-primary-sep text-xs px-4"
                data-bs-toggle="modal" data-bs-target="#modalNuevaConfig">
            <i class="bi bi-plus-lg me-2"></i> NUEVA CONFIGURACIÓN
        </button>
    </div>

    @if (!Model.Configuraciones.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-gear fs-1 text-muted opacity-50"></i>
            <p class="text-muted mt-3 text-sm">No hay configuraciones registradas.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle text-sm table-borderless mb-0">
                <thead class="bg-app text-xxs fw-bold text-muted">
                    <tr>
                        <th class="ps-3 border-0 py-3">Carrera</th>
                        <th class="border-0 py-3">Límite</th>
                        <th class="fw-bold pb-3">Límite Inscripciones</th>
                        <th class="border-0 py-3">Fecha Inicio</th>
                        <th class="border-0 py-3">Fecha Fin</th>
                        <th class="border-0 py-3">Estado</th>
                        <th class="border-0 py-3 pe-3 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Configuraciones)
                    {
                        <tr>
                            <td class="ps-3 fw-bold txt-title text-xs">@item.academiccontrol_inscription_ticketconfig_career</td>
                            <td>
                                <span class="badge bg-primary-100 txt-primary-dark px-3 py-1">
                                    @item.academiccontrol_inscription_ticketconfig_limit fichas
                                </span>
                            </td>
                            <td class="txt-body">
                                @(item.academiccontrol_inscription_ticketconfig_inscriptionLimit.HasValue
                                                        ? $"{item.academiccontrol_inscription_ticketconfig_inscriptionLimit} fichas"
                                                        : "Sin límite")
                    </td>
                            <td class="text-muted text-xs">@item.academiccontrol_inscription_ticketconfig_startDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted text-xs">@item.academiccontrol_inscription_ticketconfig_endDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.academiccontrol_inscription_ticketconfig_status)
                                {
                                    <span class="badge badge-status status-aceptado shadow-sm">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary text-xxs">Inactivo</span>
                                }
                            </td>
                            <td class="pe-3 text-end">
                                <button type="button" class="btn btn-sm btn-light border text-xxs fw-bold px-3"
                                        data-bs-toggle="modal" data-bs-target="#modalEditarConfig"
                                        data-id="@item.academiccontrol_inscription_ticketconfig_ID"
                                        data-carrera="@item.academiccontrol_inscription_ticketconfig_career"
                                        data-limite="@item.academiccontrol_inscription_ticketconfig_limit"
                                        data-limiteins="@item.academiccontrol_inscription_ticketconfig_inscriptionLimit"
                                        data-inicio="@item.academiccontrol_inscription_ticketconfig_startDate.ToString("yyyy-MM-dd")"
                                        data-fin="@item.academiccontrol_inscription_ticketconfig_endDate.ToString("yyyy-MM-dd")"
                                        data-activo="@item.academiccontrol_inscription_ticketconfig_status.ToString().ToLower()">
                                    <i class="bi bi-pencil me-1"></i> Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="admin-card-white shadow-sm mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
        <div>
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">
                <i class="bi bi-calendar-range me-2"></i>Periodos de Inscripción
            </h6>
            <p class="text-xxs text-muted mt-1 mb-0">Define cuándo está activo el proceso de preinscripción</p>
        </div>
        <button type="button" class="btn-primary-sep text-xs px-4"
                data-bs-toggle="modal" data-bs-target="#modalNuevoPeriodo">
            <i class="bi bi-plus-lg me-2"></i> NUEVO PERIODO
        </button>
    </div>

    @if (!Model.Periodos.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x fs-1 text-muted opacity-50"></i>
            <p class="text-muted mt-3 text-sm">No hay periodos registrados.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle text-sm table-borderless mb-0">
                <thead class="bg-app text-xxs fw-bold text-muted">
                    <tr>
                        <th class="ps-3 border-0 py-3">Nombre</th>
                        <th class="border-0 py-3">Fecha Inicio</th>
                        <th class="border-0 py-3">Fecha Fin</th>
                        <th class="border-0 py-3">Estado</th>
                        <th class="border-0 py-3 pe-3 text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Periodos)
                    {
                        bool isActivo = item.academiccontrol_inscription_period_status &&
                        item.academiccontrol_inscription_period_startDate <= DateTime.Today &&
                        item.academiccontrol_inscription_period_endDate >= DateTime.Today;
                        <tr>
                            <td class="ps-3 fw-bold txt-title text-xs">@item.academiccontrol_inscription_period_name</td>
                            <td class="text-muted text-xs">@item.academiccontrol_inscription_period_startDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted text-xs">@item.academiccontrol_inscription_period_endDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (isActivo)
                                {
                                    <span class="badge badge-status status-aceptado shadow-sm">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary text-xxs">Inactivo</span>
                                }
                            </td>
                            <td class="pe-3 text-end">
                                <button type="button" class="btn btn-sm btn-light border text-xxs fw-bold px-3"
                                        data-bs-toggle="modal" data-bs-target="#modalEditarPeriodo"
                                        data-id="@item.academiccontrol_inscription_period_ID"
                                        data-nombre="@item.academiccontrol_inscription_period_name"
                                        data-inicio="@item.academiccontrol_inscription_period_startDate.ToString("yyyy-MM-dd")"
                                        data-fin="@item.academiccontrol_inscription_period_endDate.ToString("yyyy-MM-dd")"
                                        data-activo="@item.academiccontrol_inscription_period_status.ToString().ToLower()">
                                    <i class="bi bi-pencil me-1"></i> Editar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="modal fade" id="modalNuevaConfig" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Nueva Configuración</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarConfiguracionFichas" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="academiccontrol_inscription_ticketconfig_ID" value="0" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">CARRERA *</label>
                        <select name="academiccontrol_inscription_ticketconfig_career" class="form-select text-sm fw-semibold" required>
                            @foreach (var c in CatalogosHelper.Carreras)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">LÍMITE *</label>
                        <input type="number" name="academiccontrol_inscription_ticketconfig_limit" class="form-control text-sm fw-semibold" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label txt-body text-xs fw-bold tracking-wide">LÍMITE INSCRIPCIONES</label>
                        <input type="number" name="academiccontrol_inscription_ticketconfig_inscriptionLimit"
                               class="form-control bg-app border-theme txt-title fw-bold"
                               placeholder="Dejar vacío si no aplica" />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">INICIO</label>
                            <input type="date" name="academiccontrol_inscription_ticketconfig_startDate" class="form-control text-sm fw-semibold" required />
                        </div>
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">FIN</label>
                            <input type="date" name="academiccontrol_inscription_ticketconfig_endDate" class="form-control text-sm fw-semibold" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="submit" class="btn-primary-sep text-xs px-4">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditarConfig" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Editar Configuración</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarConfiguracionFichas" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="academiccontrol_inscription_ticketconfig_ID" id="editId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">CARRERA</label>
                        <select name="academiccontrol_inscription_ticketconfig_career" id="editCarrera" class="form-select text-sm fw-semibold" required>
                            @foreach (var c in CatalogosHelper.Carreras)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">LÍMITE</label>
                        <input type="number" name="academiccontrol_inscription_ticketconfig_limit" id="editLimite" class="form-control text-sm fw-semibold" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label txt-body text-xs fw-bold tracking-wide">LÍMITE INSCRIPCIONES</label>
                        <input type="number" name="academiccontrol_inscription_ticketconfig_inscriptionLimit"
                               id="editLimiteIns"
                               class="form-control bg-app border-theme txt-title fw-bold"
                               placeholder="Dejar vacío si no aplica" />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">INICIO</label>
                            <input type="date" name="academiccontrol_inscription_ticketconfig_startDate" id="editInicio" class="form-control text-sm fw-semibold" required />
                        </div>
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">FIN</label>
                            <input type="date" name="academiccontrol_inscription_ticketconfig_endDate" id="editFin" class="form-control text-sm fw-semibold" required />
                        </div>
                    </div>
                    <div class="form-check mt-3">
                        <input type="hidden" id="hiddenConfigActivo" name="academiccontrol_inscription_ticketconfig_status" value="false" />
                        <input class="form-check-input" type="checkbox" id="editActivo" />
                        <label class="form-check-label text-sm fw-bold" for="editActivo">Activo</label>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="submit" class="btn-primary-sep text-xs px-4">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalNuevoPeriodo" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Nuevo Periodo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarPeriodo" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="academiccontrol_inscription_period_ID" value="0" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">NOMBRE</label>
                        <input type="text" name="academiccontrol_inscription_period_name" class="form-control text-sm fw-semibold" required />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">INICIO</label>
                            <input type="date" name="academiccontrol_inscription_period_startDate" class="form-control text-sm fw-semibold" required />
                        </div>
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">FIN</label>
                            <input type="date" name="academiccontrol_inscription_period_endDate" class="form-control text-sm fw-semibold" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="submit" class="btn-primary-sep text-xs px-4">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditarPeriodo" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Editar Periodo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarPeriodo" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="academiccontrol_inscription_period_ID" id="editPeriodoId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">NOMBRE</label>
                        <input type="text" name="academiccontrol_inscription_period_name" id="editPeriodoNombre" class="form-control text-sm fw-semibold" required />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">INICIO</label>
                            <input type="date" name="academiccontrol_inscription_period_startDate" id="editPeriodoInicio" class="form-control text-sm fw-semibold" required />
                        </div>
                        <div class="col-md-6">
                            <label class="section-label text-muted mb-2 d-block">FIN</label>
                            <input type="date" name="academiccontrol_inscription_period_endDate" id="editPeriodoFin" class="form-control text-sm fw-semibold" required />
                        </div>
                    </div>
                    <div class="form-check mt-3">
                        <input type="hidden" id="hiddenPeriodoActivo" name="academiccontrol_inscription_period_status" value="false" />
                        <input class="form-check-input" type="checkbox" id="editPeriodoActivo" />
                        <label class="form-check-label text-sm fw-bold" for="editPeriodoActivo">Activo</label>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="submit" class="btn-primary-sep text-xs px-4">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalEditarPeriodo')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('editPeriodoId').value = btn.dataset.id;
            document.getElementById('editPeriodoNombre').value = btn.dataset.nombre;
            document.getElementById('editPeriodoInicio').value = btn.dataset.inicio;
            document.getElementById('editPeriodoFin').value = btn.dataset.fin;
            const isActivo = btn.dataset.activo === 'true';
            document.getElementById('editPeriodoActivo').checked = isActivo;
            document.getElementById('hiddenPeriodoActivo').value = isActivo ? 'true' : 'false';
        });
        document.getElementById('editPeriodoActivo')?.addEventListener('change', function () {
            document.getElementById('hiddenPeriodoActivo').value = this.checked ? 'true' : 'false';
        });
        document.getElementById('modalEditarConfig')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editLimite').value = btn.dataset.limite;
            document.getElementById('editLimiteIns').value = btn.dataset.limiteins ?? '';
            document.getElementById('editInicio').value = btn.dataset.inicio;
            document.getElementById('editFin').value = btn.dataset.fin;
            const isActivo = btn.dataset.activo === 'true';
            document.getElementById('editActivo').checked = isActivo;
            document.getElementById('hiddenConfigActivo').value = isActivo ? 'true' : 'false';
            const selectCarrera = document.getElementById('editCarrera');
            if (selectCarrera) selectCarrera.value = btn.dataset.carrera;
        });
        document.getElementById('editActivo')?.addEventListener('change', function () {
            document.getElementById('hiddenConfigActivo').value = this.checked ? 'true' : 'false';
        });
    </script>
}