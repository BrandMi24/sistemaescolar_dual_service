@using ControlEscolar.Helpers
@using ControlEscolar.Enums
@model ControlEscolar.Models.HistorialViewModel

@{
    ViewData["Title"] = "Historial de Preinscripciones";
    Layout = "_Layout";
}

<div class="main-container pt-5 mb-5">
    <div class="container">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold txt-primary-dark mb-1">Historial de Preinscripciones</h2>
                <p class="txt-body small mb-0">Consulta y filtra el registro histórico de preinscripciones</p>
            </div>
            @* <a asp-action="Index" class="btn btn-ghost-sep px-4">
                <i class="bi bi-arrow-left me-2"></i> Volver
            </a> *@
            <a asp-action="ExportarHistorialExcel"
               asp-route-carrera="@Model.FiltroCarrera"
               asp-route-estado="@Model.FiltroEstado"
               asp-route-municipio="@Model.FiltroMunicipio"
               asp-route-anio="@Model.FiltroAnio"
               asp-route-fechaInicio="@Model.FiltroFechaInicio?.ToString("yyyy-MM-dd")"
               asp-route-fechaFin="@Model.FiltroFechaFin?.ToString("yyyy-MM-dd")"
               class="btn btn-primary-sep px-4">
                <i class="bi bi-file-earmark-excel me-2"></i> Exportar Excel
            </a>
        </div>

        <div class="bg-surface rounded-4 shadow-sm border-theme p-4 mb-4">
            <form method="get" asp-action="Historial" class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label txt-body text-xs fw-bold tracking-wide">CARRERA</label>
                    <select name="carrera" class="form-select bg-app border-theme txt-title fw-bold">
                        <option value="">Todas</option>
                        @foreach (var c in CatalogosHelper.Carreras)
                        {
                            <option value="@c" selected="@(Model.FiltroCarrera == c)">@c</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label txt-body text-xs fw-bold tracking-wide">ESTADO</label>
                    <select name="estado" class="form-select bg-app border-theme txt-title fw-bold">
                        <option value="">Todos</option>
                        @foreach (var e in Enum.GetNames(typeof(EstadoPreinscripcion)))
                        {
                            <option value="@e" selected="@(Model.FiltroEstado == e)">@e</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label txt-body text-xs fw-bold tracking-wide">AÑO</label>
                    <select name="anio" class="form-select bg-app border-theme txt-title fw-bold">
                        <option value="">Todos</option>
                        @foreach (var a in Model.AniosDisponibles)
                        {
                            <option value="@a" selected="@(Model.FiltroAnio == a)">@a</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label txt-body text-xs fw-bold tracking-wide">DESDE</label>
                    <input type="date" name="fechaInicio"
                           value="@Model.FiltroFechaInicio?.ToString("yyyy-MM-dd")"
                           class="form-control bg-app border-theme txt-title fw-bold" />
                </div>
                <div class="col-md-2">
                    <label class="form-label txt-body text-xs fw-bold tracking-wide">HASTA</label>
                    <input type="date" name="fechaFin"
                           value="@Model.FiltroFechaFin?.ToString("yyyy-MM-dd")"
                           class="form-control bg-app border-theme txt-title fw-bold" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary-sep w-100">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                    <a href="@Url.Action("Historial")" class="btn btn-ghost-sep w-100">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                </div>
            </form>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="bg-surface rounded-4 shadow-sm border-theme p-3 text-center">
                    <div class="txt-body text-xs fw-bold tracking-wide mb-1">TOTAL</div>
                    <h4 class="fw-bold txt-primary-dark mb-0">@Model.Preinscripciones.Count</h4>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-surface rounded-4 shadow-sm border-theme p-3 text-center">
                    <div class="txt-body text-xs fw-bold tracking-wide mb-1">PENDIENTES</div>
                    <h4 class="fw-bold txt-primary-dark mb-0">
                        @Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "Pendiente")
                    </h4>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-surface rounded-4 shadow-sm border-theme p-3 text-center">
                    <div class="txt-body text-xs fw-bold tracking-wide mb-1">HABILITADAS</div>
                    <h4 class="fw-bold txt-primary-dark mb-0">
                        @Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "InscripcionHabilitada")
                    </h4>
                </div>
            </div>
            <div class="col-md-3">
                <div class="bg-surface rounded-4 shadow-sm border-theme p-3 text-center">
                    <div class="txt-body text-xs fw-bold tracking-wide mb-1">RECHAZADAS</div>
                    <h4 class="fw-bold txt-primary-dark mb-0">
                        @Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "Rechazada")
                    </h4>
                </div>
            </div>
        </div>

        <div class="bg-surface rounded-4 shadow-sm border-theme p-4">
            @if (!Model.Preinscripciones.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 txt-body opacity-50"></i>
                    <p class="txt-body mt-3">No hay registros con los filtros aplicados.</p>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="txt-body small">
                        Mostrando <strong>@Model.Preinscripciones.Count</strong> registros
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0" style="font-size: 0.875rem;">
                        <thead>
                            <tr class="txt-body border-bottom border-theme">
                                <th class="fw-bold pb-3">Folio</th>
                                <th class="fw-bold pb-3">Aspirante</th>
                                <th class="fw-bold pb-3">Carrera</th>
                                <th class="fw-bold pb-3">Municipio</th>
                                <th class="fw-bold pb-3">Promedio</th>
                                <th class="fw-bold pb-3">Fecha</th>
                                <th class="fw-bold pb-3">Estado</th>
                                <th class="fw-bold pb-3 text-end">Detalle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Preinscripciones)
                            {
                                <tr class="border-bottom border-theme">
                                    <td class="fw-bold txt-primary-dark">
                                        @(item.academiccontrol_preinscription_folio ?? $"#{item.academiccontrol_preinscription_ID}")
                                    </td>
                                    <td>
                                        <div class="fw-bold txt-title">
                                            @item.DatosPersonales?.academiccontrol_preinscription_personaldata_paternalSurname,
                                            @item.DatosPersonales?.academiccontrol_preinscription_personaldata_maternalSurname,
                                            @item.DatosPersonales?.academiccontrol_preinscription_personaldata_name
                                        </div>
                                        <small class="txt-body">@item.DatosPersonales?.academiccontrol_preinscription_personaldata_CURP</small>
                                    </td>
                                    <td class="txt-body">@item.academiccontrol_preinscription_careerRequested</td>
                                    <td class="txt-body">@item.Domicilio?.academiccontrol_preinscription_address_municipality</td>
                                    <td class="txt-body">@item.academiccontrol_preinscription_average.ToString("F1")</td>
                                    <td class="txt-body">
                                        @item.academiccontrol_preinscription_registrationDate.ToString("dd/MM/yyyy")
                                    </td>
                                    <td>
                                        @await Html.PartialAsync("_StatusBadge", null,
                                        new ViewDataDictionary(ViewData)
                                                                {
                                                                { "StatusValue", item.academiccontrol_preinscription_state },
                                                                { "StatusType", "preinscripcion" }
                                                                })
                            </td>
                            <td class="text-end">
                                <a asp-controller="Preinscripciones"
                                   asp-action="Details"
                                   asp-route-id="@item.academiccontrol_preinscription_ID"
                                   class="btn btn-sm btn-ghost-sep px-3">
                                    <i class="bi bi-eye me-1"></i> Ver
                                </a>
                            </td>
                        </tr>
                                                }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>