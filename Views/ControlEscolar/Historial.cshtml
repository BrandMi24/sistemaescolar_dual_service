@using ControlEscolar.Helpers
@using ControlEscolar.Enums
@model ControlEscolar.Models.HistorialViewModel

@{
    ViewData["Title"] = "Historial";
    Layout = "_LayoutControlEscolar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold txt-primary-dark mb-0 text-uppercase tracking-tight">Historial de Registros</h5>
        <div class="text-xxs fw-bold text-muted text-uppercase">Consulta y filtra el registro histórico</div>
    </div>
    <form method="get" asp-action="ExportarHistorialExcel">
        <input type="hidden" name="carrera" value="@Model.FiltroCarrera" />
        <input type="hidden" name="estado" value="@Model.FiltroEstado" />
        <input type="hidden" name="municipio" value="@Model.FiltroMunicipio" />
        <input type="hidden" name="anio" value="@Model.FiltroAnio" />
        <input type="hidden" name="fechaInicio" value="@Model.FiltroFechaInicio?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="fechaFin" value="@Model.FiltroFechaFin?.ToString("yyyy-MM-dd")" />
        <input type="hidden" name="tab" value="@Model.TabActiva" />
        <button type="submit" class="btn-primary-sep text-xs px-4">
            <i class="bi bi-file-earmark-excel me-2"></i> EXPORTAR EXCEL
        </button>
    </form>
</div>

<div class="admin-card-white mb-4 shadow-sm">
    <form method="get" asp-action="Historial" class="row g-3 align-items-end">
        <input type="hidden" name="tab" value="@Model.TabActiva" />
        <div class="col-md-2">
            <label class="section-label text-muted mb-1 d-block">CARRERA</label>
            <select name="carrera" class="form-select text-sm fw-semibold">
                <option value="">Todas</option>
                @foreach (var c in CatalogosHelper.Carreras)
                {
                    if (Model.FiltroCarrera == c)
                    {
                        <option value="@c" selected>@c</option>
                    }
                    else
                    {
                        <option value="@c">@c</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="section-label text-muted mb-1 d-block">ESTADO</label>
            <select name="estado" class="form-select text-sm fw-semibold">
                <option value="">Todos</option>
                @if (Model.TabActiva == "preinscripciones")
                {
                    foreach (var e in Enum.GetNames(typeof(EstadoPreinscripcion)))
                    {
                        if (Model.FiltroEstado == e)
                        {
                            <option value="@e" selected>@e</option>
                        }
                        else
                        {
                            <option value="@e">@e</option>
                        }
                    }
                }
                else
                {
                    foreach (var e in Enum.GetNames(typeof(EstadoInscripcion)))
                    {
                        if (Model.FiltroEstado == e)
                        {
                            <option value="@e" selected>@e</option>
                        }
                        else
                        {
                            <option value="@e">@e</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-1">
            <label class="section-label text-muted mb-1 d-block">AÑO</label>
            <select name="anio" class="form-select text-sm fw-semibold">
                <option value="">Todos</option>
                @foreach (var a in Model.AniosDisponibles)
                {
                    if (Model.FiltroAnio == a)
                    {
                        <option value="@a" selected>@a</option>
                    }
                    else
                    {
                        <option value="@a">@a</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="section-label text-muted mb-1 d-block">DESDE</label>
            <input type="date" name="fechaInicio"
                   value="@Model.FiltroFechaInicio?.ToString("yyyy-MM-dd")"
                   class="form-control text-sm fw-semibold" />
        </div>
        <div class="col-md-2">
            <label class="section-label text-muted mb-1 d-block">HASTA</label>
            <input type="date" name="fechaFin"
                   value="@Model.FiltroFechaFin?.ToString("yyyy-MM-dd")"
                   class="form-control text-sm fw-semibold" />
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn-primary-sep text-xs px-4">
                <i class="bi bi-funnel me-2"></i> FILTRAR
            </button>
            <a href="@Url.Action("Historial", new { tab = Model.TabActiva })" class="btn-ghost-sep text-xs px-4 bg-surface">
                LIMPIAR
            </a>
        </div>
    </form>
</div>

<ul class="nav mb-4" style="gap: 8px;">
    <li class="nav-item">
        <a class="fw-bold text-xs tracking-wide px-4 py-2 rounded-2 text-decoration-none d-flex align-items-center gap-2"
           style="@(Model.TabActiva == "preinscripciones" ? "background-color: var(--primary-900); color: white;" : "background-color: var(--bg-surface, #fff); color: var(--text-title); border: 1px solid var(--border-theme);")"
           href="@Url.Action("Historial", new { tab = "preinscripciones", carrera = Model.FiltroCarrera, estado = Model.FiltroEstado, anio = Model.FiltroAnio, fechaInicio = Model.FiltroFechaInicio?.ToString("yyyy-MM-dd"), fechaFin = Model.FiltroFechaFin?.ToString("yyyy-MM-dd") })">
            <i class="bi bi-person-lines-fill"></i>
            PREINSCRIPCIONES
            <span class="badge ms-1" style="@(Model.TabActiva == "preinscripciones" ? "background-color: rgba(255,255,255,0.2); color: white;" : "background-color: var(--primary-900); color: white;")">
                @Model.Preinscripciones.Count
            </span>
        </a>
    </li>
    <li class="nav-item">
        <a class="fw-bold text-xs tracking-wide px-4 py-2 rounded-2 text-decoration-none d-flex align-items-center gap-2"
           style="@(Model.TabActiva == "inscripciones" ? "background-color: var(--primary-900); color: white;" : "background-color: var(--bg-surface, #fff); color: var(--text-title); border: 1px solid var(--border-theme);")"
           href="@Url.Action("Historial", new { tab = "inscripciones", carrera = Model.FiltroCarrera, estado = Model.FiltroEstado, anio = Model.FiltroAnio, fechaInicio = Model.FiltroFechaInicio?.ToString("yyyy-MM-dd"), fechaFin = Model.FiltroFechaFin?.ToString("yyyy-MM-dd") })">
            <i class="bi bi-person-check-fill"></i>
            INSCRIPCIONES
            <span class="badge ms-1" style="@(Model.TabActiva == "inscripciones" ? "background-color: rgba(255,255,255,0.2); color: white;" : "background-color: var(--primary-900); color: white;")">
                @Model.Inscripciones.Count
            </span>
        </a>
    </li>
</ul>

@if (Model.TabActiva == "preinscripciones")
{
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <div class="stat-card-sep">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Total</span>
                    <div class="icon-circle bg-accent-light txt-primary-dark shadow-sm"><i class="bi bi-person-plus fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Preinscripciones.Count</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Pendientes</span>
                    <div class="icon-circle bg-warning-100 shadow-sm" style="color: var(--warning-700);"><i class="bi bi-hourglass-split fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "Pendiente")</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--success-700);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Habilitadas</span>
                    <div class="icon-circle bg-success-100 shadow-sm" style="color: var(--success-700);"><i class="bi bi-unlock fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "InscripcionHabilitada")</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--error-500, #dc3545);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Rechazadas</span>
                    <div class="icon-circle shadow-sm" style="background: #fee2e2; color: #dc3545;"><i class="bi bi-x-circle fs-5"></i></div>
                </div>
                <div class="stat-value text-danger">@Model.Preinscripciones.Count(p => p.academiccontrol_preinscription_state == "Rechazada")</div>
            </div>
        </div>
    </div>

    <div class="admin-card-white shadow-sm">
        @if (!Model.Preinscripciones.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 text-sm">No hay registros con los filtros aplicados.</p>
            </div>
        }
        else
        {
            <div class="text-xxs text-muted mb-3 fw-bold">Mostrando <strong>@Model.Preinscripciones.Count</strong> registros</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle text-sm table-borderless mb-0">
                    <thead class="bg-primary-dark txt-white text-xxs" style="position: sticky; top: 0;">
                        <tr>
                            <th class="ps-3 border-0 py-3">Folio</th>
                            <th class="border-0">Aspirante</th>
                            <th class="border-0">Carrera</th>
                            <th class="border-0">Municipio</th>
                            <th class="text-center border-0">Promedio</th>
                            <th class="border-0">Fecha</th>
                            <th class="border-0">Estado</th>
                            <th class="text-end pe-3 border-0">Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Preinscripciones)
                        {
                            <tr>
                                <td class="ps-3 fw-bold txt-primary-dark">
                                    @(item.academiccontrol_preinscription_folio ?? $"#{item.academiccontrol_preinscription_ID}")
                                </td>
                                <td>
                                    <div class="fw-bold txt-title text-xs">
                                        @($"{item.DatosPersonales?.academiccontrol_preinscription_personaldata_paternalSurname} {item.DatosPersonales?.academiccontrol_preinscription_personaldata_maternalSurname}, {item.DatosPersonales?.academiccontrol_preinscription_personaldata_name}")
                                    </div>
                                    <small class="text-muted">@item.DatosPersonales?.academiccontrol_preinscription_personaldata_CURP</small>
                                </td>
                                <td class="text-muted text-xs">@item.academiccontrol_preinscription_careerRequested</td>
                                <td class="text-muted text-xs">@item.Domicilio?.academiccontrol_preinscription_address_municipality</td>
                                <td class="text-center fw-bold">@item.academiccontrol_preinscription_average.ToString("F1")</td>
                                <td class="text-muted text-xs">@item.academiccontrol_preinscription_registrationDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData)
                                    {
                                        { "StatusValue", item.academiccontrol_preinscription_state },
                                                { "StatusType", "preinscripcion" }
                                    })
                    </td>
                    <td class="text-end pe-3">
                        <a asp-controller="Preinscripciones"
                           asp-action="Details"
                           asp-route-id="@item.academiccontrol_preinscription_ID"
                           asp-route-returnUrl="@Url.Action("Historial", "ControlEscolar", new { tab = "preinscripciones" })"
                           class="btn btn-sm btn-ghost-sep px-3">
                            <i class="bi bi-eye me-1"></i> Ver
                        </a>
                    </td>
                </tr>
                                }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@if (Model.TabActiva == "inscripciones")
{
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <div class="stat-card-sep">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Total</span>
                    <div class="icon-circle bg-accent-light txt-primary-dark shadow-sm"><i class="bi bi-people-fill fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Inscripciones.Count</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Pendientes</span>
                    <div class="icon-circle bg-warning-100 shadow-sm" style="color: var(--warning-700);"><i class="bi bi-hourglass-split fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Inscripciones.Count(i => i.academiccontrol_inscription_state == "Pendiente")</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--success-700);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Aprobadas</span>
                    <div class="icon-circle bg-success-100 shadow-sm" style="color: var(--success-700);"><i class="bi bi-check-circle-fill fs-5"></i></div>
                </div>
                <div class="stat-value">@Model.Inscripciones.Count(i => i.academiccontrol_inscription_state == "Aprobada")</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--error-500, #dc3545);">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="stat-label">Rechazadas</span>
                    <div class="icon-circle shadow-sm" style="background: #fee2e2; color: #dc3545;"><i class="bi bi-x-circle fs-5"></i></div>
                </div>
                <div class="stat-value text-danger">@Model.Inscripciones.Count(i => i.academiccontrol_inscription_state == "Rechazada")</div>
            </div>
        </div>
    </div>

    <div class="admin-card-white shadow-sm">
        @if (!Model.Inscripciones.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 text-sm">No hay registros con los filtros aplicados.</p>
            </div>
        }
        else
        {
            <div class="text-xxs text-muted mb-3 fw-bold">Mostrando <strong>@Model.Inscripciones.Count</strong> registros</div>
            <div class="table-responsive">
                <table class="table table-hover align-middle text-sm table-borderless mb-0">
                    <thead class="bg-primary-dark txt-white text-xxs" style="position: sticky; top: 0;">
                        <tr>
                            <th class="ps-3 border-0 py-3">Matrícula</th>
                            <th class="border-0">Aspirante</th>
                            <th class="border-0">Carrera</th>
                            <th class="border-0">Municipio</th>
                            <th class="border-0">Fecha</th>
                            <th class="border-0">Estado</th>
                            <th class="text-end pe-3 border-0">Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Inscripciones)
                        {
                            <tr>
                                <td class="ps-3 fw-bold txt-primary-dark">
                                    @(item.academiccontrol_inscription_enrollment ?? $"#{item.academiccontrol_inscription_ID}")
                                </td>
                                <td>
                                    <div class="fw-bold txt-title text-xs">
                                        @($"{item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_paternalSurname} {item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_maternalSurname}, {item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_name}")
                                    </div>
                                    <small class="text-muted">Folio: @item.Preinscripcion?.academiccontrol_preinscription_folio</small>
                                </td>
                                <td class="text-muted text-xs">@item.academiccontrol_inscription_careerRequested</td>
                                <td class="text-muted text-xs">@item.Preinscripcion?.Domicilio?.academiccontrol_preinscription_address_municipality</td>
                                <td class="text-muted text-xs">@item.academiccontrol_inscription_registrationDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData)
                                    {
                                        { "StatusValue", item.academiccontrol_inscription_state },
                                                { "StatusType", "inscripcion" }
                                    })
                    </td>
                    <td class="text-end pe-3">
                        <a asp-controller="Aspirantes"
                           asp-action="Details"
                           asp-route-id="@item.academiccontrol_inscription_ID"
                           asp-route-returnUrl="@Url.Action("Historial", "ControlEscolar", new { tab = "inscripciones" })"
                           class="btn btn-sm btn-ghost-sep px-3">
                            <i class="bi bi-eye me-1"></i> Ver
                        </a>
                    </td>
                </tr>
                                }
                    </tbody>
                </table>
            </div>
        }
    </div>
}