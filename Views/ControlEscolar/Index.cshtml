@using ControlEscolar.Helpers
@using ControlEscolar.Enums
@model ControlEscolar.Models.ControlEscolarViewModel

@{
    ViewData["Title"] = "Control Escolar — Gestión";
    Layout = "_LayoutControlEscolar";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4 text-sm fw-bold" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4 text-sm fw-bold" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <ul class="nav mb-4" id="controlTab" style="gap: 8px;">
        <li class="nav-item">
            <a class="fw-bold text-xs tracking-wide px-4 py-2 rounded-2 text-decoration-none d-flex align-items-center gap-2"
               style="@(Model.Tab == "preinscripciones" ? "background-color: var(--primary-900); color: white;" : "background-color: var(--bg-surface); color: var(--text-title); border: 1px solid var(--border-theme);")"
               href="@Url.Action("Index", new { tab = "preinscripciones", carrera = Model.FiltroCarrera, estado = Model.FiltroEstado })">
                <i class="bi bi-person-lines-fill"></i>
                PREINSCRIPCIONES
                <span class="badge ms-1" style="@(Model.Tab == "preinscripciones" ? "background-color: rgba(255,255,255,0.2); color: white;" : "background-color: var(--primary-900); color: white;")">
                    @Model.Preinscripciones.Count
                </span>
            </a>
        </li>
        <li class="nav-item">
            <a class="fw-bold text-xs tracking-wide px-4 py-2 rounded-2 text-decoration-none d-flex align-items-center gap-2"
               style="@(Model.Tab == "inscripciones" ? "background-color: var(--primary-900); color: white;" : "background-color: var(--bg-surface); color: var(--text-title); border: 1px solid var(--border-theme);")"
               href="@Url.Action("Index", new { tab = "inscripciones", carrera = Model.FiltroCarrera, estado = Model.FiltroEstado })">
                <i class="bi bi-person-check-fill"></i>
                INSCRIPCIONES
                <span class="badge ms-1" style="@(Model.Tab == "inscripciones" ? "background-color: rgba(255,255,255,0.2); color: white;" : "background-color: var(--primary-900); color: white;")">
                    @Model.Inscripciones.Count
                </span>
            </a>
        </li>
    </ul>
</div>

<div class="admin-card-white p-4 mb-4 shadow-sm">
    <form method="get" asp-action="Index" class="row g-3 align-items-end">
        <input type="hidden" name="tab" value="@Model.Tab" />
        <div class="col-md-4">
            <label class="section-label text-muted mb-2 d-block">Carrera</label>
            <select name="carrera" class="form-select text-sm fw-semibold">
                <option value="">Todas las carreras</option>
                @foreach (var c in CatalogosHelper.Carreras)
                {
                    if (Model.FiltroCarrera == c)
                    {
                        <option value="@c" selected>@c</option>
                    }
                    else
                    {
                        <option value="@c">@c</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="section-label text-muted mb-2 d-block">Estado</label>
            <select name="estado" class="form-select text-sm fw-semibold">
                <option value="">Todos los estados</option>
                @if (Model.Tab == "preinscripciones")
                {
                    foreach (var e in Enum.GetNames(typeof(EstadoPreinscripcion)))
                    {
                        if (Model.FiltroEstado == e)
                        {
                            <option value="@e" selected>@e</option>
                        }
                        else
                        {
                            <option value="@e">@e</option>
                        }
                    }
                }
                else
                {
                    foreach (var e in Enum.GetNames(typeof(EstadoInscripcion)))
                    {
                        if (Model.FiltroEstado == e)
                        {
                            <option value="@e" selected>@e</option>
                        }
                        else
                        {
                            <option value="@e">@e</option>
                        }
                    }
                }
            </select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn-primary-sep text-xs px-4">
                <i class="bi bi-funnel me-2"></i> FILTRAR
            </button>
            <a href="@Url.Action("Index", new { tab = Model.Tab, estado = "Pendiente" })" class="btn-ghost-sep text-xs px-4 bg-surface">
                LIMPIAR
            </a>
        </div>
    </form>
</div>

@if (Model.Tab == "preinscripciones")
{
    <div class="admin-card-white shadow-sm">
        @if (!Model.Preinscripciones.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 text-sm">No hay preinscripciones que mostrar.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-sm table-borderless mb-0">
                    <thead class="bg-primary-dark txt-white text-xxs fw-bold">
                        <tr>
                            <th class="ps-4 border-0 py-3">Folio</th>
                            <th class="border-0 py-3">Aspirante</th>
                            <th class="border-0 py-3">Carrera</th>
                            <th class="border-0 py-3">Promedio</th>
                            <th class="border-0 py-3">Fecha</th>
                            <th class="border-0 py-3">Estado</th>
                            <th class="border-0 py-3 pe-4 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Preinscripciones)
                        {
                            <tr>
                                <td class="ps-4 fw-bold txt-primary-dark">
                                    @(item.academiccontrol_preinscription_folio ?? $"#{item.academiccontrol_preinscription_ID}")
                                </td>
                                <td>
                                    <div class="fw-bold txt-title text-xs">
                                        @item.DatosPersonales?.academiccontrol_preinscription_personaldata_paternalSurname
                                        @item.DatosPersonales?.academiccontrol_preinscription_personaldata_maternalSurname,
                                        @item.DatosPersonales?.academiccontrol_preinscription_personaldata_name
                                    </div>
                                    <div class="text-xxs text-muted">@item.DatosPersonales?.academiccontrol_preinscription_personaldata_email</div>
                                </td>
                                <td class="text-muted text-xs">@item.academiccontrol_preinscription_careerRequested</td>
                                <td class="fw-bold text-xs">@item.academiccontrol_preinscription_average.ToString("F1")</td>
                                <td class="text-muted text-xs">@item.academiccontrol_preinscription_registrationDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData)
                                    {
                                        { "StatusValue", item.academiccontrol_preinscription_state },
                                                { "StatusType", "preinscripcion" }
                                    })
                    </td>
                    <td class="pe-4 text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="Preinscripciones"
                               asp-action="Details"
                               asp-route-id="@item.academiccontrol_preinscription_ID"
                               asp-route-returnUrl="@Url.Action("Index", "ControlEscolar", new { tab = "preinscripciones", carrera = Model.FiltroCarrera, estado = Model.FiltroEstado })"
                               class="btn btn-sm btn-ghost-sep px-3">
                                <i class="bi bi-eye me-1"></i> Ver
                            </a>
                            @if (item.academiccontrol_preinscription_state == EstadoPreinscripcion.Pendiente.ToString())
                                        {
                                            <form asp-action="ValidarPreinscripcion" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.academiccontrol_preinscription_ID" />
                                                <button type="submit" class="btn btn-sm btn-primary-sep text-xxs px-3 btn-validar-pre"
                                                        data-folio="@item.academiccontrol_preinscription_folio">
                                                    <i class="bi bi-check-lg me-1"></i> Validar
                                                </button>
                                            </form>
                                        }
                                        @if (item.academiccontrol_preinscription_state == EstadoPreinscripcion.Validada.ToString())
                                        {
                                            <form asp-action="HabilitarInscripcion" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.academiccontrol_preinscription_ID" />
                                                <button type="submit" class="btn btn-sm text-xxs px-3 btn-habilitar"
                                                        style="background-color: var(--success-700); color: white;"
                                                        data-folio="@item.academiccontrol_preinscription_folio">
                                                    <i class="bi bi-unlock me-1"></i> Habilitar
                                                </button>
                                            </form>
                                        }
                                        @if (item.academiccontrol_preinscription_state == EstadoPreinscripcion.Pendiente.ToString()
                                                                    || item.academiccontrol_preinscription_state == EstadoPreinscripcion.Validada.ToString())
                                        {
                                            <button type="button" class="btn btn-sm btn-danger text-xxs px-3"
                                                    data-bs-toggle="modal" data-bs-target="#modalRechazarPre"
                                                    data-id="@item.academiccontrol_preinscription_ID"
                                                    data-folio="@item.academiccontrol_preinscription_folio">
                                                <i class="bi bi-x-lg me-1"></i> Rechazar
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@if (Model.Tab == "inscripciones")
{
    <div class="admin-card-white shadow-sm">
        @if (!Model.Inscripciones.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted opacity-50"></i>
                <p class="text-muted mt-3 text-sm">No hay inscripciones que mostrar.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-sm table-borderless mb-0">
                    <thead class="bg-primary-dark txt-white text-xxs fw-bold">
                        <tr>
                            <th class="ps-4 border-0 py-3">Matrícula</th>
                            <th class="border-0 py-3">Aspirante</th>
                            <th class="border-0 py-3">Carrera</th>
                            <th class="border-0 py-3">Documentos</th>
                            <th class="border-0 py-3">Fecha</th>
                            <th class="border-0 py-3">Estado</th>
                            <th class="border-0 py-3 pe-4 text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Inscripciones)
                        {
                            <tr>
                                <td class="ps-4 fw-bold txt-primary-dark">
                                    @(item.academiccontrol_inscription_enrollment ?? $"#{item.academiccontrol_inscription_ID}")
                                </td>
                                <td>
                                    <div class="fw-bold txt-title text-xs">
                                        @item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_paternalSurname
                                        @item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_maternalSurname,
                                        @item.Preinscripcion?.DatosPersonales?.academiccontrol_preinscription_personaldata_name
                                    </div>
                                    <div class="text-xxs text-muted">Folio: @item.Preinscripcion?.academiccontrol_preinscription_folio</div>
                                </td>
                                <td class="text-muted text-xs">@item.academiccontrol_inscription_careerRequested</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <div class="d-flex align-items-center gap-1">
                                            @if (!string.IsNullOrEmpty(item.academiccontrol_inscription_birthCertificatePath))
                                            {
                                                <a href="@item.academiccontrol_inscription_birthCertificatePath" target="_blank"
                                                   class="btn btn-sm btn-light border text-xxs px-2">
                                                    <i class="bi bi-file-earmark-pdf text-danger"></i> Acta
                                                </a>
                                                @if (!item.academiccontrol_inscription_actaValidada)
                                                {
                                                    <form asp-action="ValidarActa" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.academiccontrol_inscription_ID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success text-xxs px-2 btn-validar-acta"
                                                                data-nombre="Acta de Nacimiento">
                                                            <i class="bi bi-check2"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success text-xxs"><i class="bi bi-check2-circle me-1"></i>OK</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary bg-opacity-50 text-xxs">Sin Acta</span>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center gap-1">
                                            @if (!string.IsNullOrEmpty(item.academiccontrol_inscription_curpPdfPath))
                                            {
                                                <a href="@item.academiccontrol_inscription_curpPdfPath" target="_blank"
                                                   class="btn btn-sm btn-light border text-xxs px-2">
                                                    <i class="bi bi-file-earmark-pdf text-danger"></i> CURP
                                                </a>
                                                @if (!item.academiccontrol_inscription_curpValidado)
                                                {
                                                    <form asp-action="ValidarCurp" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.academiccontrol_inscription_ID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success text-xxs px-2 btn-validar-curp"
                                                                data-nombre="CURP">
                                                            <i class="bi bi-check2"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success text-xxs"><i class="bi bi-check2-circle me-1"></i>OK</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary bg-opacity-50 text-xxs">Sin CURP</span>
                                            }
                                        </div>
                                        <div class="d-flex align-items-center gap-1">
                                            @if (!string.IsNullOrEmpty(item.academiccontrol_inscription_transcriptPath))
                                            {
                                                <a href="@item.academiccontrol_inscription_transcriptPath" target="_blank"
                                                   class="btn btn-sm btn-light border text-xxs px-2">
                                                    <i class="bi bi-file-earmark-pdf text-danger"></i> Boleta
                                                </a>
                                                @if (!item.academiccontrol_inscription_boletaValidada)
                                                {
                                                    <form asp-action="ValidarBoleta" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.academiccontrol_inscription_ID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-success text-xxs px-2 btn-validar-boleta"
                                                                data-nombre="Boleta">
                                                            <i class="bi bi-check2"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success text-xxs"><i class="bi bi-check2-circle me-1"></i>OK</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary bg-opacity-50 text-xxs">Sin Boleta</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted text-xs">@item.academiccontrol_inscription_registrationDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData)
                                    {
                                        { "StatusValue", item.academiccontrol_inscription_state },
                                                { "StatusType", "inscripcion" }
                                    })
                    </td>
                    <td class="pe-4 text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-controller="Aspirantes"
                               asp-action="Details"
                               asp-route-id="@item.academiccontrol_inscription_ID"
                               class="btn btn-sm btn-ghost-sep px-3">
                                <i class="bi bi-eye me-1"></i> Ver
                            </a>
                            @if (item.academiccontrol_inscription_state == EstadoInscripcion.PagoValidado.ToString())
                                        {
                                            <form asp-action="AprobarInscripcion" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.academiccontrol_inscription_ID" />
                                                <button type="submit" class="btn btn-sm text-xxs px-3 btn-aprobar"
                                                        style="background-color: var(--success-700); color: white;"
                                                        data-matricula="@item.academiccontrol_inscription_enrollment">
                                                    <i class="bi bi-check-circle me-1"></i> Aprobar
                                                </button>
                                            </form>
                                        }
                                        @if (item.academiccontrol_inscription_state != EstadoInscripcion.Aprobada.ToString()
                                                                    && item.academiccontrol_inscription_state != EstadoInscripcion.Rechazada.ToString())
                                        {
                                            <button type="button" class="btn btn-sm btn-danger text-xxs px-3"
                                                    data-bs-toggle="modal" data-bs-target="#modalRechazarIns"
                                                    data-id="@item.academiccontrol_inscription_ID"
                                                    data-matricula="@item.academiccontrol_inscription_enrollment">
                                                <i class="bi bi-x-lg me-1"></i> Rechazar
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

<div class="modal fade" id="modalRechazarPre" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Rechazar Preinscripción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RechazarPreinscripcion" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="preRechazarId" />
                    <p class="text-sm text-muted">¿Está seguro que desea rechazar el folio <strong id="preRechazarFolio"></strong>?</p>
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">MOTIVO (OPCIONAL)</label>
                        <textarea name="motivo" class="form-control text-sm" rows="3" placeholder="Indique el motivo del rechazo..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn-ghost-sep text-xs px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger text-xs px-4 fw-bold">Confirmar Rechazo</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalRechazarIns" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom">
                <h5 class="modal-title fw-bold txt-primary-dark text-sm">Rechazar Inscripción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RechazarInscripcion" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="insRechazarId" />
                    <p class="text-sm text-muted">¿Está seguro que desea rechazar la matrícula <strong id="insRechazarMatricula"></strong>?</p>
                    <div class="mb-3">
                        <label class="section-label text-muted mb-2 d-block">MOTIVO (OPCIONAL)</label>
                        <textarea name="motivo" class="form-control text-sm" rows="3" placeholder="Indique el motivo del rechazo..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button type="button" class="btn-ghost-sep text-xs px-4" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger text-xs px-4 fw-bold">Confirmar Rechazo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        ['btn-validar-acta', 'btn-validar-curp', 'btn-validar-boleta'].forEach(cls => {
            document.querySelectorAll(`.${cls}`).forEach(btn => {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    const form = this.closest('form');
                    const nombre = this.dataset.nombre;
                    Swal.fire({
                        title: `¿Validar ${nombre}?`,
                        text: `¿Confirma que el documento ${nombre} es correcto?`,
                        icon: 'question', showCancelButton: true,
                        confirmButtonText: 'Sí, validar', cancelButtonText: 'Cancelar',
                        confirmButtonColor: '#13322B', cancelButtonColor: '#6c757d'
                    }).then(result => { if (result.isConfirmed) form.submit(); });
                });
            });
        });

        document.querySelectorAll('.btn-validar-pre').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const form = this.closest('form');
                Swal.fire({
                    title: '¿Validar preinscripción?',
                    text: `¿Está seguro que desea validar el folio ${this.dataset.folio}?`,
                    icon: 'question', showCancelButton: true,
                    confirmButtonText: 'Sí, validar', cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#13322B', cancelButtonColor: '#6c757d'
                }).then(result => { if (result.isConfirmed) form.submit(); });
            });
        });

        document.querySelectorAll('.btn-habilitar').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const form = this.closest('form');
                Swal.fire({
                    title: '¿Habilitar inscripción?',
                    text: `¿Está seguro que desea habilitar la inscripción para el folio ${this.dataset.folio}?`,
                    icon: 'question', showCancelButton: true,
                    confirmButtonText: 'Sí, habilitar', cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#13322B', cancelButtonColor: '#6c757d'
                }).then(result => { if (result.isConfirmed) form.submit(); });
            });
        });

        document.querySelectorAll('.btn-aprobar').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const form = this.closest('form');
                Swal.fire({
                    title: '¿Aprobar inscripción?',
                    text: `¿Está seguro que desea aprobar la matrícula ${this.dataset.matricula}?`,
                    icon: 'question', showCancelButton: true,
                    confirmButtonText: 'Sí, aprobar', cancelButtonText: 'Cancelar',
                    confirmButtonColor: '#13322B', cancelButtonColor: '#6c757d'
                }).then(result => { if (result.isConfirmed) form.submit(); });
            });
        });

        document.getElementById('modalRechazarPre')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('preRechazarId').value = btn.dataset.id;
            document.getElementById('preRechazarFolio').textContent = btn.dataset.folio || `#${btn.dataset.id}`;
        });

        document.getElementById('modalRechazarIns')?.addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('insRechazarId').value = btn.dataset.id;
            document.getElementById('insRechazarMatricula').textContent = btn.dataset.matricula || `#${btn.dataset.id}`;
        });
    </script>
}