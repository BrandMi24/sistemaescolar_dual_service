                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="assignStudentsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden bg-white">
            
            <div class="modal-header bg-app border-bottom border-light p-4">
                <div>
                    <h6 class="modal-title txt-title fw-bold text-uppercase tracking-widest text-xs mb-1">Asignar Estudiantes a Supervisión</h6>
                    <p class="text-muted text-xxs fw-medium mb-0">Mtra. Ana Martínez Ruiz</p>
                </div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            
            <div class="modal-body p-4 bg-white">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="text-xxs fw-bold text-muted text-uppercase mb-2 d-block">Buscar Alumno</label>
                        <input type="text" id="assignSearchInput" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="Nombre o matrícula..." />
                    </div>
                    <div class="col-md-3">
                        <label class="text-xxs fw-bold text-muted text-uppercase mb-2 d-block">Programa</label>
                        <select id="assignProgramFilter" class="form-select border-0 bg-app py-2 px-3 text-xs fw-bold txt-title shadow-none cursor-pointer">
                            <option value="">TODOS LOS PROGRAMAS</option>
                            <option value="SERVICIO_SOCIAL">SERVICIO SOCIAL</option>
                            <option value="PRACTICAS">PRÁCTICAS PROFESIONALES</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="text-xxs fw-bold text-muted text-uppercase mb-2 d-block">Estatus de Asignación</label>
                        <select id="assignStatusFilter" class="form-select border-0 bg-app py-2 px-3 text-xs fw-bold txt-title shadow-none cursor-pointer">
                            <option value="">TODOS LOS ESTADOS</option>
                            <option value="unassigned">SIN PROFESOR ASIGNADO</option>
                            <option value="assigned">YA ASIGNADOS</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn-ghost-sep bg-app border-0 w-100 py-2 text-xxs fw-bold" id="assignClearFilters">LIMPIAR</button>
                    </div>
                </div>

                <form id="assignStudentsForm" action="#" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="teacherId" value="1" />

                    <div class="table-responsive border border-light rounded-3 custom-scroll" style="max-height: 350px; overflow-y: auto;">
                        <table class="table align-middle text-sm mb-0">
                            <thead class="bg-app border-0 sticky-top" style="z-index: 10;">
                                <tr>
                                    <th style="width:50px;" class="text-center py-3 border-0">
                                        <input type="checkbox" id="assignSelectAll" class="form-check-input shadow-none" />
                                    </th>
                                    <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Estudiante</th>
                                    <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Matrícula</th>
                                    <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Carrera</th>
                                    <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Programa</th>
                                    <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Profesor Actual</th>
                                </tr>
                            </thead>
                            <tbody id="assignStudentsTableBody">
                                <tr class="border-bottom border-light">
                                    <td class="text-center"><input type="checkbox" name="enrollmentIds" value="1" class="form-check-input assign-check shadow-none" /></td>
                                    <td class="fw-bold txt-title text-xs text-uppercase">Luis Ángel García</td>
                                    <td class="text-muted fw-bold">ASP-001</td>
                                    <td class="text-muted text-xxs fw-bold">MECATRÓNICA</td>
                                    <td><span class="badge bg-app text-dark border border-light text-xxs px-2 py-1">ESTADÍAS</span></td>
                                    <td class="text-xxs fw-bold text-muted italic">-- SIN ASIGNAR --</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4 d-flex justify-content-between align-items-center">
                        <span class="txt-title fw-bold text-xs text-uppercase tracking-widest" id="assignSelectedCount">0 estudiantes seleccionados</span>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn-ghost-sep bg-app border-0 text-xxs fw-bold px-4" data-bs-dismiss="modal">CANCELAR</button>
                            <button type="button" class="btn-primary-sep border-0 px-4 text-xxs fw-bold tracking-widest shadow-sm" id="assignSubmitBtn" disabled>
                                CONFIRMAR ASIGNACIÓN
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos de Feedback Visual */
    .status-aceptado { background-color: var(--success-100) !important; color: var(--success-700) !important; }
    .status-pendiente { background-color: var(--warning-100) !important; color: var(--warning-700) !important; }
    .status-rechazado { background-color: var(--error-100) !important; color: var(--error-700) !important; }

    .hover-bg-app:hover { background-color: var(--bg-main) !important; }
    .transition-all { transition: all 0.2s ease; }
    
    .form-control:focus, .form-select:focus {
        background-color: var(--white) !important;
        box-shadow: 0 0 0 4px var(--accent-100) !important;
        border: 1px solid var(--accent-500) !important;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Checkbox "Seleccionar Todos"
            const selectAll = document.getElementById('assignSelectAll');
            if(selectAll) {
                selectAll.addEventListener('change', function () {
                    var checked = this.checked;
                    document.querySelectorAll('.assign-check').forEach(function (cb) {
                        cb.checked = checked;
                    });
                    updateSelectedCount();
                });
            }

            // Checkbox individuales
            const tableBody = document.getElementById('assignStudentsTableBody');
            if(tableBody) {
                tableBody.addEventListener('change', function (e) {
                    if (e.target.classList.contains('assign-check')) {
                        updateSelectedCount();
                    }
                });
            }

            function updateSelectedCount() {
                var count = document.querySelectorAll('.assign-check:checked').length;
                document.getElementById('assignSelectedCount').textContent = count + ' ESTUDIANTE(S) SELECCIONADO(S)';
                document.getElementById('assignSubmitBtn').disabled = count === 0;
            }

            // Auto-ocultar alertas
            setTimeout(function () {
                $('.alert-dismissible').fadeOut('slow');
            }, 4000);
        });
    </script>
}