        </h6>
        <div class="row g-0 text-center">
            <div class="col-6 col-md-2 border-end border-light py-2">
                <div class="fs-3 fw-bold txt-title">12</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">ESTUDIANTES</div>
            </div>
            <div class="col-6 col-md-2 border-end border-light py-2">
                <div class="fs-3 fw-bold txt-title">10</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">ACTIVOS</div>
            </div>
            <div class="col-6 col-md-2 border-end border-light py-2">
                <div class="fs-3 fw-bold text-danger">4</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">HRS. PENDIENTES</div>
            </div>
            <div class="col-6 col-md-2 border-end border-light py-2">
                <div class="fs-3 fw-bold text-warning" style="color: var(--warning-700) !important;">2</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">DOCS. PENDIENTES</div>
            </div>
            <div class="col-6 col-md-2 border-end border-light py-2">
                <div class="fs-3 fw-bold txt-primary-dark">8</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">EVALUACIONES</div>
            </div>
            <div class="col-6 col-md-2 py-2">
                <div class="fs-3 fw-bold text-success" style="color: var(--success-700) !important;">85%</div>
                <div class="text-xxs fw-bold text-muted tracking-wide text-uppercase">COMPLETITUD</div>
            </div>
        </div>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden bg-white">
        <div class="bg-white p-4 border-bottom border-light d-flex justify-content-between align-items-center">
            <div>
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Estudiantes Asignados</h6>
                <p class="text-muted text-xxs fw-medium mb-0">DOCENTES RESPONSABLES DEL SEGUIMIENTO</p>
            </div>
            <button type="button" class="btn-primary-sep border-0 px-4 py-2 text-xxs fw-bold tracking-widest shadow-sm" data-bs-toggle="modal" data-bs-target="#assignStudentsModal">
                ASIGNAR ESTUDIANTES
            </button>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-app border-0">
                    <tr>
                        <th class="py-3 px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider">Estudiante</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Matrícula</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Programa / Carrera</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Tipo</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Estado</th>
                        <th class="py-3 text-center px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider" width="150">Progreso</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-bottom border-light hover-bg-app transition-all">
                        <td class="px-4 py-3">
                            <div class="txt-title fw-bold text-xs text-uppercase">Roberto Carlos Perez Cadena</div>
                        </td>
                        <td class="text-xs fw-bold text-muted">24001504</td>
                        <td>
                            <div class="text-xxs fw-bold txt-title text-uppercase">Ing. Desarrollo de Software</div>
                        </td>
                        <td><span class="badge bg-app text-dark border border-light text-xxs px-2 py-1 fw-bold">ESTADÍAS</span></td>
                        <td><span class="badge status-aceptado text-xxs px-2 py-1 fw-bold rounded-pill">ACTIVO</span></td>
                        <td class="px-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 4px; background-color: var(--bg-main);">
                                    <div class="progress-bar" style="width: 80%; background-color: var(--primary-900) !important;"></div>
                                </div>
                                <span class="text-xxs fw-bold txt-title">80%</span>
                            </div>
                        </td>
                    </tr>
                    <tr class="border-bottom border-light hover-bg-app transition-all">
                        <td class="px-4 py-3">
                            <div class="txt-title fw-bold text-xs text-uppercase">María Fernanda Salas</div>
                        </td>
                        <td class="text-xs fw-bold text-muted">23001122</td>
                        <td>
                            <div class="text-xxs fw-bold txt-title text-uppercase">Mecatrónica</div>
                        </td>
                        <td><span class="badge bg-app text-dark border border-light text-xxs px-2 py-1 fw-bold">SERVICIO SOCIAL</span></td>
                        <td><span class="badge status-pendiente text-xxs px-2 py-1 fw-bold rounded-pill">EN PROCESO</span></td>
                        <td class="px-4">
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height: 4px; background-color: var(--bg-main);">
                                    <div class="progress-bar" style="width: 45%; background-color: var(--warning-700) !important;"></div>
                                </div>
