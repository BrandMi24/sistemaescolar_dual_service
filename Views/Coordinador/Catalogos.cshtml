                colspan: 6,
                getFilters: () => ({
                    search: ($('#dtSearchBajas').val() || '').toLowerCase(),
                    tipo: ($('#filterTipoBajas').val() || '').toUpperCase(),
                    estado: ($('#filterEstadoBajas').val() || '').toUpperCase()
                }),
                filter: (row, f) => {
                    const haystack = `${row.identificador || ''} ${row.nombreCompleto || ''} ${row.email || ''} ${row.tipoUsuario || ''}`.toLowerCase();
                    if (f.search && !haystack.includes(f.search)) return false;
                    if (f.tipo && (row.tipoUsuario || '').toUpperCase() !== f.tipo) return false;
                    if (f.estado && (row.estadoCodigo || '').toUpperCase() !== f.estado) return false;
                    return true;
                },
                renderRow: item => {
                    const badgeCls = item.estadoBadgeClass || 'status-rechazado';
                    return `<tr>
                        <td class="px-4"><div class="txt-primary-dark fw-bold">${item.identificador || '-'}</div></td>
                        <td><div class="txt-title fw-bold">${item.nombreCompleto || '-'}</div></td>
                        <td>${item.tipoUsuario || '-'}</td>
                        <td>${item.email || '-'}</td>
                        <td class="text-center"><span class="badge ${badgeCls}">${item.estadoCodigo || '-'}</span></td>
                        <td class="text-end px-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn-action btn-action-delete" title="Eliminar definitivo" onclick="eliminarDefinitivo('${item.tipoUsuario}', ${item.id}, ${item.userId || 0})"><i class="bi bi-trash3"></i></button>
                            </div>
                        </td>
                    </tr>`;
                }
            });

            // =============================================================
            // Tabla: CUENTAS
            // =============================================================
            const tblCuentas = createTable({
                url: '@Url.Action("GetUsersJson", "Coordinador")',
                bodyId: '#cuentasBody',
                infoId: '#cuentasInfo',
                paginationId: '#cuentasPagination',
                rowsPerPageId: '#cuentasRpp',
                colspan: 6,
                transform: rows => rows.filter(x => x.id && x.username && x.username !== '-'),
                onData: rows => fillRoleSelect('#filterRolCuentas', rows),
                getFilters: () => ({
                    search: ($('#dtSearchCuentas').val() || '').toLowerCase(),
                    rol: ($('#filterRolCuentas').val() || '').toUpperCase(),
                    estado: ($('#filterEstadoCuentas').val() || '').toUpperCase()
                }),
                filter: (row, f) => {
                    const haystack = `${row.username || ''} ${row.nombreCompleto || ''} ${row.correo || ''} ${row.roles || ''}`.toLowerCase();
                    if (f.search && !haystack.includes(f.search)) return false;
                    if (f.rol && !(row.roles || '').toUpperCase().includes(f.rol)) return false;
                    if (f.estado && (row.estado || '').toUpperCase() !== f.estado) return false;
                    return true;
                },
                renderRow: item => {
                    const estado = (item.estado || '').toUpperCase();
                    const isActive = (estado === 'ACTIVO' || estado === 'INSCRITO' || estado === 'PREINSCRITO');
                    const toggleBtn = isActive
                        ? `<button class="btn-action btn-action-toggle-off" title="Desactivar" onclick="toggleUsuario(${item.id}, false)"><i class="bi bi-person-dash"></i></button>`
                        : `<button class="btn-action btn-action-toggle-on" title="Activar" onclick="toggleUsuario(${item.id}, true)"><i class="bi bi-person-check"></i></button>`;

                    return `<tr>
                        <td class="px-4"><div class="txt-title fw-bold">${item.username || '-'}</div></td>
                        <td>${item.nombreCompleto || '-'}</td>
                        <td>${rolBadge(item.roles)}</td>
                        <td>${item.correo || '-'}</td>
                        <td class="text-center">${estadoBadge(item.estado)}</td>
                        <td class="text-end px-4">
                            <div class="d-flex justify-content-end gap-2">
