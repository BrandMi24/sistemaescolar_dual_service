            <div class="table-responsive bg-surface">
                <table id="tablaPersonas" class="table table-borderless align-middle mb-0 w-100" style="min-width:1150px;">
                    <thead class="admin-table-header border-bottom border-theme">
                        <tr>
                            <th class="py-3 px-4">Identificador</th>
                            <th class="py-3">Nombre Completo</th>
                            <th class="py-3">Rol</th>
                            <th class="py-3">Tipo</th>
                            <th class="py-3">Carrera / Depto</th>
                            <th class="py-3">Correo</th>
                            <th class="py-3 text-center">Estado</th>
                            <th class="py-3 text-end px-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
