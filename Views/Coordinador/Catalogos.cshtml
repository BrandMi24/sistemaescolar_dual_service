@section Scripts {
    <link href="https://cdn.datatables.net/v/bs5/jszip-3.10.1/dt-2.0.0/b-3.0.0/b-html5-3.0.0/b-print-3.0.0/r-3.0.0/datatables.min.css" rel="stylesheet">
    <script src="https://cdn.datatables.net/v/bs5/jszip-3.10.1/dt-2.0.0/b-3.0.0/b-html5-3.0.0/b-print-3.0.0/r-3.0.0/datatables.min.js"></script>

    <script>
        $(document).ready(function () {
            const dtLang = "https://cdn.datatables.net/plug-ins/2.1.0/i18n/es-ES.json";
            const csrfToken = '@token';

        let dtPersonas, dtAlumnos, dtDocentes, dtGrupos, dtCarreras, dtBajas, dtCuentas,dtRoles;

            function setActiveTab(tabId) {
                $('.nav-tab-item').removeClass('active');
                $(`.nav-tab-item[data-target="#${tabId}"]`).addClass('active');
                $('.tab-content-pane').hide();
                $('#' + tabId).show();

                const url = new URL(window.location.href);
                url.searchParams.set('tab', tabId);
                window.history.replaceState({}, '', url.toString());

                setTimeout(function () {
                    $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust().responsive.recalc();
                }, 80);
            }

            $('.nav-tab-item').on('click', function (e) {
                e.preventDefault();
                const targetId = ($(this).data('target') || '').replace('#', '');
                if (!targetId) return;
                setActiveTab(targetId);
            });

            setActiveTab('@activeTab');

            function estadoBadge(estado) {
                const value = (estado || '').toUpperCase();
                if (value === 'ACTIVO' || value === 'INSCRITO' || value === 'PREINSCRITO') {
                    return `<span class="badge status-aceptado text-xxs px-2 py-1 shadow-sm">${estado || '-'}</span>`;
                }
                return `<span class="badge status-rechazado text-xxs px-2 py-1 shadow-sm">${estado || '-'}</span>`;
            }

            function rolBadge(roles) {
                const value = (roles || 'Sin Rol').toString().toUpperCase();
                let badgeClass = 'bg-app border border-theme text-dark';

                if (value.includes('ADMIN')) badgeClass = 'bg-primary-dark text-white';
                else if (value.includes('TEACHER') || value.includes('DOCENTE')) badgeClass = 'bg-accent-light txt-primary-dark';
                else if (value.includes('STUDENT') || value.includes('ALUMNO') || value.includes('ESTUDIANTE')) badgeClass = 'bg-app border border-theme text-dark';

                return `<span class="badge ${badgeClass} text-xxs px-2 py-1">${value}</span>`;
            }

            function fillRoleSelect(selectId, rows) {
                const select = $(selectId);
                const current = select.val();
                const roles = new Set();

                rows.forEach(r => {
                    (r.roles || '')
                        .split(',')
                        .map(x => x.trim())
                        .filter(Boolean)
                        .forEach(x => roles.add(x.toUpperCase()));
                });

                select.empty().append('<option value="">Todos</option>');
                Array.from(roles).sort().forEach(role => {
                    select.append(`<option value="${role}">${role}</option>`);
                });

                if (current && select.find(`option[value="${current}"]`).length) {
                    select.val(current);
                }
            }

            $.fn.dataTable.ext.search.push(function (settings, data, dataIndex) {
                const tableId = settings.nTable.id;

                if (tableId === 'tablaPersonas') {
                    const row = dtPersonas.row(dataIndex).data();
                    if (!row) return true;

                    const rol = ($('#filterRolPersonas').val() || '').toUpperCase();
                    const estado = ($('#filterEstadoPersonas').val() || '').toUpperCase();
                    const tipo = ($('#filterTipoPersonas').val() || '').toUpperCase();

                    if (rol && !(row.roles || '').toUpperCase().includes(rol)) return false;
                    if (estado && (row.estado || '').toUpperCase() !== estado) return false;
                    if (tipo && (row.tipoUsuario || '').toUpperCase() !== tipo) return false;
                    return true;
                }

                if (tableId === 'tablaAlumnos') {
                    const row = dtAlumnos.row(dataIndex).data();
                    if (!row) return true;

                    const carrera = ($('#filterCarreraAlumnos').val() || '').toUpperCase();
                    const estado = ($('#filterEstadoAlumnos').val() || '').toUpperCase();

                    if (carrera && !(row.carrera || '').toUpperCase().includes(carrera)) return false;
                    if (estado && (row.estadoCodigo || '').toUpperCase() !== estado) return false;
                    return true;
                }

                if (tableId === 'tablaDocentes') {
                    const row = dtDocentes.row(dataIndex).data();
                    if (!row) return true;

                    const estado = ($('#filterEstadoDocentes').val() || '').toUpperCase();
                    const correo = ($('#filterCorreoDocentes').val() || '').toUpperCase();

                    if (estado && (row.estado || '').toUpperCase() !== estado) return false;
                    if (correo && !(row.email || '').toUpperCase().includes(correo)) return false;
                    return true;
                }

                if (tableId === 'tablaGrupos') {
                    const row = dtGrupos.row(dataIndex).data();
                    if (!row) return true;

                    const carrera = ($('#filterCarreraGrupos').val() || '').toUpperCase();
                    const estado = ($('#filterEstadoGrupos').val() || '');
                    const estadoTexto = row.esActivo ? 'Activo' : 'Inactivo';

                    if (carrera && !(row.carrera || '').toUpperCase().includes(carrera)) return false;
                    if (estado && estadoTexto !== estado) return false;
                    return true;
                }

                if (tableId === 'tablaCareer') {
                    const row = dtCarreras.row(dataIndex).data();
                    if (!row) return true;

                    const codigo = ($('#filterCodigoCarreras').val() || '').toUpperCase();
                    if (codigo && !(row.codigo || '').toUpperCase().includes(codigo)) return false;
                    return true;
                }

                if (tableId === 'tablaBajas') {
                    const row = dtBajas.row(dataIndex).data();
                    if (!row) return true;

                    const tipo = ($('#filterTipoBajas').val() || '').toUpperCase();
                    const estado = ($('#filterEstadoBajas').val() || '').toUpperCase();

                    if (tipo && (row.tipoUsuario || '').toUpperCase() !== tipo) return false;
                    if (estado && (row.estadoCodigo || '').toUpperCase() !== estado) return false;
                    return true;
                }

                if (tableId === 'tablaCuentas') {
                    const row = dtCuentas.row(dataIndex).data();
                    if (!row) return true;

                    const rol = ($('#filterRolCuentas').val() || '').toUpperCase();
                    const estado = ($('#filterEstadoCuentas').val() || '').toUpperCase();

                    if (rol && !(row.roles || '').toUpperCase().includes(rol)) return false;
                    if (estado && (row.estado || '').toUpperCase() !== estado) return false;
                    return true;
                }

                return true;
            });

            dtPersonas = $('#tablaPersonas').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-end pt-3"B>rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                buttons: [{ extend: 'excel', text: 'Excel' }, { extend: 'pdf', text: 'PDF' }],
                ajax: {
                    url: '@Url.Action("GetUsersJson", "Coordinador")',
                    type: 'GET',
                    dataSrc: function (json) {
                        const rows = json.data || [];
                        fillRoleSelect('#filterRolPersonas', rows);
                        return rows;
                    }
                },
                columns: [
                    { data: 'identificador', className: 'px-4 fw-bold txt-primary-dark text-sm' },
                    { data: 'nombreCompleto', className: 'txt-title fw-bold text-sm' },
                    { data: 'roles', render: function (d) { return rolBadge(d); } },
                    { data: 'tipoUsuario', className: 'txt-body text-xs' },
                    { data: 'carrera', className: 'txt-body text-xs' },
                    { data: 'correo', className: 'txt-body text-xs' },
                    { data: 'estado', className: 'text-center', render: function (d) { return estadoBadge(d); } },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (row) {
                            let editBtn = '';
                            let deleteBtn = '';

                            if ((row.tipoUsuario || '').toUpperCase() === 'ADMIN') {
                                editBtn = `<button onclick="window.location.href='@Url.Action("EditUser", "Coordinador")/${row.id}?tab=tab-personas'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>`;
                                deleteBtn = `<button onclick="eliminarRegistro('Usuarios', ${row.id})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                            } else if ((row.tipoUsuario || '').toUpperCase() === 'DOCENTE' && row.teacherId) {
                                editBtn = `<button onclick="window.location.href='@Url.Action("EditTeacher", "Coordinador")/${row.teacherId}?tab=tab-personas'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>`;
                                deleteBtn = `<button onclick="eliminarRegistro('Docentes', ${row.teacherId})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                            } else if ((row.tipoUsuario || '').toUpperCase() === 'ALUMNO' && row.studentId) {
                                editBtn = `<button onclick="window.location.href='@Url.Action("EditStudent", "Coordinador")/${row.studentId}?tab=tab-personas'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>`;
                                deleteBtn = `<button onclick="eliminarRegistro('Alumnos', ${row.studentId})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                            }

                            return editBtn + deleteBtn;
                        }
                    }
                ]
            });

            dtAlumnos = $('#tablaAlumnos').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-end pt-3"B>rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                buttons: [{ extend: 'excel', text: 'Excel' }, { extend: 'pdf', text: 'PDF' }],
                ajax: { url: '@Url.Action("GetAlumnosJson", "Coordinador")', type: 'GET', dataSrc: 'data' },
                columns: [
                    { data: 'identificador', className: 'px-4 fw-bold txt-primary-dark text-sm' },
                    { data: 'nombreCompleto', className: 'txt-title fw-bold text-sm' },
                    { data: 'carrera', className: 'txt-body text-xs' },
                    { data: 'grupo', className: 'txt-body text-xs' },
                    {
                        data: 'estadoCodigo',
                        className: 'text-center',
                        render: function (d, t, row) {
                            return `<span class="badge ${row.estadoBadgeClass} text-xxs px-2 py-1">${d}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (d, t, row) {
                            let btnDel = row.esActivo
                                ? `<button onclick="eliminarRegistro('Alumnos', ${d})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`
                                : '';

                            return `<button onclick="window.location.href='@Url.Action("StudentDetail", "Coordinador")/${d}?tab=tab-alumnos'" class="btn btn-sm btn-ghost-sep text-body px-2"><i class="bi bi-eye"></i></button>
                                    <button onclick="window.location.href='@Url.Action("EditStudent", "Coordinador")/${d}?tab=tab-alumnos'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>
                                    ${btnDel}`;
                        }
                    }
                ]
            });

            dtDocentes = $('#tablaDocentes').DataTable({
                responsive: true,
                dom: 'rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                ajax: { url: '@Url.Action("GetDocentesJson", "Coordinador")', type: 'GET', dataSrc: 'data' },
                columns: [
                    { data: 'numeroEmpleado', className: 'text-center px-4 fw-bold text-sm txt-body' },
                    { data: 'nombreCompleto', className: 'txt-title fw-bold text-sm' },
                    { data: 'email', className: 'txt-body text-xs' },
                    { data: 'telefono', className: 'txt-body text-xs' },
                    {
                        data: 'estado',
                        className: 'text-center',
                        render: function (d, t, row) {
                            return `<span class="badge ${row.badgeClass} text-xxs px-2 py-1">${d}</span>`;
                        }
                    },
                    {
                        data: 'teacherId',
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (d, t, row) {
                            return `<button onclick="window.location.href='@Url.Action("TeacherDetail", "Coordinador")/${row.teacherId}?tab=tab-docentes'" class="btn btn-sm btn-ghost-sep text-body px-2"><i class="bi bi-eye"></i></button>
                                    <button onclick="window.location.href='@Url.Action("EditTeacher", "Coordinador")/${row.teacherId}?tab=tab-docentes'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>
                                    <button onclick="eliminarRegistro('Docentes', ${d})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ]
            });

            dtGrupos = $('#tablaGrupos').DataTable({
                responsive: true,
                dom: 'rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                ajax: { url: '@Url.Action("GetGruposJson", "Coordinador")', type: 'GET', dataSrc: 'data' },
                columns: [
                    { data: 'id', className: 'px-4 fw-bold txt-primary-dark text-sm' },
                    { data: 'nombre', className: 'txt-title fw-bold text-sm' },
                    { data: 'carrera', className: 'txt-body text-xs' },
                    {
                        data: 'esActivo',
                        className: 'text-center',
                        render: function (d) {
                            return `<span class="badge ${d ? 'status-aceptado' : 'status-rechazado'} text-xxs px-2 py-1">${d ? 'Activo' : 'Inactivo'}</span>`;
                        }
                    },
                    {
                        data: 'id',
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (d) {
                            return `<button onclick="window.location.href='@Url.Action("EditGroup", "Coordinador")/${d}?tab=tab-grupos'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>
                                    <button onclick="eliminarRegistro('Grupos', ${d})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ]
            });

            dtCarreras = $('#tablaCareer').DataTable({
                responsive: true,
                dom: 'rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                ajax: { url: '@Url.Action("GetCareersJson", "Coordinador")', type: 'GET', dataSrc: 'data' },
                columns: [
                    { data: 'id', className: 'px-4 fw-bold txt-primary-dark text-sm' },
                    { data: 'codigo', className: 'txt-title fw-bold text-sm' },
                    { data: 'nombre', className: 'txt-body text-xs text-uppercase' },
                    {
                        data: 'id',
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (d) {
                            return `<button onclick="window.location.href='@Url.Action("EditCareer", "Coordinador")/${d}?tab=tab-career'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>
                                    <button onclick="eliminarRegistro('Carrera', ${d})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;
                        }
                    }
                ]
            });

            dtBajas = $('#tablaBajas').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-end pt-3"B>rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                buttons: [{ extend: 'excel', text: 'Excel' }, { extend: 'pdf', text: 'PDF' }],
                ajax: { url: '@Url.Action("GetBajasJson", "Coordinador")', type: 'GET', dataSrc: 'data' },
                columns: [
                    { data: 'identificador', className: 'px-4 fw-bold txt-primary-dark text-sm' },
                    { data: 'nombreCompleto', className: 'txt-title fw-bold text-sm' },
                    { data: 'tipoUsuario', className: 'txt-body text-xs' },
                    { data: 'email', className: 'txt-body text-xs' },
                    {
                        data: 'estadoCodigo',
                        className: 'text-center',
                        render: function (d, t, row) {
                            return `<span class="badge ${row.estadoBadgeClass} text-xxs px-2 py-1">${d}</span>`;
                        }
                    },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (row) {
                            return `<button onclick="eliminarDefinitivo('${row.tipoUsuario}', ${row.id}, ${row.userId || 0})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash3"></i></button>`;
                        }
                    }
                ]
            });

            dtRoles = $('#tablaRoles').DataTable({
                responsive: true,
                dom: 'rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                ajax: {
                url: '@Url.Action("GetRolesJson", "Coordinador")',
                type: 'GET',
                dataSrc: 'data'
                },
                columns: [
                    { data: 'nombre', className: 'px-4 fw-bold text-sm' },
                    { data: 'descripcion', className: 'text-xs' },
                    {
                        data: 'id',
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (d) {
                            return `
                                <button onclick="window.location.href='@Url.Action("EditRole", "Coordinador")/${d}?tab=tab-roles'"
                                class="btn btn-sm btn-ghost-sep text-primary px-2">
                                <i class="bi bi-pencil"></i>
                                </button>

                                <button onclick="eliminarRol(${d})"
                                class="btn btn-sm btn-ghost-sep text-danger px-2">
                                <i class="bi bi-trash"></i>
                                </button>`;
                        }
                    }
                ]
            });

            dtCuentas = $('#tablaCuentas').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-end pt-3"B>rtip',
                language: { url: dtLang },
                pageLength: 10,
                lengthChange: false,
                pagingType: 'simple_numbers',
                buttons: [{ extend: 'excel', text: 'Excel' }, { extend: 'pdf', text: 'PDF' }],
                ajax: {
                    url: '@Url.Action("GetUsersJson", "Coordinador")',
                    type: 'GET',
                    dataSrc: function (json) {
                        const rows = json.data || [];
                        fillRoleSelect('#filterRolCuentas', rows);
                        return rows.filter(x => x.id && x.username && x.username !== '-');
                    }
                },
                columns: [
                    { data: 'username', className: 'px-4 txt-title fw-bold text-sm' },
                    { data: 'nombreCompleto', className: 'txt-body text-xs' },
                    { data: 'roles', render: function (d) { return rolBadge(d); } },
                    { data: 'correo', className: 'txt-body text-xs' },
                    { data: 'estado', className: 'text-center', render: function (d) { return estadoBadge(d); } },
                    {
                        data: null,
                        orderable: false,
                        className: 'text-end px-4',
                        render: function (row) {
                            const editBtn = `<button onclick="window.location.href='@Url.Action("EditUser", "Coordinador")/${row.id}?tab=tab-cuentas'" class="btn btn-sm btn-ghost-sep text-primary px-2"><i class="bi bi-pencil"></i></button>`;

                            const estado = (row.estado || '').toUpperCase();
                            const toggleBtn =
                                (estado === 'ACTIVO' || estado === 'INSCRITO' || estado === 'PREINSCRITO')
                                    ? `<button onclick="toggleUsuario(${row.id}, false)" class="btn btn-sm btn-ghost-sep text-warning px-2"><i class="bi bi-person-dash"></i></button>`
                                    : `<button onclick="toggleUsuario(${row.id}, true)" class="btn btn-sm btn-ghost-sep text-success px-2"><i class="bi bi-person-check"></i></button>`;

                            const deleteBtn = `<button onclick="eliminarRegistro('Usuarios', ${row.id})" class="btn btn-sm btn-ghost-sep text-danger px-2"><i class="bi bi-trash"></i></button>`;

                            return editBtn + toggleBtn + deleteBtn;
                        }
                    }
                ]
            });



            $('#dtSearchPersonas').on('keyup', function () { dtPersonas.search(this.value).draw(); });
            $('#filterRolPersonas, #filterEstadoPersonas, #filterTipoPersonas').on('change', function () { dtPersonas.draw(); });

            $('#dtSearchAlumnos').on('keyup', function () { dtAlumnos.search(this.value).draw(); });
            $('#filterCarreraAlumnos, #filterEstadoAlumnos').on('keyup change', function () { dtAlumnos.draw(); });

            $('#dtSearchDocentes').on('keyup', function () { dtDocentes.search(this.value).draw(); });
            $('#filterEstadoDocentes, #filterCorreoDocentes').on('keyup change', function () { dtDocentes.draw(); });

            $('#dtSearchGrupos').on('keyup', function () { dtGrupos.search(this.value).draw(); });
            $('#filterCarreraGrupos, #filterEstadoGrupos').on('keyup change', function () { dtGrupos.draw(); });

            $('#dtSearchCarreras').on('keyup', function () { dtCarreras.search(this.value).draw(); });
            $('#filterCodigoCarreras').on('keyup', function () { dtCarreras.draw(); });

            $('#dtSearchBajas').on('keyup', function () { dtBajas.search(this.value).draw(); });
            $('#filterTipoBajas, #filterEstadoBajas').on('change', function () { dtBajas.draw(); });

            $('#dtSearchRoles').on('keyup', function () { dtRoles.search(this.value).draw();});

            $('#dtSearchCuentas').on('keyup', function () { dtCuentas.search(this.value).draw(); });
            $('#filterRolCuentas, #filterEstadoCuentas').on('change', function () { dtCuentas.draw(); });

            window.eliminarRegistro = function (controlador, id) {
                if (!confirm('¿Deseas aplicar baja lógica a este registro?')) return;

                let url = '';
                if (controlador === 'Usuarios') url = `/Coordinador/DeleteUser/${id}`;
                if (controlador === 'Alumnos') url = `/Coordinador/DeleteStudent/${id}`;
                if (controlador === 'Docentes') url = `/Coordinador/DeleteTeacher/${id}`;
                if (controlador === 'Grupos') url = `/Coordinador/DeleteGroup/${id}`;
                if (controlador === 'Carrera') url = `/Coordinador/DeleteCareer/${id}`;

                fetch(url, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrfToken }
                })
                .then(r => {
                    if (!r.ok) throw new Error('Error al aplicar la baja');
                    recargarTodo();
                })
                .catch(err => alert(err.message));
            };

            window.toggleUsuario = function (id, activar) {
                fetch('/Coordinador/ToggleUserStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({ id, activar })
                })
                .then(async r => {
                    if (!r.ok) {
                        const txt = await r.text();
                        throw new Error(txt || 'No fue posible cambiar el estado');
                    }
                    recargarTodo();
                })
                .catch(err => alert(err.message));
            };

            window.eliminarRol = function (id) {
                if (!confirm('¿Deseas eliminar este rol?')) return;

                fetch(`/Coordinador/DeleteRole/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrfToken }
                })
                .then(r => {
                    if (!r.ok) throw new Error('Error al eliminar');
                    dtRoles.ajax.reload(null, false);
                })
                .catch(err => alert(err.message));
            };

            window.eliminarDefinitivo = function (tipoUsuario, id, userId) {
                if (!confirm('¿Deseas eliminar definitivamente este registro inactivo?')) return;

                fetch('/Coordinador/DeleteInactiveRecord', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify({ tipo: tipoUsuario, id: id, userId: userId })
                })
                .then(async r => {
                    if (!r.ok) {
                        const txt = await r.text();
                        throw new Error(txt || 'No fue posible eliminar definitivamente');
                    }
                    recargarTodo();
                })
                .catch(err => alert(err.message));
            };

            function recargarTodo() {
                dtPersonas.ajax.reload(null, false);
                dtAlumnos.ajax.reload(null, false);
                dtDocentes.ajax.reload(null, false);
                dtGrupos.ajax.reload(null, false);
                dtCarreras.ajax.reload(null, false);
                dtBajas.ajax.reload(null, false);
                dtCuentas.ajax.reload(null, false);
        dtRoles.ajax.reload(null, false);
            }
        });
    </script>
}