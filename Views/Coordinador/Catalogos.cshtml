@section Scripts {
    <script>
        $(document).ready(function () {

            // =============================================================
            // Navegación entre pestañas
            // =============================================================
            function setActiveTab(tabId) {
                $('.nav-tab-item').removeClass('active');
                $(`.nav-tab-item[data-target="#${tabId}"]`).addClass('active');
                $('.tab-content-pane').hide();
                $('#' + tabId).show();

                const url = new URL(window.location.href);
                url.searchParams.set('tab', tabId);
                window.history.replaceState({}, '', url.toString());
            }

            $('.nav-tab-item').on('click', function (e) {
                e.preventDefault();
                const targetId = ($(this).data('target') || '').replace('#', '');
                if (!targetId) return;
                setActiveTab(targetId);
            });

            setActiveTab('@activeTab');

            // =============================================================
            // Helpers de presentación
            // =============================================================
            function estadoBadge(estado) {
                const value = (estado || '').toString().toUpperCase();
                const ok = (value === 'ACTIVO' || value === 'INSCRITO' || value === 'PREINSCRITO');
                const cls = ok ? 'status-aceptado' : 'status-rechazado';
                return `<span class="badge ${cls}">${estado || '-'}</span>`;
            }

            function rolBadge(roles) {
                const value = (roles || 'Sin Rol').toString().toUpperCase();
                let badgeClass = 'bg-app text-secondary border';
                if (value.includes('ADMIN')) badgeClass = 'bg-primary-dark text-white';
                else if (value.includes('TEACHER') || value.includes('DOCENTE')) badgeClass = 'bg-accent-light txt-primary-dark';
                else if (value.includes('STUDENT') || value.includes('ALUMNO') || value.includes('ESTUDIANTE')) badgeClass = 'bg-app border';
                return `<span class="badge ${badgeClass}">${value}</span>`;
            }

            function fillRoleSelect(selectId, rows) {
                const select = $(selectId);
                const current = select.val();
                const roles = new Set();

                rows.forEach(r => {
                    (r.roles || '')
                        .split(',')
                        .map(x => x.trim())
                        .filter(Boolean)
                        .forEach(x => roles.add(x.toUpperCase()));
                });

                select.empty().append('<option value="">Todos</option>');
                Array.from(roles).sort().forEach(role => {
                    select.append(`<option value="${role}">${role}</option>`);
                });

                if (current && select.find(`option[value="${current}"]`).length) {
                    select.val(current);
                }
            }

            // =============================================================
            // Factory de tabla paginada (patrón Ciclos)
            // =============================================================
            function createTable(cfg) {
                let allData = [];
                let currentPage = 1;
                const api = {};

                function loadData() {
                    $.get(cfg.url, function (response) {
                        const rows = (response && response.data !== undefined) ? response.data : (response || []);
                        allData = cfg.transform ? cfg.transform(rows) : rows;
                        if (cfg.onData) cfg.onData(allData);
                        updateTable();
                    });
                }

                function renderRows(data) {
                    let html = '';
                    if (!data || data.length === 0) {
                        html = `<tr>
                            <td colspan="${cfg.colspan}">
                                <div class="catalog-empty">
                                    <i class="bi bi-folder2-open"></i>
                                    <span>Sin registros disponibles</span>
                                </div>
                            </td>
                        </tr>`;
                    } else {
                        data.forEach(item => { html += cfg.renderRow(item); });
                    }
                    $(cfg.bodyId).html(html);
                }

                function updateTable() {
                    const filters = cfg.getFilters ? cfg.getFilters() : {};
                    const rowsPerPage = parseInt($(cfg.rowsPerPageId).val()) || 10;

                    let filteredData = allData;
                    if (cfg.filter) filteredData = allData.filter(row => cfg.filter(row, filters));

                    const totalRecords = filteredData.length;
                    const totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                    if (currentPage > totalPages) currentPage = totalPages;
                    if (currentPage < 1) currentPage = 1;

                    const startIndex = (currentPage - 1) * rowsPerPage;
                    const endIndex = Math.min(startIndex + rowsPerPage, totalRecords);
                    const pageData = filteredData.slice(startIndex, endIndex);

                    renderRows(pageData);

                    $(cfg.infoId).text(totalRecords === 0 ? '0 REGISTROS' : `${startIndex + 1} - ${endIndex} DE ${totalRecords}`);
                    renderPagination(totalPages);
                }

                function renderPagination(totalPages) {
                    let html = '';
                    html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage - 1}"><i class="bi bi-chevron-left"></i></a>
                    </li>`;
                    for (let i = 1; i <= totalPages; i++) {
                        html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="#" data-page="${i}">${i}</a>
                        </li>`;
                    }
                    html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="#" data-page="${currentPage + 1}"><i class="bi bi-chevron-right"></i></a>
                    </li>`;
                    $(cfg.paginationId).html(html);
                }

                $(cfg.paginationId).on('click', '.page-link', function (e) {
                    e.preventDefault();
                    const page = parseInt($(this).data('page'));
                    if (page && !$(this).parent().hasClass('disabled')) {
                        currentPage = page;
                        updateTable();
                    }
                });

                $(cfg.rowsPerPageId).on('change', function () { currentPage = 1; updateTable(); });

                api.reload = loadData;
                api.redraw = function () { currentPage = 1; updateTable(); };
                return api;
            }

            // =============================================================
            // Tabla: PERSONAS
