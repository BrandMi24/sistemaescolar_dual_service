                        delBtn = `<button class="btn-action btn-action-delete" title="Eliminar" onclick="eliminarRegistro('Docentes', ${item.teacherId})"><i class="bi bi-trash3-fill"></i></button>`;
                    } else if (tipo === 'ALUMNO' && item.studentId) {
