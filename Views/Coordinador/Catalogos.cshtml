@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    ViewData["Title"] = "Gestión Académica y Usuarios";
    Layout = "_LayoutCoordinador";

    var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
    var activeTab = Context.Request.Query["tab"].ToString();

    if (string.IsNullOrWhiteSpace(activeTab))
    {
        activeTab = "tab-personas";
    }

    var cuatrimestres = (ViewBag.Cuatrimestres as IEnumerable<ControlEscolar.Models.ManagementOperational.CuatrimestreCatalog>)
        ?? Enumerable.Empty<ControlEscolar.Models.ManagementOperational.CuatrimestreCatalog>();
    var moduleConfigs = (ViewBag.ModuleFlowConfigs as IEnumerable<ControlEscolar.Models.Operational.OperationalModuleFlowConfig>)
        ?? Enumerable.Empty<ControlEscolar.Models.Operational.OperationalModuleFlowConfig>();
    var moduleStepRules = (ViewBag.ModuleStepRules as IEnumerable<ControlEscolar.Models.Operational.OperationalModuleStepRule>)
        ?? Enumerable.Empty<ControlEscolar.Models.Operational.OperationalModuleStepRule>();
}

<input type="hidden" name="__RequestVerificationToken" value="@token" />

<div class="d-flex flex-column gap-4 fade-in catalog-canvas">

    @*  Navegación de pestañas  *@
    <div class="nav-tabs-custom px-2 mb-1 overflow-auto d-flex flex-nowrap" style="white-space: nowrap;">
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-personas" ? "active" : "")" data-target="#tab-personas">Personas Totales</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-alumnos" ? "active" : "")" data-target="#tab-alumnos">Alumnos</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-docentes" ? "active" : "")" data-target="#tab-docentes">Docentes</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-grupos" ? "active" : "")" data-target="#tab-grupos">Grupos</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-career" ? "active" : "")" data-target="#tab-career">Carreras</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-bajas" ? "active" : "")" data-target="#tab-bajas">Histórico de Bajas</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-flujo-modulos" ? "active" : "")" data-target="#tab-flujo-modulos">Flujo Módulos</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-roles" ? "active" : "")" data-target="#tab-roles">Roles</a>
        <a href="#" class="nav-tab-item text-decoration-none @(activeTab == "tab-cuentas" ? "active" : "")" data-target="#tab-cuentas">Creación y Gestión de cuentas</a>
    </div>

    @*  =========================================================
        TAB: PERSONAS
        ========================================================= *@
    <div id="tab-personas" class="tab-content-pane" style="display:@(activeTab == "tab-personas" ? "block" : "none");">
        <div class="catalog-filter-card mb-4">
            <div class="d-flex flex-column gap-3">
                <div>
                    <h5 class="fw-bold mb-1">Personas Totales</h5>
                    <p class="text-xs mb-3">Vista consolidada de alumnos, docentes y cuentas del sistema. Incluye activos e inactivos según filtros.</p>
                </div>

                <div class="row g-3 align-items-end">
                    <div class="col-lg-4">
                        <label>BUSCAR</label>
                        <div class="position-relative search-wrapper">
                            <i class="bi bi-search position-absolute search-icon-left"></i>
                            <input type="text" id="dtSearchPersonas" class="form-control search-input-custom" placeholder="Buscar nombre, correo o rol...">
                        </div>
                    </div>

                    <div class="col-md-4 col-lg-3">
                        <label>ROL</label>
                        <select id="filterRolPersonas" class="form-select">
                            <option value="">Todos</option>
                        </select>
                    </div>

                    <div class="col-md-4 col-lg-2">
                        <label>ESTADO</label>
                        <select id="filterEstadoPersonas" class="form-select">
                            <option value="">Todos</option>
                            <option value="ACTIVO">Activo</option>
                            <option value="INSCRITO">Inscrito</option>
                            <option value="PREINSCRITO">Preinscrito</option>
                            <option value="INACTIVO">Inactivo</option>
                            <option value="BAJA">Baja</option>
                            <option value="LICENCIA">Licencia</option>
                        </select>
                    </div>

                    <div class="col-md-4 col-lg-3">
                        <label>TIPO</label>
                        <select id="filterTipoPersonas" class="form-select">
                            <option value="">Todos</option>
                            <option value="ADMIN">Administrativo</option>
                            <option value="DOCENTE">Docente</option>
                            <option value="ALUMNO">Alumno</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="catalog-table-card">
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="px-4">Identificador</th>
                            <th>Nombre Completo</th>
                            <th>Rol</th>
                            <th>Tipo</th>
                            <th>Carrera / Depto</th>
                            <th>Correo</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end px-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="personasBody"></tbody>
                </table>
            </div>

            <div class="catalog-pagination-bar">
                <div class="d-flex align-items-center gap-3">
                    <span class="rows-label">MOSTRAR:</span>
                    <select id="personasRpp" class="form-select form-select-sm rows-per-page">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div id="personasInfo" class="info-label"></div>
                </div>
                <nav aria-label="Paginación personas">
                    <ul class="pagination pagination-sm mb-0" id="personasPagination"></ul>
                </nav>
            </div>
        </div>
    </div>

