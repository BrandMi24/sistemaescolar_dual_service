<style>
    .page-link-custom {
        color: var(--text-title);
        background-color: var(--white);
        border-color: var(--border-color);
        font-weight: 700;
        cursor: pointer;
    }

        .page-link-custom:hover {
            background-color: var(--bg-main);
            color: var(--primary-900);
        }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900);
        border-color: var(--primary-900);
        color: var(--white);
    }

    .page-item.disabled .page-link-custom {
        color: var(--text-body);
        background-color: var(--bg-main);
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {

            function updateActiveTable() {
                let $activePane = $('.tab-content-pane:visible');
                if ($activePane.length === 0) return;

                let searchTerm = $activePane.find('.tab-search').val()?.toLowerCase() || '';
                let rowsPerPage = parseInt($activePane.find('.rows-per-page').val()) || 5;
                let $paginationControls = $activePane.find('.pagination-controls');
                let currentPage = parseInt($paginationControls.attr('data-current-page')) || 1;

                let activeFilters = {};
                $activePane.find('.tab-filter').each(function() {
                    activeFilters[$(this).data('filter')] = $(this).val();
                });

                let filteredRows = [];

                $activePane.find('.data-row').each(function () {
                    let text = $(this).find('.search-target').text().toLowerCase();
                    let matchesSearch = text.indexOf(searchTerm) > -1;

                    let matchesFilters = true;
                    for (const [key, value] of Object.entries(activeFilters)) {
                        let rowValue = $(this).data(key);
                        if (value !== 'todos' && rowValue !== value) {
                            matchesFilters = false;
                            break;
                        }
                    }

                    if (matchesSearch && matchesFilters) {
                        filteredRows.push($(this));
                    }
                    $(this).hide();
                });

                let totalRecords = filteredRows.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;

                if (currentPage > totalPages) {
                    currentPage = totalPages;
                    $paginationControls.attr('data-current-page', currentPage);
                }

                let startIndex = (currentPage - 1) * rowsPerPage;
                let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);

                for (let i = startIndex; i < endIndex; i++) {
                    filteredRows[i].show();
                }

                if (totalRecords === 0) {
                    $activePane.find('.table-info').text('No se encontraron registros');
                } else {
                    $activePane.find('.table-info').text(`Mostrando ${startIndex + 1} a ${endIndex} de ${totalRecords} registros`);
                }

                renderPagination($paginationControls, currentPage, totalPages);
            }

            function renderPagination($container, currentPage, totalPages) {
                let paginationHtml = '';

                paginationHtml += `
                    <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link page-link-custom" href="#" data-page="${currentPage - 1}"><i class="bi bi-chevron-left"></i></a>
                    </li>`;

                for (let i = 1; i <= totalPages; i++) {
                    paginationHtml += `
                        <li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link page-link-custom" href="#" data-page="${i}">${i}</a>
                        </li>`;
                }

                paginationHtml += `
                    <li class="page-item ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}">
                        <a class="page-link page-link-custom" href="#" data-page="${currentPage + 1}"><i class="bi bi-chevron-right"></i></a>
                    </li>`;

                $container.html(paginationHtml);
            }

            // Cambio de Pestañas
            $('.nav-tab-item').on('click', function(e) {
                e.preventDefault();
                $('.nav-tab-item').removeClass('active');
                $(this).addClass('active');
                $('.tab-content-pane').hide();
                var targetId = $(this).data('target');
                $(targetId).fadeIn(300, function() {
                    updateActiveTable();
                });
            });

            // Listeners globales delegados para la tabla activa
            $(document).on('input change', '.tab-search, .tab-filter', function() {
                let $pane = $(this).closest('.tab-content-pane');
                $pane.find('.pagination-controls').attr('data-current-page', 1);
                updateActiveTable();
            });

            $(document).on('change', '.rows-per-page', function() {
                let $pane = $(this).closest('.tab-content-pane');
                $pane.find('.pagination-controls').attr('data-current-page', 1);
                updateActiveTable();
            });

            $(document).on('click', '.pagination-controls .page-link', function(e) {
                e.preventDefault();
                let $parent = $(this).parent();
                if (!$parent.hasClass('disabled') && !$parent.hasClass('active')) {
                    let newPage = $(this).data('page');
                    let $pane = $(this).closest('.tab-content-pane');
                    $pane.find('.pagination-controls').attr('data-current-page', newPage);
                    updateActiveTable();
                }
            });

            // Inicializar la tabla activa al cargar
            updateActiveTable();
        });
    </script>
}