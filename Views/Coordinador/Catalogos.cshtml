            const tblRoles = createTable({
                url: '@Url.Action("GetRolesJson", "Coordinador")',
                bodyId: '#rolesBody',
                infoId: '#rolesInfo',
                paginationId: '#rolesPagination',
                rowsPerPageId: '#rolesRpp',
                colspan: 3,
                getFilters: () => ({
                    search: ($('#dtSearchRoles').val() || '').toLowerCase()
                }),
                filter: (row, f) => {
                    const haystack = `${row.nombre || ''} ${row.descripcion || ''}`.toLowerCase();
                    if (f.search && !haystack.includes(f.search)) return false;
                    return true;
                },
                renderRow: item => `<tr>
                    <td class="px-4"><div class="txt-title fw-bold">${item.nombre || '-'}</div></td>
                    <td>${item.descripcion || '-'}</td>
                    <td class="text-end px-4">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="/Coordinador/EditRole/${item.id}?tab=tab-roles" class="btn-action btn-action-edit" title="Editar"><i class="bi bi-pencil-square"></i></a>
                            <button class="btn-action btn-action-delete" title="Eliminar" onclick="eliminarRol(${item.id})"><i class="bi bi-trash3-fill"></i></button>
                        </div>
                    </td>
                </tr>`
            });

            // =============================================================
            // Bindings de búsqueda y filtros
            // =============================================================
            $('#dtSearchPersonas, #filterRolPersonas, #filterEstadoPersonas, #filterTipoPersonas').on('input change', () => tblPersonas.redraw());
            $('#dtSearchAlumnos, #filterCarreraAlumnos, #filterEstadoAlumnos').on('input change', () => tblAlumnos.redraw());
            $('#dtSearchDocentes, #filterEstadoDocentes, #filterCorreoDocentes').on('input change', () => tblDocentes.redraw());
            $('#dtSearchGrupos, #filterCarreraGrupos, #filterEstadoGrupos').on('input change', () => tblGrupos.redraw());
            $('#dtSearchCarreras, #filterCodigoCarreras').on('input change', () => tblCareer.redraw());
            $('#dtSearchBajas, #filterTipoBajas, #filterEstadoBajas').on('input change', () => tblBajas.redraw());
            $('#dtSearchCuentas, #filterRolCuentas, #filterEstadoCuentas').on('input change', () => tblCuentas.redraw());
            $('#dtSearchRoles').on('input', () => tblRoles.redraw());

            // =============================================================
            // Acciones globales (baja lógica / toggle / eliminar definitivo)
            // =============================================================
            function getToken() {
                return $('input[name="__RequestVerificationToken"]').val();
            }

            function recargarTodo() {
                tblPersonas.reload();
                tblAlumnos.reload();
                tblDocentes.reload();
                tblGrupos.reload();
                tblCareer.reload();
                tblBajas.reload();
                tblCuentas.reload();
                tblRoles.reload();
            }

            window.eliminarRegistro = function (controlador, id) {
                if (!confirm('¿Deseas aplicar baja lógica a este registro?')) return;

                let url = '';
                if (controlador === 'Usuarios') url = `/Coordinador/DeleteUser/${id}`;
                else if (controlador === 'Alumnos') url = `/Coordinador/DeleteStudent/${id}`;
                else if (controlador === 'Docentes') url = `/Coordinador/DeleteTeacher/${id}`;
                else if (controlador === 'Grupos') url = `/Coordinador/DeleteGroup/${id}`;
                else if (controlador === 'Carrera') url = `/Coordinador/DeleteCareer/${id}`;

                $.post(url, { __RequestVerificationToken: getToken() })
                    .done(recargarTodo)
                    .fail(() => alert('Error al aplicar la baja'));
            };

            window.toggleUsuario = function (id, activar) {
                $.ajax({
                    url: '/Coordinador/ToggleUserStatus',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': getToken() },
                    data: JSON.stringify({ id: id, activar: activar })
                })
                .done(recargarTodo)
                .fail(xhr => alert(xhr.responseText || 'No fue posible cambiar el estado'));
            };

            window.eliminarRol = function (id) {
                if (!confirm('¿Deseas eliminar este rol?')) return;

                $.post(`/Coordinador/DeleteRole/${id}`, { __RequestVerificationToken: getToken() })
                    .done(() => tblRoles.reload())
                    .fail(() => alert('Error al eliminar'));
            };

            window.eliminarDefinitivo = function (tipoUsuario, id, userId) {
                if (!confirm('¿Deseas eliminar definitivamente este registro inactivo?')) return;

                $.ajax({
                    url: '/Coordinador/DeleteInactiveRecord',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': getToken() },
                    data: JSON.stringify({ tipo: tipoUsuario, id: id, userId: userId })
                })
                .done(recargarTodo)
                .fail(xhr => alert(xhr.responseText || 'No fue posible eliminar definitivamente'));
            };

            window.deleteCuatrimestre = function (id) {
                if (!confirm('¿Deseas eliminar este cuatrimestre?')) return;

                fetch(`/Coordinador/DeleteCuatrimestre/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrfToken }
                })
                .then(r => {
                    if (!r.ok) throw new Error('No fue posible eliminar el cuatrimestre');
                    window.location.href = '@Url.Action("Catalogos", "Coordinador", new { tab = "tab-flujo-modulos" })';
                })
                .catch(err => alert(err.message));
            };

            window.deleteModuleFlowConfig = function (id) {
                if (!confirm('¿Deseas eliminar esta configuración de módulo?')) return;

                fetch(`/Coordinador/DeleteModuleFlowConfig/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrfToken }
                })
                .then(r => {
                    if (!r.ok) throw new Error('No fue posible eliminar la configuración');
                    window.location.href = '@Url.Action("Catalogos", "Coordinador", new { tab = "tab-flujo-modulos" })';
                })
                .catch(err => alert(err.message));
            };

            window.deleteModuleStepRule = function (id) {
                if (!confirm('¿Deseas eliminar esta regla de paso?')) return;

                fetch(`/Coordinador/DeleteModuleStepRule/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': csrfToken }
                })
                .then(r => {
                    if (!r.ok) throw new Error('No fue posible eliminar la regla');
                    window.location.href = '@Url.Action("Catalogos", "Coordinador", new { tab = "tab-flujo-modulos" })';
                })
                .catch(err => alert(err.message));
            };

            function recargarTodo() {
                dtPersonas.ajax.reload(null, false);
                dtAlumnos.ajax.reload(null, false);
                dtDocentes.ajax.reload(null, false);
                dtGrupos.ajax.reload(null, false);
                dtCarreras.ajax.reload(null, false);
                dtBajas.ajax.reload(null, false);
                dtCuentas.ajax.reload(null, false);
                dtRoles.ajax.reload(null, false);
            }
        });
    </script>
}
