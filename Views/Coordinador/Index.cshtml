@{
    ViewData["Title"] = "Panel de Coordinación";
    Layout = "_LayoutCoordinador";
}

<div class="d-flex flex-column gap-4">

    <div class="admin-grid-dashboard">
        <div class="admin-stat-card border-start" style="border-left-width: 4px !important; border-left-color: var(--primary-900) !important;">
            <div>
                <div class="txt-body text-xs fw-bold tracking-wide mb-2 text-uppercase">Grupos Activos</div>
                <div class="admin-stat-number">18</div>
            </div>
            <div class="icon-circle-lg bg-accent-light txt-primary-dark">
                <i class="bi bi-collection-fill fs-4"></i>
            </div>
        </div>

        <div class="admin-stat-card border-start" style="border-left-width: 4px !important; border-left-color: var(--accent-500) !important;">
            <div>
                <div class="txt-body text-xs fw-bold tracking-wide mb-2 text-uppercase">Docentes Asignados</div>
                <div class="admin-stat-number">45</div>
            </div>
            <div class="icon-circle-lg bg-surface border border-theme txt-primary-dark">
                <i class="bi bi-person-workspace fs-4"></i>
            </div>
        </div>

        <div class="admin-stat-card border-start" style="border-left-width: 4px !important; border-left-color: var(--warning-700) !important;">
            <div>
                <div class="txt-body text-xs fw-bold tracking-wide mb-2 text-uppercase">Materias sin Docente</div>
                <div class="admin-stat-number txt-warning">3</div>
            </div>
            <div class="icon-circle-lg bg-warning bg-opacity-10" style="color: var(--warning-700);">
                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
            </div>
        </div>

        <div class="admin-stat-card border-start" style="border-left-width: 4px !important; border-left-color: var(--success-700) !important;">
            <div>
                <div class="txt-body text-xs fw-bold tracking-wide mb-2 text-uppercase">Ciclo Actual</div>
                <div class="txt-primary-dark fw-bold fs-4 mt-1">ENE-ABR 2026</div>
            </div>
            <div class="icon-circle-lg bg-success-100 txt-success-700">
                <i class="bi bi-calendar-check-fill fs-4"></i>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="admin-card-white p-4 h-100 d-flex flex-column">
                <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-3">Estado de Asignaciones (ENE-ABR 2026)</h6>

                <div class="flex-grow-1 d-flex flex-column justify-content-center gap-4">
                    <div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="txt-title fw-bold text-sm">Progreso General de Asignación Docente</span>
                            <span class="txt-primary-dark fw-bold">92%</span>
                        </div>
                        <div class="progress rounded-pill bg-app" style="height: 10px;">
                            <div class="progress-bar rounded-pill bg-primary-dark" style="width: 92%;"></div>
                        </div>
                        <p class="txt-body text-xs mt-2 mb-0">Faltan 3 materias por asignar maestro en la carrera de Mecatrónica.</p>
                    </div>

                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <a href="@Url.Action("Asignaciones", "Coordinador")" class="bg-surface border border-theme rounded-4 p-3 d-flex align-items-center justify-content-between text-decoration-none transition hover-bg-app">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-circle bg-warning bg-opacity-10 text-warning-700"><i class="bi bi-person-fill-add"></i></div>
                                    <span class="txt-title fw-bold text-sm">Completar Asignaciones</span>
                                </div>
                                <i class="bi bi-arrow-right txt-body"></i>
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="@Url.Action("Catalogos", "Coordinador")" class="bg-surface border border-theme rounded-4 p-3 d-flex align-items-center justify-content-between text-decoration-none transition hover-bg-app">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-circle bg-accent-light txt-primary-dark"><i class="bi bi-people-fill"></i></div>
                                    <span class="txt-title fw-bold text-sm">Ver Catálogo Docente</span>
                                </div>
                                <i class="bi bi-arrow-right txt-body"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="bg-surface p-4 rounded-4 border-theme shadow-sm border-start h-100" style="border-left-width: 4px !important; border-left-color: var(--error-700) !important;">
                <h6 class="txt-error fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i> Alertas de Deserción
                </h6>

                <div class="d-flex flex-column gap-3">
                    <div class="p-3 bg-error-100 rounded-3 border-error border-opacity-25">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="txt-error fw-bold">Grupo 4º A (Software)</span>
                            <span class="badge bg-white txt-error fw-bold">13% bajas</span>
                        </div>
                        <div class="txt-error opacity-75 text-xs">4 alumnos se han dado de baja este mes.</div>
                    </div>

                    <div class="p-3 bg-app rounded-3 border border-theme">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span class="txt-title fw-bold">Grupo 2º C (Mecatrónica)</span>
                            <span class="badge bg-white txt-title fw-bold border border-theme">8% bajas</span>
                        </div>
                        <div class="txt-body text-xs">3 alumnos se han dado de baja.</div>
                    </div>
                </div>

                <a href="@Url.Action("Reportes", "Coordinador")" class="btn btn-ghost-sep w-100 mt-4 text-xs">Ver todos los reportes</a>
            </div>
        </div>
    </div>
</div>