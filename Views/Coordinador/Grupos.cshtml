@{
    ViewData["Title"] = "Control de Grupos";
    Layout = "_LayoutCoordinador";
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in" style="min-height: 82vh;">

    <div class="bg-white p-4 rounded-4 border-0 shadow-sm d-flex flex-column flex-lg-row align-items-lg-end gap-3 flex-shrink-0">
        <div class="flex-grow-1">
            <label class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">CICLO ESCOLAR</label>
            <select class="form-select border-0 bg-app py-2 text-xs fw-bold txt-title shadow-none cursor-pointer">
                <option>Enero - Abril 2026</option>
                <option>Septiembre - Diciembre 2025</option>
            </select>
        </div>
        <div class="flex-grow-1">
            <label class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">PROGRAMA EDUCATIVO</label>
            <select class="form-select border-0 bg-app py-2 text-xs fw-bold txt-title shadow-none cursor-pointer">
                <option>Ing. Desarrollo y Gestión de Software</option>
                <option>Mecatrónica</option>
            </select>
        </div>
        <div class="flex-grow-1">
            <label class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">GRUPO</label>
            <select class="form-select border-0 bg-app py-2 text-xs fw-bold txt-title shadow-none cursor-pointer">
                <option value="">-- Seleccionar --</option>
                <option value="7A">7º A - Matutino</option>
                <option value="7B">7º B - Vespertino</option>
            </select>
        </div>
        <div class="flex-shrink-0">
            <button id="btnCargarGrupo" class="btn-primary-sep border-0 w-100 py-2 shadow-sm text-xxs tracking-widest fw-bold" style="min-width: 180px;">
                ACTUALIZAR GRUPO
            </button>
        </div>
    </div>

    <div id="emptyStateGrupo" class="admin-card-white rounded-4 border-0 shadow-sm text-center py-5 d-flex flex-column align-items-center justify-content-center flex-grow-1">
        <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-2">GESTIÓN DE AULA</h6>
        <p class="text-muted text-xs fw-medium mb-0">Selecciona un ciclo, carrera y grupo en la parte superior para administrar a los alumnos.</p>
    </div>

    <div id="grupoContent" class="d-none flex-column gap-4 flex-grow-1">

        <div class="bg-white p-4 rounded-4 border-0 shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-4 border-start border-4 flex-shrink-0" style="border-left-color: var(--primary-900) !important;">
            <div>
                <div class="d-flex align-items-center gap-3 mb-2">
                    <h5 class="txt-title fw-bold mb-0 text-uppercase">Grupo 7º A</h5>
                    <span class="badge bg-app text-dark text-xxs px-3 py-2 fw-bold rounded-pill">MATUTINO</span>
                </div>
                <div class="text-muted text-xs fw-medium text-uppercase">Ing. Desarrollo y Gestión de Software • Enero - Abril 2026</div>
            </div>

            <div class="bg-app p-3 rounded-3 border-0 d-flex flex-column" style="min-width: 350px;">
                <label class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">TUTOR ASIGNADO</label>
                <select class="form-select border-0 bg-white py-2 text-xs fw-bold shadow-sm select-tutor cursor-pointer">
                    <option value="">+ Seleccionar Tutor...</option>
                    <option value="1" selected>ING. JUAN PÉREZ MARTÍNEZ</option>
                    <option value="2">DR. GABRIEL LÓPEZ</option>
                </select>
            </div>
        </div>

        <div class="row g-3 flex-shrink-0">
            <div class="col-md-4">
                <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm d-flex justify-content-between align-items-center">
                    <div class="text-muted text-xxs fw-bold tracking-wide text-uppercase">ALUMNOS INSCRITOS</div>
                    <h4 class="txt-title fw-bold mb-0">28</h4>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm d-flex justify-content-between align-items-center">
                    <div class="text-muted text-xxs fw-bold tracking-wide text-uppercase">PROMEDIO GRUPAL</div>
                    <h4 class="txt-title fw-bold mb-0">8.9</h4>
                </div>
            </div>
            <div class="col-md-4">
                <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm d-flex justify-content-between align-items-center border-start border-4" style="border-left-color: var(--error-700) !important;">
                    <div class="text-muted text-xxs fw-bold tracking-wide text-uppercase">EN RIESGO (IRREGULARES)</div>
                    <h4 class="txt-error fw-bold mb-0">2</h4>
                </div>
            </div>
        </div>

        <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
    
            <div class="bg-white p-4 border-bottom border-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 flex-shrink-0">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">LISTA DE ALUMNOS</h6>
                <div class="position-relative" style="width: 100%; max-width: 300px;">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" id="searchInput" class="form-control border-0 bg-app py-2 ps-5 text-xs fw-medium shadow-none" placeholder="Buscar alumno o matrícula...">
                </div>
            </div>

            <div class="table-responsive bg-white flex-grow-1" style="min-height: 250px;">
                <table class="table align-middle mb-0 w-100" style="min-width: 800px;">
                    <thead class="bg-app border-0 sticky-top" style="z-index: 5;">
                        <tr>
                            <th class="py-3 px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider" width="15%">Matrícula</th>
                            <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider" width="35%">Alumno</th>
                            <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider" width="15%">Estado</th>
                            <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider" width="15%">Promedio</th>
                            <th class="py-3 text-end px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider" width="20%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="alumnosBody">
                    </tbody>
                </table>
            </div>

            <div class="bg-white p-3 border-top border-light d-flex flex-column flex-xl-row justify-content-between align-items-center gap-3 flex-shrink-0">
        
                <div class="d-flex align-items-center gap-3">
                    <span class="text-secondary fw-bold" style="font-size: 0.65rem;">MOSTRAR:</span>
                    <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs" style="width: 70px; cursor: pointer;">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
                </div>

                <nav aria-label="Paginación">
                    <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                    </ul>
                </nav>

                <button class="btn-ghost-sep border-0 bg-app px-4 py-2 text-xxs fw-bold tracking-wide d-flex align-items-center gap-2">
                    <i class="bi bi-download"></i> DESCARGAR LISTA
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Lógica corregida usando las clases nativas de Bootstrap
            $('#btnCargarGrupo').click(function() {
                var $btn = $(this);
                
                // Mostrar carga
                $btn.prop('disabled', true).text('CARGANDO...');

                setTimeout(function() {
                    // Ocultar Empty State limpiamente
                    $('#emptyStateGrupo').addClass('d-none').removeClass('d-flex');
                    
                    // Mostrar Contenedor principal con Flexbox activo
                    $('#grupoContent').removeClass('d-none').addClass('d-flex');
                    
                    // Estilizar el botón como secundario
                    $btn.prop('disabled', false).text('ACTUALIZAR GRUPO');
                    $btn.removeClass('btn-primary-sep').addClass('btn-ghost-sep bg-app border-0 text-secondary');
                }, 600);
            });

            // Lógica para color del tutor
            $('.select-tutor').change(function() {
                if($(this).val() !== "") {
                    $(this).removeClass('bg-white text-dark').addClass('bg-success-100 text-success-700');
                    $(this).css('border', '1px solid var(--success-700)');
                } else {
                    $(this).removeClass('bg-success-100 text-success-700').addClass('bg-white text-dark');
                    $(this).css('border', 'none');
                }
            });
            
            $('.select-tutor').trigger('change');
        });
    </script>

    <script>
        $(document).ready(function () {
        
            // ==========================================
            // 1. LÓGICA DE LA VISTA (BOTÓN ENTRAR GRUPO)
            // ==========================================
            $('#btnCargarGrupo').click(function() {
                var $btn = $(this);
                $btn.prop('disabled', true).text('CARGANDO...');

                setTimeout(function() {
                    $('#emptyStateGrupo').addClass('d-none').removeClass('d-flex');
                    $('#grupoContent').removeClass('d-none').addClass('d-flex');
                    $btn.prop('disabled', false).text('ACTUALIZAR GRUPO');
                    $btn.removeClass('btn-primary-sep').addClass('btn-ghost-sep bg-app border-0 text-secondary');
                
                    // Cargar datos de la tabla cuando se entra al grupo
                    loadData();
                }, 600);
            });

            // Estilos del Select Tutor
            $('.select-tutor').change(function() {
                if($(this).val() !== "") {
                    $(this).removeClass('bg-white text-dark').addClass('bg-success-100 text-success-700').css('border', '1px solid var(--success-700)');
                } else {
                    $(this).removeClass('bg-success-100 text-success-700').addClass('bg-white text-dark').css('border', 'none');
                }
            });
            $('.select-tutor').trigger('change');

            // ==========================================
            // 2. LÓGICA DE LA TABLA (ESTÁNDAR CICLOS)
            // ==========================================
            let allData = [];
            let currentPage = 1;

            function loadData() {
                // AQUÍ IRÍA TU AJAX REAL. Ejemplo simulado con la estructura que tenías en HTML:
                allData = [
                    { matricula: '24001504', nombre: 'Roberto Carlos Perez Cadena', correo: 'rperez@alumnos.uttn.mx', estado: 'REGULAR', promedio: 9.5, iniciales: 'RC' },
                    { matricula: '24001892', nombre: 'Luis Ángel García', correo: 'lgarcia@alumnos.uttn.mx', estado: 'IRREGULAR', promedio: 6.8, iniciales: 'LA' }
                ];
                updateTable();
            }

            function renderRows(data) {
                let html = '';
                if (data.length === 0) {
                    html = `<tr>
                        <td colspan="5" class="text-center py-5">
                            <div class="d-flex flex-column align-items-center opacity-50 py-5">
                                <i class="bi bi-people fs-1 mb-2"></i>
                                <span class="fw-bold text-xxs text-uppercase tracking-widest">Sin registros disponibles</span>
                            </div>
                        </td>
                    </tr>`;
                } else {
                    data.forEach(item => {
                        let isRegular = item.estado === 'REGULAR';
                        let rowClass = isRegular ? '' : 'bg-error-100 bg-opacity-10';
                        let badgeClass = isRegular ? 'bg-success-100 text-success-700' : 'bg-error-100 text-error-700';
                        let matriculaClass = isRegular ? 'txt-primary-dark' : 'text-danger';
                        let promClass = isRegular ? 'txt-title' : 'text-danger';
                        let avatarClass = isRegular ? 'bg-accent-100 txt-primary-dark' : 'bg-app text-secondary border border-light';

                        html += `
                        <tr class="border-bottom border-light hover-bg-app transition-all ${rowClass}">
                            <td class="px-4 py-3 ${matriculaClass} fw-bold text-xs">${item.matricula}</td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="${avatarClass} fw-bold rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.75rem;">${item.iniciales}</div>
                                    <div>
                                        <div class="txt-title fw-bold text-xs text-uppercase mb-1">${item.nombre}</div>
                                        <div class="text-muted text-xxs fw-medium">${item.correo}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge ${badgeClass} text-xxs px-3 py-1 fw-bold rounded-pill">${item.estado}</span>
                            </td>
                            <td class="text-center ${promClass} fw-bold text-sm">${item.promedio}</td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-sm border-0 bg-primary-100 txt-primary-dark rounded-2 py-1 px-2" title="Ver Expediente">
                                        <i class="bi bi-folder2-open fs-6"></i>
                                    </button>
                                    <button class="btn btn-sm border-0 bg-app text-secondary rounded-2 py-1 px-2" title="Transferir de Grupo">
                                        <i class="bi bi-arrow-left-right fs-6"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>`;
                    });
                }
                $('#alumnosBody').html(html);
            }

            function updateTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let rowsPerPage = parseInt($('#rowsPerPage').val());

                let filteredData = allData.filter(item => {
                    return item.nombre.toLowerCase().includes(searchTerm) || item.matricula.includes(searchTerm);
                });

                let totalRecords = filteredData.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                if (currentPage > totalPages) currentPage = totalPages;

                let startIndex = (currentPage - 1) * rowsPerPage;
                let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);
                let pageData = filteredData.slice(startIndex, endIndex);

                renderRows(pageData);

                $('#tableInfo').text(totalRecords === 0 ? '0 REGISTROS' : `${startIndex + 1} - ${endIndex} DE ${totalRecords}`);
                renderPagination(totalPages);
            }

            function renderPagination(totalPages) {
                let html = '';
            
                html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage - 1}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>`;

                for (let i = 1; i <= totalPages; i++) {
                    let btnClass = (i === currentPage) ? 'bg-primary-dark text-white shadow-sm' : 'bg-app txt-title hover-bg-light';
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link border-0 ${btnClass} rounded-2 mx-1 fw-bold text-xxs px-3" href="#" data-page="${i}">${i}</a>
                    </li>`;
                }

                html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage + 1}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>`;

                $('#paginationControls').html(html);
            }

            // Eventos de la Tabla
            $('#searchInput, #rowsPerPage').on('change input', () => { currentPage = 1; updateTable(); });

            $('#paginationControls').on('click', '.page-link', function (e) {
                e.preventDefault();
                let page = parseInt($(this).data('page'));
                if (page && !$(this).parent().hasClass('disabled')) {
                    currentPage = page;
                    updateTable();
                }
            });

        });
    </script>
}