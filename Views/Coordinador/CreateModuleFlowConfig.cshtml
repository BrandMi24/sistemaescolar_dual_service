@model ModuleFlowConfigViewModel
@{
    ViewData["Title"] = "Configuración de Módulo";
    Layout = "_LayoutCoordinador";

    var isEdit = ViewBag.IsEdit as bool? ?? false;
    var returnTab = ViewBag.ReturnTab as string ?? "tab-flujo-modulos";
}

<div class="fade-in d-flex flex-column gap-4">
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex justify-content-between align-items-center">
        <div>
            <h3 class="txt-title fw-bold mb-1">@(isEdit ? "Editar Configuración de Módulo" : "Nueva Configuración de Módulo")</h3>
            <span class="txt-body text-xs">Define cuatrimestre de apertura de portal y seguimiento por módulo.</span>
        </div>

        <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })" class="btn btn-sm btn-ghost-sep border border-theme shadow-sm fw-semibold">
            Volver a Catálogos
        </a>
    </div>

    <form asp-action="@(isEdit ? "EditModuleFlowConfig" : "CreateModuleFlowConfig")" asp-controller="Coordinador" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnTab" value="@returnTab" />
        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm bg-white">
                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">CONFIGURACIÓN BASE</h6>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label asp-for="ModuleType" class="fw-bold text-xs">MÓDULO</label>
                        <select asp-for="ModuleType" class="form-select search-input-custom">
                            <option value="">Selecciona...</option>
                            <option value="PRACTICAS_PROFESIONALES">PRACTICAS_PROFESIONALES</option>
                            <option value="SERVICIO_SOCIAL">SERVICIO_SOCIAL</option>
                        </select>
                        <span asp-validation-for="ModuleType" class="text-danger text-xs"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PortalStartCuatrimestre" class="fw-bold text-xs">CUATRIMESTRE DE INICIO DE PORTAL</label>
                        <input asp-for="PortalStartCuatrimestre" class="form-control search-input-custom" type="number" min="1" max="20" />
                        <span asp-validation-for="PortalStartCuatrimestre" class="text-danger text-xs"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TrackingStartCuatrimestre" class="fw-bold text-xs">CUATRIMESTRE DE INICIO DE SEGUIMIENTO</label>
                        <input asp-for="TrackingStartCuatrimestre" class="form-control search-input-custom" type="number" min="1" max="20" />
                        <span asp-validation-for="TrackingStartCuatrimestre" class="text-danger text-xs"></span>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="admin-card-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column bg-white border-theme">
                    <div class="mt-auto">
                        <button type="submit" class="btn btn-primary-sep w-100 fw-bold py-2">@(isEdit ? "Guardar Cambios" : "Crear Configuración")</button>
                        <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })" class="btn btn-ghost-sep border border-theme w-100 mt-2">Cancelar</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
