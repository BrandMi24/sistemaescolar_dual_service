@model CreateCareerViewModel
@{
    // Declaración de variables para evitar errores de compilación
    var isEdit = ViewBag.IsEdit as bool? ?? false;
    var returnTab = ViewBag.ReturnTab as string ?? Context.Request.Query["tab"].ToString();

    if (string.IsNullOrWhiteSpace(returnTab))
    {
        returnTab = "tab-career";
    }

    ViewData["Title"] = isEdit ? "Editar Carrera" : "Registrar Carrera";
    Layout = "_LayoutCoordinador";
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in">

    <div class="bg-white p-4 rounded-4 shadow-sm border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h5 class="txt-title fw-bold mb-1 text-uppercase">@(isEdit ? "Modificar Catálogo de Carrera" : "Nuevo Registro de Carrera")</h5>
            <p class="txt-body text-xxs fw-bold text-uppercase tracking-widest mb-0 opacity-75">
                @(isEdit
                    ? "Actualice los metadatos de la carrera para la correcta organización de grupos."
                    : "Capture la información básica para dar de alta un nuevo programa educativo.")
            </p>
        </div>
        <div class="flex-shrink-0">
            <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })"
                   class="btn-ghost-sep bg-app border-0 px-4 py-2 fw-bold text-xxs d-flex align-items-center text-decoration-none shadow-none">
                REGRESAR A CATÁLOGOS
            </a>
        </div>
    </div>

    <form asp-action="@(isEdit ? "EditCareer" : "CreateCareer")"
          asp-controller="Coordinador"
          method="post"
          class="needs-validation"
          novalidate>
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@ViewBag.CareerId" />
        <input type="hidden" name="returnTab" value="@returnTab" />

        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                
                <div class="admin-card-white p-4 p-md-5 rounded-4 border-0 shadow-sm bg-white">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">
                            INFORMACIÓN DE LA CARRERA
                        </h6>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="bg-error-100 border-start border-4 text-danger text-xs fw-bold rounded-3 p-3 mb-4" style="border-left-color: var(--error-700) !important;"></div>
                    }

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">
                                CÓDIGO DE CARRERA <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Code"
                                   class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium text-uppercase shadow-none"
                                   placeholder="EJ. ISC" required />
                            <span asp-validation-for="Code" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Name" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">
                                NOMBRE DE LA CARRERA <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name"
                                   class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none"
                                   placeholder="EJ. INGENIERÍA EN SISTEMAS" required />
                            <span asp-validation-for="Name" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top border-light d-flex flex-column flex-sm-row justify-content-end gap-3">
                        <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })"
                               class="btn-ghost-sep bg-app border-0 px-5 py-2 fw-bold text-xxs text-muted text-center text-decoration-none shadow-none">
                            CANCELAR
                        </a>

                        <button type="submit" class="btn-primary-sep border-0 px-5 py-2 fw-bold text-xxs tracking-widest shadow-sm">
                            @(isEdit ? "GUARDAR CAMBIOS" : "GUARDAR CARRERA")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        /* Glow institucional en foco */
        .form-control:focus {
            background-color: var(--white) !important;
            box-shadow: 0 0 0 4px var(--accent-100) !important;
            border: 1px solid var(--accent-500) !important;
        }
    </style>
}