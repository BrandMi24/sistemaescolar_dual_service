@{
    ViewData["Title"] = "Ciclos Escolares";
    Layout = "_LayoutCoordinador";
}

<div class="d-flex flex-column gap-4">

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1" style="max-width: 650px;">
            <div class="position-relative search-wrapper flex-grow-1">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" id="searchInput" class="form-control search-input-custom" placeholder="Buscar ciclo...">
            </div>

            <select id="statusFilter" class="form-select bg-app border-theme txt-title fw-bold" style="width: auto; min-width: 180px;">
                <option value="">Todos</option>
                <option value="ACTIVO">Activos</option>
                <option value="FINALIZADO">Finalizados</option>
                <option value="PROGRAMADO">Programados</option>
            </select>
        </div>

        <!-- BOTÓN CORREGIDO -->
        <a href="@Url.Action("CreateCycle", "Coordinador")"
               class="btn btn-primary-sep d-flex align-items-center gap-2 shadow-sm">
            <i class="bi bi-plus-lg"></i> Crear Nuevo Ciclo
        </a>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden">

        <div class="table-responsive bg-surface">
            <table class="table table-borderless align-middle mb-0" id="ciclosTable">
                <thead class="admin-table-header">
                    <tr>
                        <th class="py-3 px-4">Nombre del Ciclo</th>
                        <th class="py-3 text-center">Fecha Inicio</th>
                        <th class="py-3 text-center">Fecha Fin</th>
                        <th class="py-3 text-center">Estado</th>
                        <th class="py-3 text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody id="ciclosBody"></tbody>
            </table>
        </div>
        <div class="bg-surface p-3 border-top border-theme d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        
            <div class="d-flex align-items-center gap-3">
                <span class="txt-body text-xs fw-bold">Mostrar:</span>

                <select id="rowsPerPage"
                        class="form-select form-select-sm bg-app border-theme txt-title fw-bold"
                        style="width: 70px;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                </select>

                <div id="tableInfo" class="txt-body text-xs fw-bold"></div>
            </div> 
    </div>
</div>

<style>
    /* Estilos personalizados para la paginación usando los colores del Design System */
    .page-link-custom {
        color: var(--text-title);
        background-color: var(--surface);
        border-color: var(--border-color);
        font-weight: 700;
        cursor: pointer;
    }

        .page-link-custom:hover {
            background-color: var(--bg-main);
            color: var(--primary-900);
        }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900);
        border-color: var(--primary-900);
        color: var(--white);
    }

    .page-item.disabled .page-link-custom {
        color: var(--text-body);
        background-color: var(--bg-main);
        opacity: 0.6;
        cursor: not-allowed;
    }
</style>

@section Scripts {
        <script>
                $(document).ready(function () {

                    let allData = [];
                    let currentPage = 1;

                    // =========================
                    // CARGAR DATOS
                    // =========================
                    function loadData() {
                        $.get('@Url.Action("GetCyclesJson", "Coordinador")', function (response) {
                            allData = response.data ? response.data : response;
                            updateTable();
                        });
                    }

                    // =========================
                    // RENDER FILAS
                    // =========================
                    function renderRows(data) {
                        let html = '';

                        data.forEach(item => {

                            let estadoClass = item.estado === 'ACTIVO'
                                ? 'status-aceptado'
                                : 'bg-app txt-body border border-theme';

                            html += `
                            <tr class="border-bottom border-theme hover-bg-app data-row">

                                <td class="px-4 py-3">
                                    <div class="fw-bold">${item.nombre}</div>
                                    <div class="text-xs">Ciclo escolar</div>
                                </td>

                                <td class="text-center">${item.inicio}</td>
                                <td class="text-center">${item.fin}</td>

                                <td class="text-center">
                                    <span class="badge ${estadoClass}">
                                        ${item.estado}
                                    </span>
                                </td>

                                <td class="text-end px-4">

                                    <!-- EDIT -->
                                    <a href="/Coordinador/EditCycle?id=${item.id}"
                                       class="btn btn-sm btn-primary me-1">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- DELETE -->
                                    <button class="btn btn-sm btn-danger delete-cycle me-1"
                                            data-id="${item.id}">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </td>
                            </tr>`;
                        });

                        $('#ciclosBody').html(html);
                    }

                    // =========================
                    // FILTRO + PAGINACIÓN
                    // =========================
                    function updateTable() {

                        let searchTerm = $('#searchInput').val().toLowerCase();
                        let statusFilter = $('#statusFilter').val();
                        let rowsPerPage = parseInt($('#rowsPerPage').val());

                        let filteredData = allData.filter(item => {

                            let matchesSearch = item.nombre.toLowerCase().includes(searchTerm);
                            let matchesStatus = (!statusFilter) || (item.estado === statusFilter);

                            return matchesSearch && matchesStatus;
                        });

                        let totalRecords = filteredData.length;
                        let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;

                        if (currentPage > totalPages) currentPage = totalPages;

                        let startIndex = (currentPage - 1) * rowsPerPage;
                        let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);

                        let pageData = filteredData.slice(startIndex, endIndex);

                        renderRows(pageData);

                        if (totalRecords === 0) {
                            $('#tableInfo').text('No se encontraron registros');
                        } else {
                            $('#tableInfo').text(`Mostrando ${startIndex + 1} a ${endIndex} de ${totalRecords} registros`);
                        }

                        renderPagination(totalPages);
                    }

                    // =========================
                    // PAGINACIÓN
                    // =========================
                    function renderPagination(totalPages) {

                        let html = '';

                        html += `
                        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                            <a class="page-link page-link-custom" href="#" data-page="${currentPage - 1}">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>`;

                        for (let i = 1; i <= totalPages; i++) {
                            html += `
                            <li class="page-item ${i === currentPage ? 'active' : ''}">
                                <a class="page-link page-link-custom" href="#" data-page="${i}">${i}</a>
                            </li>`;
                        }

                        html += `
                        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                            <a class="page-link page-link-custom" href="#" data-page="${currentPage + 1}">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>`;

                        $('#paginationControls').html(html);
                    }

                    // =========================
                    // EVENTOS
                    // =========================

                    $('#searchInput').on('input', function () {
                        currentPage = 1;
                        updateTable();
                    });

                    $('#statusFilter').on('change', function () {
                        currentPage = 1;
                        updateTable();
                    });

                    $('#rowsPerPage').on('change', function () {
                        currentPage = 1;
                        updateTable();
                    });

                    $('#paginationControls').on('click', '.page-link', function (e) {
                        e.preventDefault();

                        let parent = $(this).parent();

                        if (!parent.hasClass('disabled') && !parent.hasClass('active')) {
                            currentPage = parseInt($(this).data('page'));
                            updateTable();
                        }
                    });

                    // =========================
                    // DELETE
                    // =========================
                    $('#ciclosBody').on('click', '.delete-cycle', function () {

                        const id = $(this).data('id');

                        if (!confirm('¿Seguro que deseas eliminar este ciclo?')) return;

                        $.post('/Coordinador/DeleteCycle', {
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        })
                        .done(function () {
                            loadData();
                        })
                        .fail(function (err) {
                            console.error(err);
                            alert('Error al eliminar');
                        });
                    });

                    // =========================
                    // INIT
                    // =========================
                    loadData();

                });
        </script>
}