@{
    ViewData["Title"] = "Nuevo Profesor";
    Layout = "_LayoutCoordinador";
}

<div class="fade-in d-flex flex-column gap-4">

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h3 class="txt-title fw-bold mb-1">Registrar Nuevo Profesor</h3>
            <div class="d-flex align-items-center gap-3 mt-2 txt-body text-xs">
                <span>Ingrese los datos para integrar al profesor al sistema y generar su cuenta de acceso.</span>
            </div>
        </div>
        <div class="text-end d-flex flex-column align-items-md-end gap-2">
            <a href="@Url.Action("Catalogos", "Coordinador")" class="btn btn-sm btn-ghost-sep border border-theme shadow-sm mt-1 fw-semibold">
                Volver a Catálogos
            </a>
        </div>
    </div>

    <div class="alert bg-error-100 border border-error border-opacity-25 txt-error rounded-3 mb-4 shadow-sm" style="display: none;">
        <span class="text-sm fw-bold">Por favor, verifique los datos ingresados e intente nuevamente.</span>
    </div>
    @{
        var isEdit = ViewBag.IsEdit as bool? ?? false;
    }
    <form asp-action="@(isEdit ? "EditTeacher" : "CreateTeacher")"
      asp-controller="Coordinador" method="post" class="needs-validation">
        @Html.AntiForgeryToken()

        <div class="row g-4">
            <input type="hidden" name="TeacherId" value="@Model?.TeacherId" />
            <input type="hidden" name="PersonId" value="@Model?.PersonId" />
            <div class="col-lg-8 d-flex flex-column gap-4">
                
                <div class="admin-card-white p-4 p-md-5 rounded-4 border-theme shadow-sm bg-white">
                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">
                        DATOS PERSONALES
                    </h6>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">NOMBRE(S) <span class="text-danger">*</span></label>
                            <input name="FirstName" type="text" class="form-control search-input-custom ps-3" placeholder="Ej. Carlos" required value="@Model?.FirstName" />
                        </div>
                        <div class="col-md-4">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">APELLIDO PATERNO <span class="text-danger">*</span></label>
                            <input name="LastNamePaternal" type="text" class="form-control search-input-custom ps-3" placeholder="Ej. García" required value="@Model?.LastNamePaternal" />
                        </div>
                        <div class="col-md-4">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">APELLIDO MATERNO</label>
                            <input name="LastNameMaternal" type="text" class="form-control search-input-custom ps-3" placeholder="Opcional" value="@Model?.LastNameMaternal" />
                        </div>
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">CORREO ELECTRÓNICO</label>
                            <input name="Email" type="email" class="form-control search-input-custom ps-3" placeholder="correo@institucion.edu.mx" value="@Model?.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">TELÉFONO</label>
                            <input name="Phone" type="text" class="form-control search-input-custom ps-3" placeholder="10 dígitos (opcional)" maxlength="30" value="@Model?.Phone" />
                        </div>
                    </div>
                </div>

                <div class="admin-card-white p-4 p-md-5 rounded-4 border-theme shadow-sm bg-white">
                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">
                        DATOS LABORALES
                    </h6>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">NÚMERO DE EMPLEADO</label>
                            <input name="EmployeeNumber" type="text" class="form-control search-input-custom ps-3" placeholder="Ej. EMP-001 (opcional)" maxlength="30" value="@Model?.EmployeeNumber" />
                        </div>
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2">ESTADO INICIAL</label>
                            <select name="StatusCode" class="form-select bg-app border-theme txt-title fw-semibold py-2" value="@Model?.StatusCode">
                                <option value="ACTIVO" selected>Activo</option>
                                <option value="INACTIVO">Inactivo</option>
                                <option value="LICENCIA">Licencia</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="admin-card-white p-4 p-md-5 rounded-4 shadow-sm h-100 d-flex flex-column bg-white border-theme">
                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">
                        CUENTA DE SISTEMA
                    </h6>
                    @if (!(ViewBag.IsEdit as bool? ?? false))
                        {
                            <div class="alert bg-surface border border-theme txt-body text-xs mb-4 lh-base shadow-sm">
                                Si proporciona credenciales, el profesor tendrá acceso al sistema con roles de <strong>Profesor / Asesor</strong> y <strong>Supervisor Académico</strong>.
                            </div>

                            <div class="mb-4">
                                <label class="txt-body text-xs fw-bold tracking-wide mb-2">USUARIO DE ACCESO</label>
                                <input name="Username" type="text" class="form-control search-input-custom ps-3" placeholder="Ej. jgarcia" maxlength="80" autocomplete="off" value="@Model?.Username" />
                            </div>

                            <div class="mb-5">
                                <label class="txt-body text-xs fw-bold tracking-wide mb-2">CONTRASEÑA</label>
                                <input name="Password" type="password" class="form-control search-input-custom ps-3" placeholder="Mínimo 8 caracteres" autocomplete="new-password" value="@Model?.Password" />
                            </div>
                        }
                        <div class="mt-auto pt-4 border-top border-theme d-flex flex-column gap-3">
                        <button type="submit" class="btn btn-primary-sep bg-primary-900 w-100 fw-bold py-3 shadow-sm text-white">
                            @(isEdit ? "Editar Profesor" : "Registrar Nuevo Profesor")
                        </button>
                        <a href="@Url.Action("Catalogos", "Coordinador")" class="btn btn-ghost-sep border border-theme w-100 py-2 shadow-sm text-body fw-semibold">
                            Cancelar
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>