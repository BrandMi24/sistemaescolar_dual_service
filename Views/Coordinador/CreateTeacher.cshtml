@model CreateTeacherViewModel
@{
    var isEdit = ViewBag.IsEdit as bool? ?? false;
    var returnTab = ViewBag.ReturnTab as string ?? Context.Request.Query["tab"].ToString();

    if (string.IsNullOrWhiteSpace(returnTab))
    {
        returnTab = "tab-docentes";
    }

    ViewData["Title"] = isEdit ? "Editar Profesor" : "Nuevo Profesor";
    Layout = "_LayoutCoordinador";
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in">

    <div class="bg-white p-4 rounded-4 shadow-sm border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h5 class="txt-title fw-bold mb-1 text-uppercase">@(isEdit ? "Modificar Registro de Docente" : "Alta de Nuevo Profesor")</h5>
            <p class="txt-body text-xxs fw-bold text-uppercase tracking-widest mb-0 opacity-75">
                @(isEdit
                    ? "Actualización de expediente y estatus laboral del docente."
                    : "Captura de información para integrar al personal docente y generar accesos.")
            </p>
        </div>
        <div class="flex-shrink-0">
            <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })"
                   class="btn-ghost-sep bg-app border-0 px-4 py-2 fw-bold text-xxs d-flex align-items-center text-decoration-none shadow-none">
                REGRESAR A CATÁLOGOS
            </a>
        </div>
    </div>

    <form asp-action="@(isEdit ? "EditTeacher" : "CreateTeacher")"
          asp-controller="Coordinador"
          method="post"
          class="needs-validation"
          novalidate>
        @Html.AntiForgeryToken()

        <input type="hidden" name="returnTab" value="@returnTab" />
        <input type="hidden" name="TeacherId" value="@Model?.TeacherId" />
        <input type="hidden" name="PersonId" value="@Model?.PersonId" />

        <div class="row g-4">
            <div class="col-lg-8 d-flex flex-column gap-4">

                <div class="admin-card-white p-4 p-md-5 rounded-4 border-0 shadow-sm bg-white">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Información de Identidad</h6>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="ModelOnly" class="bg-error-100 border-start border-4 text-danger text-xs fw-bold rounded-3 p-3 mb-4" style="border-left-color: var(--error-700) !important;"></div>
                    }

                    <div class="row g-4">
                        <div class="col-md-4">
                            <label asp-for="FirstName" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Nombre(s) <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="EJ. CARLOS" required />
                            <span asp-validation-for="FirstName" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="LastNamePaternal" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Apellido Paterno <span class="text-danger">*</span></label>
                            <input asp-for="LastNamePaternal" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="EJ. GARCÍA" required />
                            <span asp-validation-for="LastNamePaternal" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="LastNameMaternal" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Apellido Materno</label>
                            <input asp-for="LastNameMaternal" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="OPCIONAL" />
                            <span asp-validation-for="LastNameMaternal" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Correo Electrónico <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="CORREO@INSTITUCION.EDU.MX" required />
                            <span asp-validation-for="Email" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Teléfono</label>
                            <input asp-for="Phone" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="10 DÍGITOS" maxlength="30" />
                            <span asp-validation-for="Phone" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>
                    </div>
                </div>

                <div class="admin-card-white p-4 p-md-5 rounded-4 border-0 shadow-sm bg-white">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Estatus Laboral</h6>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="EmployeeNumber" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Número de Empleado</label>
                            <input asp-for="EmployeeNumber" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium text-uppercase shadow-none" placeholder="EJ. EMP-001" maxlength="30" />
                            <span asp-validation-for="EmployeeNumber" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StatusCode" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Estado Administrativo</label>
                            <select asp-for="StatusCode" class="form-select border-0 bg-app py-2 px-3 text-xs fw-bold txt-title shadow-none cursor-pointer">
                                <option value="ACTIVO">ACTIVO</option>
                                <option value="INACTIVO">INACTIVO</option>
                                <option value="LICENCIA">EN LICENCIA</option>
                            </select>
                            <span asp-validation-for="StatusCode" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="admin-card-white p-4 p-md-5 rounded-4 border-0 shadow-sm bg-white h-100 d-flex flex-column">
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-4 border-bottom border-light pb-2">Acceso al Sistema</h6>

                    @if (!isEdit)
                    {
                        <div class="bg-app rounded-3 p-3 mb-4 text-xxs fw-medium txt-body lh-base border-start border-4 border-primary">
                            Al asignar credenciales, el docente obtendrá acceso automático a los roles de <span class="fw-bold">Profesor/Asesor</span> y <span class="fw-bold">Supervisor</span>.
                        </div>

                        <div class="mb-4">
                            <label asp-for="Username" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Nombre de Usuario</label>
                            <input asp-for="Username" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="EJ. JGARCIAM" autocomplete="off" />
                            <span asp-validation-for="Username" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Password" class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">Contraseña Inicial</label>
                            <input asp-for="Password" type="password" class="form-control border-0 bg-app py-2 px-3 text-xs fw-medium shadow-none" placeholder="MÍN. 8 CARACTERES" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="text-danger text-xxs fw-bold mt-1 d-block"></span>
                        </div>
                    }
                    else
                    {
                        <div class="bg-app rounded-3 p-3 mb-4 text-xxs fw-medium text-muted lh-base">
                            Este formulario gestiona datos operativos. Para cambios de contraseña o permisos avanzados, diríjase al módulo de <span class="fw-bold">Gestión de Cuentas</span>.
                        </div>
                    }

                    <div class="mt-auto pt-4 border-top border-light d-flex flex-column gap-3">
                        <button type="submit" class="btn-primary-sep border-0 w-100 py-3 text-xxs fw-bold tracking-widest shadow-sm">
                            @(isEdit ? "GUARDAR CAMBIOS" : "REGISTRAR PROFESOR")
                        </button>
                        <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })"
                               class="btn-ghost-sep bg-app border-0 w-100 py-2 text-xxs fw-bold text-muted text-center text-decoration-none shadow-none">
                            CANCELAR
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        /* Glow institucional en foco */
        .form-control:focus, .form-select:focus {
            background-color: var(--white) !important;
            box-shadow: 0 0 0 4px var(--accent-100) !important;
            border: 1px solid var(--accent-500) !important;
        }
    </style>
}