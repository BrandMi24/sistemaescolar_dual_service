@model CycleViewModel
@{
    ViewData["Title"] = "Nuevo Ciclo";
    Layout = "_LayoutCoordinador";

    var isEdit = ViewBag.IsEdit as bool? ?? false;
}

<div class="fade-in d-flex flex-column gap-4">

    <!-- HEADER -->
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex justify-content-between align-items-center">
        <div>
            <h3 class="fw-bold mb-1">
                @(isEdit ? "Editar Ciclo" : "Registrar Nuevo Ciclo")
            </h3>
            <span>
                @(isEdit ? "Modifique la información del ciclo." : "Ingrese la información del ciclo escolar.")
            </span>
        </div>

        <a href="@Url.Action("Ciclos", "Coordinador")"
               class="btn btn-sm btn-ghost-sep border border-theme shadow-sm fw-semibold">
            Volver a Ciclos
        </a>
    </div>

    <!-- FORM -->
    <form asp-action="@(isEdit ? "EditCycle" : "CreateCycle")"
          asp-controller="Coordinador"
          method="post"
          class="needs-validation"
          novalidate>

        @Html.AntiForgeryToken()

        @if (isEdit)
        {
            <input type="hidden" name="Id" value="@Model?.Id" />
        }

        <!-- ERRORES -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <div class="row g-4">

            <!-- MAIN -->
            <div class="col-lg-8">

                <div class="p-4 border rounded shadow-sm bg-white">

                    <h5 class="mb-4">Datos del Ciclo</h5>

                    <div class="mb-3">
                        <label>Nombre</label>
                        <input name="Name"
                               class="form-control"
                               value="@Model?.Name" />
                    </div>

                    <div class="mb-3">
                        <label>Fecha Inicio</label>
                        <input name="StartDate"
                               type="date"
                               class="form-control"
                               value="@(Model != null ? Model.StartDate.ToString("yyyy-MM-dd") : "")" />
                    </div>

                    <div class="mb-3">
                        <label>Fecha Fin</label>
                        <input name="EndDate"
                               type="date"
                               class="form-control"
                               value="@(Model != null ? Model.EndDate.ToString("yyyy-MM-dd") : "")" />
                    </div>

                    <div class="mb-3">
                        <label>Estado</label>
                        <select name="StatusCode" class="form-select">
                            <option value="ACTIVO" selected="@(Model?.StatusCode == "ACTIVO")">Activo</option>
                            <option value="FINALIZADO" selected="@(Model?.StatusCode == "FINALIZADO")">Finalizado</option>
                            <option value="PROGRAMADO" selected="@(Model?.StatusCode == "PROGRAMADO")">Programado</option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-4">
                <div class="p-4 border rounded shadow-sm bg-white h-100 d-flex flex-column">

                    <div class="mt-auto">
                        <button type="submit" class="btn btn-primary w-100 mb-2">
                            @(isEdit ? "Guardar Cambios" : "Registrar Ciclo")
                        </button>

                        <a href="@Url.Action("Ciclos", "Coordinador")"
                               class="btn btn-secondary w-100">
                            Cancelar
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </form>
</div>