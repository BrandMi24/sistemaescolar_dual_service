@{
    ViewData["Title"] = "Nuevo Ciclo";
    Layout = "_LayoutCoordinador";
}

<div class="fade-in d-flex flex-column gap-4">

    <!-- HEADER -->
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h3 class="txt-title fw-bold mb-1">Registrar Nuevo Ciclo</h3>
            <div class="d-flex align-items-center gap-3 mt-2 txt-body text-xs">
                <span>Ingrese la información del ciclo escolar.</span>
            </div>
        </div>
        <div class="text-end">
            <a href="@Url.Action("Ciclos", "Coordinador")"
                   class="btn btn-sm btn-ghost-sep border border-theme shadow-sm fw-semibold">
                Volver a Ciclos
            </a>
        </div>
    </div>

    @{
        var isEdit = ViewBag.IsEdit as bool? ?? false;
    }

    <!-- FORM -->
    <form asp-action="@(isEdit ? "EditCycle" : "CreateCycle")"
          asp-controller="Coordinador"
          method="post"
          class="needs-validation">

        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert bg-error-100 border border-error border-opacity-25 txt-error rounded-3 mb-4 shadow-sm">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div class="text-sm fw-bold">@error.ErrorMessage</div>
                }
            </div>
        }

        <div class="row g-4">

            <!-- MAIN -->
            <div class="col-lg-8 d-flex flex-column gap-4">

                <div class="admin-card-white p-4 p-md-5 rounded-4 border-theme shadow-sm bg-white">
                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">
                        DATOS DEL CICLO
                    </h6>

                    <div class="row g-4">

                        <!-- NOMBRE -->
                        <div class="col-md-12">
                            <label class="txt-body text-xs fw-bold mb-2">
                                NOMBRE DEL CICLO <span class="text-danger">*</span>
                            </label>
                            <input name="Name"
                                   type="text"
                                   class="form-control search-input-custom ps-3"
                                   placeholder="Ej. Enero - Abril 2026"
                                   required
                                   value="@Model?.Name" />
                        </div>

                        <!-- FECHA INICIO -->
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold mb-2">
                                FECHA DE INICIO <span class="text-danger">*</span>
                            </label>
                            <input name="StartDate"
                                   type="date"
                                   class="form-control search-input-custom ps-3"
                                   required
                                   value="@(Model?.StartDate.ToString("yyyy-MM-dd"))" />
                        </div>

                        <!-- FECHA FIN -->
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold mb-2">
                                FECHA DE FIN <span class="text-danger">*</span>
                            </label>
                            <input name="EndDate"
                                   type="date"
                                   class="form-control search-input-custom ps-3"
                                   required
                                   value="@(Model?.EndDate.ToString("yyyy-MM-dd"))" />
                        </div>

                        <!-- ESTADO -->
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold mb-2">
                                ESTADO
                            </label>
                            <select name="StatusCode"
                                    class="form-select bg-app border-theme txt-title fw-semibold py-2">
                                <option value="ACTIVO" selected>Activo</option>
                                <option value="FINALIZADO">Finalizado</option>
                                <option value="PROGRAMADO">Programado</option>
                            </select>
                        </div>

                    </div>
                </div>
            </div>

            <!-- SIDEBAR -->
            <div class="col-lg-4">
                <div class="admin-card-white p-4 p-md-5 rounded-4 shadow-sm h-100 d-flex flex-column bg-white border-theme">

                    <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2">
                        ACCIONES
                    </h6>

                    <div class="mt-auto pt-4 border-top border-theme d-flex flex-column gap-3">

                        <button type="submit"
                                class="btn btn-primary-sep bg-primary-900 w-100 fw-bold py-3 shadow-sm text-white">
                            @(isEdit ? "Editar Ciclo" : "Registrar Ciclo")
                        </button>

                        <a href="@Url.Action("Ciclos", "Coordinador")"
                               class="btn btn-ghost-sep border border-theme w-100 py-2 shadow-sm text-body fw-semibold">
                            Cancelar
                        </a>

                    </div>
                </div>
            </div>

        </div>
    </form>
</div>