@{
    ViewData["Title"] = "Expediente del Estudiante";
    Layout = "_LayoutCoordinador";
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in">

    <div class="bg-white p-4 rounded-4 shadow-sm border-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 border-start border-4" style="border-left-color: var(--primary-900) !important;">
        <div class="d-flex align-items-center gap-4">
            <div class="bg-accent-light txt-primary-dark fw-bold rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 64px; height: 64px; font-size: 1.5rem; background-color: var(--accent-100) !important;">
                LG
            </div>
            <div>
                <h5 class="txt-title fw-bold mb-1 text-uppercase">Luis Ángel García</h5>
                <div class="d-flex flex-wrap align-items-center gap-3 text-xxs fw-bold text-muted tracking-wide text-uppercase">
                    <span><i class="bi bi-person-badge me-1"></i> MAT: 24001892</span>
                    <span><i class="bi bi-envelope me-1"></i> lgarcia@alumnos.uttn.mx</span>
                    <span><i class="bi bi-telephone me-1"></i> 899-123-4567</span>
                </div>
            </div>
        </div>
        <div class="text-end d-flex flex-column align-items-md-end gap-2">
            <span class="badge status-aceptado px-3 py-2 text-xxs fw-bold rounded-pill shadow-sm">ESTADO: INSCRITO</span>
            
            <a href="@Url.Action("Catalogos", "Coordinador", new { tab = "tab-alumnos" })" 
               class="btn-ghost-sep bg-app border-0 px-4 py-2 fw-bold text-xxs d-flex align-items-center text-decoration-none shadow-none mt-1">
                REGRESAR A LISTADO
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm h-100 bg-white">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-4 border-bottom border-light pb-2">Datos Generales</h6>
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="text-xxs fw-bold text-muted tracking-wide text-uppercase d-block mb-1">CURP</label>
                        <div class="txt-title text-xs fw-bold">GAML000101XYZ12345</div>
                    </div>
                    <div>
                        <label class="text-xxs fw-bold text-muted tracking-wide text-uppercase d-block mb-1">CARRERA</label>
                        <div class="txt-title text-xs fw-bold">INGENIERÍA MECATRÓNICA</div>
                    </div>
                    <div>
                        <label class="text-xxs fw-bold text-muted tracking-wide text-uppercase d-block mb-1">FECHA DE REGISTRO</label>
                        <div class="txt-title text-xs fw-bold">15 DE AGOSTO, 2024</div>
                    </div>
                    <div class="pt-2">
                        <span class="badge bg-app txt-primary-dark text-xxs px-3 py-1 fw-bold rounded-pill border border-light">CUENTA ACTIVA</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm h-100 bg-white">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-4 border-bottom border-light pb-2">Horas Acreditadas</h6>
                <div class="row g-0 h-75 align-items-center text-center">
                    <div class="col-6 border-end border-light">
                        <div class="display-6 fw-bold txt-primary-dark mb-1" style="color: var(--primary-900) !important;">320</div>
                        <div class="text-xxs fw-bold text-muted tracking-widest text-uppercase">APROBADAS</div>
                    </div>
                    <div class="col-6">
                        <div class="display-6 fw-bold text-muted mb-1 opacity-50">160</div>
                        <div class="text-xxs fw-bold text-muted tracking-widest text-uppercase">PENDIENTES</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm h-100 bg-white">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-4 border-bottom border-light pb-2">Resumen de Actividad</h6>
                <div class="row g-2 h-75 align-items-center text-center">
                    <div class="col-4">
                        <div class="fs-4 fw-bold txt-title mb-0">2</div>
                        <div class="text-xxs fw-bold text-muted text-uppercase tracking-tighter">TRÁMITES</div>
                    </div>
                    <div class="col-4">
                        <div class="fs-4 fw-bold txt-title mb-0">5</div>
                        <div class="text-xxs fw-bold text-muted text-uppercase tracking-tighter">DOCUMENTOS</div>
                    </div>
                    <div class="col-4">
                        <div class="fs-4 fw-bold txt-title mb-0">3</div>
                        <div class="text-xxs fw-bold text-muted text-uppercase tracking-tighter">EVALUACIONES</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden bg-white mt-2">
        <div class="bg-white p-4 border-bottom border-light">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Historial de Inscripciones</h6>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-app border-0">
                    <tr>
                        <th class="py-3 px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider">Programa / Entidad</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Tipo</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Supervisor</th>
                        <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider">Estado</th>
                        <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider">Avance Horas</th>
                        <th class="py-3 text-end px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-bottom border-light hover-bg-app transition-all">
                        <td class="px-4 py-3">
                            <div class="txt-title fw-bold text-xs text-uppercase mb-0">Corning Optical Comm.</div>
                            <div class="text-xxs text-muted fw-medium">PERIODO: ENE-ABR 2026</div>
                        </td>
                        <td><span class="badge bg-app text-dark border border-light text-xxs px-3 py-1 fw-bold rounded-pill">ESTADÍAS</span></td>
                        <td class="text-xs fw-bold text-muted">ING. JUAN PÉREZ</td>
                        <td class="text-center">
                            <span class="badge status-pendiente text-xxs px-3 py-1 fw-bold rounded-pill shadow-none">EN PROGRESO</span>
                        </td>
                        <td class="text-center">
                            <div class="txt-title fw-bold text-xs mb-1">320 / 600</div>
                            <div class="progress" style="height: 4px; width: 80px; margin: 0 auto; background-color: var(--bg-main);">
                                <div class="progress-bar" style="width: 53%; background-color: var(--primary-900) !important;"></div>
                            </div>
                        </td>
                        <td class="text-end px-4">
                            <button type="button" class="btn btn-sm border-0 bg-app txt-primary-dark rounded-2 py-1 px-2" title="Ver Detalle">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden h-100 bg-white">
                <div class="bg-white p-4 border-bottom border-light d-flex justify-content-between align-items-center">
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Documentación Técnica</h6>
                    <span class="badge bg-primary-dark text-white rounded-pill text-xxs px-2" style="background-color: var(--primary-900) !important;">2 ARCHIVOS</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-app border-0">
                            <tr>
                                <th class="py-2 px-4 text-xxs fw-bold text-uppercase tracking-wider">Título del Documento</th>
                                <th class="py-2 text-center text-xxs fw-bold text-uppercase tracking-wider">Estado</th>
                                <th class="py-2 text-end px-4 text-xxs fw-bold text-uppercase tracking-wider">Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-bottom border-light">
                                <td class="px-4 py-3 fw-bold text-xs text-muted text-uppercase">Carta de Aceptación</td>
                                <td class="text-center">
                                    <span class="badge status-aceptado text-xxs px-2 py-1 fw-bold">APROBADO</span>
                                </td>
                                <td class="text-end px-4 text-xxs fw-medium text-muted">15/01/26</td>
                            </tr>
                            <tr class="border-bottom border-light">
                                <td class="px-4 py-3 fw-bold text-xs text-muted text-uppercase">Reporte Mensual 1</td>
                                <td class="text-center">
                                    <span class="badge status-pendiente text-xxs px-2 py-1 fw-bold">PENDIENTE</span>
                                </td>
                                <td class="text-end px-4 text-xxs fw-medium text-muted">15/02/26</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden h-100 bg-white">
                <div class="bg-white p-4 border-bottom border-light d-flex justify-content-between align-items-center">
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Evaluaciones Parciales</h6>
                    <span class="badge bg-primary-dark text-white rounded-pill text-xxs px-2" style="background-color: var(--primary-900) !important;">1 REGISTRO</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-app border-0">
                            <tr>
                                <th class="py-2 px-4 text-xxs fw-bold text-uppercase tracking-wider">Parcial</th>
                                <th class="py-2 text-center text-xxs fw-bold text-uppercase tracking-wider">Puntaje</th>
                                <th class="py-2 text-end px-4 text-xxs fw-bold text-uppercase tracking-wider">Cierre</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-bottom border-light">
                                <td class="px-4 py-3 fw-bold text-xs text-muted text-uppercase">Primer Parcial</td>
                                <td class="text-center txt-title fw-bold text-sm">9.5 <small class="text-muted fw-normal">/ 10</small></td>
                                <td class="text-end px-4 text-xxs fw-medium text-muted">10/02/26</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Forzar visibilidad de estados si el CSS externo falla */
    .status-aceptado { background-color: var(--success-100) !important; color: var(--success-700) !important; }
    .status-rechazado { background-color: var(--error-100) !important; color: var(--error-700) !important; }
    .status-pendiente { background-color: var(--warning-100) !important; color: var(--warning-700) !important; }
    
    .display-6 { font-size: 2.5rem; letter-spacing: -1.5px; }
    .transition-all { transition: all 0.2s ease; }
    .hover-bg-app:hover { background-color: var(--bg-main) !important; }
</style>