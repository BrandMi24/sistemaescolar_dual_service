@model ControlEscolar.Models.CoordinadorStudentDetailViewModel
@{
    ViewData["Title"] = "Expediente del Estudiante";
    Layout = "_LayoutCoordinador";

    var statusBadgeClass = Model.IsActive ? "status-aceptado" : "status-rechazado";
    var moduleScopeLabel = ViewBag.ModuleScopeLabel as string ?? "Todos los módulos";
    string ModuleLabel(string programType) => programType == "SERVICIO_SOCIAL" ? "Servicio Social" : "Módulo Dual";
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in">

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h3 class="txt-title fw-bold mb-1">@Model.FullName</h3>
            <div class="d-flex align-items-center gap-3 mt-2 txt-body text-xs">
                <span><i class="bi bi-hash me-1 text-primary"></i>@Model.Matricula</span>
                <span><i class="bi bi-envelope me-1 text-primary"></i>@Model.Email</span>
                <span><i class="bi bi-telephone me-1 text-primary"></i>@Model.Phone</span>
            </div>
            <div class="mt-3">
                <span class="badge bg-app border border-theme text-dark px-2 py-1">Alcance visible: @moduleScopeLabel</span>
            </div>
        </div>
        <div class="text-end d-flex flex-column align-items-md-end gap-2">
            <span class="badge @statusBadgeClass px-3 py-2 text-sm shadow-sm rounded-pill">ESTADO: @Model.StatusCode</span>
            <a href="@Url.Action("Catalogos", "Coordinador")" class="btn btn-sm btn-ghost-sep border border-theme shadow-sm mt-1">
                <i class="bi bi-arrow-left me-1"></i> Volver a Catálogos
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-0 shadow-sm h-100 bg-white">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-4 border-bottom border-light pb-2">Datos Generales</h6>
                <div class="d-flex flex-column gap-3">
                    <div>
                        <div class="txt-body text-xs fw-bold tracking-wide mb-1">CURP</div>
                        <div class="txt-title text-sm text-uppercase">@Model.Curp</div>
                    </div>
                    <div>
                        <div class="txt-body text-xs fw-bold tracking-wide mb-1">CARRERA</div>
                        <div class="txt-title text-sm fw-semibold">@Model.CareerName</div>
                    </div>
                    <div>
                        <div class="txt-body text-xs fw-bold tracking-wide mb-1">GRUPO</div>
                        <div class="txt-title text-sm">@Model.GroupName</div>
                    </div>
                    <div class="mt-auto pt-3 border-top border-theme">
                        <span class="badge bg-app border border-theme text-dark px-2 py-1">@(Model.IsActive ? "Cuenta Activa" : "Cuenta Inactiva")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column text-center justify-content-center bg-white">
                <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2 text-start">
                    <i class="bi bi-clock-history me-2 text-primary"></i>Horas Acreditadas
                </h6>
                <div class="row g-0 flex-grow-1 align-items-center">
                    <div class="col-6 border-end border-theme">
                        <div class="fs-1 fw-bold txt-primary-dark">@Model.ApprovedHours</div>
                        <div class="txt-body text-xs fw-bold tracking-wide">APROBADAS</div>
                    </div>
                    <div class="col-6">
                        <div class="fs-1 fw-bold text-muted">@Model.PendingHours</div>
                        <div class="txt-body text-xs fw-bold tracking-wide">PENDIENTES</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column text-center justify-content-center bg-white">
                <h6 class="txt-title fw-bold mb-4 border-bottom border-theme pb-2 text-start">
                    <i class="bi bi-kanban me-2 text-primary"></i>Métricas del Alumno
                </h6>
                <div class="row g-0 flex-grow-1 align-items-center">
                    <div class="col-4 border-end border-theme">
                        <div class="fs-2 fw-bold text-dark">@Model.Assignments.Count</div>
                        <div class="txt-body text-xxs tracking-wide fw-bold">INSCRIPCIONES</div>
                    </div>
                    <div class="col-4 border-end border-theme">
                        <div class="fs-2 fw-bold text-dark">@Model.DocumentsCount</div>
                        <div class="txt-body text-xxs tracking-wide fw-bold">DOCS.</div>
                    </div>
                    <div class="col-4">
                        <div class="fs-2 fw-bold text-dark">@Model.EvaluationsCount</div>
                        <div class="txt-body text-xxs tracking-wide fw-bold">EVALS.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden bg-white mt-2">
        <div class="bg-white p-4 border-bottom border-light">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-widest mb-0">Historial de Inscripciones</h6>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="bg-app border-0">
                    <tr>
                        <th class="py-3 px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider">Programa / Entidad</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Tipo</th>
                        <th class="py-3 border-0 text-xxs fw-bold text-uppercase tracking-wider">Supervisor</th>
                        <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider">Estado</th>
                        <th class="py-3 text-center border-0 text-xxs fw-bold text-uppercase tracking-wider">Avance Horas</th>
                        <th class="py-3 text-end px-4 border-0 text-xxs fw-bold text-uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Assignments.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 txt-body">No hay historial de inscripciones para este alumno.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.Assignments)
                        {
                            var itemBadgeClass = item.StatusCode == "COMPLETED" ? "status-aceptado" : "bg-warning text-dark";
                            <tr class="border-bottom border-theme">
                                <td class="px-4 py-3 txt-title fw-bold text-sm">@item.ProgramName</td>
                                <td><span class="badge bg-app border border-theme text-dark text-xxs px-2 py-1">@ModuleLabel(item.ProgramType)</span></td>
                                <td class="txt-body text-xs">@item.TeacherName</td>
                                <td class="text-center">
                                    <span class="badge @itemBadgeClass text-xxs px-2 py-1 shadow-sm">@item.StatusCode</span>
                                </td>
                                <td class="text-center txt-title fw-bold text-xs">@item.ApprovedHours / @item.RequiredHours</td>
                                <td class="txt-body text-xs">@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center px-4">
                                    <a href="@Url.Action("SeguimientoAlumno", "Coordinador", new { studentId = Model.StudentId, assignmentId = item.AssignmentId })" class="btn btn-sm btn-ghost-sep px-2 py-1">
                                        <i class="bi bi-journal-text me-1"></i> Ver seguimiento
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-6">
            <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden h-100 bg-white">
                <div class="bg-surface p-3 border-bottom border-theme d-flex justify-content-between align-items-center">
                    <h6 class="txt-title fw-bold mb-0"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Documentos Subidos</h6>
                    <span class="badge bg-primary-900 text-white rounded-pill">@Model.DocumentsCount</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-app border-0">
                            <tr>
                                <th class="py-2 px-3">Título</th>
                                <th class="py-2">Programa</th>
                                <th class="py-2">Tipo</th>
                                <th class="py-2 text-center">Estado</th>
                                <th class="py-2">Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Documents.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 txt-body">No hay documentos registrados.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.Documents)
                                {
                                    var docBadgeClass = item.StatusCode == "APPROVED" ? "status-aceptado" : item.StatusCode == "REJECTED" ? "status-rechazado" : "bg-warning text-dark";
                                    <tr class="border-bottom border-theme">
                                        <td class="px-3">
                                            <div class="fw-semibold txt-title text-xs">@item.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(item.OriginalFileName))
                                            {
                                                <div class="txt-body text-xxs">Archivo: @item.OriginalFileName</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                                            {
                                                <div class="txt-body text-xxs mt-1">Alumno: @item.Notes</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(item.ReviewComments))
                                            {
                                                <div class="txt-body text-xxs mt-1">Revisión: @item.ReviewComments</div>
                                            }
                                        </td>
                                        <td>
                                            <div class="txt-title text-xs fw-semibold">@item.ProgramName</div>
                                            <div class="txt-body text-xxs">@ModuleLabel(item.ProgramType)</div>
                                        </td>
                                        <td><span class="badge bg-app border border-theme text-dark text-xxs">@item.DocumentType</span></td>
                                        <td class="text-center"><span class="badge @docBadgeClass text-xxs px-2 py-1 shadow-sm">@item.StatusCode</span></td>
                                        <td class="txt-body text-xs">
                                            <div>@item.UploadDate.ToString("dd/MM/yy")</div>
                                            @if (item.ReviewDate.HasValue)
                                            {
                                                <div class="text-xxs">Rev: @item.ReviewDate.Value.ToString("dd/MM/yy")</div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-xl-6">
            <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden h-100 bg-white">
                <div class="bg-surface p-3 border-bottom border-theme d-flex justify-content-between align-items-center">
                    <h6 class="txt-title fw-bold mb-0"><i class="bi bi-star me-2 text-primary"></i>Calificaciones</h6>
                    <span class="badge bg-primary-900 text-white rounded-pill">@Model.EvaluationsCount</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-app border-0">
                            <tr>
                                <th class="py-2 px-4 text-xxs fw-bold text-uppercase tracking-wider">Parcial</th>
                                <th class="py-2 text-center text-xxs fw-bold text-uppercase tracking-wider">Puntaje</th>
                                <th class="py-2 text-end px-4 text-xxs fw-bold text-uppercase tracking-wider">Cierre</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.EvaluationsCount == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 txt-body">No hay evaluaciones registradas.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model.Assignments.Where(x => x.EvaluationScore.HasValue).Take(10))
                                {
                                    <tr class="border-bottom border-theme">
                                        <td class="px-3"><span class="badge bg-app border border-theme text-dark text-xxs">EVALUACIÓN</span></td>
                                        <td class="txt-body text-xs fw-bold">@ModuleLabel(item.ProgramType)</td>
                                        <td class="text-center txt-title fw-bold">@item.EvaluationScore <span class="text-muted fw-normal text-xs">/ 10</span></td>
                                        <td class="txt-body text-xs">@item.CreatedDate.ToString("dd/MM/yy")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Forzar visibilidad de estados si el CSS externo falla */
    .status-aceptado { background-color: var(--success-100) !important; color: var(--success-700) !important; }
    .status-rechazado { background-color: var(--error-100) !important; color: var(--error-700) !important; }
    .status-pendiente { background-color: var(--warning-100) !important; color: var(--warning-700) !important; }
    
    .display-6 { font-size: 2.5rem; letter-spacing: -1.5px; }
    .transition-all { transition: all 0.2s ease; }
    .hover-bg-app:hover { background-color: var(--bg-main) !important; }
</style>