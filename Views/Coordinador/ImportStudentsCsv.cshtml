@model ControlEscolar.Models.ImportStudentsCsvViewModel

@{
    ViewData["Title"] = "Importación Masiva de Alumnos";
    Layout = "_LayoutCoordinador";
    var returnTab = ViewBag.ReturnTab as string ?? Model.ReturnTab ?? "tab-alumnos";
}

<div class="d-flex flex-column gap-4 fade-in">
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm">
        <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
            <div style="max-width:800px;">
                <h4 class="txt-title fw-bold mb-1">Carga masiva de alumnos por CSV</h4>
                <p class="txt-body text-xs mb-0">
                    Importa alumnos en lote usando un archivo CSV. El sistema validará carrera, grupo, CURP y estatus antes de insertar cada registro.
                </p>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a href="@Url.Action("Catalogos", "Coordinador", new { tab = returnTab })"
                   class="btn btn-outline-secondary rounded-3 px-4">
                    Volver
                </a>
            </div>
        </div>
    </div>

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm">
        <div class="row g-4">
            <div class="col-lg-7">
                <h5 class="txt-title fw-bold mb-3">Subir archivo</h5>

                <form asp-action="ImportStudentsCsv"
                      asp-controller="Coordinador"
                      method="post"
                      enctype="multipart/form-data"
                      class="d-flex flex-column gap-3">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="returnTab" value="@returnTab" />
                    <input asp-for="ReturnTab" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-0"></div>

                    <div>
                        <label asp-for="CsvFile" class="form-label fw-semibold txt-title">Archivo CSV</label>
                        <input asp-for="CsvFile"
                               type="file"
                               accept=".csv,text/csv"
                               class="form-control rounded-3" />
                        <span asp-validation-for="CsvFile" class="text-danger small"></span>
                        <div class="form-text">
                            Solo se aceptan archivos .csv
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 pt-2">
                        <button type="submit" class="btn btn-primary-sep bg-primary-900 shadow-sm px-4">
                            Importar alumnos
                        </button>

                        <button type="button" class="btn btn-outline-secondary px-4" onclick="downloadTemplate()">
                            Descargar plantilla
                        </button>
                    </div>
                </form>
            </div>

            <div class="col-lg-5">
                <div class="border-theme rounded-4 p-3 bg-app h-100">
                    <h6 class="fw-bold txt-title mb-3">Estructura requerida del CSV</h6>

                    <div class="small txt-body">
                        <p class="mb-2 fw-semibold">Encabezados esperados:</p>
                        <code class="d-block p-3 rounded-3 bg-light border" style="white-space: pre-wrap;">
                            FirstName,LastNamePaternal,LastNameMaternal,Email,Phone,CURP,CareerId,GroupId,StatusCode
                        </code>

                        <p class="mt-3 mb-2 fw-semibold">Ejemplo:</p>
                        <code class="d-block p-3 rounded-3 bg-light border" style="white-space: pre-wrap;">
                            Juan,Perez,Lopez,juan@correo.com,8991234567,PELJ010101HTSRPN01,1,2,INSCRITO
                            Maria,Gomez,Ruiz,maria@correo.com,8995556677,GORM020202MTSMRA02,1,,PREINSCRITO
                        </code>

                        <ul class="mt-3 mb-0 ps-3">
                            <li><strong>FirstName</strong>, <strong>LastNamePaternal</strong> y <strong>CareerId</strong> son obligatorios.</li>
                            <li><strong>StatusCode</strong> solo admite <strong>INSCRITO</strong> o <strong>PREINSCRITO</strong>.</li>
                            <li><strong>GroupId</strong> puede ir vacío.</li>
                            <li>Si la <strong>CURP</strong> ya existe, esa fila se marcará con error.</li>
                            <li>La carrera y el grupo deben existir y estar activos.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalRows > 0)
    {
        <div class="bg-surface p-4 rounded-4 border-theme shadow-sm">
            <h5 class="txt-title fw-bold mb-3">Resumen de importación</h5>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="border-theme rounded-4 p-3 bg-app h-100">
                        <div class="text-xs txt-body mb-1">Total procesadas</div>
                        <div class="fs-4 fw-bold txt-title">@Model.TotalRows</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border-theme rounded-4 p-3 bg-app h-100">
                        <div class="text-xs txt-body mb-1">Correctas</div>
                        <div class="fs-4 fw-bold text-success">@Model.SuccessCount</div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border-theme rounded-4 p-3 bg-app h-100">
                        <div class="text-xs txt-body mb-1">Con error</div>
                        <div class="fs-4 fw-bold text-danger">@Model.ErrorCount</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden d-flex flex-column">
            <div class="table-responsive bg-surface">
                <table class="table table-borderless align-middle mb-0 w-100" style="min-width:1100px;">
                    <thead class="admin-table-header border-bottom border-theme">
                        <tr>
                            <th class="py-3 px-4">Fila</th>
                            <th class="py-3 text-center">Resultado</th>
                            <th class="py-3">Mensaje</th>
                            <th class="py-3">PersonID</th>
                            <th class="py-3">StudentID</th>
                            <th class="py-3">Matrícula</th>
                            <th class="py-3 px-4">Folio</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Results.OrderBy(x => x.RowNumber))
                        {
                            <tr class="border-bottom border-theme">
                                <td class="px-4 fw-semibold">@item.RowNumber</td>
                                <td class="text-center">
                                    @if (item.IsSuccess)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                            Correcto
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                            Error
                                        </span>
                                    }
                                </td>
                                <td>@item.Message</td>
                                <td>@(item.PersonId?.ToString() ?? "-")</td>
                                <td>@(item.StudentId?.ToString() ?? "-")</td>
                                <td>@(!string.IsNullOrWhiteSpace(item.Matricula) ? item.Matricula : "-")</td>
                                <td class="px-4">@(!string.IsNullOrWhiteSpace(item.Folio) ? item.Folio : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
                function downloadTemplate() {
                    const csvContent =
        `FirstName,LastNamePaternal,LastNameMaternal,Email,Phone,CURP,CareerId,GroupId,StatusCode
        Juan,Perez,Lopez,juan@correo.com,8991234567,PCMJ010101HTSRPN01,3,2,INSCRITO
        Maria,Gomez,Ruiz,maria@correo.com,8995556677,GCRM020202MTSMRA02,3,,PREINSCRITO`;

                    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
                    const url = URL.createObjectURL(blob);
                    const link = document.createElement('a');

                    link.setAttribute('href', url);
                    link.setAttribute('download', 'plantilla_importacion_alumnos.csv');
                    link.style.visibility = 'hidden';

                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                }
    </script>
}