@model List<ControlEscolar.ViewModels.OperationalTracking.CoordinatorAssignmentRowViewModel>
@{
    ViewData["Title"] = "Gestión de Asignaciones";
    Layout = "_LayoutCoordinador";
    var search = ViewBag.Search as string ?? string.Empty;
    var selectedStatus = ViewBag.Status as string ?? string.Empty;
    int? selectedTeacher = ViewBag.Teacher as int?;
    var createdFrom = ViewBag.CreatedFrom as string ?? string.Empty;
    var createdTo = ViewBag.CreatedTo as string ?? string.Empty;
    var selectedModule = ViewBag.Module as string ?? string.Empty;
    int? selectedCuatrimestre = ViewBag.Cuatrimestre as int?;
    int? selectedModuleNumber = ViewBag.ModuleNumber as int?;
    var canDualModule = (bool)(ViewBag.CanDualModule ?? true);
    var canServiceModule = (bool)(ViewBag.CanServiceModule ?? true);
    var sort = ViewBag.Sort as string ?? "created";
    var order = ViewBag.Order as string ?? "desc";
    var currentPage = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 10);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalItems = (int)(ViewBag.TotalItems ?? Model.Count);
    var prevPage = currentPage > 1 ? currentPage - 1 : 1;
    var nextPage = currentPage < totalPages ? currentPage + 1 : totalPages;
    string ToggleOrder(string key) => sort == key && order == "asc" ? "desc" : "asc";
    var teachers = ViewBag.Teachers as IEnumerable<dynamic>;
}

<div class="container-fluid d-flex flex-column gap-4 p-0 fade-in" style="height: 82vh;">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success-100 border-start border-4 border-success text-success-700 rounded-3 alert-dismissible fade show shadow-sm flex-shrink-0">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-error-100 border-start border-4 border-error txt-error rounded-3 alert-dismissible fade show shadow-sm flex-shrink-0" style="border-left-color: var(--error-700) !important;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <form method="get" class="d-flex flex-column flex-md-row gap-3 flex-grow-1 w-100" style="max-width: 1000px;">
            <input type="hidden" name="sort" value="@sort" />
            <input type="hidden" name="order" value="@order" />
            <input type="hidden" name="page" value="1" />
            <input type="hidden" name="pageSize" value="@pageSize" />
            
            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                <input type="text" id="searchInput" class="form-control border-0 bg-app py-2 ps-5 text-xs fw-medium shadow-none" placeholder="Buscar por alumno o matrícula..." value="@search">
            </div>
            
            <select name="status" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 160px;">
                <option value="">Estado</option>
                <option value="ASSIGNED" selected="@(selectedStatus == "ASSIGNED")">Asignado</option>
                <option value="IN_PROGRESS" selected="@(selectedStatus == "IN_PROGRESS")">En Progreso</option>
                <option value="COMPLETED" selected="@(selectedStatus == "COMPLETED")">Completado</option>
                <option value="FINALIZED" selected="@(selectedStatus == "FINALIZED")">Finalizado</option>
                <option value="RELEASED" selected="@(selectedStatus == "RELEASED")">Liberado</option>
            </select>
            
            <select name="teacher" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 200px;">
                <option value="">Todos los Profesores</option>
                @if (teachers != null)
                {
                    foreach (var t in teachers)
                    {
                        <option value="@t.Id" selected="@(selectedTeacher != null && selectedTeacher == (int)t.Id)">@t.Name</option>
                    }
                }
            </select>

            <input type="date" name="createdFrom" class="form-control bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 170px;" value="@createdFrom" title="Desde" />
            <input type="date" name="createdTo" class="form-control bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 170px;" value="@createdTo" title="Hasta" />

            <select name="module" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 210px;">
                <option value="">Todos los módulos</option>
                @if (canDualModule)
                {
                    <option value="PRACTICAS_PROFESIONALES" selected="@(selectedModule == "PRACTICAS_PROFESIONALES")">Coordinador módulo dual</option>
                }
                @if (canServiceModule)
                {
                    <option value="SERVICIO_SOCIAL" selected="@(selectedModule == "SERVICIO_SOCIAL")">Coordinador servicio social</option>
                }
            </select>

            <select name="cuatrimestre" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 170px;">
                <option value="">Todos los cuatrimestres</option>
                @for (var q = 1; q <= 11; q++)
                {
                    <option value="@q" selected="@(selectedCuatrimestre == q)">@q Cuatrimestre</option>
                }
            </select>

            <select name="moduleNumber" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 150px;">
                <option value="">Módulo (1-5)</option>
                @for (var m = 1; m <= 5; m++)
                {
                    <option value="@m" selected="@(selectedModuleNumber == m)">Módulo @m</option>
                }
            </select>

            <div class="d-flex gap-2 flex-shrink-0">
                <button type="button" id="btnLimpiar" class="btn-ghost-sep bg-app border-0 shadow-none px-4 py-2 text-xxs fw-bold d-flex align-items-center gap-2">
                    LIMPIAR
                </button>
            </div>
        </form>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-0 shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
        
        <div class="table-responsive bg-white flex-grow-1 custom-scroll" style="min-height: 250px;">
            <table class="table align-middle mb-0 w-100" style="min-width: 1100px;">
                <thead class="bg-app border-0 sticky-top" style="z-index: 5;">
                    <tr>
                        <th class="py-3 px-4" width="25%">
                            <a class="text-reset text-decoration-none" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort = "student", order = ToggleOrder("student"), page = 1, pageSize })">Estudiante</a>
                        </th>
                        <th class="py-3" width="20%">
                            <a class="text-reset text-decoration-none" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort = "program", order = ToggleOrder("program"), page = 1, pageSize })">Programa / Org.</a>
                        </th>
                        <th class="py-3" width="20%">Supervisor</th>
                        <th class="py-3 text-center" width="10%">
                            <a class="text-reset text-decoration-none" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort = "status", order = ToggleOrder("status"), page = 1, pageSize })">Estado</a>
                        </th>
                        <th class="py-3 text-center" width="15%">
                            <a class="text-reset text-decoration-none" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort = "hours", order = ToggleOrder("hours"), page = 1, pageSize })">Horas</a>
                        </th>
                        <th class="py-3 text-end px-4" width="10%">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 txt-body">No hay asignaciones con los filtros seleccionados.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var row in Model)
                        {
                            var initials = string.Join("", row.StudentName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(s => s[0])).ToUpper();
                            <tr class="border-bottom border-theme hover-bg-app data-row">
                                <td class="px-4 py-3 search-target">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-md avatar-sm bg-accent-light txt-primary-dark fw-bold flex-shrink-0">@initials</div>
                                        <div>
                                            <div class="txt-title fw-bold text-sm mb-1">@row.StudentName</div>
                                            <div class="txt-body text-xs">Mat: @(row.Matricula ?? "N/A")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="txt-title fw-bold text-sm mb-1">@row.ProgramName</div>
                                    <div class="d-flex flex-wrap gap-1">
                                        <span class="badge bg-app border border-theme txt-title text-xxs px-2 py-1">@row.OrganizationName</span>
                                        <span class="badge border border-theme text-xxs px-2 py-1">@(row.ProgramType == "SERVICIO_SOCIAL" ? "Servicio Social" : "Módulo Dual")</span>
                                        <span class="badge border border-theme text-xxs px-2 py-1">Módulo @row.ModuleNumber</span>
                                        @if (row.Cuatrimestre.HasValue)
                                        {
                                            <span class="badge border border-theme text-xxs px-2 py-1">@row.Cuatrimestre°</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (row.TeacherId.HasValue)
                                    {
                                        <div class="txt-title fw-bold text-sm">@row.TeacherName</div>
                                        <div class="txt-body text-xs">Asignado</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-error-100 txt-error border border-error border-opacity-25 text-xxs px-2 py-1">SIN ASIGNAR</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-app txt-body border border-theme text-xxs px-2 py-1 shadow-sm">@row.StatusCode</span>
                                </td>
                                <td class="text-center">
                                    <div class="txt-title fw-bold text-sm mb-1">@row.ApprovedHours / @row.RequiredHours hrs</div>
                                    <div class="progress" style="height: 6px; width: 100px; margin: 0 auto; background-color: var(--bg-main);">
                                        <div class="progress-bar bg-primary-900" style="width: @row.ProgressPercent%"></div>
                                    </div>
                                </td>
                                <td class="text-end px-4">
                                    <button class="btn btn-sm btn-ghost-sep px-2 py-1 text-primary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalReasignar"
                                            data-enrollment-id="@row.AssignmentId">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-xl-row justify-content-between align-items-center gap-3 flex-shrink-0">
            <div class="d-flex align-items-center gap-3">
                <span class="txt-body text-xs fw-bold">Mostrar:</span>
                <select id="rowsPerPage" class="form-select form-select-sm bg-app border-theme txt-title fw-bold rows-per-page" style="width: 70px; cursor: pointer;">
                    <option value="5" selected="@(pageSize == 5)">5</option>
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                </select>
                <div class="txt-body text-xs fw-bold tracking-wide table-info">Página @currentPage de @totalPages • Total @totalItems registro(s).</div>
            </div>
            <nav aria-label="Navegación de tabla">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link page-link-custom" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort, order, page = prevPage, pageSize })"><i class="bi bi-chevron-left"></i></a>
                    </li>

                    @{
                        var startPage = Math.Max(1, currentPage - 2);
                        var endPage = Math.Min(totalPages, startPage + 4);
                        if (endPage - startPage < 4)
                        {
                            startPage = Math.Max(1, endPage - 4);
                        }
                    }

                    @for (var p = startPage; p <= endPage; p++)
                    {
                        <li class="page-item @(p == currentPage ? "active" : "")">
                            <a class="page-link page-link-custom" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort, order, page = p, pageSize })">@p</a>
                        </li>
                    }

                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link page-link-custom" href="@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort, order, page = nextPage, pageSize })"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<div class="modal fade" id="modalReasignar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden bg-white">
            <form action="@Url.Action("ReassignSupervisor", "Coordinador")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="enrollmentId" id="inputEnrollmentId" value="0" />
                
                <div class="modal-header border-bottom border-light p-4 bg-app">
                    <h6 class="modal-title txt-title fw-bold text-uppercase tracking-widest text-xs">
                        ASIGNAR SUPERVISOR
                    </h6>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                
                <div class="modal-body p-4">
                    <p class="text-muted text-xs fw-medium mb-4">Seleccione al docente que será responsable del seguimiento del estudiante.</p>
                    
                    <div class="mb-3">
                        <label class="txt-body text-xxs fw-bold tracking-wide mb-2 d-block text-uppercase">DOCENTE DISPONIBLE</label>
                        <select name="newTeacherId" class="form-select border-0 bg-app py-2 text-xs fw-bold txt-title shadow-none cursor-pointer" required>
                            <option value="">-- Seleccionar Docente --</option>
                            @if (teachers != null)
                            {
                                foreach (var t in teachers)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div class="modal-footer border-top border-light p-3">
                    <button type="button" class="btn-ghost-sep bg-app border-0 text-xxs fw-bold px-4" data-bs-dismiss="modal">CANCELAR</button>
                    <button type="submit" class="btn-primary-sep border-0 px-4 text-xxs fw-bold tracking-widest shadow-sm">GUARDAR ASIGNACIÓN</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Animación para desaparecer alertas
            setTimeout(function () {
                $('.alert-dismissible').fadeOut('slow', function() {
                    $(this).remove();
                });
            }, 4000);

            // Modal ID handling
            $('#modalReasignar').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var id = button.data('enrollment-id');
                $(this).find('#inputEnrollmentId').val(id || 0);
            });

            $('#rowsPerPage').on('change', function () {
                const size = $(this).val();
                const url = '@Url.Action("SeguimientoDualEstadias", new { search, status = selectedStatus, teacher = selectedTeacher, createdFrom, createdTo, module = selectedModule, cuatrimestre = selectedCuatrimestre, moduleNumber = selectedModuleNumber, sort, order, page = 1, pageSize = "__SIZE__" })';
                window.location.href = url.replace('__SIZE__', size);
            });

            // ==========================================
            // LÓGICA DE TABLA DINÁMICA
            // ==========================================
            // ==========================================
        // LÓGICA DE TABLA DINÁMICA DE ASIGNACIONES
        // ==========================================
        let allData = [];
        let currentPage = 1;

        function loadData() {
            // Datos simulados. (Reemplazar por tu $.get real)
            allData = [
                {
                    id: 1, matricula: '24001504', nombre: 'Roberto Carlos Perez Cadena', iniciales: 'RC',
                    programa: 'Estadías Profesionales', org: 'CORNING OPTICAL',
                    supervisor: 'Ing. Juan Pérez Martínez', estadoSupervisor: 'Asignado',
                    estado: 'EN PROGRESO', horasHechas: 320, horasTotal: 600, progreso: 53
                },
                {
                    id: 2, matricula: '24001892', nombre: 'Luis Ángel García', iniciales: 'LA',
                    programa: 'Educación Dual', org: 'NIDEC MOTORS',
                    supervisor: 'Sin Supervisor', estadoSupervisor: 'Pendiente',
                    estado: 'SIN ASIGNAR', horasHechas: 0, horasTotal: 480, progreso: 0
                }
            ];
            updateTable();
        }

        function renderRows(data) {
            let html = '';
            if (data.length === 0) {
                html = `<tr>
                    <td colspan="6" class="text-center py-5">
                        <div class="d-flex flex-column align-items-center opacity-50 py-5">
                            <i class="bi bi-folder-x fs-1 mb-2"></i>
                            <span class="fw-bold text-xxs text-uppercase tracking-widest">Sin registros disponibles</span>
                        </div>
                    </td>
                </tr>`;
            } else {
                data.forEach(item => {
                    // Lógica para asignar colores basados en las variables CSS proporcionadas
                    let estadoClass = '';
                    let rowClass = 'hover-bg-app transition-all';
                    let isAssigned = false;
                    
                    if(item.estado === 'EN PROGRESO' || item.estado === 'COMPLETADO') {
                        estadoClass = 'status-aceptado text-white bg-success-700 bg-opacity-75'; // Verde
                        isAssigned = true;
                    } else if (item.estado === 'SIN ASIGNAR') {
                        estadoClass = 'status-rechazado bg-error-100 txt-error border border-error border-opacity-25'; // Rojo claro
                        rowClass += ' bg-error-100 bg-opacity-10'; // Fila con fondo rojo sutil
                    } else {
                        estadoClass = 'bg-warning-100 text-warning-700 border border-warning border-opacity-25'; // Amarillo/Naranja
                    }

                    let avatarColor = isAssigned ? 'bg-accent-light txt-primary-dark' : 'bg-app text-secondary border border-theme';
                    
                    html += `
                    <tr class="border-bottom border-light ${rowClass}">
                        <td class="px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="${avatarColor} fw-bold rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.75rem;">${item.iniciales}</div>
                                <div>
                                    <div class="txt-title fw-bold text-xs text-uppercase mb-1">${item.nombre}</div>
                                    <div class="text-muted text-xxs fw-medium">Mat: ${item.matricula}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="txt-title fw-bold text-xs text-uppercase mb-1">${item.programa}</div>
                            <span class="badge bg-app txt-title border border-theme text-xxs px-2 py-1 shadow-sm">${item.org}</span>
                        </td>
                        <td>
                            <div class="txt-title fw-bold text-xs mb-1 ${isAssigned ? '' : 'text-danger'}">${item.supervisor}</div>
                            <div class="text-muted text-xxs fw-medium text-uppercase">${item.estadoSupervisor}</div>
                        </td>
                        <td class="text-center">
                            <span class="badge rounded-pill px-3 py-1 text-xxs fw-bold ${estadoClass}">${item.estado}</span>
                        </td>
                        <td class="text-center">
                            <div class="txt-title fw-bold text-xs mb-1">${item.horasHechas} / ${item.horasTotal} hrs</div>
                            <div class="progress" style="height: 6px; width: 100px; margin: 0 auto; background-color: var(--bg-main);">
                                <div class="progress-bar bg-primary-900" style="width: ${item.progreso}%"></div>
                            </div>
                        </td>
                        <td class="text-end px-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm border-0 bg-primary-100 txt-primary-dark rounded-2 py-1 px-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalReasignar" data-id="${item.id}" title="Asignar / Reasignar">
                                    <i class="bi bi-person-plus-fill fs-6"></i>
                                </button>
                                <button class="btn btn-sm border-0 bg-app text-secondary rounded-2 py-1 px-2 shadow-sm" title="Ver Detalles">
                                    <i class="bi bi-eye fs-6"></i>
                                </button>
                            </div>
                        </td>
                    </tr>`;
                });
            }
            $('#asignacionesBody').html(html);
        }

            function updateTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let statusFilter = $('#statusFilter').val();
                let rowsPerPage = parseInt($('#rowsPerPage').val());

                let filteredData = allData.filter(item => {
                    let matchesSearch = item.nombre.toLowerCase().includes(searchTerm) || item.matricula.includes(searchTerm);
                    let matchesStatus = (!statusFilter) || (item.estado === statusFilter);
                    return matchesSearch && matchesStatus;
                });

                let totalRecords = filteredData.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                if (currentPage > totalPages) currentPage = totalPages;

                let startIndex = (currentPage - 1) * rowsPerPage;
                let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);
                let pageData = filteredData.slice(startIndex, endIndex);

                renderRows(pageData);

                $('#tableInfo').text(totalRecords === 0 ? '0 REGISTROS' : `${startIndex + 1} - ${endIndex} DE ${totalRecords}`);
                renderPagination(totalPages);
            }

            function renderPagination(totalPages) {
                let html = '';
                
                html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage - 1}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>`;

                for (let i = 1; i <= totalPages; i++) {
                    let btnClass = (i === currentPage) ? 'bg-primary-dark text-white shadow-sm' : 'bg-app txt-title hover-bg-light';
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link border-0 ${btnClass} rounded-2 mx-1 fw-bold text-xxs px-3" href="#" data-page="${i}">${i}</a>
                    </li>`;
                }

                html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link border-0 bg-app rounded-2 txt-title fw-bold text-xxs" href="#" data-page="${currentPage + 1}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>`;

                $('#paginationControls').html(html);
            }

            // Eventos
            $('#searchInput, #statusFilter, #teacherFilter, #rowsPerPage').on('change input', () => { currentPage = 1; updateTable(); });

            $('#paginationControls').on('click', '.page-link', function (e) {
                e.preventDefault();
                let page = parseInt($(this).data('page'));
                if (page && !$(this).parent().hasClass('disabled')) {
                    currentPage = page;
                    updateTable();
                }
            });

            $('#btnLimpiar').click(function() {
                $('#searchInput').val('');
                $('#statusFilter').val('');
                $('#teacherFilter').val('');
                currentPage = 1;
                updateTable();
            });

            loadData();
        });
    </script>
}