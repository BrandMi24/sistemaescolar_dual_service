@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SIE UTTN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-layout">

        <div class="bg-primary-dark p-3 d-flex d-lg-none justify-content-between align-items-center flex-shrink-0 z-3">
            <div class="d-flex align-items-center gap-2">
                <div class="brand-logo" style="width: 32px; height: 32px; font-size: 0.8rem;">UT</div>
                <span class="txt-white fw-bold fs-6">Portal Admin</span>
            </div>
            <button id="btnMobileMenu" class="btn btn-link text-white p-0 fs-2 lh-1">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div id="mobileOverlay" class="mobile-overlay"></div>

        <aside id="sidebar" class="sidebar-sep">
            <div class="sidebar-brand">
                <div class="brand-logo"><i class="bi bi-bank"></i></div>
                <div class="ms-2">
                    <div class="fw-bold small text-white">UT TAMAULIPAS</div>
                    <div class="opacity-50 text-white" style="font-size: 0.6rem;">Nivel Medio Superior</div>
                </div>
            </div>

            <div class="d-flex d-lg-none justify-content-end p-2">
                <button id="btnCloseMenu" class="btn btn-link text-white p-0 fs-3">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="sidebar-nav mt-1">
                <a class="nav-link" href="@Url.Action("Index", "Admin")">
                    <i class="bi bi-grid-1x2"></i> Dashboard
                </a>

                <div class="nav-group-label">Control Escolar</div>
                <a class="nav-link active" href="@Url.Action("Index", "Admisiones")">
                    <i class="bi bi-inbox"></i> Bandeja Admisiones
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Entrevista")">
                    <i class="bi bi-person-badge"></i> Entrevista y Asignación
                </a>

                <div class="nav-group-label">Gestión Docente</div>
                <a class="nav-link" href="@Url.Action("Index", "Tutor")">
                    <i class="bi bi-people"></i> Panel del Tutor
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Asistencia")">
                    <i class="bi bi-list-check"></i> Pase de Lista
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Calificaciones")">
                    <i class="bi bi-journal-text"></i> Calificaciones
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-2">
                    <div class="avatar-sm bg-accent-light txt-primary-dark fw-bold">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                    <div class="overflow-hidden">
                        <div class="fw-bold small text-white text-truncate">@User.Identity.Name</div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-link p-0 opacity-50 small text-white text-decoration-none shadow-none border-0" style="font-size: 0.7rem;">Cerrar Sesión</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="admin-header border-bottom border-theme">
                <h5 class="fw-bold txt-title mb-0">@ViewData["Title"]</h5>
                <div class="d-flex align-items-center gap-3">
                    <div class="search-wrapper d-none d-md-block position-relative">
                        <i class="bi bi-search position-absolute" style="left:15px; top:10px; color:#94a3b8;"></i>
                        <input type="text" class="form-control ps-5" placeholder="Buscar...">
                    </div>
                    <button class="icon-btn border-theme txt-body position-relative">
                        <i class="bi bi-bell"></i>
                        <span class="badge-dot"></span>
                    </button>
                </div>
            </header>

            <div class="p-4 p-lg-5 container-fluid" style="max-width: 1600px;">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            const sidebar = $('#sidebar');
            const overlay = $('#mobileOverlay');
            $('#btnMobileMenu').click(function() { sidebar.addClass('show'); overlay.addClass('active'); });
            $('#btnCloseMenu, #mobileOverlay').click(function() { sidebar.removeClass('show'); overlay.removeClass('active'); });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>