<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Portal UTTN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/alumno-styles.css" asp-append-version="true" />
</head>
<body class="alumno-portal">

    <nav class="alumno-app-bar py-2 px-3 d-flex justify-content-between align-items-center">
        
        <div class="d-flex align-items-center gap-2">
            @if (ViewData["ShowBackButton"] != null && (bool)ViewData["ShowBackButton"])
            {
                <a href="@Url.Action("Index", "Alumno")" class="btn btn-link text-white p-0 me-2 text-decoration-none">
                    <i class="bi bi-arrow-left fs-4"></i>
                </a>
                <span class="txt-white fw-bold fs-5 mb-0 text-truncate">@ViewData["Title"]</span>
            }
            else
            {
                <div class="avatar-sm bg-accent-500 txt-primary-dark fw-bold rounded-circle d-flex justify-content-center align-items-center text-xs">UT</div>
                <span class="txt-white fw-bold fs-5 mb-0 tracking-wide">Mi Portal</span>
            }
        </div>
        
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link text-white p-0 position-relative">
                <i class="bi bi-bell fs-5"></i>
                <span class="position-absolute top-0 start-100 translate-middle p-1 bg-error-700 border border-light rounded-circle"></span>
            </button>
            <form asp-con   troller="Account" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="btn btn-link text-white opacity-75 p-0" title="Cerrar Sesión">
                    <i class="bi bi-box-arrow-right fs-5"></i>
                </button>
            </form>
        </div>
    </nav>

    <main class="container-fluid p-3 p-md-4 pb-5">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>