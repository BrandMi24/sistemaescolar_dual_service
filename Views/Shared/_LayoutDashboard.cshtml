@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Analítica UTTN</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-styles.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-layout">
        
        <aside id="sidebar" class="sidebar-sep">
            <div class="sidebar-brand">
                <div class="brand-logo"><i class="bi bi-pie-chart-fill"></i></div>
                <div class="ms-2">
                    <div class="fw-bold small text-white">UT TAMAULIPAS</div>
                    <div class="opacity-50 text-white text-xxs">Módulo de Analítica</div>
                </div>
            </div>

            <nav class="sidebar-nav mt-1">
                <div class="nav-group-label">Tableros Directivos</div>
                <a class="nav-link" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-building"></i> Visión Rectoría
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Aspirantes")">
                    <i class="bi bi-people-fill"></i> Aspirantes
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Admissions")">
                    <i class="bi bi-door-open-fill"></i> Admisiones
                </a>
                <a class="nav-link" href="@Url.Action("Index", "Tramites")">
                    <i class="bi bi-file-earmark-check-fill"></i> Trámites Operativos
                </a>

                <div class="nav-group-label">Mantenimiento</div>
                <a class="nav-link" href="@Url.Action("Index", "Diagnostic")">
                    <i class="bi bi-database-check"></i> Diagnóstico de BD
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <a href="/Home/Index" class="btn btn-ghost-sep w-100 text-white border-surface d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-box-arrow-left"></i> Salir al Portal
                </a>
            </div>
        </aside>

        <main class="main-content">
            <header class="admin-header">
                <h5 class="fw-bold txt-title mb-0">@ViewData["Title"]</h5>
                
                <div class="d-flex align-items-center gap-3">
                    <div class="text-end d-none d-md-block">
                        <div class="fw-bold txt-title text-sm">@User.Identity.Name</div>
                        <div class="text-xxs txt-body text-uppercase tracking-wide">Administrador</div>
                    </div>
                    <div class="avatar-md bg-accent-light txt-primary-dark shadow-sm">
                        @User.Identity.Name?.Substring(0, 1).ToUpper()
                    </div>
                </div>
            </header>

            <div class="dash-body-padding">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Este script marca en color oscuro la pestaña actual en el menú lateral
        $(document).ready(function() {
        const currentPath = window.location.pathname;
        $('.sidebar-nav a').each(function() {
        if ($(this).attr('href') === currentPath) {
        $('.sidebar-nav a').removeClass('active');
        $(this).addClass('active');
        }
        });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>