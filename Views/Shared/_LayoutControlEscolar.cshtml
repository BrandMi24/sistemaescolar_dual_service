@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Control Escolar</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard-styles.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Montserrat', sans-serif !important;
            background-color: #F3F4F6;
        }

        .nav-link {
            font-size: 0.75rem;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            color: rgba(255,255,255,0.7) !important;
            transition: all 0.2s ease;
            border-radius: 8px;
            margin-bottom: 4px;
        }

            .nav-link i {
                font-size: 1.1rem;
                opacity: 0.8;
            }

            .nav-link:hover {
                background: rgba(255,255,255,0.1) !important;
                color: #fff !important;
            }

            .nav-link.active {
                background: rgba(255,255,255,0.15) !important;
                color: #fff !important;
            }

                .nav-link.active i {
                    opacity: 1;
                }

        .nav-group-label {
            font-size: 0.65rem;
            text-transform: uppercase;
            color: #fff;
            opacity: 0.5;
            font-weight: 800;
            letter-spacing: 1.2px;
            margin: 1.8rem 0 0.6rem 1rem;
        }

        .user-initial-avatar {
            width: 38px;
            height: 38px;
            background-color: #D4C19C;
            color: #13322B;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-weight: 800;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .admin-header {
            background-color: #fff;
            border-bottom: 1px solid #E5E7EB;
            padding: 1rem 2rem;
        }
    </style>
</head>
<body>
    <div class="admin-layout">

        <div class="bg-primary-dark p-3 d-flex d-lg-none justify-content-between align-items-center flex-shrink-0 z-3 shadow-sm">
            <div class="d-flex align-items-center gap-2">
                <div class="bg-white text-dark fw-bold rounded-1 px-2 py-1" style="font-size: 0.7rem;">CE</div>
                <span class="text-white fw-bold text-xs tracking-widest">CONTROL ESCOLAR</span>
            </div>
            <button id="btnMobileMenu" class="btn btn-link text-white p-0 text-decoration-none fw-bold text-xs border border-white border-opacity-25 px-2 py-1 rounded">
                MENÚ
            </button>
        </div>

        <div id="mobileOverlay" class="mobile-overlay"></div>

        <aside id="sidebar" class="sidebar-sep bg-primary-dark border-end border-white border-opacity-10 shadow">

            <div class="sidebar-brand d-flex align-items-center p-4">
                <div class="brand-logo bg-white d-flex align-items-center justify-content-center rounded-2" style="width:35px; height:35px; font-size: 1.1rem; color: #13322B; font-weight: 800;">
                    CE
                </div>
                <div class="ms-3">
                    <div class="sidebar-brand-text fw-bold text-white fs-6 mb-0">CONTROL ESCOLAR</div>
                    <div class="opacity-50 text-white text-xxs fw-semibold text-uppercase tracking-wider">Gestión de Inscripciones</div>
                </div>
            </div>

            <nav class="sidebar-nav custom-scroll mt-2 px-3">
                <div class="nav-group-label">Módulo</div>

                <a class="nav-link px-3 py-2 @(currentAction == "Index" && currentController == "ControlEscolar" ? "active" : "")"
                   href="@Url.Action("Index", "ControlEscolar")">
                    <i class="bi bi-person-lines-fill"></i> Gestión
                </a>

                <a class="nav-link px-3 py-2 @(currentAction == "Historial" ? "active" : "")"
                   href="@Url.Action("Historial", "ControlEscolar")">
                    <i class="bi bi-clock-history"></i> Historial
                </a>

                <a class="nav-link px-3 py-2 @(currentAction == "ConfigurarFichas" ? "active" : "")"
                   href="@Url.Action("ConfigurarFichas", "ControlEscolar")">
                    <i class="bi bi-gear-fill"></i> Configurar Fichas
                </a>
            </nav>

            <div class="sidebar-footer p-4 mt-auto border-top border-white border-opacity-10 bg-black bg-opacity-10">
                <div class="d-flex align-items-center gap-3">
                    <div class="user-initial-avatar shadow-sm">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "A")
                    </div>
                    <div class="overflow-hidden">
                        <div class="fw-bold text-white text-xs text-truncate">@User.Identity?.Name</div>
                        <a href="/Home/Index" class="text-white opacity-50 text-xxs text-decoration-none fw-bold tracking-tighter text-uppercase">
                            Volver al Portal
                        </a>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main-content d-flex flex-column">
            <header class="admin-header d-flex align-items-center justify-content-between shadow-sm">
                <div>
                    <h5 class="fw-bold text-dark mb-0 text-uppercase tracking-tight" style="font-size: 1.1rem;">@ViewData["Title"]</h5>
                    <div class="text-xxs fw-bold text-muted text-uppercase tracking-tighter">Control Escolar • Gestión de Inscripciones</div>
                </div>
                <a href="@Url.Action("Index", "Admin")" class="btn btn-sm btn-outline-dark fw-bold text-xxs tracking-widest px-3">
                    <i class="bi bi-arrow-left me-1"></i> PANEL ADMIN
                </a>
            </header>

            <div class="p-4 p-lg-5 flex-grow-1 bg-app">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            const sidebar = $('#sidebar');
            const overlay = $('#mobileOverlay');
            $('#btnMobileMenu, #mobileOverlay').click(function () {
                sidebar.toggleClass('show');
                overlay.toggleClass('active');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>