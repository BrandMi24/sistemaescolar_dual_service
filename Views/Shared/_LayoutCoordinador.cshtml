@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coordinación UTTN</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">

    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/coordinador-styles.css" asp-append-version="true" />
</head>

<body>
    <div class="admin-layout">

        <!-- HEADER MOBILE -->
        <div class="bg-primary-dark p-3 d-flex d-lg-none justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <span class="txt-white fw-bold fs-6">Portal Coordinador</span>
            </div>
            <button id="btnMobileMenu" class="btn btn-link text-white p-0 fs-2">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div id="mobileOverlay" class="mobile-overlay"></div>

        <!-- SIDEBAR -->
        <aside id="sidebar" class="sidebar-sep">

            <!-- LOGO -->
            <div class="sidebar-brand">
                <div class="brand-logo">
                    <i class="bi bi-diagram-3-fill"></i>
                </div>
                <div class="ms-2">
                    <div class="fw-bold small text-white">UT TAMAULIPAS</div>
                    <div class="opacity-50 text-white text-xxs">Coordinación Académica</div>
                </div>
            </div>

            <!-- CLOSE MOBILE -->
            <div class="d-flex d-lg-none justify-content-end p-2">
                <button id="btnCloseMenu" class="btn btn-link text-white p-0 fs-3">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <!-- NAV -->
            <nav class="sidebar-nav mt-2">

                <!-- PANEL PRINCIPAL (CATÁLOGOS) -->
                <a class="nav-link @(currentAction == "Catalogos" ? "active" : "")"
                       href="@Url.Action("Catalogos", "Coordinador")">
                    <i class="bi bi-grid-1x2"></i> Panel Principal
                </a>

                <div class="nav-group-label">Organización Escolar</div>

                <!-- CICLOS -->
                <a class="nav-link @(currentAction == "Ciclos" ? "active" : "")"
                       href="@Url.Action("Ciclos", "Coordinador")">
                    <i class="bi bi-calendar-range"></i> Ciclos Escolares
                </a>

                <!-- CARGA MASIVA CSV -->
                <a class="nav-link @(currentAction == "ImportStudentsCsv" ? "active" : "")"
                       href="@Url.Action("ImportStudentsCsv", "Coordinador", new { tab = "tab-alumnos" })">
                    <i class="bi bi-upload"></i> Carga masiva CSV
                </a>

            </nav>

            <!-- FOOTER -->
            <div class="sidebar-footer">
                <div class="d-flex flex-column gap-1 px-2">

                    <!-- USUARIO -->
                    <div class="fw-semibold text-white" style="font-size: 0.95rem;">
                        @User.Identity.Name
                    </div>

                    <!-- LOGOUT -->
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit"
                                class="btn btn-link p-0 text-white text-decoration-none border-0"
                                style="font-size: 0.85rem; opacity: 0.8;">
                            Cerrar Sesión
                        </button>
                    </form>

                </div>
            </div>

        </aside>

        <!-- MAIN -->
        <main class="main-content">

            <header class="admin-header border-bottom border-theme">
                <h5 class="fw-bold txt-title mb-0">@ViewData["Title"]</h5>
            </header>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="p-4 pb-0">
                    <div class="alert bg-success-100 border border-success-700 text-success-700 rounded-3 alert-dismissible fade show shadow-sm mb-0">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                </div>
            }

            <div class="p-4 p-lg-5 container-fluid">
                @RenderBody()
            </div>

        </main>
    </div>

    <!-- SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
        const sidebar = $('#sidebar');
        const overlay = $('#mobileOverlay');

        $('#btnMobileMenu').click(function () {
        sidebar.addClass('show');
        overlay.addClass('active');
        });

        $('#btnCloseMenu, #mobileOverlay').click(function () {
        sidebar.removeClass('show');
        overlay.removeClass('active');
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>