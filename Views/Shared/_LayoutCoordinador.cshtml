@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Coordinación UTTN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/coordinador-styles.css" asp-append-version="true" />
</head>
<body>
    <div class="admin-layout">

        <div class="bg-primary-dark p-3 d-flex d-lg-none justify-content-between align-items-center flex-shrink-0 z-3">
            <div class="d-flex align-items-center gap-2">
                <div class="brand-logo avatar-sm text-xs">UT</div>
                <span class="txt-white fw-bold fs-6">Portal Coordinador</span>
            </div>
            <button id="btnMobileMenu" class="btn btn-link text-white p-0 fs-2 lh-1">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div id="mobileOverlay" class="mobile-overlay"></div>

        <aside id="sidebar" class="sidebar-sep">
            <div class="sidebar-brand">
                <div class="brand-logo"><i class="bi bi-diagram-3-fill"></i></div>
                <div class="ms-2">
                    <div class="fw-bold small text-white">UT TAMAULIPAS</div>
                    <div class="opacity-50 text-white text-xxs">Coordinación Académica</div>
                </div>
            </div>

            <div class="d-flex d-lg-none justify-content-end p-2">
                <button id="btnCloseMenu" class="btn btn-link text-white p-0 fs-3">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <nav class="sidebar-nav mt-1">
                <a class="nav-link active" href="@Url.Action("Index", "Coordinador")">
                    <i class="bi bi-grid-1x2"></i> Panel Principal
                </a>

                <div class="nav-group-label">Organización Escolar</div>
                <a class="nav-link" href="@Url.Action("Ciclos", "Coordinador")">
                    <i class="bi bi-calendar-range"></i> Ciclos Escolares
                </a>
                <a class="nav-link" href="@Url.Action("Catalogos", "Coordinador")">
                    <i class="bi bi-folder2-open"></i> Catálogos Generales
                </a>

                <div class="nav-group-label">Gestión Operativa</div>
                <a class="nav-link" href="@Url.Action("Asignaciones", "Coordinador")">
                    <i class="bi bi-table"></i> Matriz de Asignaciones
                </a>
                <a class="nav-link" href="@Url.Action("Grupos", "Coordinador")">
                    <i class="bi bi-collection-fill"></i> Control de Grupos
                </a>

                <div class="nav-group-label">Analítica</div>
                <a class="nav-link" href="@Url.Action("Reportes", "Coordinador")">
                    <i class="bi bi-graph-up-arrow"></i> Reportes y Deserción
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-2">
                    <div class="avatar-sm bg-accent-light txt-primary-dark fw-bold">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                    <div class="overflow-hidden">
                        <div class="fw-bold small text-white text-truncate">@User.Identity.Name</div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="btn btn-link p-0 opacity-50 text-xxs text-white text-decoration-none shadow-none border-0">Cerrar Sesión</button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <header class="admin-header border-bottom border-theme">
                <h5 class="fw-bold txt-title mb-0">@ViewData["Title"]</h5>
            </header>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="p-4 pb-0">
                    <div class="alert bg-success-100 border border-success-700 text-success-700 rounded-3 alert-dismissible fade show shadow-sm mb-0" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                </div>
            }

            <div class="p-4 p-lg-5 container-fluid">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function() {
            const sidebar = $('#sidebar');
            const overlay = $('#mobileOverlay');
            $('#btnMobileMenu').click(function() { sidebar.addClass('show'); overlay.addClass('active'); });
            $('#btnCloseMenu, #mobileOverlay').click(function() { sidebar.removeClass('show'); overlay.removeClass('active'); });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>