@model List<ControlEscolar.ViewModels.OperationalTracking.AsesorDocumentoRowViewModel>
@{
    var isGlobalView = ViewBag.IsGlobalAdvisorView is bool flag && flag;
    var moduleFilter = ViewBag.ModuleFilter as string ?? "";
    var roleScopedModule = ViewBag.RoleScopedModule as string ?? "";
    ViewData["Title"] = isGlobalView ? "Revisión Global de Documentos" : "Validación de Documentación";
    Layout = isGlobalView ? "_LayoutCoordinador" : "_LayoutTutor";
    var search = ViewBag.SearchText as string ?? "";
    var estadoFilter = ViewBag.EstadoFilter as string ?? "";
    int pendingCount = ViewBag.PendingCount ?? 0;
}

<div class="d-flex flex-column gap-4 fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success text-success rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-danger-100 border border-danger text-danger rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="catalog-filter-card">
        <div class="d-flex flex-column gap-2">
        <h1 class="txt-title fw-bold mb-0">@(isGlobalView ? "Revisión global de documentos" : "Revisión de Documentos")</h1>
        <p class="text-muted text-sm mb-0">@(isGlobalView ? "Consulta archivos enviados en módulo dual y servicio social, junto con comentarios e historial del asesor académico." : "Aprueba o rechaza los documentos que envían tus estudiantes")</p>
        </div>
    </div>

    <!-- FILTERS & ALERTS -->
    <div class="catalog-filter-card d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <form method="get" class="d-flex flex-column flex-md-row gap-3 flex-grow-1 w-100">
            <div class="position-relative search-wrapper flex-grow-1">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" name="search" class="form-control search-input-custom tab-search" placeholder="Buscar por alumno o matrícula..." value="@search">
            </div>
            @if (isGlobalView)
            {
                if (string.IsNullOrWhiteSpace(roleScopedModule))
                {
                    <select name="module" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 190px;">
                        <option value="">Todos los módulos</option>
                        <option value="PRACTICAS_PROFESIONALES" selected="@(moduleFilter == "PRACTICAS_PROFESIONALES")">Módulo Dual</option>
                        <option value="SERVICIO_SOCIAL" selected="@(moduleFilter == "SERVICIO_SOCIAL")">Servicio Social</option>
                    </select>
                }
                else
                {
                    <input type="hidden" name="module" value="@roleScopedModule" />
                    <span class="badge bg-primary-100 txt-primary-dark px-3 py-2 align-self-center">
                        @(roleScopedModule == "PRACTICAS_PROFESIONALES" ? "Módulo Dual" : "Servicio Social")
                    </span>
                }
            }
            <select name="estado" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 150px;">
                <option value="">Todos los Documentos</option>
                <option value="PENDING" selected="@(estadoFilter == "PENDING")">Solo Pendientes</option>
                <option value="APPROVED" selected="@(estadoFilter == "APPROVED")">Aprobados</option>
                <option value="REJECTED" selected="@(estadoFilter == "REJECTED")">Rechazados</option>
            </select>
            <div class="d-flex gap-2 flex-shrink-0">
                <button type="submit" class="btn btn-primary-sep bg-primary-900 text-white shadow-sm">
                    <i class="bi bi-funnel-fill me-1"></i> Filtrar
                </button>
                <a href="@Url.Action("RevisionDocumentos")" class="btn btn-ghost-sep shadow-sm">
                    <i class="bi bi-x-lg me-1"></i> Limpiar
                </a>
            </div>
        </form>
        @if (pendingCount > 0)
        {
            <span class="badge bg-danger text-white px-3 py-2 text-xs shadow-sm flex-shrink-0">
                <i class="bi bi-clock me-1"></i> @pendingCount pendiente(s)
            </span>
        }
    </div>

    <!-- TABLE -->
    <div class="catalog-table-card">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0" id="tblRevisionDocs" style="min-width: 1100px;">
                <thead>
                    <tr>
                        <th class="px-4">Estudiante</th>
                        @if (isGlobalView)
                        {
                            <th>Asesor / Módulo</th>
                        }
                        <th>Documento</th>
                        <th>Fecha Envío</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="@(isGlobalView ? 6 : 5)">
                                <div class="catalog-empty">
                                    <i class="bi bi-file-earmark-check"></i>
                                    <span>Sin registros disponibles</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var doc in Model)
                    {
                        var statusBadge = doc.StatusCode switch
                        {
                            "APPROVED" => ("bg-success text-white", "APROBADO", "bi-check-circle-fill"),
                            "REJECTED" => ("bg-danger text-white", "RECHAZADO", "bi-x-circle-fill"),
                            _ => ("bg-warning text-dark", "PENDIENTE", "bi-clock-history")
                        };
                        <tr class="data-row">
                            <td class="px-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-sm bg-info-light text-info fw-bold d-flex align-items-center justify-content-center flex-shrink-0">
                                        @doc.StudentName.Split(' ')[0][0]@(doc.StudentName.Split(' ').Length > 1 ? doc.StudentName.Split(' ')[1][0] : doc.StudentName[1])
                                    </div>
                                    <div>
                                        <div class="txt-title fw-bold text-sm mb-0">@doc.StudentName</div>
                                        <div class="txt-body text-xxs">
                                            <i class="bi bi-shield-check me-1"></i> @doc.Matricula
                                        </div>
                                    </div>
                                </div>
                            </td>
                            @if (isGlobalView)
                            {
                                <td>
                                    <div class="txt-title fw-bold text-sm mb-1">@doc.AdvisorName</div>
                                    <div class="txt-body text-xxs">@doc.ProgramType</div>
                                </td>
                            }
                            <td>
                                <div class="txt-title fw-bold text-sm mb-1">@doc.Title</div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-light border border-theme text-dark text-xxs px-2 py-1">
                                        <i class="bi bi-file-earmark me-1"></i> @doc.DocumentType
                                    </span>
                                    @if (!string.IsNullOrEmpty(doc.FilePath))
                                    {
                                        <a href="@doc.FilePath" target="_blank" class="text-primary text-xs fw-bold text-decoration-none">
                                            <i class="bi bi-download me-1"></i>Descargar
                                        </a>
                                    }
                                </div>
                            </td>
                            <td class="txt-body text-xs">
                                <i class="bi bi-calendar-event me-1"></i>
                                @doc.UploadDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center gap-2">
                                    <span class="badge @statusBadge.Item1 text-xxs px-3 py-2 shadow-sm">
                                        <i class="bi @statusBadge.Item3 me-1"></i> @statusBadge.Item2
                                    </span>
                                    @if (!string.IsNullOrEmpty(doc.ReviewComments))
                                    {
                                        <button type="button" class="btn btn-xs btn-outline-secondary" 
                                                data-bs-toggle="popover" 
                                                data-bs-trigger="hover" 
                                                title="Comentarios"
                                                data-bs-content="@doc.ReviewComments">
                                            <i class="bi bi-chat-left-text"></i> Ver comentarios
                                        </button>
                                    }
                                </div>
                            </td>
                            <td class="text-end px-4">
                                @if (doc.StatusCode == "PENDING")
                                {
                                    <div class="d-flex justify-content-end gap-2">
                                        <form asp-action="AprobarDocumento" asp-controller="AsesorAcademico" method="post" class="d-inline" style="margin: 0;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="documentId" value="@doc.DocumentId" />
                                            <button type="submit" class="btn-action btn-action-toggle-on" title="Aprobar documento">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn-action btn-action-delete"
                                                data-bs-toggle="modal" data-bs-target="#modalRechazo"
                                                data-doc-id="@doc.DocumentId" 
                                                title="Rechazar documento">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="txt-body text-xxs opacity-50">Sin acciones</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Any())
        {
            <div class="catalog-pagination-bar">
                <div class="d-flex align-items-center gap-3">
                    <span class="rows-label">MOSTRAR:</span>
                    <select id="tblRevisionDocsRpp" class="form-select form-select-sm rows-per-page">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div id="tblRevisionDocsInfo" class="info-label"></div>
                </div>
                <nav aria-label="Paginación revisión documentos">
                    <ul class="pagination pagination-sm mb-0" id="tblRevisionDocsPagination"></ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- Modal Rechazo -->
<div class="modal fade" id="modalRechazo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-theme shadow-sm rounded-4 overflow-hidden bg-surface">
            <form asp-action="RechazarDocumento" asp-controller="AsesorAcademico" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="rechazarDocId" name="documentId" value="" />
                <div class="modal-header border-bottom border-theme p-4">
                    <h5 class="modal-title txt-title fw-bold">
                        <i class="bi bi-exclamation-circle-fill me-2 text-danger"></i> Rechazar Documento
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted text-sm mb-3">
                        Proporciona retroalimentación detallada sobre qué debe corregir el estudiante.
                    </p>
                    <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">COMENTARIOS Y CORRECCIONES REQUERIDAS*</label>
                    <textarea name="comments" class="form-control bg-app border-theme text-sm" rows="5" placeholder="Ej: Falta la firma del responsable, revisa el formato de fechas..." required></textarea>
                    <small class="text-muted d-block mt-2">Estos comentarios se enviarán al estudiante para que realice las correcciones necesarias.</small>
                </div>
                <div class="modal-footer border-top border-theme bg-app p-3">
                    <button type="button" class="btn btn-ghost-sep" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-sep bg-danger text-white shadow-sm">
                        <i class="bi bi-send-fill me-1"></i> Enviar Retroalimentación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalRechazo').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('rechazarDocId').value = btn.getAttribute('data-doc-id');
        });

        // Inicializar popovers
        var popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'))
        var popoverList = popoverTriggerList.map(function (popoverTriggerEl) {
            return new bootstrap.Popover(popoverTriggerEl)
        })

        (function () {
            var table = document.getElementById('tblRevisionDocs');
            if (!table) return;

            var rows = Array.from(table.querySelectorAll('tbody tr.data-row'));
            if (!rows.length) return;

            var page = 1;
            var pageSize = 10;
            var total = rows.length;

            var rppEl = document.getElementById('tblRevisionDocsRpp');
            var infoEl = document.getElementById('tblRevisionDocsInfo');
            var paginationEl = document.getElementById('tblRevisionDocsPagination');

            function buildPagination(totalPages) {
                if (!paginationEl) return;
                paginationEl.innerHTML = '';

                function createItem(label, targetPage, disabled, active) {
                    var li = document.createElement('li');
                    li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');
                    var link = document.createElement('a');
                    link.className = 'page-link';
                    link.href = '#';
                    link.innerHTML = label;
                    if (!disabled) {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            page = targetPage;
                            render();
                        });
                    }
                    li.appendChild(link);
                    paginationEl.appendChild(li);
                }

                createItem('<i class="bi bi-chevron-left"></i>', Math.max(1, page - 1), page === 1, false);
                for (var i = 1; i <= totalPages; i++) {
                    createItem(String(i), i, false, i === page);
                }
                createItem('<i class="bi bi-chevron-right"></i>', Math.min(totalPages, page + 1), page === totalPages, false);
            }

            function render() {
                var totalPages = Math.max(1, Math.ceil(total / pageSize));
                if (page > totalPages) page = totalPages;

                var start = (page - 1) * pageSize;
                var end = Math.min(start + pageSize, total);

                rows.forEach(function (row, index) {
                    row.style.display = (index >= start && index < end) ? '' : 'none';
                });

                if (infoEl) {
                    infoEl.textContent = (start + 1) + ' - ' + end + ' DE ' + total;
                }

                buildPagination(totalPages);
            }

            if (rppEl) {
                rppEl.addEventListener('change', function () {
                    pageSize = parseInt(rppEl.value, 10);
                    page = 1;
                    render();
                });
            }

            render();
        })();
    </script>
}