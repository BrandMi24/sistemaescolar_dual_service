@model ControlEscolar.ViewModels.OperationalTracking.AsesorSeguimientoViewModel
@{
    ViewData["Title"] = "Bitácora de Seguimiento";
    var isGlobalView = ViewBag.IsGlobalAdvisorView is bool flag && flag;
    Layout = isGlobalView ? "_LayoutCoordinador" : "_LayoutTutor";
    var assignmentStatus = (Model.StatusCode ?? string.Empty).Trim().ToUpperInvariant();
    var statusBadgeClass = assignmentStatus switch
    {
        "COMPLETED" or "FINALIZED" => "status-aceptado",
        "IN_PROGRESS" => "bg-info text-white",
        "REGISTERED" => "status-pendiente",
        _ => "bg-secondary text-white"
    };
    var statusLabel = assignmentStatus switch
    {
        "COMPLETED" => "COMPLETADO",
        "FINALIZED" => "FINALIZADO",
        "IN_PROGRESS" => "EN PROCESO",
        "REGISTERED" => "REGISTRADO",
        _ => string.IsNullOrWhiteSpace(Model.StatusCode) ? "SIN ESTADO" : Model.StatusCode
    };
}

<div class="d-flex flex-column gap-4 fade-in">
    <div class="admin-card-white p-4 p-lg-5 shadow-sm advisor-hero">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <a href="@Url.Action("AlumnosAsignados")" class="back-link-chip mb-3">
                    <i class="bi bi-arrow-left"></i>
                    <span>Volver a Mis Estudiantes</span>
                </a>
                <h1 class="txt-title fw-bold mb-1">Bitácora de Seguimiento</h1>
                <p class="text-muted text-sm mb-0">Historial completo de actividades, reportes y documentación del estudiante.</p>
            </div>
        </div>
    </div>

    <div class="admin-card-white p-4 shadow-sm student-summary-card">
        <div class="row g-4 align-items-start">
            <div class="col-12 col-xl-8">
                <div class="d-flex gap-3 gap-lg-4 align-items-start">
                    <div class="tracking-avatar bg-accent-light txt-primary-dark fw-bold d-flex align-items-center justify-content-center flex-shrink-0">
                        @Model.StudentName.Split(' ')[0][0]@(Model.StudentName.Split(' ').Length > 1 ? Model.StudentName.Split(' ')[1][0] : Model.StudentName[1])
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="txt-title fw-bold mb-3">@Model.StudentName</h4>
                        <div class="row g-3 summary-grid mb-3">
                            <div class="col-6 col-md-4">
                                <span class="summary-label">Matrícula</span>
                                <div class="summary-value">@Model.Matricula</div>
                            </div>
                            <div class="col-6 col-md-4">
                                <span class="summary-label">Carrera</span>
                                <div class="summary-value">@Model.CareerCode</div>
                            </div>
                            <div class="col-6 col-md-4">
                                <span class="summary-label">Grupo</span>
                                <div class="summary-value">@Model.GroupCode</div>
                            </div>
                            <div class="col-6 col-md-4">
                                <span class="summary-label">Programa</span>
                                <div class="summary-value">@Model.ProgramName</div>
                            </div>
                            <div class="col-6 col-md-4">
                                <span class="summary-label">Asesor</span>
                                <div class="summary-value">@Model.AdvisorName</div>
                            </div>
                            <div class="col-12 col-md-4">
                                <span class="summary-label">Organización</span>
                                <div class="summary-value">@Model.OrganizationName</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-4">
                <div class="d-flex flex-column gap-3 status-panel">
                    <div class="status-box">
                        <span class="summary-label">Estado</span>
                        <span class="badge @statusBadgeClass fw-bold px-3 py-2">@statusLabel</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="stat-card-sep h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Horas Completadas</span>
                    <div class="icon-circle bg-primary-100 txt-primary-dark shadow-sm">
                        <i class="bi bi-check2-circle fs-5"></i>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mb-3">
                    <div>
                        <div class="stat-value">@Model.ApprovedHours.ToString("F1")</div>
                        <span class="text-xxs txt-body fw-medium">Horas aprobadas</span>
                    </div>
                    <div class="text-end">
                        <div class="txt-title fw-bold fs-4 text-success">@Model.ProgressPercent%</div>
                        <span class="text-xxs txt-body fw-medium">De @Model.RequiredHours requeridas</span>
                    </div>
                </div>
                <div class="progress tracking-progress mb-3">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: @Model.ProgressPercent%;" aria-valuenow="@Model.ProgressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <span class="text-xxs txt-body fw-medium">
                    <i class="bi bi-hourglass-split me-1"></i>
                    @(Model.RequiredHours - Model.ApprovedHours > 0 ? $"Faltan {(Model.RequiredHours - Model.ApprovedHours).ToString("F1")} horas" : "Meta completada")
                </span>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="stat-card-sep h-100" style="border-left: 3px solid var(--warning-700, #f59e0b);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Horas Registradas</span>
                    <div class="icon-circle bg-warning-100 shadow-sm" style="color: var(--warning-700, #f59e0b);">
                        <i class="bi bi-clock-history fs-5"></i>
                    </div>
                </div>
                <div class="d-flex align-items-end justify-content-between mb-3">
                    <div>
                        <div class="stat-value">@Model.TotalHours.ToString("F1")</div>
                        <span class="text-xxs txt-body fw-medium">Total registrado</span>
                    </div>
                    <div class="text-end">
                        <div class="txt-title fw-bold fs-4" style="color: #fd7e14;">@((Model.TotalHours - Model.ApprovedHours).ToString("F1"))</div>
                        <span class="text-xxs txt-body fw-medium">Por procesar</span>
                    </div>
                </div>
                <div class="rounded-3 border border-theme bg-app px-3 py-3 text-xxs txt-body fw-medium">
                    <i class="bi bi-info-circle me-2"></i>
                    Horas pendientes de aprobación en la sección de Evaluaciones.
                </div>
            </div>
        </div>
    </div>

    <div class="catalog-table-card">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 p-4 pb-0">
            <div>
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-1"><i class="bi bi-clock-history me-2"></i>Historial de Actividades</h6>
                <p class="text-muted text-xs mb-0">Seguimiento cronológico de reportes, observaciones y archivos asociados.</p>
            </div>
            <div class="text-xxs text-muted fw-bold">@Model.Timeline.Count registro(s) en bitácora</div>
        </div>

        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0" id="tblBitacora" style="min-width: 1100px;">
                <thead>
                    <tr>
                        <th class="px-4">Fecha</th>
                        <th>Reporte / Bitácora</th>
                        <th>Observaciones</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Timeline.Any())
                    {
                        <tr>
                            <td colspan="5">
                                <div class="catalog-empty">
                                    <i class="bi bi-inbox"></i>
                                    <span>Sin registros disponibles</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Timeline)
                    {
                        <tr class="data-row">
                            <td class="px-4">
                                <div class="txt-title fw-bold text-sm">@item.UploadDate.ToString("dd/MM/yyyy")</div>
                                <div class="txt-body text-xxs">@item.UploadDate.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div class="txt-title fw-bold text-sm">@item.Title</div>
                                <div class="txt-body text-xxs">@item.DocumentType</div>
                            </td>
                            <td>
                                <div class="txt-body text-xs">@(string.IsNullOrWhiteSpace(item.Notes) ? "Sin notas del estudiante" : item.Notes)</div>
                                @if (!string.IsNullOrWhiteSpace(item.ReviewComments))
                                {
                                    <div class="text-xxs text-warning mt-2"><i class="bi bi-chat-left-text me-1"></i>@item.ReviewComments</div>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @item.StatusBadgeClass text-xxs px-3 py-2 shadow-sm">@item.StatusLabel</span>
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    @if (!string.IsNullOrWhiteSpace(item.FilePath))
                                    {
                                        <a href="@item.FilePath" target="_blank" class="btn-action btn-action-view" title="Descargar archivo">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted text-xxs">Sin archivo</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Timeline.Any())
        {
            <div class="catalog-pagination-bar">
                <div class="d-flex align-items-center gap-3">
                    <span class="rows-label">MOSTRAR:</span>
                    <select id="tblBitacoraRpp" class="form-select form-select-sm rows-per-page">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div id="tblBitacoraCount" class="info-label"></div>
                </div>
                <nav aria-label="Paginación bitácora seguimiento">
                    <ul class="pagination pagination-sm mb-0" id="tblBitacoraPagination"></ul>
                </nav>
            </div>
        }
    </div>
</div>

<style>
    .advisor-hero {
        background: linear-gradient(120deg, rgba(19, 50, 43, 0.08), rgba(19, 50, 43, 0.015));
        border-top: 4px solid var(--primary-900);
    }

    .back-link-chip {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        padding: .65rem 1rem;
        border-radius: 999px;
        background: #fff;
        color: var(--primary-700, #1f6feb);
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .02em;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .06);
        border: 1px solid rgba(31, 111, 235, .12);
        transition: transform .15s ease, box-shadow .15s ease, color .15s ease;
    }

    .back-link-chip:hover {
        color: var(--primary-900, #13322B);
        transform: translateY(-1px);
        box-shadow: 0 10px 28px rgba(15, 23, 42, .1);
    }

    .tracking-avatar {
        width: 72px;
        height: 72px;
        border-radius: 16px;
        font-size: 1.65rem;
    }

    .student-summary-card {
        border-radius: 1.25rem;
    }

    .summary-grid {
        row-gap: 1rem;
    }

    .summary-label {
        display: block;
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--text-body, #6a6f7a);
        margin-bottom: .3rem;
    }

    .summary-value {
        font-size: .9rem;
        font-weight: 700;
        color: var(--text-title, #1a2b6b);
        line-height: 1.35;
    }

    .status-panel {
        border-left: 1px solid rgba(0, 0, 0, .08);
        padding-left: 1.25rem;
        min-height: 100%;
    }

    .status-box {
        display: flex;
        flex-direction: column;
        gap: .45rem;
        min-height: 84px;
        justify-content: center;
    }

    .tracking-progress {
        height: 10px;
        background-color: var(--bg-app, #f5f6fa);
        border-radius: 999px;
    }

    @@media (max-width: 1199px) {
        .status-panel {
            border-left: 0;
            border-top: 1px solid rgba(0, 0, 0, .08);
            padding-left: 0;
            padding-top: 1rem;
        }
    }

    @@media (max-width: 767px) {
        .tracking-avatar {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            font-size: 1.35rem;
        }
    }
</style>

@section Scripts {
    <script>
        (function () {
            var table = document.getElementById('tblBitacora');
            if (!table) return;

            var rows = Array.from(table.querySelectorAll('tbody tr.data-row'));
            if (!rows.length) return;

            var pageSize = 10;
            var page = 1;
            var total = rows.length;

            var countEl = document.getElementById('tblBitacoraCount');
            var rppEl = document.getElementById('tblBitacoraRpp');
            var paginationEl = document.getElementById('tblBitacoraPagination');

            function buildPagination(totalPages) {
                if (!paginationEl) return;
                paginationEl.innerHTML = '';

                function createItem(label, targetPage, disabled, active) {
                    var li = document.createElement('li');
                    li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');
                    var link = document.createElement('a');
                    link.className = 'page-link';
                    link.href = '#';
                    link.innerHTML = label;
                    if (!disabled) {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            page = targetPage;
                            render();
                        });
                    }
                    li.appendChild(link);
                    paginationEl.appendChild(li);
                }

                createItem('<i class="bi bi-chevron-left"></i>', Math.max(1, page - 1), page === 1, false);
                for (var i = 1; i <= totalPages; i++) {
                    createItem(String(i), i, false, i === page);
                }
                createItem('<i class="bi bi-chevron-right"></i>', Math.min(totalPages, page + 1), page === totalPages, false);
            }

            function render() {
                var totalPages = Math.max(1, Math.ceil(total / pageSize));
                if (page > totalPages) page = totalPages;

                var start = (page - 1) * pageSize;
                var end = Math.min(start + pageSize, total);

                rows.forEach(function (row, index) {
                    row.style.display = (index >= start && index < end) ? '' : 'none';
                });

                if (countEl) {
                    countEl.textContent = total === 0 ? '0 REGISTROS' : (start + 1) + ' - ' + end + ' DE ' + total;
                }

                buildPagination(totalPages);
            }

            if (rppEl) {
                rppEl.addEventListener('change', function () {
                    pageSize = parseInt(rppEl.value, 10);
                    page = 1;
                    render();
                });
            }

            render();
        })();
    </script>
}
