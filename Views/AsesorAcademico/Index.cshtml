@using System.Text.Json
@model ControlEscolar.ViewModels.OperationalTracking.AsesorDashboardViewModel
@{
    var isGlobalView = ViewBag.IsGlobalAdvisorView is bool flag && flag;
    var moduleFilter = ViewBag.ModuleFilter as string ?? "";
    var roleScopedModule = ViewBag.RoleScopedModule as string ?? "";
    ViewData["Title"] = isGlobalView ? "Panel Global de Asesoria Academica" : "Panel de Asesoria Academica";
    Layout = isGlobalView ? "_LayoutCoordinador" : "_LayoutTutor";
    var hasAttention = Model.PendingDocuments > 0 || Model.ReadyToEvaluate > 0;
}

<div class="fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-box-sep mb-4 shadow-sm border-theme alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-box-sep mb-4 shadow-sm border-theme alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="admin-card-white p-4 p-lg-5 mb-4 shadow-sm advisor-hero">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
            <div>
                <h1 class="txt-title fw-bold mb-1">@(isGlobalView ? "Panel Global de Asesoria Academica" : "Panel de Asesoria Academica")</h1>
                <p class="text-muted text-sm mb-0">Vista de seguimiento academico con indicadores dinamicos por fecha y por alumno.</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <a href="@Url.Action("AlumnosAsignados")" class="btn-primary-sep text-xs px-4 py-2"><i class="bi bi-people me-2"></i>ESTUDIANTES</a>
                <a href="@Url.Action("RevisionDocumentos")" class="btn-ghost-sep text-xs px-4 py-2">DOCUMENTOS</a>
                <a href="@Url.Action("Evaluaciones")" class="btn-ghost-sep text-xs px-4 py-2">EVALUACIONES</a>
            </div>
        </div>
    </div>

    @if (hasAttention)
    {
        <div class="admin-card-white p-3 mb-4 shadow-sm" style="border-left: 4px solid var(--warning-700, #f59e0b) !important; background: linear-gradient(135deg, #fffbeb 0%, #ffffff 100%);">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-bell-fill" style="color: var(--warning-700, #f59e0b); font-size: 1.1rem;"></i>
                <span class="fw-bold txt-title text-xs text-uppercase tracking-wide">Requiere Atencion</span>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (Model.PendingDocuments > 0)
                {
                    <a href="@Url.Action("RevisionDocumentos")" class="d-flex align-items-center gap-2 bg-surface p-2 px-3 rounded-3 border text-decoration-none">
                        <span class="badge bg-danger">@Model.PendingDocuments</span>
                        <span class="text-xs txt-title fw-semibold">documentos pendientes</span>
                    </a>
                }
                @if (Model.ReadyToEvaluate > 0)
                {
                    <a href="@Url.Action("Evaluaciones")" class="d-flex align-items-center gap-2 bg-surface p-2 px-3 rounded-3 border text-decoration-none">
                        <span class="badge bg-warning text-dark">@Model.ReadyToEvaluate</span>
                        <span class="text-xs txt-title fw-semibold">listos para evaluar</span>
                    </a>
                }
            </div>
        </div>
    }

    <div class="admin-card-white p-4 mb-4 shadow-sm">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="section-label text-muted mb-2 d-block">Vista</label>
                <select id="kpiMode" class="form-select">
                    <option value="fecha">Por Fecha</option>
                    <option value="alumno">Por Alumno</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="section-label text-muted mb-2 d-block">Rango</label>
                <select id="kpiRange" class="form-select">
                    <option value="all">Todo</option>
                    <option value="90">Ultimos 90 dias</option>
                    <option value="30" selected>Ultimos 30 dias</option>
                    <option value="7">Ultimos 7 dias</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="section-label text-muted mb-2 d-block">Buscar Alumno</label>
                <div class="position-relative search-wrapper">
                    <i class="bi bi-search position-absolute search-icon-left"></i>
                    <input id="kpiStudentSearch" type="text" class="form-control search-input-custom" placeholder="Filtrar por alumno..." />
                </div>
            </div>

            @if (isGlobalView)
            {
                <div class="col-12 d-flex gap-2 flex-wrap pt-1">
                    <span class="text-muted text-xxs fw-bold align-self-center">MODULO:</span>
                    @if (string.IsNullOrWhiteSpace(roleScopedModule))
                    {
                        <a href="@Url.Action("Index", "AsesorAcademico")" class="btn-ghost-sep text-xxs px-3 py-2">TODOS</a>
                        <a href="@Url.Action("Index", "AsesorAcademico", new { module = "PRACTICAS_PROFESIONALES" })" class="btn-ghost-sep text-xxs px-3 py-2">DUAL</a>
                        <a href="@Url.Action("Index", "AsesorAcademico", new { module = "SERVICIO_SOCIAL" })" class="btn-ghost-sep text-xxs px-3 py-2">SERVICIO SOCIAL</a>
                    }
                    @if (!string.IsNullOrWhiteSpace(moduleFilter))
                    {
                        <span class="badge bg-primary-100 txt-primary-dark px-3 py-2">VISTA: @moduleFilter</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card-sep">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Estudiantes Asignados</span>
                    <div class="icon-circle bg-accent-light txt-primary-dark shadow-sm">
                        <i class="bi bi-people fs-5"></i>
                    </div>
                </div>
                <div class="stat-value" id="kpiTotalStudents">@Model.TotalStudents</div>
                <span class="text-xxs txt-body mt-1 fw-medium">Total vigente en seguimiento</span>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--warning-700);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Listos para Evaluar</span>
                    <div class="icon-circle bg-warning-100 shadow-sm" style="color: var(--warning-700);">
                        <i class="bi bi-exclamation-triangle fs-5"></i>
                    </div>
                </div>
                <div class="stat-value" id="kpiReady">@Model.ReadyToEvaluate</div>
                <span class="text-xxs txt-body mt-1 fw-medium">Con progreso igual o mayor a 80%</span>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--success-700);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Evaluados</span>
                    <div class="icon-circle bg-success-100 shadow-sm" style="color: var(--success-700);">
                        <i class="bi bi-check2-circle fs-5"></i>
                    </div>
                </div>
                <div class="stat-value" id="kpiEvaluated">@Model.Evaluated</div>
                <span class="text-xxs txt-body mt-1 fw-medium">Con calificacion registrada</span>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="stat-card-sep" style="border-left: 3px solid var(--primary-700);">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="stat-label">Horas Promedio</span>
                    <div class="icon-circle bg-primary-100 txt-primary-dark shadow-sm">
                        <i class="bi bi-clock-history fs-5"></i>
                    </div>
                </div>
                <div class="stat-value" id="kpiAvgHours">@Model.AverageHours.ToString("F1")</div>
                <span class="text-xxs txt-body mt-1 fw-medium">Horas aprobadas por alumno</span>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-lg-8">
            <div class="admin-card-white h-100">
                <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-3">
                    <div style="width: 4px; height: 18px; background: var(--primary-900); border-radius: 2px;"></div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0" id="chartTitle">Tendencia por Fecha</h6>
                </div>
                <p class="text-muted text-xs mb-3">Comparativa de asignaciones, evaluaciones y horas segun filtros seleccionados.</p>
                <div class="chart-container" style="height: 320px;">
                    <canvas id="advisorKpiChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="admin-card-white h-100">
                <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-3">
                    <div style="width: 4px; height: 18px; background: var(--accent-500, #d4c19c); border-radius: 2px;"></div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">Resumen Operativo</h6>
                </div>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between align-items-center rounded-3 border border-theme p-3 bg-app">
                        <span class="fw-semibold">Documentos Pendientes</span>
                        <span class="badge bg-danger text-white px-3" id="kpiPendingDocs">@Model.PendingDocuments</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center rounded-3 border border-theme p-3 bg-app">
                        <span class="fw-semibold">Cobertura Evaluacion</span>
                        <span class="badge bg-success text-white px-3" id="kpiCoverage">0%</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center rounded-3 border border-theme p-3 bg-app">
                        <span class="fw-semibold">Promedio Progreso</span>
                        <span class="badge bg-primary text-white px-3" id="kpiProgress">0%</span>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <a href="@Url.Action("RevisionDocumentos")" class="btn-ghost-sep text-xs flex-fill text-center py-2">Revisar Docs</a>
                    <a href="@Url.Action("Evaluaciones")" class="btn-primary-sep text-xs flex-fill text-center py-2">Evaluaciones</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .advisor-hero {
        background: linear-gradient(120deg, rgba(19, 50, 43, 0.08), rgba(19, 50, 43, 0.015));
        border-top: 4px solid var(--primary-900);
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const rawStudents = @Html.Raw(JsonSerializer.Serialize(Model.Students));
        const kpiMode = document.getElementById('kpiMode');
        const kpiRange = document.getElementById('kpiRange');
        const kpiStudentSearch = document.getElementById('kpiStudentSearch');

        const dom = {
            total: document.getElementById('kpiTotalStudents'),
            ready: document.getElementById('kpiReady'),
            evaluated: document.getElementById('kpiEvaluated'),
            avgHours: document.getElementById('kpiAvgHours'),
            pendingDocs: document.getElementById('kpiPendingDocs'),
            coverage: document.getElementById('kpiCoverage'),
            progress: document.getElementById('kpiProgress'),
            chartTitle: document.getElementById('chartTitle')
        };

        const ctx = document.getElementById('advisorKpiChart').getContext('2d');
        let chart = null;

        function parseDate(value) {
            const dt = new Date(value);
            return Number.isNaN(dt.getTime()) ? null : dt;
        }

        function filterStudents() {
            const now = new Date();
            const range = kpiRange.value;
            const search = (kpiStudentSearch.value || '').trim().toLowerCase();

            return rawStudents.filter(s => {
                if (search && !(s.studentName || '').toLowerCase().includes(search)) {
                    return false;
                }

                if (range === 'all') {
                    return true;
                }

                const dt = parseDate(s.createdDate);
                if (!dt) {
                    return false;
                }

                const diffDays = (now - dt) / (1000 * 60 * 60 * 24);
                return diffDays <= parseInt(range);
            });
        }

        function setCards(rows) {
            const total = rows.length;
            const ready = rows.filter(r => !r.isEvaluated && (r.progressPercent || 0) >= 80).length;
            const evaluated = rows.filter(r => r.isEvaluated).length;
            const avgHours = total > 0 ? (rows.reduce((acc, r) => acc + (r.approvedHours || 0), 0) / total) : 0;
            const avgProgress = total > 0 ? (rows.reduce((acc, r) => acc + (r.progressPercent || 0), 0) / total) : 0;
            const coverage = total > 0 ? (evaluated * 100 / total) : 0;

            dom.total.textContent = total;
            dom.ready.textContent = ready;
            dom.evaluated.textContent = evaluated;
            dom.avgHours.textContent = avgHours.toFixed(1);
            dom.coverage.textContent = `${coverage.toFixed(1)}%`;
            dom.progress.textContent = `${avgProgress.toFixed(1)}%`;
        }

        function buildByDate(rows) {
            const map = new Map();
            rows.forEach(r => {
                const dt = parseDate(r.createdDate);
                if (!dt) return;
                const key = `${dt.getFullYear()}-${String(dt.getMonth() + 1).padStart(2, '0')}`;
                if (!map.has(key)) {
                    map.set(key, { total: 0, evaluated: 0, hours: 0 });
                }
                const item = map.get(key);
                item.total += 1;
                item.evaluated += r.isEvaluated ? 1 : 0;
                item.hours += (r.approvedHours || 0);
            });

            const labels = Array.from(map.keys()).sort();
            return {
                labels,
                total: labels.map(l => map.get(l).total),
                evaluated: labels.map(l => map.get(l).evaluated),
                hours: labels.map(l => Number(map.get(l).hours.toFixed(1)))
            };
        }

        function buildByStudent(rows) {
            const map = new Map();
            rows.forEach(r => {
                const key = r.studentName || 'Sin nombre';
                if (!map.has(key)) {
                    map.set(key, { total: 0, evaluated: 0, hours: 0 });
                }
                const item = map.get(key);
                item.total += 1;
                item.evaluated += r.isEvaluated ? 1 : 0;
                item.hours += (r.approvedHours || 0);
            });

            const sorted = Array.from(map.entries())
                .sort((a, b) => b[1].hours - a[1].hours)
                .slice(0, 8);

            const labels = sorted.map(x => x[0]);
            return {
                labels,
                total: sorted.map(x => x[1].total),
                evaluated: sorted.map(x => x[1].evaluated),
                hours: sorted.map(x => Number(x[1].hours.toFixed(1)))
            };
        }

        function renderChart(dataset, isByDate) {
            dom.chartTitle.textContent = isByDate ? 'Tendencia por Fecha' : 'Top Alumnos por Horas';
            const data = isByDate ? buildByDate(dataset) : buildByStudent(dataset);

            if (chart) {
                chart.destroy();
            }

            chart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels,
                    datasets: [
                        {
                            label: 'Asignaciones',
                            data: data.total,
                            backgroundColor: '#13322B',
                            borderRadius: 8,
                        },
                        {
                            label: 'Evaluados',
                            data: data.evaluated,
                            backgroundColor: '#D4C19C',
                            borderRadius: 8,
                        },
                        {
                            label: 'Horas Aprobadas',
                            data: data.hours,
                            backgroundColor: '#204A40',
                            borderRadius: 8,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0
                            }
                        }
                    }
                }
            });
        }

        function repaintDashboard() {
            const rows = filterStudents();
            setCards(rows);
            renderChart(rows, kpiMode.value === 'fecha');
        }

        [kpiMode, kpiRange, kpiStudentSearch].forEach(el => {
            el.addEventListener('input', repaintDashboard);
            el.addEventListener('change', repaintDashboard);
        });

        repaintDashboard();
    </script>
}
