@model ControlEscolar.ViewModels.OperationalTracking.AsesorDashboardViewModel
@{
    ViewData["Title"] = "Panel de Asesoría Académica";
    Layout = "_LayoutTutor";
}

<div class="d-flex flex-column gap-4 fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success text-success rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-danger-100 border border-danger text-danger rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- HEADER CON TÍTULO -->
    <div class="d-flex flex-column gap-2">
        <h1 class="txt-title fw-bold mb-0">Panel de Asesoría Académica</h1>
        <p class="text-muted text-sm mb-0">Gestiona el seguimiento académico de tus estudiantes asignados</p>
    </div>

    <!-- STATISTICS CARDS GRID -->
    <div class="row g-3">
        <!-- Card 1: Total Estudiantes -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-card-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column border-theme">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="icon-circle-lg bg-primary-light text-primary">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <span class="badge bg-primary-light text-primary fw-bold">Total</span>
                </div>
                <h6 class="txt-title fw-bold mb-1">Estudiantes Asignados</h6>
                <h3 class="text-primary fw-bold mb-2">@Model.TotalStudents</h3>
                <p class="text-muted text-xs mb-0">
                    <i class="bi bi-arrow-right-short"></i> Activos en tu seguimiento
                </p>
            </div>
        </div>

        <!-- Card 2: Listos para Evaluar -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-card-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column border-theme">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="icon-circle-lg bg-warning-light text-warning">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <span class="badge bg-warning-light text-warning fw-bold">Acción</span>
                </div>
                <h6 class="txt-title fw-bold mb-1">Listos para Evaluar</h6>
                <h3 class="text-warning fw-bold mb-2">@Model.ReadyToEvaluate</h3>
                <p class="text-muted text-xs mb-0">
                    <i class="bi bi-arrow-right-short"></i> 80% de avance completado
                </p>
            </div>
        </div>

        <!-- Card 3: Evaluados -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-card-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column border-theme">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="icon-circle-lg bg-success-light text-success">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <span class="badge bg-success-light text-success fw-bold">Completado</span>
                </div>
                <h6 class="txt-title fw-bold mb-1">Evaluados</h6>
                <h3 class="text-success fw-bold mb-2">@Model.Evaluated</h3>
                <p class="text-muted text-xs mb-0">
                    <i class="bi bi-arrow-right-short"></i> Con calificación asignada
                </p>
            </div>
        </div>

        <!-- Card 4: Promedio Horas -->
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="admin-card-white p-4 rounded-4 shadow-sm h-100 d-flex flex-column border-theme">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="icon-circle-lg bg-info-light text-info">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <span class="badge bg-info-light text-info fw-bold">Promedio</span>
                </div>
                <h6 class="txt-title fw-bold mb-1">Horas Promedio</h6>
                <h3 class="text-info fw-bold mb-2">@Model.AverageHours.ToString("F1")</h3>
                <p class="text-muted text-xs mb-0">
                    <i class="bi bi-arrow-right-short"></i> Horas aprobadas por alumno
                </p>
            </div>
        </div>
    </div>

    <!-- SECONDARY METRICS SECTION -->
    <div class="row g-3 mt-2">
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="icon-circle-lg bg-danger-light text-danger">
                        <i class="bi bi-file-earmark-exclamation"></i>
                    </div>
                    <div>
                        <h6 class="txt-title fw-bold mb-0">Documentos Pendientes</h6>
                        <p class="text-muted text-xs mb-0">Que requieren revisión</p>
                    </div>
                </div>
                <h3 class="text-danger fw-bold">@Model.PendingDocuments</h3>
                <a href="@Url.Action("RevisionDocumentos")" class="btn btn-sm btn-outline-danger mt-3">
                    <i class="bi bi-arrow-right me-1"></i> Revisar Documentos
                </a>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="icon-circle-lg bg-success-light text-success">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <div>
                        <h6 class="txt-title fw-bold mb-0">Estado de Evaluación</h6>
                        <p class="text-muted text-xs mb-0">Aprueba horas y calificaciones</p>
                    </div>
                </div>
                <h3 class="text-success fw-bold">@(Model.TotalStudents - Model.Evaluated) Pendientes</h3>
                <a href="@Url.Action("Evaluaciones")" class="btn btn-sm btn-outline-success mt-3">
                    <i class="bi bi-arrow-right me-1"></i> Ir a Evaluaciones
                </a>
            </div>
        </div>
    </div>

    <!-- RECENT STUDENTS SECTION -->
    @if (Model.RecentStudents.Any())
    {
        <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme">
            <div class="mb-4 pb-3 border-bottom border-theme">
                <h6 class="txt-title fw-bold mb-0">Estudiantes Recientes</h6>
                <p class="text-muted text-xs mb-0">Últimos asignados a tu seguimiento</p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="text-muted text-xs text-uppercase fw-bold border-bottom border-theme">
                        <tr>
                            <th>Estudiante</th>
                            <th>Matrícula</th>
                            <th>Programa</th>
                            <th>Progreso</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in Model.RecentStudents)
                        {
                            <tr class="border-bottom border-light">
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-sm bg-primary-light text-primary fw-bold d-flex align-items-center justify-content-center">
                                            @student.Initials
                                        </div>
                                        <div>
                                            <h6 class="txt-title fw-bold mb-0">@student.StudentName</h6>
                                            <p class="text-muted text-xs mb-0">@student.OrganizationName</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark fw-bold">@student.Matricula</span>
                                </td>
                                <td>
                                    <span class="text-sm fw-bold">@student.ProgramName</span>
                                    <br />
                                    <span class="text-xs text-muted">@student.ProgramType</span>
                                </td>
                                <td>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-primary" role="progressbar" 
                                             style="width: @student.ProgressPercent%;" 
                                             aria-valuenow="@student.ProgressPercent" 
                                             aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <p class="text-xs text-muted mt-2 mb-0">
                                        @student.ApprovedHours.ToString("F1") / @student.RequiredHours hrs
                                    </p>
                                </td>
                                <td class="text-end">
                                    <a href="@Url.Action("BitacoraSeguimiento", new { assignmentId = student.AssignmentId })" 
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i> Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3 pt-3 border-top border-theme text-center">
                <a href="@Url.Action("AlumnosAsignados")" class="btn btn-sm btn-ghost-sep">
                    Ver Todos los Estudiantes <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="alert bg-light border border-theme rounded-4 p-4 text-center">
            <i class="bi bi-inbox" style="font-size: 2rem; color: #6c757d;"></i>
            <h6 class="mt-3 fw-bold text-muted">No hay estudiantes asignados</h6>
            <p class="text-muted text-sm mb-0">Aún no tienes estudiantes asignados para seguimiento</p>
        </div>
    }

    <!-- QUICK NAVIGATION -->
    <div class="row g-3 mt-2">
        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("AlumnosAsignados")" class="text-decoration-none">
                <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme text-center hover-lift">
                    <div class="icon-circle-lg bg-primary-light text-primary mx-auto mb-3">
                        <i class="bi bi-person-video3"></i>
                    </div>
                    <h6 class="txt-title fw-bold">Mis Estudiantes</h6>
                    <p class="text-muted text-xs mb-0">Ver lista completa</p>
                </div>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("RevisionDocumentos")" class="text-decoration-none">
                <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme text-center hover-lift">
                    <div class="icon-circle-lg bg-warning-light text-warning mx-auto mb-3">
                        <i class="bi bi-file-earmark-check"></i>
                    </div>
                    <h6 class="txt-title fw-bold">Revisión de Docs</h6>
                    <p class="text-muted text-xs mb-0">Aprobar/Rechazar</p>
                </div>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("Evaluaciones")" class="text-decoration-none">
                <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme text-center hover-lift">
                    <div class="icon-circle-lg bg-success-light text-success mx-auto mb-3">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h6 class="txt-title fw-bold">Evaluaciones</h6>
                    <p class="text-muted text-xs mb-0">Calificar estudiantes</p>
                </div>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("AlumnosAsignados")" class="text-decoration-none">
                <div class="admin-card-white p-4 rounded-4 shadow-sm border-theme text-center hover-lift">
                    <div class="icon-circle-lg bg-info-light text-info mx-auto mb-3">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <h6 class="txt-title fw-bold">Horas</h6>
                    <p class="text-muted text-xs mb-0">Seguimiento de horas</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: all 0.3s ease;
    }

    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1) !important;
    }
</style>
