@model ControlEscolar.ViewModels.OperationalTracking.AsesorEvaluacionesPageViewModel
@{
    ViewData["Title"] = "Evaluaciones Académicas";
    Layout = "_LayoutTutor";
}

<div class="d-flex flex-column gap-4 fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success text-success rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-danger-100 border border-danger text-danger rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold txt-primary-dark">@Model.TotalStudents</div>
                <div class="txt-body text-xs fw-bold tracking-wide">ESTUDIANTES ASIGNADOS</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-info">@Model.ReadyToEvaluate</div>
                <div class="txt-body text-xs fw-bold tracking-wide">LISTOS PARA EVALUAR</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-success">@Model.Evaluated</div>
                <div class="txt-body text-xs fw-bold tracking-wide">YA EVALUADOS</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-warning">@Model.AverageScore</div>
                <div class="txt-body text-xs fw-bold tracking-wide">PROMEDIO GENERAL</div>
            </div>
        </div>
    </div>

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <form method="get" class="d-flex flex-column flex-md-row gap-3 flex-grow-1 w-100" style="max-width: 1000px;">
            <div class="position-relative search-wrapper flex-grow-1">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" name="search" class="form-control search-input-custom tab-search"
                       placeholder="Buscar por alumno o matrícula..." value="@Model.SearchText">
            </div>

            <select name="status" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 180px;">
                <option value="">Estado de Evaluación</option>
                <option value="READY" selected="@(Model.StatusFilter == "READY")">Listos para Evaluar</option>
                <option value="EVALUATED" selected="@(Model.StatusFilter == "EVALUATED")">Ya Evaluados</option>
                <option value="PENDING" selected="@(Model.StatusFilter == "PENDING")">Pendientes</option>
            </select>

            <div class="d-flex gap-2 flex-shrink-0">
                <button type="submit" class="btn btn-primary-sep d-flex align-items-center gap-2 shadow-sm bg-primary-900 text-white">
                    <i class="bi bi-funnel-fill"></i> Filtrar
                </button>
                <a href="@Url.Action("Evaluaciones")" class="btn btn-ghost-sep d-flex align-items-center gap-2 shadow-sm">
                    <i class="bi bi-x-lg"></i> Limpiar
                </a>
            </div>
        </form>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden d-flex flex-column">
        <div class="table-responsive bg-surface">
            <table class="table table-borderless align-middle mb-0" style="min-width: 1100px;">
                <thead class="admin-table-header">
                    <tr>
                        <th class="py-3 px-4">Estudiante</th>
                        <th class="py-3">Programa</th>
                        <th class="py-3 text-center">Progreso</th>
                        <th class="py-3 text-center">Calificación</th>
                        <th class="py-3 text-center">Estado</th>
                        <th class="py-3 text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 txt-body">
                                <i class="bi bi-graph-up-arrow fs-2 d-block mb-2 opacity-50"></i>
                                <span>No hay estudiantes para evaluar.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        var programLabel = row.ProgramType switch
                        {
                            "SERVICIO_SOCIAL" => "Servicio Social",
                            "PRACTICAS_PROFESIONALES" => "Estadías Profesionales",
                            "DUAL" => "Educación Dual",
                            _ => row.ProgramType
                        };
                        var progressColor = row.ProgressPercent >= 100
                            ? "bg-success"
                            : row.ProgressPercent >= 50 ? "bg-primary-900" : "bg-warning";
                        var evalStatus = row.IsEvaluated
                            ? ("status-aceptado", "EVALUADO")
                            : row.ProgressPercent >= 80
                                ? ("bg-info text-white", "LISTO")
                                : ("bg-secondary text-white", "EN PROGRESO");
                        <tr class="border-bottom border-theme hover-bg-app">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-md avatar-sm bg-accent-light txt-primary-dark fw-bold flex-shrink-0">@row.Initials</div>
                                    <div>
                                        <div class="txt-title fw-bold text-sm mb-1">@row.StudentName</div>
                                        <div class="txt-body text-xs">Mat: @row.Matricula</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="txt-title fw-bold text-sm">@programLabel</div>
                                <div class="txt-body text-xxs">@row.ProgramName</div>
                            </td>
                            <td class="text-center">
                                <div class="txt-title fw-bold text-xxs mb-1">@row.ProgressPercent%</div>
                                <div class="progress" style="height: 6px; width: 80px; margin: 0 auto; background-color: var(--bg-main);">
                                    <div class="progress-bar @progressColor" style="width: @row.ProgressPercent%"></div>
                                </div>
                                <div class="txt-body text-xxs mt-1">@row.ApprovedHours / @row.RequiredHours hrs</div>
                            </td>
                            <td class="text-center">
                                @if (row.IsEvaluated)
                                {
                                    <div class="txt-title fw-bold fs-5 text-success">@row.EvaluationScore!.Value.ToString("F1")</div>
                                }
                                else
                                {
                                    <span class="text-muted text-sm fst-italic">Sin asignar</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @evalStatus.Item1 text-xxs px-2 py-1 shadow-sm">@evalStatus.Item2</span>
                            </td>
                            <td class="text-end px-4">
                                <button class="btn btn-sm @(row.IsEvaluated ? "btn-ghost-sep text-primary" : "btn-primary-sep bg-primary-900 text-white") px-3 shadow-sm"
                                        data-bs-toggle="modal" data-bs-target="#modalEvaluar"
                                        data-assignment-id="@row.AssignmentId"
                                        data-student-name="@row.StudentName"
                                        data-score="@(row.EvaluationScore?.ToString("F1") ?? "")"
                                        data-notes="@(row.EvaluationNotes ?? "")">
                                    @if (row.IsEvaluated)
                                    {
                                        <i class="bi bi-pencil-square me-1"></i>
                                        <span>Editar</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star-fill me-1"></i>
                                        <span>Evaluar</span>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Rows.Any())
        {
            <div class="p-3 border-top border-theme bg-app">
                <span class="txt-body text-xs">@Model.Rows.Count estudiante(s) mostrado(s)</span>
            </div>
        }
    </div>
</div>

<!-- Modal Evaluar -->
<div class="modal fade" id="modalEvaluar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-theme shadow-sm rounded-4 overflow-hidden bg-surface">
            <form asp-action="GuardarEvaluacion" asp-controller="AsesorAcademico" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="evalAssignmentId" name="assignmentId" value="" />
                <div class="modal-header border-bottom border-theme p-4">
                    <h5 class="modal-title txt-title fw-bold">
                        <i class="bi bi-star-fill me-2 text-primary"></i> Asignar Calificación Final
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="bg-white p-3 rounded-3 border border-theme mb-4">
                        <div class="txt-body text-xxs fw-bold mb-1">ESTUDIANTE</div>
                        <div class="txt-title fw-bold" id="evalStudentName">—</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">CALIFICACIÓN (0-10)</label>
                            <input type="number" id="evalScore" name="score" class="form-control bg-app border-theme txt-title fw-bold"
                                   min="0" max="10" step="0.1" placeholder="0.0" required>
                        </div>
                        <div class="col-md-12">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">OBSERVACIONES</label>
                            <textarea id="evalNotes" name="notes" class="form-control bg-app border-theme text-sm" rows="3"
                                      placeholder="Comentarios sobre el desempeño..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-theme bg-app p-3">
                    <button type="button" class="btn btn-ghost-sep" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-sep bg-primary-900 shadow-sm text-white px-4">
                        Guardar Evaluación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('modalEvaluar').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('evalAssignmentId').value = btn.getAttribute('data-assignment-id');
            document.getElementById('evalStudentName').textContent = btn.getAttribute('data-student-name');
            var score = btn.getAttribute('data-score');
            document.getElementById('evalScore').value = score || '';
            document.getElementById('evalNotes').value = btn.getAttribute('data-notes') || '';
        });
    </script>
}
