@model ControlEscolar.ViewModels.OperationalTracking.AsesorEvaluacionesPageViewModel
@{
    var isGlobalView = ViewBag.IsGlobalAdvisorView is bool flag && flag;
    var moduleFilter = ViewBag.ModuleFilter as string ?? "";
    var roleScopedModule = ViewBag.RoleScopedModule as string ?? "";
    ViewData["Title"] = isGlobalView ? "Evaluaciones Académicas Globales" : "Evaluaciones Académicas";
    Layout = isGlobalView ? "_LayoutCoordinador" : "_LayoutTutor";
    var hasAttention = Model.ReadyToEvaluate > 0;
}

<div class="fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success text-success rounded-3 alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-danger-100 border border-danger text-danger rounded-3 alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="catalog-filter-card mb-4">
        <div class="d-flex flex-column gap-2">
            <h1 class="txt-title fw-bold mb-0">@(isGlobalView ? "Evaluaciones Académicas Globales" : "Evaluaciones Académicas")</h1>
            <p class="text-muted text-sm mb-0">Revisa bitácoras/reportes semanales, aprueba horas y luego registra la evaluación final.</p>
        </div>
    </div>

    @if (hasAttention)
    {
        <div class="admin-card-white p-3 mb-4 shadow-sm" style="border-left: 4px solid var(--warning-700, #f59e0b) !important; background: linear-gradient(135deg, #fffbeb 0%, #ffffff 100%);">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-bell-fill" style="color: var(--warning-700, #f59e0b); font-size: 1.1rem;"></i>
                <span class="fw-bold txt-title text-xs text-uppercase tracking-wide">Requiere Atención</span>
            </div>
            <div class="d-flex flex-wrap gap-3">
                <a href="#tablaEvaluaciones" class="d-flex align-items-center gap-2 bg-surface p-2 px-3 rounded-3 border text-decoration-none">
                    <span class="badge bg-warning text-dark">@Model.ReadyToEvaluate</span>
                    <span class="text-xs txt-title fw-semibold">sin pendientes y listos para evaluación</span>
                </a>
            </div>
        </div>
    }

    <div class="catalog-filter-card mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="section-label text-muted mb-2 d-block">Buscar Alumno o Matrícula</label>
                <div class="position-relative search-wrapper">
                    <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                    <input type="text" name="search" class="form-control search-input-custom tab-search"
                           placeholder="Nombre o matrícula..." value="@Model.SearchText">
                </div>
            </div>

            @if (isGlobalView)
            {
                if (string.IsNullOrWhiteSpace(roleScopedModule))
                {
                    <div class="col-md-3">
                        <label class="section-label text-muted mb-2 d-block">Módulo</label>
                        <select name="module" class="form-select text-sm fw-semibold">
                            <option value="">Todos los módulos</option>
                            <option value="PRACTICAS_PROFESIONALES" selected="@(moduleFilter == "PRACTICAS_PROFESIONALES")">Módulo Dual</option>
                            <option value="SERVICIO_SOCIAL" selected="@(moduleFilter == "SERVICIO_SOCIAL")">Servicio Social</option>
                        </select>
                    </div>
                }
                else
                {
                    <div class="col-md-3">
                        <label class="section-label text-muted mb-2 d-block">Módulo</label>
                        <input type="hidden" name="module" value="@roleScopedModule" />
                        <div class="form-control bg-app fw-semibold">@(roleScopedModule == "PRACTICAS_PROFESIONALES" ? "Módulo Dual" : "Servicio Social")</div>
                    </div>
                }
            }

            <div class="col-md-3">
                <label class="section-label text-muted mb-2 d-block">Estado de Evaluación</label>
                <select name="status" class="form-select text-sm fw-semibold">
                    <option value="">Todos</option>
                    <option value="READY" selected="@(Model.StatusFilter == "READY")">Listos para Evaluar</option>
                    <option value="PENDING" selected="@(Model.StatusFilter == "PENDING")">Pendientes de Aprobación</option>
                    <option value="EVALUATED" selected="@(Model.StatusFilter == "EVALUATED")">Ya Evaluados</option>
                </select>
            </div>

            <div class="col-md-@(isGlobalView ? "2" : "5") d-flex gap-2 flex-wrap">
                <button type="submit" class="btn-primary-sep text-xs px-4">
                    <i class="bi bi-funnel me-2"></i> FILTRAR
                </button>
                <a href="@Url.Action("Evaluaciones")" class="btn-ghost-sep text-xs px-4 bg-surface">LIMPIAR</a>
            </div>
        </form>
    </div>

    <div class="catalog-table-card mb-4" id="tablaEvaluaciones">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0" id="tblEvaluaciones" style="min-width: 1200px;">
                <thead>
                    <tr>
                        <th class="px-4">Estudiante</th>
                        @if (isGlobalView)
                        {
                            <th>Asesor</th>
                        }
                        <th>Programa</th>
                        <th class="text-center">Reportes</th>
                        <th class="text-center">Progreso</th>
                        <th class="text-center">Calificación</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rows.Any())
                    {
                        <tr>
                            <td colspan="@(isGlobalView ? 8 : 7)">
                                <div class="catalog-empty">
                                    <i class="bi bi-graph-up-arrow"></i>
                                    <span>Sin registros disponibles</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model.Rows)
                    {
                        var programLabel = row.ProgramType switch
                        {
                            "SERVICIO_SOCIAL" => "Servicio Social",
                            "PRACTICAS_PROFESIONALES" => "Estadías Profesionales",
                            _ => row.ProgramType
                        };
                        var progressColor = row.ProgressPercent >= 100
                            ? "bg-success"
                            : row.ProgressPercent >= 50 ? "bg-primary-900" : "bg-warning";
                        var evalStatus = row.IsEvaluated
                            ? ("status-aceptado", "EVALUADO")
                            : row.HasPendingReports
                                ? ("bg-warning text-dark", "PENDIENTE APROBACIÓN")
                                : row.ReadyForEvaluation
                                    ? ("bg-info text-white", "LISTO PARA EVALUAR")
                                    : ("bg-secondary text-white", "EN PROCESO");
                        <tr class="data-row">
                            <td class="px-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-md avatar-sm bg-accent-light txt-primary-dark fw-bold flex-shrink-0">@row.Initials</div>
                                    <div>
                                        <div class="txt-title fw-bold text-sm mb-1">@row.StudentName</div>
                                        <div class="txt-body text-xs">Mat: @row.Matricula</div>
                                    </div>
                                </div>
                            </td>
                            @if (isGlobalView)
                            {
                                <td>
                                    <div class="txt-title fw-bold text-sm">@row.AdvisorName</div>
                                </td>
                            }
                            <td>
                                <div class="txt-title fw-bold text-sm">@programLabel</div>
                                <div class="txt-body text-xxs">@row.ProgramName</div>
                            </td>
                            <td class="text-center">
                                <div class="txt-title fw-bold text-xxs mb-1">@row.ApprovedReports aprob. / @row.PendingReports pend.</div>
                                <span class="badge bg-light border border-theme text-dark text-xxs px-2 py-1">Total: @row.TotalReports</span>
                            </td>
                            <td class="text-center">
                                <div class="txt-title fw-bold text-xxs mb-1">@row.ProgressPercent%</div>
                                <div class="progress" style="height: 6px; width: 80px; margin: 0 auto; background-color: var(--bg-main);">
                                    <div class="progress-bar @progressColor" style="width: @row.ProgressPercent%"></div>
                                </div>
                                <div class="txt-body text-xxs mt-1">@row.ApprovedHours / @row.RequiredHours hrs</div>
                            </td>
                            <td class="text-center">
                                @if (row.IsEvaluated)
                                {
                                    <div class="txt-title fw-bold fs-5 text-success">@row.EvaluationScore!.Value.ToString("F1")</div>
                                }
                                else
                                {
                                    <span class="text-muted text-sm fst-italic">Sin asignar</span>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge @evalStatus.Item1 text-xxs px-2 py-1 shadow-sm">@evalStatus.Item2</span>
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="AprobarHorasPendientes" asp-controller="AsesorAcademico" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="assignmentId" value="@row.AssignmentId" />
                                        <button type="submit" class="btn-action btn-action-toggle-on" title="Aprobar reportes y horas" @(row.PendingReports == 0 ? "disabled" : "")>
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <button type="button"
                                            class="btn-action btn-action-delete"
                                            title="Rechazar reportes pendientes"
                                            @(row.PendingReports == 0 ? "disabled" : "")
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalRechazarHoras"
                                            data-assignment-id="@row.AssignmentId"
                                            data-student-name="@row.StudentName">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                    <button type="button"
                                            class="btn-action btn-action-edit"
                                            title="Asignar horas manualmente"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalHorasManual"
                                            data-assignment-id="@row.AssignmentId"
                                            data-student-name="@row.StudentName"
                                            data-approved-hours="@row.ApprovedHours"
                                            data-total-hours="@row.TotalHours">
                                        <i class="bi bi-clock-history"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Rows.Any())
        {
            <div class="catalog-pagination-bar">
                <div class="d-flex align-items-center gap-3">
                    <span class="rows-label">MOSTRAR:</span>
                    <select id="tblEvaluacionesRpp" class="form-select form-select-sm rows-per-page">
                        <option value="5">5</option>
                        <option value="10" selected>10</option>
                        <option value="20">20</option>
                    </select>
                    <div id="tblEvaluacionesCount" class="info-label"></div>
                </div>
                <nav aria-label="Paginación evaluaciones asesoría">
                    <ul class="pagination pagination-sm mb-0" id="tblEvaluacionesPagination"></ul>
                </nav>
            </div>
        }
    </div>
</div>

<!-- Modal Horas Manual -->
<div class="modal fade" id="modalHorasManual" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden bg-white">
            <form asp-action="AsignarHorasManual" asp-controller="AsesorAcademico" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="manualAssignmentId" name="assignmentId" value="" />
                <div class="modal-header bg-surface border-bottom border-theme p-4">
                    <h5 class="modal-title txt-title fw-bold">
                        <i class="bi bi-clock-history me-2 text-primary"></i> Asignar Horas Manualmente
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-white">
                    <div class="bg-white p-3 rounded-3 border border-theme mb-4">
                        <div class="txt-body text-xxs fw-bold mb-1">ESTUDIANTE</div>
                        <div class="txt-title fw-bold" id="manualStudentName">—</div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">HORAS APROBADAS</label>
                            <input type="number" id="manualApprovedHours" name="approvedHours" class="form-control bg-app border-theme txt-title fw-bold"
                                   min="0" step="0.1" placeholder="0.0" required>
                        </div>
                        <div class="col-md-6">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">HORAS REGISTRADAS</label>
                            <input type="text" id="manualTotalHours" class="form-control bg-light" readonly>
                        </div>
                        <div class="col-md-12">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">OBSERVACIONES</label>
                            <textarea id="manualNotes" name="comments" class="form-control bg-app border-theme text-sm" rows="3"
                                      placeholder="Justificación del ajuste manual de horas..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top border-theme bg-surface p-3">
                    <button type="button" class="btn btn-ghost-sep" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-sep bg-primary-900 shadow-sm text-white px-4">
                        Guardar Horas
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Rechazo Horas -->
<div class="modal fade" id="modalRechazarHoras" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden bg-white">
            <form asp-action="RechazarHorasPendientes" asp-controller="AsesorAcademico" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="rechazoAssignmentId" name="assignmentId" value="" />
                <div class="modal-header bg-surface border-bottom border-theme p-4">
                    <h5 class="modal-title txt-title fw-bold">
                        <i class="bi bi-exclamation-circle-fill me-2 text-danger"></i> Rechazar Reportes Pendientes
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-white">
                    <div class="bg-white p-3 rounded-3 border border-theme mb-4">
                        <div class="txt-body text-xxs fw-bold mb-1">ESTUDIANTE</div>
                        <div class="txt-title fw-bold" id="rechazoStudentName">—</div>
                    </div>
                    <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">COMENTARIOS *</label>
                    <textarea name="comments" class="form-control bg-app border-theme text-sm" rows="4" required
                              placeholder="Explica al alumno qué debe corregir en su bitácora/reporte semanal..."></textarea>
                </div>
                <div class="modal-footer border-top border-theme bg-surface p-3">
                    <button type="button" class="btn btn-ghost-sep" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-sep bg-danger text-white shadow-sm px-4">
                        Rechazar Reportes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var table = document.getElementById('tblEvaluaciones');
            if (!table) return;

            var rows = Array.from(table.querySelectorAll('tbody tr.data-row'));
            if (!rows.length) return;

            var pageSize = 10;
            var page = 1;
            var total = rows.length;

            var countEl = document.getElementById('tblEvaluacionesCount');
            var rppEl = document.getElementById('tblEvaluacionesRpp');
            var paginationEl = document.getElementById('tblEvaluacionesPagination');

            function buildPagination(totalPages) {
                if (!paginationEl) return;
                paginationEl.innerHTML = '';

                function createItem(label, targetPage, disabled, active) {
                    var li = document.createElement('li');
                    li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');
                    var link = document.createElement('a');
                    link.className = 'page-link';
                    link.href = '#';
                    link.innerHTML = label;
                    if (!disabled) {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            page = targetPage;
                            render();
                        });
                    }
                    li.appendChild(link);
                    paginationEl.appendChild(li);
                }

                createItem('<i class="bi bi-chevron-left"></i>', Math.max(1, page - 1), page === 1, false);
                for (var i = 1; i <= totalPages; i++) {
                    createItem(String(i), i, false, i === page);
                }
                createItem('<i class="bi bi-chevron-right"></i>', Math.min(totalPages, page + 1), page === totalPages, false);
            }

            function render() {
                var totalPages = Math.max(1, Math.ceil(total / pageSize));
                if (page > totalPages) page = totalPages;

                var start = (page - 1) * pageSize;
                var end = Math.min(start + pageSize, total);

                rows.forEach(function (row, index) {
                    row.style.display = (index >= start && index < end) ? '' : 'none';
                });

                if (countEl) {
                    countEl.textContent = (start + 1) + ' - ' + end + ' DE ' + total;
                }

                buildPagination(totalPages);
            }

            if (rppEl) {
                rppEl.addEventListener('change', function () {
                    pageSize = parseInt(rppEl.value, 10);
                    page = 1;
                    render();
                });
            }

            render();
        })();

        document.getElementById('modalHorasManual').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('manualAssignmentId').value = btn.getAttribute('data-assignment-id');
            document.getElementById('manualStudentName').textContent = btn.getAttribute('data-student-name');
            document.getElementById('manualApprovedHours').value = btn.getAttribute('data-approved-hours') || '0';
            document.getElementById('manualTotalHours').value = btn.getAttribute('data-total-hours') || '0';
            document.getElementById('manualNotes').value = '';
        });

        document.getElementById('modalRechazarHoras').addEventListener('show.bs.modal', function (event) {
            var btn = event.relatedTarget;
            document.getElementById('rechazoAssignmentId').value = btn.getAttribute('data-assignment-id');
            document.getElementById('rechazoStudentName').textContent = btn.getAttribute('data-student-name');
        });
    </script>
}
