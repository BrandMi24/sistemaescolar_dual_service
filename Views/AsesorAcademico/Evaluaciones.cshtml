@{
    ViewData["Title"] = "Evaluaciones Académicas";
    Layout = "_LayoutTutor";
    var search = Context.Request.Query["search"].ToString();
}

<div class="d-flex flex-column gap-4 fade-in">

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold txt-primary-dark">12</div>
                <div class="txt-body text-xs fw-bold tracking-wide">ESTUDIANTES ASIGNADOS</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-info">8</div>
                <div class="txt-body text-xs fw-bold tracking-wide">LISTOS PARA EVALUAR</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-success">4</div>
                <div class="txt-body text-xs fw-bold tracking-wide">YA EVALUADOS</div>
            </div>
        </div>
        <div class="col-lg-3">
            <div class="admin-card-white p-4 rounded-4 border-theme shadow-sm h-100 d-flex flex-column bg-white text-center">
                <div class="fs-1 fw-bold text-warning">9.2</div>
                <div class="txt-body text-xs fw-bold tracking-wide">PROMEDIO GENERAL</div>
            </div>
        </div>
    </div>

    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <form method="get" class="d-flex flex-column flex-md-row gap-3 flex-grow-1 w-100" style="max-width: 1000px;">
            <div class="position-relative search-wrapper flex-grow-1">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" name="search" class="form-control search-input-custom tab-search" placeholder="Buscar por alumno o matrícula..." value="@search">
            </div>
            
            <select name="status" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 180px;">
                <option value="">Estado de Evaluación</option>
                <option value="READY">Listos para Evaluar</option>
                <option value="EVALUATED">Ya Evaluados</option>
                <option value="PENDING">Pendientes</option>
            </select>

            <div class="d-flex gap-2 flex-shrink-0">
                <button type="submit" class="btn btn-primary-sep d-flex align-items-center gap-2 shadow-sm bg-primary-900 text-white">
                    <i class="bi bi-funnel-fill"></i> Filtrar
                </button>
                <a href="@Url.Action("Evaluaciones")" class="btn btn-ghost-sep d-flex align-items-center gap-2 shadow-sm">
                    <i class="bi bi-x-lg"></i> Limpiar
                </a>
            </div>
        </form>
    </div>

    <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden d-flex flex-column">
        <div class="table-responsive bg-surface">
            <table class="table table-borderless align-middle mb-0" style="min-width: 1100px;">
                <thead class="admin-table-header">
                    <tr>
                        <th class="py-3 px-4">Estudiante</th>
                        <th class="py-3">Programa / Requisitos</th>
                        <th class="py-3 text-center">Progreso</th>
                        <th class="py-3 text-center">Calificación</th>
                        <th class="py-3 text-center">Estado</th>
                        <th class="py-3 text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-bottom border-theme hover-bg-app">
                        <td class="px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-md avatar-sm bg-accent-light txt-primary-dark fw-bold flex-shrink-0">RC</div>
                                <div>
                                    <div class="txt-title fw-bold text-sm mb-1">Roberto Carlos Perez Cadena</div>
                                    <div class="txt-body text-xs">Mat: 24001504</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><small class="txt-body">Documentos OK</small></span>
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><small class="txt-body">Horas (600/600)</small></span>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="txt-title fw-bold text-xxs mb-1">100%</div>
                            <div class="progress" style="height: 6px; width: 80px; margin: 0 auto; background-color: var(--bg-main);">
                                <div class="progress-bar bg-success" style="width: 100%"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="text-muted text-sm italic">Sin asignar</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info text-white text-xxs px-2 py-1 shadow-sm">LISTO</span>
                        </td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-primary-sep bg-primary-900 text-white px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalEvaluar">
                                <i class="bi bi-star-fill me-1"></i> Evaluar
                            </button>
                        </td>
                    </tr>

                    <tr class="border-bottom border-theme hover-bg-app">
                        <td class="px-4 py-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-md avatar-sm bg-app border border-theme txt-title fw-bold flex-shrink-0">LA</div>
                                <div>
                                    <div class="txt-title fw-bold text-sm mb-1">Luis Ángel García</div>
                                    <div class="txt-body text-xs">Mat: 24001892</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><small class="txt-body">Documentos OK</small></span>
                                <span><i class="bi bi-check-circle-fill text-success me-1"></i><small class="txt-body">Horas (480/480)</small></span>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="txt-title fw-bold text-xxs mb-1">100%</div>
                            <div class="progress" style="height: 6px; width: 80px; margin: 0 auto; background-color: var(--bg-main);">
                                <div class="progress-bar bg-success" style="width: 100%"></div>
                            </div>
                        </td>
                        <td class="text-center">
                            <div class="txt-title fw-bold fs-5 text-success">9.5</div>
                        </td>
                        <td class="text-center">
                            <span class="badge status-aceptado text-xxs px-2 py-1 shadow-sm">EVALUADO</span>
                        </td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-ghost-sep text-primary px-3" data-bs-toggle="modal" data-bs-target="#modalEvaluar">
                                <i class="bi bi-pencil-square me-1"></i> Editar
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEvaluar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-theme shadow-sm rounded-4 overflow-hidden bg-surface">
            <form action="#" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom border-theme p-4">
                    <h5 class="modal-title txt-title fw-bold">
                        <i class="bi bi-star-fill me-2 text-primary"></i> Asignar Calificación Final
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                
                <div class="modal-body p-4">
                    <div class="bg-white p-3 rounded-3 border border-theme mb-4">
                        <div class="txt-body text-xxs fw-bold mb-1">ESTUDIANTE SELECCIONADO</div>
                        <div class="txt-title fw-bold">Roberto Carlos Perez Cadena</div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">CALIFICACIÓN</label>
                            <input type="number" name="score" class="form-control bg-app border-theme txt-title fw-bold" min="0" max="10" step="0.1" placeholder="0.0" required>
                        </div>
                        <div class="col-md-12">
                            <label class="txt-body text-xs fw-bold tracking-wide mb-2 d-block">OBSERVACIONES FINALIZACIÓN</label>
                            <textarea name="notes" class="form-control bg-app border-theme text-sm" rows="3" placeholder="Comentarios sobre el desempeño..."></textarea>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer border-top border-theme bg-app p-3">
                    <button type="button" class="btn btn-ghost-sep" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary-sep bg-primary-900 shadow-sm text-white px-4">Guardar Evaluación</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Auto-ocultar alertas
            setTimeout(function () {
                $('.alert-dismissible').fadeOut('slow');
            }, 4000);
        });
    </script>
}