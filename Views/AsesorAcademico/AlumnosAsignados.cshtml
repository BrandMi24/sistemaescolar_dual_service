@model List<ControlEscolar.ViewModels.OperationalTracking.AsesorAlumnoRowViewModel>
@{
    ViewData["Title"] = "Mis Estudiantes Asignados";
    Layout = "_LayoutTutor";
    var search = ViewBag.SearchText as string ?? "";
    var programaFilter = ViewBag.ProgramaFilter as string ?? "";
}

<div class="d-flex flex-column gap-4 fade-in">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert bg-success bg-opacity-10 border border-success text-success rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert bg-danger-100 border border-danger text-danger rounded-3 alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- HEADER -->
    <div class="d-flex flex-column gap-2">
        <h1 class="txt-title fw-bold mb-0">Mis Estudiantes Asignados</h1>
        <p class="text-muted text-sm mb-0">Gestiona y supervisa el progreso de tus estudiantes</p>
    </div>

    <!-- FILTERS -->
    <div class="bg-surface p-4 rounded-4 border-theme shadow-sm d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <form method="get" class="d-flex flex-column flex-md-row gap-3 flex-grow-1 w-100" style="max-width: 1000px;">
            <div class="position-relative search-wrapper flex-grow-1">
                <i class="bi bi-search position-absolute search-icon-left txt-body"></i>
                <input type="text" name="search" class="form-control search-input-custom tab-search" placeholder="Buscar por alumno o matrícula..." value="@search">
            </div>

            <select name="programa" class="form-select bg-app border-theme txt-title fw-bold tab-filter" style="width: auto; min-width: 180px;">
                <option value="">Todos los Programas</option>
                <option value="SERVICIO_SOCIAL" selected="@(programaFilter == "SERVICIO_SOCIAL")">Servicio Social</option>
                <option value="PRACTICAS_PROFESIONALES" selected="@(programaFilter == "PRACTICAS_PROFESIONALES")">Estadías Profesionales</option>
                <option value="DUAL" selected="@(programaFilter == "DUAL")">Educación Dual</option>
            </select>

            <div class="d-flex gap-2 flex-shrink-0">
                <button type="submit" class="btn btn-primary-sep d-flex align-items-center gap-2 shadow-sm bg-primary-900 text-white">
                    <i class="bi bi-funnel-fill"></i> Filtrar
                </button>
                <a href="@Url.Action("AlumnosAsignados")" class="btn btn-ghost-sep d-flex align-items-center gap-2 shadow-sm">
                    <i class="bi bi-x-lg"></i> Limpiar
                </a>
            </div>
        </form>
    </div>

    <!-- TABLE -->
    <div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden d-flex flex-column">
        <div class="table-responsive bg-surface">
            <table class="table table-borderless align-middle mb-0" style="min-width: 1100px;">
                <thead class="admin-table-header">
                    <tr>
                        <th class="py-3 px-4">Estudiante</th>
                        <th class="py-3">Programa</th>
                        <th class="py-3 text-center">Estado</th>
                        <th class="py-3 text-center">Horas / Progreso</th>
                        <th class="py-3 text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 txt-body">
                                <i class="bi bi-people fs-2 d-block mb-2 opacity-50"></i>
                                @if (string.IsNullOrEmpty(search) && string.IsNullOrEmpty(programaFilter))
                                {
                                    <span>No tienes estudiantes asignados aún.</span>
                                }
                                else
                                {
                                    <span>No se encontraron estudiantes con ese filtro.</span>
                                }
                            </td>
                        </tr>
                    }
                    @foreach (var row in Model)
                    {
                        var statusBadge = row.StatusCode switch
                        {
                            "COMPLETED" or "FINALIZED" => ("status-completado", "COMPLETADO"),
                            "IN_PROGRESS" => ("status-aceptado", "EN PROGRESO"),
                            "REGISTERED" => ("status-pendiente", "REGISTRADO"),
                            _ => ("bg-secondary", row.StatusCode)
                        };
                        var programLabel = row.ProgramType switch
                        {
                            "SERVICIO_SOCIAL" => "Servicio Social",
                            "PRACTICAS_PROFESIONALES" => "Estadías Profesionales",
                            "DUAL" => "Educación Dual",
                            _ => row.ProgramType
                        };
                        <tr class="border-bottom border-theme hover-bg-app data-row">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-md bg-primary-light text-primary fw-bold flex-shrink-0 d-flex align-items-center justify-content-center">
                                        @row.Initials
                                    </div>
                                    <div>
                                        <div class="txt-title fw-bold text-sm mb-1">@row.StudentName</div>
                                        <div class="txt-body text-xs">
                                            <i class="bi bi-shield-check me-1"></i> @row.Matricula
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="txt-title fw-bold text-sm mb-1">@programLabel</div>
                                <span class="badge bg-light border border-theme text-dark text-xxs px-2 py-1">
                                    <i class="bi bi-building me-1"></i> @row.OrganizationName
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge @statusBadge.Item1 text-xxs px-3 py-2 shadow-sm">@statusBadge.Item2</span>
                            </td>
                            <td class="text-center">
                                <div class="txt-title fw-bold text-sm mb-2">@row.ApprovedHours.ToString("F1") / @row.RequiredHours hrs</div>
                                <div class="d-flex align-items-center gap-2 justify-content-center">
                                    <div class="progress flex-grow-1" style="height: 6px; width: 80px; background-color: var(--bg-main);">
                                        <div class="progress-bar bg-primary" style="width: @row.ProgressPercent%"></div>
                                    </div>
                                    <span class="text-xs text-muted fw-bold">@row.ProgressPercent%</span>
                                </div>
                            </td>
                            <td class="text-end px-4">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="@Url.Action("BitacoraSeguimiento", new { assignmentId = row.AssignmentId })" 
                                       class="btn btn-outline-primary" 
                                       title="Ver bitácora de seguimiento" 
                                       data-bs-toggle="tooltip">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                    <a href="@Url.Action("RevisionDocumentos")" 
                                       class="btn btn-outline-warning" 
                                       title="Revisar documentos" 
                                       data-bs-toggle="tooltip">
                                        <i class="bi bi-file-earmark"></i>
                                    </a>
                                    <a href="@Url.Action("Evaluaciones")" 
                                       class="btn btn-outline-success" 
                                       title="Evaluar estudiante" 
                                       data-bs-toggle="tooltip">
                                        <i class="bi bi-graph-up"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Any())
        {
            <div class="p-3 border-top border-theme bg-app d-flex justify-content-between align-items-center">
                <span class="txt-body text-xs">
                    <i class="bi bi-info-circle me-1"></i>
                    @Model.Count estudiante(s) encontrado(s)
                </span>
            </div>
        }
    </div>
</div>
