@* Asegúrate de pasar un ViewModel que contenga la información necesaria para todas las pestañas, o adapta esto a tu controlador para cargar todo en un solo View *@
@{
    ViewData["Title"] = "Modelo DUAL y Estadías";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = true;
}

<div class="row g-4 align-items-start mx-auto" style="max-width: 1200px;">
    
    <div class="col-12 col-lg-4 col-xl-3 position-lg-sticky" style="top: 80px;">
        <div class="bg-white p-4 rounded-4 shadow-sm border border-light d-flex flex-column gap-4">
            
            <div class="text-center pb-3 border-bottom border-light">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 60px; height: 60px;">
                    <i class="bi bi-buildings-fill text-dark fs-3"></i>
                </div>
                <h6 class="fw-bold mb-1 txt-title">Modelo DUAL / Estadías</h6>
                <p class="text-muted text-xs mb-0">Gestión de Prácticas Profesionales</p>
                
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-xs fw-bold text-muted">Progreso General</span>
                        <span class="text-xs fw-bold text-dark">45%</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 6px;">
                        <div class="progress-bar bg-dark" role="progressbar" style="width: 45%;"></div>
                    </div>
                </div>
            </div>

            <ul class="nav flex-column nav-pills-custom" id="dualTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 active d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso1" type="button">
                        <span><i class="bi bi-person-badge me-2"></i> 1. Mis Datos</span>
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 0.8rem;"></i>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso2" type="button">
                        <span><i class="bi bi-building me-2"></i> 2. Empresa / Apoyo</span>
                        <i class="bi bi-check-circle-fill text-success d-none" style="font-size: 0.8rem;"></i>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso3" type="button">
                        <span><i class="bi bi-file-earmark-text me-2"></i> 3. Documentos CV</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso4" type="button">
                        <span><i class="bi bi-envelope-paper me-2"></i> 4. Carta Solicitud</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso5" type="button">
                        <span><i class="bi bi-people me-2"></i> 5. Asesores Asignados</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso6" type="button">
                        <span><i class="bi bi-calendar-week me-2"></i> 6. Reportes Semanales</span>
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-12 col-lg-8 col-xl-9">
        <div class="tab-content bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light">
            
            <div class="tab-pane fade show active" id="paso1" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold txt-title mb-1">1. Datos del Estudiante</h4>
                    <p class="text-muted text-sm mb-0">Información personal y académica para tu expediente.</p>
                </div>

                <form asp-action="StudentInfo" asp-controller="DualStudent" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="bg-light p-3 rounded-3 border border-light mb-4">
                        <h6 class="fw-bold text-dark text-sm mb-3"><i class="bi bi-lock-fill me-2"></i>Datos del Sistema (Solo lectura)</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Nombre Completo</label>
                                <input type="text" class="form-control custom-input bg-white text-muted" value="Roberto Carlos Perez Cadena" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">Matrícula</label>
                                <input type="text" class="form-control custom-input bg-white text-muted" value="26001504" readonly />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label-custom">CURP</label>
                                <input type="text" class="form-control custom-input bg-white text-muted" value="PECR000000XXXXXX00" readonly />
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark text-sm mb-3"><i class="bi bi-pencil-square me-2"></i>Información a Completar</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label-custom">NSS (Seguro Social) *</label>
                            <input type="text" class="form-control custom-input" name="SocialSecurityNumber" placeholder="000-00-0000" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Email Institucional *</label>
                            <input type="email" class="form-control custom-input" name="InstitutionalEmail" placeholder="26001504@uttn.mx" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Celular *</label>
                            <input type="tel" class="form-control custom-input" name="MobilePhone" placeholder="899-000-0000" />
                        </div>
                        
                        <div class="col-md-4">
                            <label class="form-label-custom">Grado *</label>
                            <select class="form-select custom-input" name="Grade">
                                <option value="">Selecciona...</option>
                                <option value="7">7° Cuatrimestre</option>
                                <option value="8">8° Cuatrimestre</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Grupo *</label>
                            <input type="text" class="form-control custom-input" name="GroupCode" placeholder="Ej: A" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-custom">Turno *</label>
                            <select class="form-select custom-input" name="Shift">
                                <option value="">Selecciona...</option>
                                <option value="Matutino">Matutino</option>
                                <option value="Vespertino">Vespertino</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-custom">Periodo de Estadías *</label>
                            <select class="form-select custom-input" name="InternshipPeriod">
                                <option value="">Selecciona...</option>
                                <option value="Enero-Junio">Enero - Junio</option>
                                <option value="Agosto-Diciembre">Agosto - Diciembre</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Año *</label>
                            <select class="form-select custom-input" name="InternshipYear">
                                <option value="2026">2026</option>
                                <option value="2027">2027</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4 text-end border-top pt-4">
                        <button type="submit" class="btn btn-outline-dark px-4 fw-bold shadow-sm">Guardar Datos <i class="bi bi-save ms-2"></i></button>
                        <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm ms-2" onclick="$('#dualTabs button[data-bs-target=\'#paso2\']').tab('show'); window.scrollTo(0,0);">Siguiente Paso <i class="bi bi-arrow-right ms-2"></i></button>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade" id="paso2" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold txt-title mb-1">2. Empresa / Apoyo de Colocación</h4>
                    <p class="text-muted text-sm mb-0">Selecciona cómo deseas realizar tus estadías.</p>
                </div>

                <form asp-action="PlacementSupport" asp-controller="DualStudent" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PlacementType" id="placementTypeInput" value="NEEDS_SUPPORT" />

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm custom-radio-card" id="card-support" onclick="selectDualType('NEEDS_SUPPORT')" style="cursor:pointer; border: 2px solid var(--primary-900) !important;">
                                <div class="card-body text-center p-4">
                                    <i class="bi bi-person-raised-hand fs-1 text-dark mb-3"></i>
                                    <h6 class="fw-bold text-dark">Necesito apoyo</h6>
                                    <p class="text-muted text-xs mb-0">La universidad me ayudará a encontrar una vacante.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm custom-radio-card bg-light" id="card-company" onclick="selectDualType('HAS_COMPANY')" style="cursor:pointer;">
                                <div class="card-body text-center p-4">
                                    <i class="bi bi-building-check fs-1 text-secondary mb-3"></i>
                                    <h6 class="fw-bold text-dark">Ya tengo empresa</h6>
                                    <p class="text-muted text-xs mb-0">Registraré los datos de la empresa donde haré estadías.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="parkSection" class="bg-light p-4 rounded-4 border border-light">
                        <h6 class="fw-bold text-dark text-sm mb-3"><i class="bi bi-geo-alt-fill me-2"></i>Selecciona tus parques industriales preferidos</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-check bg-white border rounded-3 p-3 shadow-sm d-flex align-items-center cursor-pointer">
                                    <input class="form-check-input ms-0 me-3" type="checkbox" name="SelectedParkIds" value="1" id="p1">
                                    <label class="form-check-label fw-bold text-sm w-100 cursor-pointer" for="p1">Parque Industrial Reynosa</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check bg-white border rounded-3 p-3 shadow-sm d-flex align-items-center cursor-pointer">
                                    <input class="form-check-input ms-0 me-3" type="checkbox" name="SelectedParkIds" value="2" id="p2">
                                    <label class="form-check-label fw-bold text-sm w-100 cursor-pointer" for="p2">Parque Industrial Villa Florida</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="companySection" class="d-none">
                        <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Datos de la Empresa Receptora</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Razón Social *</label>
                                <input type="text" class="form-control custom-input" name="CompanyLegalName" placeholder="Nombre legal de la empresa" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Dirección *</label>
                                <input type="text" class="form-control custom-input" name="CompanyAddress" placeholder="Dirección completa" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Contacto de RH *</label>
                                <input type="text" class="form-control custom-input" name="HRContactName" placeholder="Nombre del reclutador" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Email de RH *</label>
                                <input type="email" class="form-control custom-input" name="HRContactEmail" placeholder="correo@empresa.com" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Teléfono de RH</label>
                                <input type="tel" class="form-control custom-input" name="HRContactPhone" placeholder="899-xxx-xxxx" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Puesto del Supervisor</label>
                                <input type="text" class="form-control custom-input" name="SupervisorRole" placeholder="Ej. Gerente de TI" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 mt-md-5 d-flex flex-column-reverse flex-md-row justify-content-md-between gap-3 border-top pt-4">
                        <button type="button" class="btn text-muted fw-bold px-4" onclick="$('#dualTabs button[data-bs-target=\'#paso1\']').tab('show'); window.scrollTo(0,0);">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <div class="text-end">
                            <button type="submit" class="btn btn-outline-dark px-4 fw-bold shadow-sm">Guardar <i class="bi bi-save ms-2"></i></button>
                            <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm ms-2" onclick="$('#dualTabs button[data-bs-target=\'#paso3\']').tab('show'); window.scrollTo(0,0);">Siguiente <i class="bi bi-arrow-right ms-2"></i></button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade" id="paso3" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold txt-title mb-1">3. Documentación</h4>
                    <p class="text-muted text-sm mb-0">Sube tu Currículum y Constancia IMSS en formato PDF.</p>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="bg-white border rounded-3 p-3 text-center shadow-sm h-100">
                            <i class="bi bi-check-circle-fill text-success fs-3 mb-2 d-block"></i>
                            <h6 class="fw-bold text-dark text-sm mb-1">CV Español</h6>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success px-2">Subido</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-white border rounded-3 p-3 text-center shadow-sm h-100">
                            <i class="bi bi-x-circle text-danger fs-3 mb-2 d-block"></i>
                            <h6 class="fw-bold text-dark text-sm mb-1">CV Inglés</h6>
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2">Pendiente</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-white border rounded-3 p-3 text-center shadow-sm h-100">
                            <i class="bi bi-x-circle text-danger fs-3 mb-2 d-block"></i>
                            <h6 class="fw-bold text-dark text-sm mb-1">IMSS</h6>
                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-2">Pendiente</span>
                        </div>
                    </div>
                </div>

                <form asp-action="Documents" asp-controller="DualStudent" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div class="bg-light p-3 rounded-3 border mb-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <span class="d-block fw-bold text-sm text-dark"><i class="bi bi-file-person me-2"></i> Currículum (Español)</span>
                            <small class="text-muted text-xs">PDF. Máximo 5MB.</small>
                            <br><small class="text-success fw-bold"><i class="bi bi-check me-1"></i>mi_cv_espanol.pdf</small>
                        </div>
                        <input type="file" name="ResumeSpanishFile" class="form-control form-control-sm w-auto" accept=".pdf">
                    </div>

                    <div class="bg-light p-3 rounded-3 border mb-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <span class="d-block fw-bold text-sm text-dark"><i class="bi bi-file-person me-2"></i> Currículum (Inglés)</span>
                            <small class="text-muted text-xs">Opcional si la empresa lo requiere.</small>
                        </div>
                        <input type="file" name="ResumeEnglishFile" class="form-control form-control-sm w-auto" accept=".pdf">
                    </div>

                    <div class="bg-light p-3 rounded-3 border mb-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                        <div>
                            <span class="d-block fw-bold text-sm text-dark"><i class="bi bi-file-medical me-2"></i> Certificado IMSS</span>
                            <small class="text-muted text-xs">Vigencia de derechos descargada del IMSS.</small>
                        </div>
                        <input type="file" name="IMSSCertificateFile" class="form-control form-control-sm w-auto" accept=".pdf">
                    </div>

                    <div class="mt-4 mt-md-5 d-flex flex-column-reverse flex-md-row justify-content-md-between gap-3 border-top pt-4">
                        <button type="button" class="btn text-muted fw-bold px-4" onclick="$('#dualTabs button[data-bs-target=\'#paso2\']').tab('show'); window.scrollTo(0,0);">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <div class="text-end">
                            <button type="submit" class="btn btn-outline-dark px-4 fw-bold shadow-sm"><i class="bi bi-cloud-upload me-2"></i> Subir Archivos</button>
                            <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm ms-2" onclick="$('#dualTabs button[data-bs-target=\'#paso4\']').tab('show'); window.scrollTo(0,0);">Siguiente <i class="bi bi-arrow-right ms-2"></i></button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade" id="paso4" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold txt-title mb-1">4. Carta de Solicitud/Presentación</h4>
                    <p class="text-muted text-sm mb-0">Solicita el documento oficial de vinculación con la empresa.</p>
                </div>

                <div class="alert alert-light border border-secondary shadow-sm mb-4">
                    <i class="bi bi-info-circle me-2 text-primary-900"></i> No tienes solicitudes previas. Llena los datos para generar tu carta.
                </div>

                <form asp-action="PresentationLetter" asp-controller="DualStudent" method="post">
                    @Html.AntiForgeryToken()
                    
                    <h6 class="fw-bold text-dark border-bottom pb-2 mb-3">Datos del Destinatario (Empresa)</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label-custom">Nombre de la Empresa *</label>
                            <input type="text" class="form-control custom-input" name="CompanyName" placeholder="Razón Social Completa" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Nombre a quien va dirigida (Lic. / Ing.) *</label>
                            <input type="text" class="form-control custom-input" name="RecipientName" placeholder="Ej. Ing. Carlos López" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-custom">Puesto del Destinatario *</label>
                            <input type="text" class="form-control custom-input" name="RecipientRole" placeholder="Ej. Gerente de Recursos Humanos" />
                        </div>
                    </div>

                    <div class="mt-4 mt-md-5 d-flex flex-column-reverse flex-md-row justify-content-md-between gap-3 border-top pt-4">
                        <button type="button" class="btn text-muted fw-bold px-4" onclick="$('#dualTabs button[data-bs-target=\'#paso3\']').tab('show'); window.scrollTo(0,0);">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <div class="text-end">
                            <button type="submit" class="btn btn-outline-dark px-4 fw-bold shadow-sm"><i class="bi bi-send me-2"></i> Solicitar Carta</button>
                            <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm ms-2" onclick="$('#dualTabs button[data-bs-target=\'#paso5\']').tab('show'); window.scrollTo(0,0);">Siguiente <i class="bi bi-arrow-right ms-2"></i></button>
                        </div>
                    </div>
                </form>
            </div>

            <div class="tab-pane fade" id="paso5" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom">
                    <h4 class="fw-bold txt-title mb-1">5. Mis Asesores</h4>
                    <p class="text-muted text-sm mb-0">Quienes evaluarán y supervisarán tus prácticas.</p>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="bg-light border rounded-4 p-4 h-100 shadow-sm text-center">
                            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 70px; height: 70px;">
                                <i class="bi bi-mortarboard-fill text-dark fs-2"></i>
                            </div>
                            <h6 class="fw-bold text-dark mb-1">Ing. María Fernanda López</h6>
                            <span class="badge bg-white text-dark border px-3 py-1 mb-3 shadow-sm">Asesor Académico UTTN</span>
                            <div class="text-start bg-white p-3 rounded-3 border">
                                <p class="text-muted text-xs mb-1 fw-bold"><i class="bi bi-envelope me-2"></i>mlopez@uttn.mx</p>
                                <p class="text-muted text-xs mb-0 fw-bold"><i class="bi bi-telephone me-2"></i>899-123-4567</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="bg-white border border-secondary rounded-4 p-4 h-100 shadow-sm">
                            <h6 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-briefcase-fill me-2"></i> Asesor Empresarial</h6>
                            <p class="text-muted text-xs mb-3">Registra a la persona que te supervisará dentro de la empresa.</p>
                            
                            <form asp-action="SaveBusinessAdvisor" asp-controller="DualStudent" method="post">
                                @Html.AntiForgeryToken()
                                <div class="row g-2">
                                    <div class="col-12">
                                        <input type="text" class="form-control custom-input bg-light text-sm" name="BusinessName" placeholder="Nombre completo *" required>
                                    </div>
                                    <div class="col-12">
                                        <input type="text" class="form-control custom-input bg-light text-sm" name="BusinessRole" placeholder="Puesto en la empresa">
                                    </div>
                                    <div class="col-12">
                                        <input type="email" class="form-control custom-input bg-light text-sm" name="BusinessEmail" placeholder="Correo corporativo">
                                    </div>
                                    <div class="col-12 mt-3 text-end">
                                        <button type="submit" class="btn btn-outline-dark btn-sm fw-bold w-100 shadow-sm">Guardar Asesor</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="mt-4 mt-md-5 d-flex flex-column-reverse flex-md-row justify-content-md-between gap-3 border-top pt-4">
                    <button type="button" class="btn text-muted fw-bold px-4" onclick="$('#dualTabs button[data-bs-target=\'#paso4\']').tab('show'); window.scrollTo(0,0);">
                        <i class="bi bi-arrow-left me-2"></i> Anterior
                    </button>
                    <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm" onclick="$('#dualTabs button[data-bs-target=\'#paso6\']').tab('show'); window.scrollTo(0,0);">
                        Siguiente (Reportes) <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>

            <div class="tab-pane fade" id="paso6" role="tabpanel">
                <div class="mb-4 pb-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold txt-title mb-1">6. Reportes Semanales</h4>
                        <p class="text-muted text-sm mb-0">Sube tus avances y revisa los comentarios de tus asesores.</p>
                    </div>
                    <div class="text-end">
                        <span class="d-block fw-bold text-dark fs-5">2 / 15</span>
                        <small class="text-muted text-xs">Semanas</small>
                    </div>
                </div>

                <div class="bg-light p-4 rounded-4 border border-light mb-4 shadow-sm">
                    <form asp-action="WeeklyReports" asp-controller="DualStudent" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="row g-3 align-items-end">
                            <div class="col-md-2">
                                <label class="form-label-custom">Semana</label>
                                <select class="form-select custom-input bg-white" name="WeekNumber"><option value="3">3</option></select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-custom">Título / Actividad Principal</label>
                                <input type="text" class="form-control custom-input bg-white" name="ReportTitle" placeholder="Ej. Diseño de DB" required>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label-custom">Horas</label>
                                <input type="number" class="form-control custom-input bg-white" name="HoursWorked" placeholder="40" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label-custom">Archivo (PDF)</label>
                                <input type="file" class="form-control bg-white text-sm" name="ReportFile" accept=".pdf" required>
                            </div>
                            <div class="col-12 mt-3 text-end">
                                <button type="submit" class="btn btn-dark fw-bold px-4 shadow-sm"><i class="bi bi-cloud-upload me-2"></i> Enviar Reporte</button>
                            </div>
                        </div>
                    </form>
                </div>

                <h6 class="fw-bold text-dark mb-3"><i class="bi bi-history me-2"></i>Historial de Revisiones</h6>
                <div class="table-responsive border rounded-3 overflow-hidden bg-white shadow-sm">
                    <table class="table table-borderless align-middle mb-0 text-sm">
                        <thead class="bg-light border-bottom text-muted">
                            <tr>
                                <th class="py-3 px-3 fw-bold text-xs" width="10%">SEM.</th>
                                <th class="py-3 fw-bold text-xs" width="20%">INFO</th>
                                <th class="py-3 fw-bold text-xs" width="40%">RETROALIMENTACIÓN</th>
                                <th class="py-3 text-center fw-bold text-xs px-3" width="20%">ESTATUS</th>
                                <th class="py-3 text-center fw-bold text-xs" width="10%">PDF</th>
                            </tr>
                        </thead>
                        <tbody>
                            
                            <tr class="border-bottom hover-bg-light">
                                <td class="px-3 fw-bold text-dark fs-5 text-center">1</td>
                                <td>
                                    <span class="d-block fw-bold text-dark">Inducción y Seguridad</span>
                                    <small class="text-muted">40 horas</small>
                                </td>
                                <td>
                                    <div class="bg-light p-2 rounded-2 border">
                                        <small class="text-muted fst-italic">"Excelente reporte, continuemos con la capacitación técnica." - Ing. María López</small>
                                    </div>
                                </td>
                                <td class="text-center px-3">
                                    <span class="badge bg-white text-dark border px-3 py-2 shadow-sm"><i class="bi bi-circle-fill text-success me-1" style="font-size:0.5rem;"></i> Aprobado</span>
                                </td>
                                <td class="text-center">
                                    <a href="#" class="btn btn-light btn-sm border"><i class="bi bi-download text-dark"></i></a>
                                </td>
                            </tr>

                            <tr class="border-bottom hover-bg-light">
                                <td class="px-3 fw-bold text-dark fs-5 text-center">2</td>
                                <td>
                                    <span class="d-block fw-bold text-dark">Línea de Ensamble</span>
                                    <small class="text-muted">38 horas</small>
                                </td>
                                <td>
                                    <small class="text-muted">En espera de revisión del asesor académico.</small>
                                </td>
                                <td class="text-center px-3">
                                    <span class="badge bg-white text-dark border px-3 py-2 shadow-sm"><i class="bi bi-circle-fill text-warning me-1" style="font-size:0.5rem;"></i> Pendiente</span>
                                </td>
                                <td class="text-center">
                                    <a href="#" class="btn btn-light btn-sm border"><i class="bi bi-download text-dark"></i></a>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                </div>

                <div class="mt-4 mt-md-5 border-top pt-4">
                    <button type="button" class="btn text-muted fw-bold px-0" onclick="$('#dualTabs button[data-bs-target=\'#paso5\']').tab('show'); window.scrollTo(0,0);">
                        <i class="bi bi-arrow-left me-2"></i> Regresar a Asesores
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        function selectDualType(type) {
            document.getElementById('placementTypeInput').value = type;
            
            // Lógica visual
            $('.custom-radio-card').removeClass('border-primary-900 bg-white').addClass('bg-light').css({'border': '1px solid transparent', 'transform': 'scale(1)'});
            
            if(type === 'NEEDS_SUPPORT') {
                $('#card-support').removeClass('bg-light').addClass('bg-white').css({'border': '2px solid var(--primary-900)', 'transform': 'scale(1.02)'});
                $('#parkSection').removeClass('d-none');
                $('#companySection').addClass('d-none');
            } else {
                $('#card-company').removeClass('bg-light').addClass('bg-white').css({'border': '2px solid var(--primary-900)', 'transform': 'scale(1.02)'});
                $('#companySection').removeClass('d-none');
                $('#parkSection').addClass('d-none');
            }
        }
    </script>
}