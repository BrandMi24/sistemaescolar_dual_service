@{
    ViewData["Title"] = "Mis Asistencias";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = true;
}

<div class="mx-auto" style="max-width: 1000px;">
    <div class="d-flex flex-column gap-3">

        <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            
            <div class="d-flex align-items-center gap-3 w-100 w-md-auto">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 border shadow-sm" style="width: 45px; height: 45px;">
                    <i class="bi bi-person-fill text-dark fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0 txt-title" style="font-size: 0.95rem;">Roberto Carlos Perez Cadena</h6>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <span class="text-muted text-xs fw-bold">26001504</span>
                        <i class="bi bi-circle-fill text-muted opacity-50" style="font-size: 4px;"></i>
                        <span class="text-muted text-xs fw-bold">TSU IDGS - 7º A</span>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 w-100 w-md-auto justify-content-start justify-content-md-end">
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">ASISTENCIA:</span>
                    <span class="fw-bold text-dark text-sm">95%</span>
                </div>
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">FALTAS:</span>
                    <span class="fw-bold text-dark text-sm">3</span>
                </div>
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">RETARDOS:</span>
                    <span class="fw-bold text-dark text-sm">1</span>
                </div>
            </div>
        </div>

        <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-light rounded-2 border d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                    <i class="bi bi-calendar3 text-dark fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0 txt-title">Historial de Asistencias</h6>
                    <p class="text-muted text-xs mb-0 fw-bold">Consulta tus registros diarios.</p>
                </div>
            </div>
            
            <div class="d-flex flex-column flex-sm-row gap-2">
                <select class="form-select bg-white border fw-bold text-sm text-dark shadow-sm" style="min-width: 150px; cursor: pointer;">
                    <option value="todas" selected>Todas las Materias</option>
                    <option value="web">Desarrollo Web</option>
                    <option value="bd">Base de Datos</option>
                </select>
                <select class="form-select bg-white border fw-bold text-sm text-dark shadow-sm" style="min-width: 150px; cursor: pointer;">
                    <option value="marzo" selected>Marzo 2026</option>
                    <option value="febrero">Febrero 2026</option>
                </select>
            </div>
        </div>

        <div class="bg-white p-0 rounded-4 shadow-sm border border-light overflow-hidden d-flex flex-column">
            
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0" style="min-width: 700px;">
                    <thead class="bg-light border-bottom text-muted">
                        <tr>
                            <th class="py-3 px-4 fw-bold text-xs" width="15%">FECHA</th>
                            <th class="py-3 fw-bold text-xs" width="35%">ASIGNATURA</th>
                            <th class="py-3 fw-bold text-xs" width="30%">CATEDRÁTICO</th>
                            <th class="py-3 px-4 text-center fw-bold text-xs" width="20%">ESTATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        
                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <span class="text-dark fw-bold text-sm d-block">18 Mar</span>
                                <span class="text-muted text-xs">Miércoles</span>
                            </td>
                            <td><span class="text-dark fw-bold text-sm d-block">Desarrollo de Aplicaciones Web</span></td>
                            <td><span class="text-muted text-sm">Ing. Juan Pérez</span></td>
                            <td class="px-4 text-center">
                                <span class="badge bg-white text-dark border shadow-sm px-3 py-2">
                                    <i class="bi bi-circle-fill text-success me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> Presente
                                </span>
                            </td>
                        </tr>

                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <span class="text-dark fw-bold text-sm d-block">17 Mar</span>
                                <span class="text-muted text-xs">Martes</span>
                            </td>
                            <td><span class="text-dark fw-bold text-sm d-block">Base de Datos Avanzadas</span></td>
                            <td><span class="text-muted text-sm">Mtra. Ana García</span></td>
                            <td class="px-4 text-center">
                                <span class="badge bg-white text-dark border shadow-sm px-3 py-2">
                                    <i class="bi bi-circle-fill text-danger me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> Falta
                                </span>
                            </td>
                        </tr>

                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <span class="text-dark fw-bold text-sm d-block">16 Mar</span>
                                <span class="text-muted text-xs">Lunes</span>
                            </td>
                            <td><span class="text-dark fw-bold text-sm d-block">Inglés VII</span></td>
                            <td><span class="text-muted text-sm">Lic. María Fernández</span></td>
                            <td class="px-4 text-center">
                                <span class="badge bg-white text-dark border shadow-sm px-3 py-2">
                                    <i class="bi bi-circle-fill text-warning me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> Retardo
                                </span>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
            
            <div class="bg-light p-3 text-center d-flex flex-column flex-sm-row justify-content-between align-items-center gap-2 border-top">
                <span class="text-muted text-xs fw-bold tracking-wide">Mostrando registros de Marzo 2026</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0 shadow-sm">
                        <li class="page-item disabled"><a class="page-link text-muted" href="#">Anterior</a></li>
                        <li class="page-item active"><a class="page-link bg-dark border-dark text-white" href="#">1</a></li>
                        <li class="page-item"><a class="page-link text-dark" href="#">2</a></li>
                        <li class="page-item"><a class="page-link text-dark" href="#">Siguiente</a></li>
                    </ul>
                </nav>
            </div>
            
        </div>
    </div>
</div>