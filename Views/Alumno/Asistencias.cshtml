@{
    ViewData["Title"] = "Mis Asistencias";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = true;
}

<div class="mx-auto d-flex flex-column gap-4" style="max-width: 1100px; min-height: 82vh;">

    <div class="bg-white p-4 rounded-4 shadow-sm border border-light d-flex flex-column flex-lg-row justify-content-between align-items-center gap-4">
        
        <div class="d-flex align-items-center gap-3 w-100 w-lg-auto">
            <div class="user-initial-avatar shadow-sm" style="width: 55px; height: 55px; font-size: 1.4rem; background-color: var(--accent-100); color: var(--primary-900);">
                RC
            </div>
            <div>
                <h6 class="fw-bold mb-1 txt-title text-uppercase tracking-tight">Roberto Carlos Perez Cadena</h6>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-secondary fw-bold text-xxs tracking-widest">MATRÍCULA: <span class="txt-primary-dark">26001504</span></span>
                    <span class="opacity-25">|</span>
                    <span class="text-muted fw-bold text-xxs text-uppercase tracking-tighter">TSU IDGS - 7º A</span>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 w-100 w-lg-auto justify-content-lg-end">
            <div class="bg-app px-3 py-2 rounded-3 border border-light d-flex flex-column align-items-center min-w-100 shadow-none">
                <span class="text-secondary fw-bold text-xxs tracking-widest opacity-75">ASISTENCIA</span>
                <span class="fw-bold text-sm txt-primary-dark">95%</span>
            </div>
            <div class="bg-error-100 px-3 py-2 rounded-3 border border-danger border-opacity-10 d-flex flex-column align-items-center min-w-100 shadow-none">
                <span class="text-danger fw-bold text-xxs tracking-widest opacity-75">FALTAS</span>
                <span class="fw-bold text-sm text-danger">03</span>
            </div>
            <div class="bg-warning-subtle px-3 py-2 rounded-3 border border-warning border-opacity-25 d-flex flex-column align-items-center min-w-100 shadow-none">
                <span class="text-warning fw-bold text-xxs tracking-widest opacity-75" style="color: #92400e !important;">RETARDOS</span>
                <span class="fw-bold text-sm" style="color: #92400e !important;">01</span>
            </div>
        </div>
    </div>

    <div class="bg-surface p-4 rounded-4 border border-light shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1" style="max-width: 800px;">
            
            <div class="d-flex align-items-center gap-2">
                <span class="text-secondary fw-bold text-xxs tracking-widest text-uppercase">Materia:</span>
                <select class="form-select border-0 bg-app py-2 px-3 text-xs fw-bold txt-title rounded-3 shadow-none cursor-pointer" style="min-width: 200px;">
                    <option value="">TODAS LAS ASIGNATURAS</option>
                    <option>DESARROLLO WEB</option>
                    <option>BASE DE DATOS</option>
                </select>
            </div>

            <div class="d-flex align-items-center gap-2">
                <span class="text-secondary fw-bold text-xxs tracking-widest text-uppercase">Mes:</span>
                <select class="form-select border-0 bg-app py-2 px-3 text-xs fw-bold txt-title rounded-3 shadow-none cursor-pointer">
                    <option>MARZO 2026</option>
                    <option>FEBRERO 2026</option>
                </select>
            </div>
        </div>

        <button class="btn btn-sm bg-app text-secondary border-0 py-2 px-3 rounded-3" title="Imprimir historial">
            <i class="bi bi-printer-fill"></i>
        </button>
    </div>

    <div class="bg-white p-0 rounded-4 border border-light shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
        <div class="table-responsive flex-grow-1">
            <table class="table table-borderless align-middle mb-0">
                <thead class="bg-app sticky-top" style="z-index: 5;">
                    <tr>
                        <th class="py-3 px-4 text-xxs fw-bold text-uppercase tracking-wider" width="15%">Fecha</th>
                        <th class="py-3 text-xxs fw-bold text-uppercase tracking-wider" width="35%">Asignatura</th>
                        <th class="py-3 text-xxs fw-bold text-uppercase tracking-wider" width="30%">Catedrático</th>
                        <th class="py-3 text-center text-xxs fw-bold text-uppercase tracking-wider px-4" width="20%">Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    
                    <tr class="border-bottom border-light hover-bg-app">
                        <td class="px-4 py-3">
                            <div class="txt-primary-dark fw-bold text-xs text-uppercase mb-0">18 Mar</div>
                            <div class="text-muted text-xxs fw-bold opacity-75">MIÉRCOLES</div>
                        </td>
                        <td>
                            <div class="fw-bold text-xs text-uppercase txt-title">Desarrollo de Aplicaciones Web</div>
                        </td>
                        <td>
                            <div class="text-muted text-xxs fw-bold text-uppercase tracking-tighter">ING. JUAN PÉREZ</div>
                        </td>
                        <td class="text-center px-4">
                            <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold status-aceptado">PRESENTE</span>
                        </td>
                    </tr>

                    <tr class="border-bottom border-light hover-bg-app border-start border-4 border-danger">
                        <td class="px-4 py-3">
                            <div class="text-danger fw-bold text-xs text-uppercase mb-0">17 Mar</div>
                            <div class="text-muted text-xxs fw-bold opacity-75">MARTES</div>
                        </td>
                        <td>
                            <div class="fw-bold text-xs text-uppercase text-danger">Base de Datos Avanzadas</div>
                        </td>
                        <td>
                            <div class="text-muted text-xxs fw-bold text-uppercase tracking-tighter">MTRA. ANA GARCÍA</div>
                        </td>
                        <td class="text-center px-4">
                            <span class="badge rounded-pill bg-error-100 text-danger border border-danger border-opacity-10 px-3 py-2 text-xxs fw-bold">FALTA</span>
                        </td>
                    </tr>

                    <tr class="border-bottom border-light hover-bg-app">
                        <td class="px-4 py-3">
                            <div class="txt-title fw-bold text-xs text-uppercase mb-0">16 Mar</div>
                            <div class="text-muted text-xxs fw-bold opacity-75">LUNES</div>
                        </td>
                        <td>
                            <div class="fw-bold text-xs text-uppercase txt-title">Inglés VII</div>
                        </td>
                        <td>
                            <div class="text-muted text-xxs fw-bold text-uppercase tracking-tighter">LIC. MARÍA FERNÁNDEZ</div>
                        </td>
                        <td class="text-center px-4">
                            <span class="badge rounded-pill bg-warning-subtle px-3 py-2 text-xxs fw-bold border border-warning border-opacity-25" style="color: #92400e !important;">RETARDO</span>
                        </td>
                    </tr>

                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold text-xxs">MOSTRAR:</span>
                <select class="form-select form-select-sm border-0 bg-app fw-bold text-xs" style="width: 70px; cursor: pointer;">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                </select>
                <div class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;">
                    REGISTROS 1 - 3 DE 22
                </div>
            </div>

            <nav aria-label="Navegación de asistencias">
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item disabled">
                        <a class="page-link page-link-custom" href="#"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link page-link-custom" href="#">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link page-link-custom" href="#">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link page-link-custom" href="#"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    .hover-bg-app:hover { background-color: rgba(0,0,0,0.02); transition: background 0.2s ease; }
    .min-w-100 { min-width: 100px; }
    .user-initial-avatar { display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; }
    
    .badge { border-radius: 50px; padding: 6px 14px; font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .status-aceptado { background-color: #E1F7E7; color: #15803D; border: 1px solid rgba(21, 128, 61, 0.1); }
    .bg-warning-subtle { background-color: #FEF3C7 !important; }

    /* Estilo de paginación igual a Ciclos */
    .page-link-custom {
        display: flex; align-items: center; justify-content: center;
        min-width: 32px; height: 32px; padding: 0 10px;
        font-size: 0.65rem; font-weight: 700; border-radius: 8px !important;
        border: none; background-color: var(--bg-app); color: var(--text-title);
        transition: all 0.2s ease;
    }