@{
    ViewData["Title"] = "Inicio";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = false;
    var studentName = ViewBag.StudentName as string ?? "Alumno";
    var studentCareer = ViewBag.StudentCareer as string ?? "Carrera no disponible";
    var studentMatricula = ViewBag.StudentMatricula as string ?? "SIN MATRÍCULA";
    int? currentCuatrimestre = ViewBag.CurrentCuatrimestre as int?;
    var canShowDualPortal = (bool)(ViewBag.CanShowDualPortal ?? false);
    var canShowSocialPortal = (bool)(ViewBag.CanShowSocialPortal ?? false);
}

<div class="row justify-content-center g-4 align-items-start">
    
    <div class="col-12 col-lg-5 col-xl-4 position-lg-sticky" style="top: 20px;">
        <div class="bg-primary-dark p-4 rounded-4 shadow-lg position-relative overflow-hidden" style="min-height: 500px;">
            <i class="bi bi-fingerprint position-absolute text-white opacity-10" style="font-size: 18rem; right: -40px; bottom: -40px; z-index: 0;"></i>
            
            <div class="d-flex justify-content-between align-items-start pb-3 border-bottom border-white border-opacity-10 position-relative z-1">
                <div>
                    <h6 class="fw-bold mb-0 text-uppercase tracking-widest text-xs" style="color: var(--accent-500);">Universidad Tecnológica</h6>
                    <small class="txt-white opacity-50 text-xxs fw-semibold tracking-wide">DE TAMAULIPAS NORTE</small>
                </div>
                <div class="bg-white rounded-2 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                    <span class="fw-bold text-xs txt-primary-dark">UTTN</span>
                </div>
            </div>

            <div class="text-center position-relative z-1 my-5 py-2">
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-4 border border-4 border-white border-opacity-25" style="width: 150px; height: 150px;">
                    <i class="bi bi-person-fill text-secondary opacity-50" style="font-size: 6rem;"></i>
                </div>
                
                <h5 class="fw-bold mb-1 fs-5 text-white">@studentName</h5>
                <p class="mb-0 fw-bold mt-1" style="color: var(--accent-500); font-size: 0.8rem;">@studentCareer.ToUpperInvariant()</p>
                <div class="mt-3">
                    <span class="badge bg-white text-dark rounded-pill px-4 py-2 fw-bold text-xs shadow-sm">MATRÍCULA: @studentMatricula</span>
                </div>
            </div>

            <div class="mt-auto bg-white rounded-4 p-3 position-relative z-1 text-center shadow-sm">
                <p class="txt-primary-dark fw-bold text-xxs tracking-widest mb-2 text-uppercase">Identificador de Acceso Institucional</p>
                <div class="bg-app rounded-3 p-2 d-inline-block w-100">
                    <i class="bi bi-qr-code text-dark" style="font-size: 4.5rem; line-height: 1;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7 col-xl-8">
        
        <div class="bg-white p-4 rounded-4 shadow-sm mb-4 border border-light text-center text-lg-start">
            <h4 class="txt-title fw-bold mb-1">Hola, @studentName</h4>
            <p class="txt-body text-sm mb-0">Selecciona el trámite que deseas realizar el día de hoy.</p>
            @if (currentCuatrimestre.HasValue)
            {
                <div class="txt-body text-xs mt-2">Cuatrimestre actual: <strong>@currentCuatrimestre.Value</strong></div>
            }
        </div>

        @if ((!canShowDualPortal || !canShowSocialPortal) && currentCuatrimestre.HasValue && currentCuatrimestre.Value < 10)
        {
            <div class="alert bg-light border border-theme rounded-4 shadow-sm mb-4">
                Los módulos de modelo dual y servicio social se habilitan a partir del cuatrimestre 10.
            </div>
        }

        <div class="row row-cols-2 row-cols-lg-2 row-cols-xl-3 g-3 g-md-4">
            
            <div class="col">
                <a href="@Url.Action("Entrevista", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100 position-relative">
                    <span class="position-absolute top-0 end-0 m-3 badge rounded-pill bg-error-700 text-white text-xxs fw-bold">REQUERIDO</span>
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-clipboard2-pulse-fill fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Entrevista</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Perfil clínico y social.</p>
                </a>
            </div>

            <div class="col">
                <a href="@Url.Action("Calificaciones", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100">
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-journal-check fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Kardex</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Calificaciones parciales.</p>
                </a>
            </div>

            <div class="col">
                <a href="@Url.Action("Asistencias", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100">
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-calendar2-check-fill fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Asistencias</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Registro de puntualidad.</p>
                </a>
            </div>

            @if (canShowDualPortal)
            {
            <div class="col">
                <a href="@Url.Action("ModeloDual", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100">
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-buildings-fill fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Modelo Dual</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Vinculación empresarial.</p>
                </a>
            </div>
            }

            @if (canShowSocialPortal)
            {
            <div class="col">
                <a href="@Url.Action("ServicioSocial", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100">
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-briefcase fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Servicio Social</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Gestión de cartas, reportes y liberación.</p>
                </a>
            </div>
            }

            <div class="col">
                <a href="@Url.Action("Tramites", "Alumno")" class="admin-card-white text-decoration-none d-flex flex-column align-items-center text-center h-100">
                    <div class="icon-circle-lg bg-app txt-primary-dark mb-3">
                        <i class="bi bi-file-earmark-pdf-fill fs-3"></i>
                    </div>
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-2">Trámites</h6>
                    <p class="txt-body text-xxs fw-medium mb-0 opacity-75">Constancias oficiales.</p>
                </a>
            </div>

        </div>
    </div>
</div>