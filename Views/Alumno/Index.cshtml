@{
    ViewData["Title"] = "Inicio";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = false;
    var studentName = ViewBag.StudentName as string ?? "Alumno";
    var studentCareer = ViewBag.StudentCareer as string ?? "Carrera no disponible";
    var studentMatricula = ViewBag.StudentMatricula as string ?? "SIN MATRÍCULA";
    int? currentCuatrimestre = ViewBag.CurrentCuatrimestre as int?;
    var canShowDualPortal = (bool)(ViewBag.CanShowDualPortal ?? false);
    var canShowSocialPortal = (bool)(ViewBag.CanShowSocialPortal ?? false);
}

<div class="row justify-content-center g-4 align-items-start">
    
    <div class="col-12 col-lg-5 col-xl-4 position-lg-sticky" style="top: 20px;">
        <div class="digital-id-card p-4 mx-auto w-100 shadow-lg">
            <i class="bi bi-fingerprint digital-id-pattern"></i>
            
            <div class="d-flex justify-content-between align-items-start pb-3 border-bottom border-white border-opacity-25 position-relative z-1">
                <div>
                    <h6 class="fw-bold mb-0" style="color: var(--accent-500); font-size: 0.85rem;">UNIVERSIDAD TECNOLÓGICA</h6>
                    <small class="text-white opacity-75" style="font-size: 0.7rem;">DE TAMAULIPAS NORTE</small>
                </div>
                <div class="bg-white rounded p-1 d-flex align-items-center justify-content-center" style="min-width: 45px;">
                    <span class="fw-bold text-xxs px-1" style="color: var(--primary-900) !important;">UTTN</span>
                </div>
            </div>

            <div class="text-center position-relative z-1 my-4 flex-grow-1 d-flex flex-column justify-content-center">
                <div class="student-avatar-wrapper mb-3 bg-white">
                    <i class="bi bi-person-fill text-secondary" style="font-size: 5rem;"></i>
                </div>
                
                <h5 class="fw-bold mb-1 fs-5 text-white">@studentName</h5>
                <p class="mb-0 fw-bold mt-1" style="color: var(--accent-500); font-size: 0.8rem;">@studentCareer.ToUpperInvariant()</p>
                <div class="mt-3">
                    <span class="badge bg-white text-dark rounded-pill px-4 py-2 fw-bold text-xs shadow-sm">MATRÍCULA: @studentMatricula</span>
                </div>
            </div>

            <div class="text-center bg-white bg-opacity-10 rounded-4 p-3 position-relative z-1 border border-white border-opacity-25 mt-auto">
                <p class="text-uppercase fw-bold mb-2 text-xs text-white opacity-75">CÓDIGO DE ACCESO</p>
                <div class="qr-box">
                    <i class="bi bi-qr-code text-dark" style="font-size: 4rem; line-height: 1;"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7 col-xl-8">
        
        <div class="bg-white p-4 rounded-4 shadow-sm mb-4 border border-light text-center text-lg-start">
            <h4 class="txt-title fw-bold mb-1">Hola, @studentName</h4>
            <p class="txt-body text-sm mb-0">Selecciona el trámite que deseas realizar el día de hoy.</p>
            @if (currentCuatrimestre.HasValue)
            {
                <div class="txt-body text-xs mt-2">Cuatrimestre actual: <strong>@currentCuatrimestre.Value</strong></div>
            }
        </div>

        @if ((!canShowDualPortal || !canShowSocialPortal) && currentCuatrimestre.HasValue && currentCuatrimestre.Value < 10)
        {
            <div class="alert bg-light border border-theme rounded-4 shadow-sm mb-4">
                Los módulos de modelo dual y servicio social se habilitan a partir del cuatrimestre 10.
            </div>
        }

        <div class="row row-cols-2 row-cols-lg-2 row-cols-xl-3 g-3 g-md-4">
            
            <div class="col">
                <a href="@Url.Action("Entrevista", "Alumno")" class="student-menu-card">
                    <span class="position-absolute top-0 start-50 translate-middle badge rounded-pill bg-danger text-white shadow-sm" style="font-size: 0.65rem; border: 2px solid white; letter-spacing: 0.5px;">REQUERIDO</span>
                    
                    <div class="menu-icon-wrapper icon-orange"><i class="bi bi-clipboard2-pulse"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Entrevista</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Completa tu perfil clínico y social.</p>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="@Url.Action("Calificaciones", "Alumno")" class="student-menu-card">
                    <div class="menu-icon-wrapper icon-blue"><i class="bi bi-journal-check"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Kardex</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Consulta tus calificaciones y promedios.</p>
                    </div>
                </a>
            </div>

            <div class="col">
                <a href="@Url.Action("Asistencias", "Alumno")" class="student-menu-card">
                    <div class="menu-icon-wrapper icon-green"><i class="bi bi-calendar2-check"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Asistencias</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Historial de faltas y retardos.</p>
                    </div>
                </a>
            </div>

            @if (canShowDualPortal)
            {
            <div class="col">
                <a href="@Url.Action("ModeloDual", "Alumno")" class="student-menu-card">
                    <div class="menu-icon-wrapper icon-purple"><i class="bi bi-buildings"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Modelo DUAL</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Registro de empresas y vinculación.</p>
                    </div>
                </a>
            </div>
            }

            @if (canShowSocialPortal)
            {
            <div class="col">
                <a href="@Url.Action("ServicioSocial", "Alumno")" class="student-menu-card">
                    <div class="menu-icon-wrapper icon-cyan"><i class="bi bi-briefcase"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Servicio Social</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Gestión de cartas, reportes y liberación.</p>
                    </div>
                </a>
            </div>
            }

            <div class="col">
                <a href="@Url.Action("Tramites", "Alumno")" class="student-menu-card">
                    <div class="menu-icon-wrapper icon-red"><i class="bi bi-file-earmark-pdf"></i></div>
                    <div>
                        <h6 class="txt-title fw-bold text-sm mb-1">Constancias</h6>
                        <p class="txt-body text-xs mb-0 d-none d-md-block opacity-75">Descarga documentos oficiales.</p>
                    </div>
                </a>
            </div>

        </div>
    </div>
</div>