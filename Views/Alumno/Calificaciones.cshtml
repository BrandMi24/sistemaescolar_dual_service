@{
    ViewData["Title"] = "Mis Calificaciones";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = true;
}

<div class="mx-auto" style="max-width: 1000px;">
    <div class="d-flex flex-column gap-3">
        
        <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            
            <div class="d-flex align-items-center gap-3 w-100 w-md-auto">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 border shadow-sm" style="width: 45px; height: 45px;">
                    <i class="bi bi-person-fill text-dark fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0 txt-title" style="font-size: 0.95rem;">Roberto Carlos Perez Cadena</h6>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <span class="text-muted text-xs fw-bold">26001504</span>
                        <i class="bi bi-circle-fill text-muted opacity-50" style="font-size: 4px;"></i>
                        <span class="text-muted text-xs fw-bold">TSU IDGS - 7º A</span>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2 w-100 w-md-auto justify-content-start justify-content-md-end">
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">PROMEDIO:</span>
                    <span class="fw-bold text-sm text-dark">9.2</span>
                </div>
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">APROBADAS:</span>
                    <span class="fw-bold text-sm text-dark">5</span>
                </div>
                <div class="bg-white px-3 py-2 rounded-2 border d-flex align-items-center gap-2 shadow-sm">
                    <span class="text-muted text-xs fw-bold tracking-wide">REPROBADAS:</span>
                    <span class="fw-bold text-sm text-danger">1</span>
                </div>
            </div>
        </div>

        <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-light rounded-2 border d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                    <i class="bi bi-journal-text text-dark fs-5"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0 txt-title">7º Cuatrimestre</h6>
                    <p class="text-muted text-xs mb-0 fw-bold">Historial Académico</p>
                </div>
            </div>
            
            <div class="d-flex gap-2">
                <button class="btn btn-outline-dark d-flex align-items-center gap-2 py-2 text-sm fw-bold">
                    <i class="bi bi-file-earmark-pdf"></i> Descargar Boleta
                </button>
            </div>
        </div>

        <div class="bg-white p-0 rounded-4 shadow-sm border border-light overflow-hidden d-flex flex-column">
            
            <div class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
                <span class="text-dark fw-bold text-sm"><i class="bi bi-card-checklist me-2"></i> Calificaciones por Unidad</span>
            </div>

            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0" style="min-width: 800px;">
                    <thead class="border-bottom text-muted">
                        <tr>
                            <th class="py-3 px-4 fw-bold text-xs" width="40%">ASIGNATURA</th>
                            <th class="py-3 text-center fw-bold text-xs" width="15%">UNIDAD 1</th>
                            <th class="py-3 text-center fw-bold text-xs" width="15%">UNIDAD 2</th>
                            <th class="py-3 text-center fw-bold text-xs" width="15%">UNIDAD 3</th>
                            <th class="py-3 text-center fw-bold text-xs px-4" width="15%">FINAL</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold text-sm">Desarrollo de Aplicaciones Web</span>
                                    <span class="text-muted text-xs">Ing. Juan Pérez</span>
                                </div>
                            </td>
                            <td class="text-center text-dark text-sm">9.5</td>
                            <td class="text-center text-dark text-sm">10.0</td>
                            <td class="text-center text-muted text-sm">-</td>
                            <td class="text-center px-4"><span class="fw-bold text-dark fs-6">9.7</span></td>
                        </tr>

                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold text-sm">Base de Datos Avanzadas</span>
                                    <span class="text-muted text-xs">Mtra. Ana García</span>
                                </div>
                            </td>
                            <td class="text-center text-danger text-sm">6.5</td>
                            <td class="text-center text-dark text-sm">8.5</td>
                            <td class="text-center text-muted text-sm">-</td>
                            <td class="text-center px-4"><span class="fw-bold text-dark fs-6">7.5</span></td>
                        </tr>

                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold text-sm">Estructura de Datos</span>
                                    <span class="text-muted text-xs">Ing. Carlos López</span>
                                </div>
                            </td>
                            <td class="text-center text-danger text-sm">6.0</td>
                            <td class="text-center text-danger text-sm">6.5</td>
                            <td class="text-center text-muted text-sm">-</td>
                            <td class="text-center px-4"><span class="fw-bold text-danger fs-6">6.2</span></td>
                        </tr>

                        <tr class="border-bottom hover-bg-light transition-all">
                            <td class="px-4 py-3">
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold text-sm">Inglés VII</span>
                                    <span class="text-muted text-xs">Lic. María Fernández</span>
                                </div>
                            </td>
                            <td class="text-center text-dark text-sm">10.0</td>
                            <td class="text-center text-dark text-sm">10.0</td>
                            <td class="text-center text-muted text-sm">-</td>
                            <td class="text-center px-4"><span class="fw-bold text-dark fs-6">10.0</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <div class="bg-light p-3 text-center">
                <span class="text-muted text-xs fw-bold tracking-wide">
                    <i class="bi bi-info-circle me-1"></i> Calificación mínima aprobatoria: 7.0
                </span>
            </div>
        </div>
    </div>
</div>