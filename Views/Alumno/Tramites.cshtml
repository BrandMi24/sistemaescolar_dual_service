    @model IEnumerable<ControlEscolar.Models.DetalleSolicitudViewModel>
@{
    ViewData["Title"] = "Trámites Escolares";
    Layout = "_LayoutAlumno";
    ViewData["ShowBackButton"] = true;
}


<div class="row g-4 align-items-start mx-auto" style="max-width: 1200px;">
    
    <div class="col-12 col-lg-4 col-xl-3 position-lg-sticky" style="top: 80px;">
        <div class="bg-white p-4 rounded-4 shadow-sm border border-light d-flex flex-column gap-4">
            
            <div class="text-center pb-3 border-bottom border-light">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 60px; height: 60px;">
                    <i class="bi bi-folder2-open text-dark fs-3"></i>
                </div>
                <h6 class="fw-bold mb-1 txt-title">Trámites Escolares</h6>
                <p class="text-muted text-xs mb-0">Gestión de Documentos Oficiales</p>
            </div>

            <ul class="nav flex-column nav-pills-custom" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 active d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#nuevo-tramite" type="button">
                        <span><i class="bi bi-file-earmark-plus me-2"></i> Solicitar Trámite</span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#historial" type="button">
                        <span><i class="bi bi-clock-history me-2"></i> Mis Trámites</span>
                        @if (Model != null && Model.Any(m => m.Estatus.Equals("Rechazado", StringComparison.OrdinalIgnoreCase)))
                        {
                            <i class="bi bi-circle-fill text-danger shadow-sm" style="font-size: 0.6rem;"></i>
                        }
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-12 col-lg-8 col-xl-9">
        <div class="tab-content">
            
            <div class="tab-pane fade show active" id="nuevo-tramite" role="tabpanel">
                <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light">
                    
                    <div class="mb-4 pb-3 border-bottom text-center text-md-start">
                        <h4 class="fw-bold txt-title mb-1">Información del Solicitante</h4>
                        <p class="text-muted text-sm mb-0">Verifica tus datos académicos para iniciar el trámite.</p>
                    </div>

                    <div id="infoAlumnoCargando" class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted text-sm">Obteniendo tus datos académicos...</p>
                    </div>

                    <div id="infoAlumno" class="bg-light p-4 rounded-4 border border-light mb-4 shadow-sm" style="display:none;">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="text-muted text-xs fw-bold tracking-wide d-block mb-1">NOMBRE COMPLETO</label>
                                <span id="nombreAlumno" class="fw-bold text-dark text-sm">--</span>
                            </div>
                            <div class="col-md-3">
                                <label class="text-muted text-xs fw-bold tracking-wide d-block mb-1">MATRÍCULA</label>
                                <span id="matriculaAlumno" class="fw-bold text-dark text-sm">--</span>
                            </div>
                            <div class="col-md-3">
                                <label class="text-muted text-xs fw-bold tracking-wide d-block mb-1">GRADO Y GRUPO</label>
                                <span class="fw-bold text-dark text-sm"><span id="gradoAlumno">--</span>° "<span id="grupoAlumno">--</span>"</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="GuardarSolicitud" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="tramites_solicitud_matricula" id="hiddenMatricula" />

                        <div class="mb-4">
                            <label class="fw-bold text-dark text-sm mb-2">Selecciona el Tipo de Trámite *</label>
                            <select class="form-select custom-input border shadow-sm py-3" id="selectTipo" name="id_tramite" required onchange="cargarRequisitosDinamicos()">
                                <option value="">Selecciona una opción...</option>
                                <option value="1">Trámite de Título</option>
                                <option value="2">Certificación de Estudios</option>
                                <option value="3">Cursos de Extensión / Actualización</option>
                                <option value="4">Cursos Empresariales</option>
                                <option value="5">Cursos Regulares de Capacitación</option>
                                <option value="6">Inscripción a Bachillerato</option>
                                <option value="7">Reconocimiento de Competencia</option>
                            </select>
                        </div>

                        <div id="contenedorRequisitos" class="row g-3 bg-light rounded-4 p-4 border mb-4 shadow-inner">
                            <div class="col-12 text-center text-muted py-5" id="msgAyuda">
                                <i class="bi bi-info-circle d-block mb-2" style="font-size: 2rem;"></i>
                                Selecciona un tipo de trámite para ver los requisitos.
                            </div>
                        </div>

                        <div class="text-end border-top pt-4">
                            <button type="submit" id="btnEnviar" class="btn btn-dark px-5 py-2 fw-bold shadow-sm" style="display:none;">
                                <span id="textBtn"><i class="bi bi-cloud-upload-fill me-2"></i> Solicitar trámite</span>
                                <span id="spinnerBtn" style="display:none;"><span class="spinner-border spinner-border-sm me-2"></span> Subiendo archivos...</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="tab-pane fade" id="historial" role="tabpanel">
                <div class="d-flex flex-column gap-3">
                    <div class="bg-white p-3 rounded-4 shadow-sm border border-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-light rounded-2 border d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                                <i class="bi bi-clock-history text-dark fs-5"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0 txt-title">Historial Académico</h6>
                                <p class="text-muted text-xs mb-0 fw-bold">Consulta el estatus de tus solicitudes registradas.</p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white p-0 rounded-4 shadow-sm border border-light overflow-hidden d-flex flex-column">
                        <div class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
                            <span class="text-dark fw-bold text-sm"><i class="bi bi-list-stars me-2"></i> Solicitudes Recientes</span>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-borderless align-middle mb-0" id="tablaAlumno" style="min-width: 800px;">
                                <thead class="border-bottom text-muted">
                                    <tr>
                                        <th class="py-3 px-4 fw-bold text-xs" width="15%">FOLIO / FECHA</th>
                                        <th class="py-3 fw-bold text-xs" width="35%">TIPO DE TRÁMITE</th>
                                        <th class="py-3 fw-bold text-xs" width="30%">OBSERVACIONES</th>
                                        <th class="py-3 px-4 text-center fw-bold text-xs" width="20%">ESTATUS</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        @foreach (var item in Model)
                                        {
                                            bool tieneRechazos = item.Estatus.Equals("Rechazado", StringComparison.OrdinalIgnoreCase);
                                            <tr class="border-bottom hover-bg-light transition-all">
                                                <td class="px-4 py-3">
                                                    <span class="text-primary fw-bold text-sm d-block">#@item.Id</span>
                                                    <span class="text-muted text-xs">@item.Fecha.ToString("dd/MM/yyyy")</span>
                                                </td>
                                                <td>
                                                    <span class="text-dark fw-bold text-sm d-block">@item.Tipo</span>
                                                </td>
                                                <td>
                                                    <span class="text-muted text-sm d-block text-truncate" style="max-width: 200px;">
                                                        @(string.IsNullOrEmpty(item.Observaciones) ? "Sin observaciones al momento." : item.Observaciones)
                                                    </span>
                                                </td>
                                                <td class="px-4 text-center">
                                                    @if (tieneRechazos)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-white border shadow-sm px-3 py-2 text-danger fw-bold btn-detalle-alumno"
                                                                data-id="@item.Id" data-id-tramite="@item.IdTramite" data-tipo="@item.Tipo"
                                                                data-archivopath="@item.ArchivoPath" data-estatus="@item.Estatus">
                                                            <i class="bi bi-exclamation-circle-fill me-1" style="font-size: 0.5rem;"></i> Corregir
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-white text-dark border shadow-sm px-3 py-2">
                                                            <i class="bi bi-circle-fill @(item.Estatus == "Pendiente" ? "text-warning" : "text-success") me-1" style="font-size: 0.5rem; vertical-align: middle;"></i> @item.Estatus
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="4" class="text-center py-5 text-muted">Aún no has realizado ninguna solicitud.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="modalAlumno" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-dark text-white p-4">
                <h5 class="modal-title fw-bold" id="modalTitulo">Detalle del Trámite</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="d-flex flex-column flex-md-row" style="height: 70vh;">
                    <div class="bg-light border-end p-3" style="width: 100%; max-width: 380px; overflow-y: auto;">
                        <div id="listaDocumentosAlumno"></div>
                    </div>
                    <div class="flex-grow-1 bg-white d-flex flex-column position-relative">
                        <div class="bg-dark text-white p-3 shadow-sm z-1">
                            <span class="text-sm fw-bold" id="nombreDocActivo">Visor de Documentos</span>
                        </div>
                        <div id="pdfContainerAlumno" class="flex-grow-1 bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center">
                            <div class="text-center text-muted opacity-50">
                                <i class="bi bi-file-earmark-pdf mb-2" style="font-size: 5rem;"></i>
                                <p class="text-sm fw-bold tracking-wide">Selecciona un documento para visualizarlo</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // 1. Timeout de seguridad por si el servidor no responde
        setTimeout(() => {
        const loading = document.getElementById("infoAlumnoCargando");
        if (loading && loading.style.display !== "none") {
        loading.innerHTML = `<div class="alert alert-warning small">La consulta está tardando más de lo esperado.</div>`;
        }
        }, 5000);

        // 2. Carga de datos del alumno al abrir la página
        fetch('/Tramites/ValidarMatricula')
        .then(response => {
        const contentType = response.headers.get("content-type");
        if (!contentType || !contentType.includes("application/json")) {
        throw new TypeError("Sesión expirada o bloqueada por ASP.NET.");
        }
        return response.json();
        })
        .then(data => {
        const loading = document.getElementById("infoAlumnoCargando");
        const info = document.getElementById("infoAlumno");
        if (data.success) {
        document.getElementById("nombreAlumno").innerText = data.nombre || "--";
        document.getElementById("matriculaAlumno").innerText = data.matricula || "--";
        document.getElementById("gradoAlumno").innerText = data.grado || "--";
        document.getElementById("grupoAlumno").innerText = data.grupo || "--";
        if(document.getElementById("hiddenMatricula")) document.getElementById("hiddenMatricula").value = data.matricula;
        loading.style.display = "none";
        info.style.display = "block";
        } else {
        loading.innerHTML = `<div class="alert alert-danger small">${data.message}</div>`;
        }
        })
        .catch(err => {
        console.error("Error capturado:", err);
        document.getElementById("infoAlumnoCargando").innerHTML =
        `<div class="alert alert-danger small"><strong>Error:</strong> No se pudo conectar. Verifica tu sesión.</div>`;
        });
        });

        // 3. Cargar los inputs de PDF dinámicamente cuando elige el trámite
        function cargarRequisitosDinamicos() {
        const id = document.getElementById("selectTipo").value;
        const contenedor = document.getElementById("contenedorRequisitos");
        const btnEnviar = document.getElementById("btnEnviar");
        
        if (!id) {
        btnEnviar.style.display = "none";
        contenedor.innerHTML = '<div class="col-12 text-center text-muted py-5" id="msgAyuda"><i class="bi bi-info-circle d-block mb-2" style="font-size: 2rem;"></i>Selecciona un tipo de trámite para ver los requisitos.</div>';
        return;
        }
        
        contenedor.innerHTML = '<div class="text-center p-5 col-12"><div class="spinner-border text-primary"></div><p class="mt-2 text-muted small">Cargando requisitos...</p></div>';

        fetch(`/Tramites/ObtenerRequisitosJson?id=${id}`)
        .then(res => res.json())
        .then(requisitos => {
        let html = '<h6 class="fw-bold text-dark text-sm border-bottom border-light pb-2 mb-3 col-12"><i class="bi bi-paperclip me-2"></i>Adjuntar Documentación (Solo PDF)</h6>';
                
        if (requisitos.length === 0) {
        html += '<div class="alert alert-warning small col-12">No hay requisitos configurados para este trámite.</div>';
        } else {
        requisitos.forEach(req => {
        const esFoto = req.nombre_documento.toLowerCase().includes("foto") || req.nombre_documento.toLowerCase().includes("fotografía");
        html += `
        <div class="col-md-6 mb-3">
        <label class="small fw-bold text-dark d-block mb-1">${req.nombre_documento}</label>
        ${esFoto ? `
        <div class="bg-light border rounded-2 py-2 px-3 text-muted text-xs shadow-sm"><i class="bi bi-camera-fill me-1"></i> Entrega física en Servicios Escolares</div>
        ` : `
        <input type="file" name="archivos" class="form-control form-control-sm bg-white shadow-sm" accept=".pdf" required>
        `}
        </div>`;
        });
        }
        contenedor.innerHTML = html;
        btnEnviar.style.display = "inline-block";
        })
        .catch(err => {
        contenedor.innerHTML = '<div class="alert alert-danger small col-12">Error al cargar los requisitos.</div>';
        });
        }

        // 4. Interceptar el envío del formulario principal
        const formSolicitud = document.querySelector("form");
        if(formSolicitud) {
        formSolicitud.addEventListener("submit", function (e) {
        e.preventDefault();

        Swal.fire({
        title: '¿Confirmar solicitud?',
        text: "Asegúrate de que todos tus documentos PDF sean correctos.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#198754',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sí, enviar ahora',
        cancelButtonText: 'Revisar'
        }).then((result) => {
        if (result.isConfirmed) {
        enviarFormulario(this);
        }
        });
        });
        }

        function enviarFormulario(formElement) {
        const btn = document.getElementById("btnEnviar");
        const textBtn = document.getElementById("textBtn");
        const spinnerBtn = document.getElementById("spinnerBtn");

        btn.disabled = true;
        textBtn.style.display = "none";
        spinnerBtn.style.display = "inline-block";

        const formData = new FormData(formElement);

        fetch(formElement.action, {
        method: 'POST',
        body: formData
        })
        .then(response => response.json())
        .then(data => {
        if (data.success) {
        Swal.fire({
        title: '¡Solicitud Enviada!',
        text: `Tu trámite con Folio #${data.folio} ha sido registrado.`,
        icon: 'success',
        confirmButtonText: 'Entendido',
        allowOutsideClick: false
        }).then(() => {
        window.location.reload();
        });
        } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
        resetBoton(btn, textBtn, spinnerBtn);
        }
        })
        .catch(err => {
        Swal.fire({ icon: 'error', title: 'Error de conexión', text: 'Fallo al subir archivos.' });
        resetBoton(btn, textBtn, spinnerBtn);
        });
        }

        function resetBoton(btn, text, spinner) {
        btn.disabled = false;
        text.style.display = "inline-block";
        spinner.style.display = "none";
        }

        // 5. Lógica del Modal del Historial (Para Ver y Corregir Archivos)
        document.addEventListener('click', function (e) {
        const btn = e.target.closest('.btn-detalle-alumno');
        if (btn) {
        const data = btn.dataset;
            
        const modalTitulo = document.getElementById('modalTitulo');
        if(modalTitulo) modalTitulo.innerText = `Detalle de Trámite: ${data.tipo}`;

        const containerPdf = document.getElementById('pdfContainerAlumno');
        if(containerPdf) {
        containerPdf.innerHTML = `
        <div class="h-100 d-flex align-items-center justify-content-center text-white opacity-50">
        <div class="text-center">
        <i class="bi bi-file-earmark-pdf" style="font-size: 3rem;"></i>
        <p>Selecciona un documento para visualizarlo</p>
        </div>
        </div>`;
        }

        cargarDetalleSubsanacion(data.id, data.archivopath, data.idTramite);
        new bootstrap.Modal(document.getElementById('modalAlumno')).show();
        }
        });

        function cargarDetalleSubsanacion(idSolicitud, folderPath, idTramite) {
        const lista = document.getElementById('listaDocumentosAlumno');
        lista.innerHTML = '<div class="text-center p-4"><div class="spinner-border text-primary"></div></div>';

        fetch(`/Tramites/ObtenerDetalleRequisitos?idSolicitud=${idSolicitud}`)
        .then(r => r.json())
        .then(requisitos => {
        lista.innerHTML = "";
        if(requisitos.length === 0) {
        lista.innerHTML = '<div class="alert alert-info small">No hay documentos.</div>';
        return;
        }

        requisitos.forEach(req => {
        const esRechazado = (req.estatus || req.Estatus).toLowerCase() === "rechazado";
        const esAprobado = (req.estatus || req.Estatus).toLowerCase() === "aprobado";
        const archivoFisico = req.nombreArchivoFisico || req.NombreArchivoFisico;
        const tieneArchivo = archivoFisico && archivoFisico !== "null" && archivoFisico !== "";
        const nombreRequisito = req.nombreRequisito || req.NombreRequisito;
        const idReq = req.idRequisito || req.IdRequisito;
                    
        let colorBorde = 'border-secondary';
        let colorIcono = 'text-secondary';
        if(esAprobado) { colorBorde = 'border-success'; colorIcono = 'text-success'; }
        if(esRechazado) { colorBorde = 'border-danger'; colorIcono = 'text-danger'; }

        lista.innerHTML += `
        <div class="bg-white border rounded-3 p-3 mb-2 shadow-sm border-start border-4 ${colorBorde}">
        <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="fw-bold text-dark text-xs">${nombreRequisito}</span>
        <i class="bi bi-circle-fill ${colorIcono}" style="font-size:0.6rem"></i>
        </div>
        <div class="d-flex gap-2">
        <button type="button" class="btn btn-dark btn-sm text-xs flex-grow-1" ${!tieneArchivo ? 'disabled' : ''} onclick="verArchivoAlumno('${folderPath}', '${archivoFisico}', '${nombreRequisito}')">${tieneArchivo ? 'Ver Documento' : 'Sin archivo'}</button>
        ${esRechazado ? `
        <button type="button" class="btn btn-outline-danger btn-sm text-xs" onclick="document.getElementById('in_${idReq}').click()" title="Subir corrección"><i class="bi bi-arrow-repeat"></i> Reemplazar</button>
        <input type="file" id="in_${idReq}" class="d-none" accept=".pdf" onchange="subirCorreccion(this, ${idSolicitud}, ${idReq}, '${folderPath}')">
        ` : ''}
        </div>
        </div>`;
        });
        })
        .catch(err => {
        lista.innerHTML = '<div class="alert alert-danger small">Error al cargar documentos.</div>';
        });
        }

        function verArchivoAlumno(folderPath, archivoFisico, nombre) {
        if (!archivoFisico || archivoFisico === "null" || archivoFisico === "") return;

        let path = folderPath.replace(/\\/g, '/');
        if (!path.includes('/Carpetas_ZIP/')) {
        path = path.replace('Carpetas_ZIP', '/Carpetas_ZIP/');
        }
        const url = `/uploads/tramites/${path}/${archivoFisico}`.replace(/\/+/g, '/');

        const labelActivo = document.getElementById('nombreDocActivo');
        if(labelActivo) labelActivo.innerText = nombre;
        
        const container = document.getElementById('pdfContainerAlumno');
        container.innerHTML = `<div class="d-flex flex-column align-items-center justify-content-center h-100"><div class="spinner-border text-light"></div></div>`;

        setTimeout(() => {
        container.innerHTML = `<iframe src="${url}?v=${new Date().getTime()}#toolbar=1" style="width:100%; height:100%; border:none; min-height: 500px;"></iframe>`;
        }, 300);
        }

        function subirCorreccion(input, idSolicitud, idRequisito, folderPath) {
        if (!input.files || input.files.length === 0) return;

        const archivo = input.files[0];
        if (archivo.type !== "application/pdf") {
        Swal.fire({ icon: 'error', title: 'Formato inválido', text: 'Solo se permiten archivos PDF.' });
        input.value = "";
        return;
        }

        const formData = new FormData();
        formData.append("idDetalle", idRequisito);
        formData.append("idSolicitud", idSolicitud);
        formData.append("archivoNuevo", archivo);

        const btnReemplazar = input.previousElementSibling;
        const btnOriginalHtml = btnReemplazar.innerHTML;
        btnReemplazar.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btnReemplazar.disabled = true;

        fetch('/Tramites/SubsanarDocumento', {
        method: 'POST',
        body: formData
        })
        .then(response => response.json())
        .then(data => {
        if (data.success) {
        Swal.fire({ icon: 'success', title: '¡Actualizado!', text: 'El documento ha sido reemplazado.', timer: 2000, showConfirmButton: false });
        const btnDetalle = document.querySelector(`.btn-detalle-alumno[data-id="${idSolicitud}"]`);
        cargarDetalleSubsanacion(idSolicitud, folderPath, btnDetalle ? btnDetalle.dataset.idTramite : 0);
        } else {
        Swal.fire({ icon: 'warning', title: 'Error', text: data.message });
        btnReemplazar.innerHTML = btnOriginalHtml;
        btnReemplazar.disabled = false;
        }
        })
        .catch(err => {
        Swal.fire({ icon: 'error', title: 'Error', text: 'No se pudo conectar con el servidor.' });
        btnReemplazar.innerHTML = btnOriginalHtml;
        btnReemplazar.disabled = false;
        });
        }

        // 6. Recargar la tabla si el alumno cierra el modal después de corregir algo
        const modalElement = document.getElementById('modalAlumno');
        if(modalElement) {
        modalElement.addEventListener('hidden.bs.modal', function () {
        window.location.reload();
        });
        }
    </script>
}