@model ControlEscolar.Models.Dashboard.AcademicQualityViewModel
@{
    ViewData["Title"] = "Calidad Académica — Rendimiento Estudiantil";
    Layout = "_LayoutDashboard";
    var cuatNames = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center mb-4 text-sm">
        <i class="bi bi-exclamation-triangle-fill fs-5 me-3"></i>
        <div><strong>Error:</strong> @ViewBag.Error</div>
    </div>
}

<div class="admin-card-white p-3 mb-4 shadow-sm border-0">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">AÑO</label>
            <select name="year" class="form-select bg-app border-0 text-sm fw-bold">
                @foreach (var y in Model.AvailableYears)
                {
                    if (y == Model.SelectedYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">CUATRIMESTRE</label>
            <select name="cuatrimestre" class="form-select bg-app border-0 text-sm fw-bold">
                @{
                    var cuatOptions = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
                }
                @foreach (var opt in cuatOptions)
                {
                    if (opt.Key == Model.SelectedCuatrimestre)
                    {
                        <option value="@opt.Key" selected>@opt.Value</option>
                    }
                    else
                    {
                        <option value="@opt.Key">@opt.Value</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-dark text-xs px-4 fw-bold shadow-sm">
                <i class="bi bi-funnel-fill me-2"></i> APLICAR
            </button>
            <a href="@Url.Action("Calidad", "Dashboard")" class="btn btn-light border text-xs px-4 fw-bold">
                LIMPIAR
            </a>
        </div>
    </form>
</div>

@if (Model.SelectedCuatrimestre > 0)
{
    <div class="badge bg-dark mb-4 px-3 py-2 fw-normal text-xs shadow-sm">
        <i class="bi bi-filter-circle me-1"></i> Filtro activo: Año @Model.SelectedYear, @cuatNames[Model.SelectedCuatrimestre]
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Calificaciones</div>
                <div class="fs-2 fw-bold txt-title" style="color: #0d9e7a;">@Model.TotalFinalGrades</div>
                <div class="text-xxs text-muted mt-1">@Model.TotalGradeRecords registros parciales</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-journal-check fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div class="w-100">
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Tasa Aprobación</div>
                <div class="fs-2 fw-bold txt-title text-success">@Model.TasaAprobacion%</div>
                <div class="progress mt-2" style="height: 6px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: @Model.TasaAprobacion%"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Promedio General</div>
                <div class="fs-2 fw-bold txt-title text-primary">@Model.PromedioGeneral</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-award fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Oportunidades</div>
                <div class="fs-2 fw-bold txt-title text-warning">@Model.TotalOpportunities</div>
                <div class="text-xxs text-muted mt-1">@Model.Reprobados reprobados</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-arrow-repeat fs-3"></i></div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-bar-chart-fill text-muted me-2"></i>Distribución de Calificaciones Finales</h6>
            @if (Model.GradeDistribution.Any())
            {
                <div style="position: relative; height: 280px; width: 100%;">
                    <canvas id="chartDist"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos para este periodo</div>
            }
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-pie-chart-fill text-muted me-2"></i>Aprobación vs Reprobación</h6>
            @if (Model.ByPassStatus.Any())
            {
                <div style="position: relative; height: 260px; width: 100%;">
                    <canvas id="chartPass"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos para este periodo</div>
            }
        </div>
    </div>
</div>

@if (Model.GradesBySubject.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-book-fill me-2"></i>Rendimiento por Materia</h6>
            <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblSubjects','rendimiento_materias.csv')">
                <i class="bi bi-download me-1"></i> CSV
            </button>
        </div>
        <div class="table-responsive custom-scroll" style="max-height: 350px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblSubjects">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Materia</th>
                        <th class="border-0">Carrera</th>
                        <th class="text-center border-0">Promedio</th>
                        <th class="text-center border-0">Alumnos</th>
                        <th class="text-center border-0">Aprobados</th>
                        <th class="text-center border-0">Reprobados</th>
                        <th class="text-center pe-3 border-0">% Aprob.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.GradesBySubject)
                    {
                        var pc = s.PassRate >= 80 ? "bg-success" : s.PassRate >= 60 ? "bg-warning text-dark" : "bg-danger";
                        var gc = s.Average >= 8 ? "bg-success" : s.Average >= 7 ? "bg-primary" : "bg-danger";
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@s.SubjectName</td>
                            <td class="text-muted text-xs">@s.CareerName</td>
                            <td class="text-center"><span class="badge @gc">@s.Average.ToString("0.0")</span></td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@s.TotalStudents</span></td>
                            <td class="text-center text-success fw-bold">@s.Passed</td>
                            <td class="text-center @(s.Failed > 0 ? "text-danger fw-bold" : "text-muted")">@s.Failed</td>
                            <td class="text-center pe-3"><span class="badge @pc">@s.PassRate.ToString("0.0")%</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.GradesByTeacher.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-person-video3 me-2"></i>Rendimiento por Docente</h6>
        </div>
        <div class="table-responsive custom-scroll" style="max-height: 300px;">
            <table class="table table-hover align-middle text-sm mb-0">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Docente</th>
                        <th class="text-center border-0">Materias</th>
                        <th class="text-center border-0">Alumnos</th>
                        <th class="text-center border-0">Promedio</th>
                        <th class="text-center pe-3 border-0">% Aprob.</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.GradesByTeacher)
                    {
                        var pc = t.PassRate >= 80 ? "bg-success" : t.PassRate >= 60 ? "bg-warning text-dark" : "bg-danger";
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@t.TeacherName</td>
                            <td class="text-center"><span class="badge bg-primary">@t.TotalSubjects</span></td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@t.TotalStudents</span></td>
                            <td class="text-center fw-bold" style="color: #0d9e7a;">@t.AverageGrade.ToString("0.0")</td>
                            <td class="text-center pe-3"><span class="badge @pc">@t.PassRate.ToString("0.0")%</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    @if (Model.SubjectsByCareer.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2">Materias por Carrera</h6>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Carrera</th><th class="text-center border-0">Materias</th><th class="text-center border-0">Hrs/Sem</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var sc in Model.SubjectsByCareer)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold txt-body text-xs">@sc.CareerName</td>
                                    <td class="text-center"><span class="badge bg-primary">@sc.SubjectCount</span></td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">@sc.TotalHours</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    @if (Model.GradeDistribution.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2">Distribución de Promedios</h6>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Rango</th><th class="text-center border-0">Total</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var g in Model.GradeDistribution)
                            {
                                var gc = g.Range.StartsWith("9") ? "bg-success" : g.Range.StartsWith("8") ? "bg-primary" : g.Range.StartsWith("7") ? "bg-warning text-dark" : "bg-danger";
                                <tr>
                                    <td class="ps-3 fw-bold txt-body">@g.Range</td>
                                    <td class="text-center"><span class="badge @gc">@g.Count</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.Periods.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2"><i class="bi bi-calendar-range me-2"></i>Periodos Académicos</h6>
        <div class="table-responsive custom-scroll" style="max-height: 250px;">
            <table class="table table-hover align-middle text-sm mb-0">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Periodo</th>
                        <th class="text-center border-0">Inicio</th>
                        <th class="text-center border-0">Fin</th>
                        <th class="text-center border-0">Asignaciones</th>
                        <th class="text-center pe-3 border-0">Estatus</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Periods)
                    {
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@p.Name</td>
                            <td class="text-center text-muted text-xs">@p.StartDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-center text-muted text-xs">@p.EndDate.ToString("dd/MM/yyyy")</td>
                            <td class="text-center"><span class="badge bg-primary">@p.Assignments</span></td>
                            <td class="text-center pe-3">
                                @if (p.IsActive)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary">Cerrado</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.SubjectCatalog.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-journal-text me-2"></i>Catálogo de Materias</h6>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value,'tblCatalog',2)">
                    <option value="">Carrera (Todas)</option>
                    @foreach (var c in Model.SubjectsByCareer)
                    {
                        <option value="@c.CareerName">@c.CareerName</option>
                    }
                </select>
                <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblCatalog','catalogo_materias.csv')">
                    <i class="bi bi-download me-1"></i> CSV
                </button>
            </div>
        </div>
        
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblCatalogCount">Mostrando 1 a @Model.SubjectCatalog.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 350px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblCatalog">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Código</th>
                        <th class="border-0">Materia</th>
                        <th class="border-0">Carrera</th>
                        <th class="text-center border-0">Cuatrimestre</th>
                        <th class="text-center pe-3 border-0">Hrs/Sem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.SubjectCatalog)
                    {
                        <tr>
                            <td class="ps-3 fw-bold" style="color: var(--primary-900);">@s.Code</td>
                            <td class="fw-bold txt-title">@s.Name</td>
                            <td class="text-muted text-xs">@s.CareerName</td>
                            <td class="text-center"><span class="badge bg-primary">@s.Semester</span></td>
                            <td class="text-center pe-3"><span class="badge bg-light text-dark border">@s.WeeklyHours</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.RecentFinalGrades.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-card-checklist me-2"></i>Calificaciones Finales Recientes</h6>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value,'tblGrades',5)">
                    <option value="">Estatus (Todos)</option>
                    <option value="Aprobado">Aprobado</option>
                    <option value="Reprobado">Reprobado</option>
                </select>
                <button class="btn btn-dark text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblGrades','calificaciones_finales.csv')">
                    <i class="bi bi-download me-1"></i> EXPORTAR
                </button>
            </div>
        </div>
        
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblGradesCount">Mostrando 1 a @Model.RecentFinalGrades.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblGrades">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Alumno</th>
                        <th class="border-0">Matrícula</th>
                        <th class="border-0">Materia</th>
                        <th class="border-0">Docente</th>
                        <th class="text-center border-0">Calif.</th>
                        <th class="text-center border-0">Estatus</th>
                        <th class="pe-3 border-0">Periodo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.RecentFinalGrades)
                    {
                        var sc = g.PassStatus == "Aprobado" ? "bg-success" : "bg-danger";
                        var gc = g.FinalValue >= 9 ? "text-success" : g.FinalValue >= 8 ? "text-primary" : g.FinalValue >= 7 ? "text-warning" : "text-danger";
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@g.StudentName</td>
                            <td class="text-muted text-xs">@g.Matricula</td>
                            <td class="text-truncate" style="max-width: 150px;" title="@g.SubjectName">@g.SubjectName</td>
                            <td class="text-xs">@g.TeacherName</td>
                            <td class="text-center fw-bold @gc">@g.FinalValue.ToString("0.0")</td>
                            <td class="text-center"><span class="badge @sc">@g.PassStatus</span></td>
                            <td class="text-muted text-xs pe-3">@g.PeriodName</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.RecentOpportunities.Any())
{
    <div class="admin-card-white p-4 shadow-sm mb-5" style="border-left: 4px solid #f59e0b !important;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="text-warning fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-exclamation-circle-fill me-2"></i>Oportunidades Extraordinarias</h6>
            <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblOpp','oportunidades.csv')">
                <i class="bi bi-download me-1"></i> CSV
            </button>
        </div>
        <div class="table-responsive custom-scroll" style="max-height: 300px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblOpp">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Alumno</th>
                        <th class="border-0">Materia</th>
                        <th class="text-center border-0">Tipo</th>
                        <th class="text-center border-0">Calif. Original</th>
                        <th class="text-center border-0">Calif. Oportunidad</th>
                        <th class="text-center border-0">Máx. Perm.</th>
                        <th class="pe-3 border-0">Notas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.RecentOpportunities)
                    {
                        var oc = o.OpportunityGrade >= 7 ? "bg-success" : "bg-danger";
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@o.StudentName</td>
                            <td class="text-truncate" style="max-width: 150px;">@o.SubjectName</td>
                            <td class="text-center"><span class="badge bg-warning text-dark">@o.Type</span></td>
                            <td class="text-center"><span class="badge bg-danger">@o.OriginalGrade.ToString("0.0")</span></td>
                            <td class="text-center"><span class="badge @oc">@o.OpportunityGrade.ToString("0.0")</span></td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@(o.MaxAllowed.HasValue? o.MaxAllowed.Value.ToString("0.0") : "—")</span></td>
                            <td class="text-xs text-muted text-truncate pe-3" style="max-width: 150px;">@(string.IsNullOrEmpty(o.Notes) ? "—" : o.Notes)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    
    <script>
        Chart.register(ChartDataLabels);
        Chart.defaults.color = '#6c757d';
        Chart.defaults.borderColor = 'rgba(0,0,0,0.05)';
        Chart.defaults.font.family = "'Plus Jakarta Sans', system-ui, sans-serif";
        Chart.defaults.font.size = 12;

        @if (Model.GradeDistribution.Any())
        {
            <text>
                new Chart(document.getElementById('chartDist'), {
                type: 'bar',
                data: {
                labels: [@Html.Raw(string.Join(",", Model.GradeDistribution.Select(g => $"'{g.Range}'")))],
                datasets: [{
                data: [@string.Join(",", Model.GradeDistribution.Select(g => g.Count))],
                backgroundColor: ['#18BC9C', '#3498DB', '#F39C12', '#E67E22', '#E74C3C'], // Colores Bootstrap/Flat
                borderRadius: 6,
                maxBarThickness: 55
                }]
                },
                options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                legend: { display: false },
                datalabels: { anchor: 'end', align: 'top', color: '#212529', font: { weight: 'bold', size: 12 }, offset: 4 }
                },
                scales: {
                x: { grid: { display: false } },
                y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { precision: 0 } }
                }
                }
                });
            </text>
        }

        @if (Model.ByPassStatus.Any())
        {
            <text>
                new Chart(document.getElementById('chartPass'), {
                type: 'doughnut',
                data: {
                labels: [@Html.Raw(string.Join(",", Model.ByPassStatus.Select(s => $"'{s.Status}'")))],
                datasets: [{
                data: [@string.Join(",", Model.ByPassStatus.Select(s => s.Count))],
                backgroundColor: ['#18BC9C', '#E74C3C'], // Éxito / Error
                borderWidth: 0
                }]
                },
                options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, boxWidth: 8, font: { size: 11 } } },
                datalabels: {
                color: '#fff',
                font: { weight: 'bold', size: 13 },
                formatter: function(v, ctx) {
                var t = ctx.dataset.data.reduce((a, b) => a + b, 0);
                var p = t > 0 ? Math.round(v / t * 100) : 0;
                return p > 5 ? p + '%' : '';
                }
                }
                }
                }
                });
            </text>
        }

        // Funciones de filtrado y exportación unificadas
        function filterTableByColumn(value, tableId, colIndex) {
        var table = document.getElementById(tableId);
        if (!table) return;
        if (!window._filters) window._filters = {};
        if (!window._filters[tableId]) window._filters[tableId] = {};
            
        if (value) window._filters[tableId][colIndex] = value;
        else delete window._filters[tableId][colIndex];
            
        var rows = table.querySelectorAll('tbody tr');
        var visible = 0;
        rows.forEach(function(row) {
        var show = true;
        for (var ci in window._filters[tableId]) {
        var filterVal = window._filters[tableId][ci];
        var cell = row.cells[parseInt(ci)];
        if (cell && cell.textContent.trim().indexOf(filterVal) === -1) { show = false; break; }
        }
        row.style.display = show ? '' : 'none';
        if (show) visible++;
        });
            
        var countEl = document.getElementById(tableId + 'Count');
        if (countEl) countEl.textContent = 'Mostrando 1 a ' + visible + ' registros';
        }

        function exportTableToCSV(tid, fn) {
        var t = document.getElementById(tid);
        var r = t.querySelectorAll('tr');
        var c = [];
        r.forEach(function(row) {
        if (row.style.display === 'none') return;
        var cols = row.querySelectorAll('th,td');
        var d = [];
        cols.forEach(function(col) { d.push('"' + col.textContent.trim().replace(/\n/g,' ').replace(/"/g,'""') + '"'); });
        c.push(d.join(','));
        });
        var b = new Blob(['\uFEFF' + c.join('\n')], { type: 'text/csv;charset=utf-8;' });
        var l = document.createElement('a');
        l.href = URL.createObjectURL(b);
        l.download = fn;
        l.click();
        }
    </script>
}