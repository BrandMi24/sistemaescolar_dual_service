@model ControlEscolar.Models.Dashboard.VinculacionViewModel
@{
    ViewData["Title"] = "Vinculación — Relaciones Corporativas";
    Layout = "_LayoutDashboard";
    var cuatNames = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
}

@if (ViewBag.Error != null)
{
    <div class="alert-box-sep mb-4 shadow-sm border-theme">
        <i class="bi bi-exclamation-octagon-fill txt-error fs-5"></i>
        <div class="txt-title text-sm"><strong>Error de Sistema:</strong> @ViewBag.Error</div>
    </div>
}

@* ═══════════ FILTER BAR ═══════════ *@
<div class="admin-card-white p-4 mb-4 shadow-sm">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="section-label text-muted mb-2 d-block">Año Académico</label>
            <select name="year" class="form-select text-sm fw-semibold">
                @foreach (var y in Model.AvailableYears)
                {
                    if (y == Model.SelectedYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="section-label text-muted mb-2 d-block">Periodo (Cuatrimestre)</label>
            <select name="cuatrimestre" class="form-select text-sm fw-semibold">
                @{
                    var cuatOptions = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
                }
                @foreach (var opt in cuatOptions)
                {
                    if (opt.Key == Model.SelectedCuatrimestre)
                    {
                        <option value="@opt.Key" selected>@opt.Value</option>
                    }
                    else
                    {
                        <option value="@opt.Key">@opt.Value</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button type="submit" class="btn-primary-sep text-xs px-4"><i class="bi bi-funnel me-2"></i> FILTRAR DATOS</button>
            <a href="@Url.Action("Vinculacion", "Dashboard")" class="btn-ghost-sep text-xs px-4 bg-surface">LIMPIAR</a>
        </div>
    </form>
</div>

@if (Model.SelectedCuatrimestre > 0)
{
    <div class="mb-4 d-inline-flex align-items-center bg-primary-dark txt-white text-xxs fw-bold tracking-wide px-3 py-2 rounded-pill shadow-sm">
        <i class="bi bi-info-circle me-2"></i> VISTA ACTUAL: AÑO @Model.SelectedYear / @cuatNames[Model.SelectedCuatrimestre].ToUpper()
    </div>
}

@* ═══════════ KPI CARDS ═══════════ *@
<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card-sep">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="stat-label">Programas Activos</span>
                <div class="icon-circle bg-accent-light txt-primary-dark shadow-sm"><i class="bi bi-briefcase fs-5"></i></div>
            </div>
            <div class="stat-value">@Model.TotalPrograms</div>
            <span class="text-xxs txt-body mt-1 fw-medium">Programas registrados</span>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card-sep" style="border-left: 3px solid var(--success-700);">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="stat-label">Organizaciones</span>
                <div class="icon-circle bg-success-100 shadow-sm" style="color: var(--success-700);"><i class="bi bi-buildings fs-5"></i></div>
            </div>
            <div class="stat-value">@Model.TotalOrganizations</div>
            <span class="text-xxs txt-body mt-1 fw-medium">Empresas y dependencias</span>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card-sep" style="border-left: 3px solid var(--primary-700);">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="stat-label">Asignaciones</span>
                <div class="icon-circle bg-primary-100 txt-primary-dark shadow-sm"><i class="bi bi-person-workspace fs-5"></i></div>
            </div>
            <div class="stat-value">@Model.TotalAssignments</div>
            <span class="text-xxs txt-body mt-1 fw-medium">@Model.Completados completados · @Model.EnProceso en proceso</span>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card-sep" style="border-left: 3px solid var(--warning-700);">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="stat-label">Evaluación Promedio</span>
                <div class="icon-circle bg-warning-100 shadow-sm" style="color: var(--warning-700);"><i class="bi bi-star-fill fs-5"></i></div>
            </div>
            <div class="stat-value">@Model.PromedioEvaluacion</div>
            <span class="text-xxs txt-body mt-1 fw-medium">@Model.PromedioHoras hrs aprobadas prom.</span>
        </div>
    </div>
</div>

@* ═══════════ CHARTS: Por Tipo + Estatus ═══════════ *@
<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="admin-card-white h-100">
            <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-3">
                <div style="width: 4px; height: 18px; background: var(--primary-900); border-radius: 2px;"></div>
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">Asignaciones por Tipo de Programa</h6>
            </div>
            @if (Model.ByProgramType.Any())
            {
                <div class="chart-container" style="height: 280px;"><canvas id="chartType"></canvas></div>
            }
            else
            {

                <div class="no-data">Sin datos para este periodo</div>
            }
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="admin-card-white h-100">
            <div class="d-flex align-items-center gap-2 mb-4 border-bottom pb-3">
                <div style="width: 4px; height: 18px; background: var(--accent-500); border-radius: 2px;"></div>
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">Estatus de Asignaciones</h6>
            </div>
            @if (Model.ByStatus.Any())
            {
                <div class="chart-container" style="height: 280px;"><canvas id="chartStatus"></canvas></div>
            }
            else
            {

                <div class="no-data">Sin datos para este periodo</div>
            }
        </div>
    </div>
</div>

@* ═══════════ Tables: Resumen Estatus + Documentos ═══════════ *@
<div class="row g-4 mb-4">
    @if (Model.ByStatus.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white h-100">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-4 border-bottom pb-3">Resumen por Estatus</h6>
                <table class="table table-hover align-middle text-sm mb-0 table-borderless">
                    <thead class="bg-app text-xxs fw-bold text-muted"><tr><th class="ps-3 border-0">Estatus</th><th class="text-center border-0">Total</th><th class="text-center pe-3 border-0">%</th></tr></thead>
                    <tbody>
                        @foreach (var s in Model.ByStatus)
                        {
                            var sc = s.Status switch { "Completado" => "status-aceptado", "En Proceso" => "status-pendiente", "Cancelado" => "status-rechazado", _ => "status-pendiente" };
                            <tr><td class="ps-3 fw-bold txt-title text-xs">@s.Status</td><td class="text-center"><span class="badge badge-status @sc shadow-sm">@s.Count</span></td><td class="text-center pe-3 text-muted text-xs">@s.Percentage%</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    @if (Model.DocsByStatus.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white h-100">
                <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-4 border-bottom pb-3">Documentos por Estatus</h6>
                <table class="table table-hover align-middle text-sm mb-0 table-borderless">
                    <thead class="bg-app text-xxs fw-bold text-muted"><tr><th class="ps-3 border-0">Estatus</th><th class="text-center border-0">Total</th><th class="text-center pe-3 border-0">%</th></tr></thead>
                    <tbody>
                        @foreach (var d in Model.DocsByStatus)
                        {
                            var dc = d.Status switch { "APPROVED" => "status-aceptado", "PENDING" or "SUBMITTED" => "status-pendiente", "REJECTED" => "status-rechazado", _ => "status-pendiente" };
                            <tr><td class="ps-3 fw-bold txt-title text-xs">@d.Status</td><td class="text-center"><span class="badge badge-status @dc shadow-sm">@d.Count</span></td><td class="text-center pe-3 text-muted text-xs">@d.Percentage%</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* ═══════════ Organizaciones ═══════════ *@
@if (Model.ByOrganization.Any())
{
    <div class="admin-card-white mb-4 shadow-sm">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0"><i class="bi bi-award me-2"></i>Organizaciones Vinculadas</h6>
        </div>
        <div class="table-responsive custom-scroll" style="max-height: 300px;">
            <table class="table table-hover align-middle text-sm mb-0 table-borderless">
                <thead class="bg-app text-xxs fw-bold text-muted" style="position: sticky; top: 0; z-index: 1;">
                    <tr><th class="ps-3 border-0">#</th><th class="border-0">Organización</th><th class="text-center border-0">Estudiantes</th><th class="text-center pe-3 border-0">%</th></tr>
                </thead>
                <tbody>
                    @{
                        var rk = 1;
                    }
                    @foreach (var o in Model.ByOrganization)
                    {
                        <tr><td class="ps-3 text-muted fw-bold">@rk</td><td class="fw-bold txt-title text-xs">@o.Status</td><td class="text-center"><span class="badge bg-primary-100 txt-primary-dark px-3 py-1">@o.Count</span></td><td class="text-center pe-3 text-muted text-xs">@o.Percentage%</td></tr>
                        rk++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ═══════════ Catálogo de Programas ═══════════ *@
@if (Model.Programs.Any())
{
    <div class="admin-card-white mb-4 shadow-sm">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0"><i class="bi bi-collection me-2"></i>Catálogo de Programas</h6>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblPrograms',2)">
                    <option value="">Tipo (Todos)</option>
                    @foreach (var t in Model.ByProgramType)
                    {
                        <option value="@t.Status">@t.Status</option>
                    }
                </select>
                <button class="btn btn-sm btn-light border text-xxs fw-bold px-3 py-1" onclick="exportTableToCSV('tblPrograms','catalogo_programas.csv')"><i class="bi bi-download"></i></button>
            </div>
        </div>
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblProgramsCount">Mostrando 1 a @Model.Programs.Count registros</div>
        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0 table-borderless" id="tblPrograms">
                <thead class="bg-app text-xxs fw-bold text-muted" style="position: sticky; top: 0; z-index: 1;">
                    <tr><th class="ps-3 border-0">Código</th><th class="border-0">Programa</th><th class="border-0">Tipo</th><th class="border-0">Periodo</th><th class="text-center border-0">Año</th><th class="text-center border-0">Hrs. Req.</th><th class="text-center border-0">Estudiantes</th><th class="text-center pe-3 border-0">Activo</th></tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Programs)
                    {
                        <tr>
                            <td class="ps-3 fw-bold txt-primary-dark">@p.Code</td>
                            <td class="fw-bold txt-title text-xs">@p.Name</td>
                            <td><span class="badge bg-primary-100 txt-primary-dark" style="font-size:10px;">@p.Type</span></td>
                            <td class="text-muted text-xs">@p.Period</td>
                            <td class="text-center text-muted text-xs">@p.Year</td>
                            <td class="text-center"><span class="badge bg-app txt-title">@p.RequiredHours</span></td>
                            <td class="text-center"><span class="badge bg-primary-dark txt-white px-2">@p.TotalStudents</span></td>
                            <td class="text-center pe-3">@if (p.IsActive) {
                            <span class="badge badge-status status-aceptado shadow-sm">Sí</span>
                        } else
                        {

                            <span class="badge badge-status status-rechazado shadow-sm">No</span>
                        }
    </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
}

@* ═══════════ Directorio de Organizaciones ═══════════ *@
@if (Model.Organizations.Any())
{
    <div class="admin-card-white mb-4 shadow-sm">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0"><i class="bi bi-buildings me-2"></i>Directorio de Organizaciones</h6>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblOrgs',1)">
                    <option value="">Tipo (Todos)</option>
                    @foreach (var t in Model.Organizations.Select(o => o.Type).Distinct().OrderBy(t => t))
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <button class="btn btn-sm btn-light border text-xxs fw-bold px-3 py-1" onclick="exportTableToCSV('tblOrgs','directorio_organizaciones.csv')"><i class="bi bi-download"></i></button>
            </div>
        </div>
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblOrgsCount">Mostrando 1 a @Model.Organizations.Count registros</div>
        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0 table-borderless" id="tblOrgs">
                <thead class="bg-app text-xxs fw-bold text-muted" style="position: sticky; top: 0; z-index: 1;">
                    <tr><th class="ps-3 border-0">Organización</th><th class="border-0">Tipo</th><th class="border-0">Ciudad</th><th class="border-0">Contacto</th><th class="border-0">Teléfono</th><th class="text-center pe-3 border-0">Estudiantes</th></tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Organizations)
                    {
                        <tr>
                            <td class="ps-3 fw-bold txt-title text-xs">@o.Name</td>
                            <td><span class="badge bg-primary-100 txt-primary-dark" style="font-size:10px;">@o.Type</span></td>
                            <td class="text-muted text-xs">@o.City</td>
                            <td class="text-xs">@o.ContactName</td>
                            <td class="text-muted text-xs">@o.Phone</td>
                            <td class="text-center pe-3"><span class="badge bg-primary-dark txt-white px-2">@o.TotalStudents</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ═══════════ Asignaciones de Estudiantes ═══════════ *@
@if (Model.RecentAssignments.Any())
{
    <div class="admin-card-white mb-4 shadow-sm">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0"><i class="bi bi-person-check me-2"></i>Asignaciones de Estudiantes</h6>
            <div class="d-flex gap-2 flex-wrap">
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblAssign',5)">
                    <option value="">Estatus (Todos)</option>
                    @foreach (var s in Model.ByStatus)
                    {
                        <option value="@s.Status">@s.Status</option>
                    }
                </select>
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblAssign',3)">
                    <option value="">Tipo (Todos)</option>
                    @foreach (var t in Model.ByProgramType)
                    {
                        <option value="@t.Status">@t.Status</option>
                    }
                </select>
                <button class="btn-primary-sep text-xxs py-2 px-3" onclick="exportTableToCSV('tblAssign','asignaciones_estudiantes.csv')"><i class="bi bi-file-earmark-excel me-2"></i> EXPORTAR</button>
            </div>
        </div>
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblAssignCount">Mostrando 1 a @Model.RecentAssignments.Count registros</div>
        <div class="table-responsive custom-scroll" style="max-height: 450px;">
            <table class="table table-hover align-middle text-sm mb-0 table-borderless" id="tblAssign">
                <thead class="bg-primary-dark txt-white text-xxs" style="position: sticky; top: 0; z-index: 10;">
                    <tr><th class="ps-3 border-0">Alumno</th><th class="border-0">Matrícula</th><th class="border-0">Programa</th><th class="border-0">Tipo</th><th class="border-0">Organización</th><th class="text-center border-0">Estatus</th><th class="text-center border-0">Hrs.</th><th class="text-center border-0">Eval.</th><th class="text-end pe-3 border-0">Inicio</th></tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentAssignments)
                    {
                        var sc = a.Status switch { "Completado" => "status-aceptado", "En Proceso" => "status-pendiente", "Cancelado" => "status-rechazado", _ => "status-pendiente" };
                        var ec = a.EvaluationScore.HasValue ? (a.EvaluationScore >= 9 ? "color: var(--success-700); font-weight:bold;" : a.EvaluationScore >= 7 ? "color: var(--primary-700); font-weight:bold;" : "color: var(--error-700,#991B1B); font-weight:bold;") : "color: var(--text-muted);";
                        <tr>
                            <td class="ps-3 fw-bold txt-title text-xs">@a.StudentName</td>
                            <td class="text-muted text-xs">@a.Matricula</td>
                            <td class="text-truncate text-xs" style="max-width:160px;" title="@a.ProgramName">@a.ProgramName</td>
                            <td><span class="badge bg-primary-100 txt-primary-dark" style="font-size:10px;">@a.ProgramType</span></td>
                            <td class="text-truncate text-xs" style="max-width:140px;" title="@a.OrganizationName">@a.OrganizationName</td>
                            <td class="text-center"><span class="badge badge-status @sc shadow-sm">@a.Status</span></td>
                            <td class="text-center"><span class="badge bg-app txt-title">@a.ApprovedHours</span></td>
                            <td class="text-center" style="@ec">@(a.EvaluationScore.HasValue? a.EvaluationScore.Value.ToString("0.0") : "—")</td>
                            <td class="text-end pe-3 text-muted text-xs">@(a.StartDate.HasValue? a.StartDate.Value.ToString("dd/MMM/yy") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ═══════════ Documentos de Vinculación ═══════════ *@
@if (Model.RecentDocuments.Any())
{
    <div class="admin-card-white mb-5 shadow-sm">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-4 gap-3">
            <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0"><i class="bi bi-file-earmark-pdf me-2"></i>Documentos de Vinculación</h6>
            <div class="d-flex gap-2 flex-wrap">
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblDocs',4)">
                    <option value="">Estatus (Todos)</option>
                    @foreach (var d in Model.DocsByStatus)
                    {
                        <option value="@d.Status">@d.Status</option>
                    }
                </select>
                <select class="form-select form-select-sm text-xxs fw-bold bg-app border-0" style="width: auto;" onchange="filterTableByColumn(this.value,'tblDocs',2)">
                    <option value="">Tipo (Todos)</option>
                    @foreach (var t in Model.RecentDocuments.Select(d => d.DocumentType).Distinct().OrderBy(t => t))
                    {
                        <option value="@t">@t</option>
                    }
                </select>
                <button class="btn-primary-sep text-xxs py-2 px-3" onclick="exportTableToCSV('tblDocs','documentos_vinculacion.csv')"><i class="bi bi-file-earmark-excel me-2"></i> EXPORTAR</button>
            </div>
        </div>
        <div class="text-xxs text-muted mb-2 fw-bold" id="tblDocsCount">Mostrando 1 a @Model.RecentDocuments.Count registros</div>
        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0 table-borderless" id="tblDocs">
                <thead class="bg-app text-xxs fw-bold text-muted" style="position: sticky; top: 0; z-index: 1;">
                    <tr><th class="ps-3 border-0">Título</th><th class="border-0">Alumno</th><th class="border-0">Tipo</th><th class="border-0">Programa</th><th class="text-center border-0">Estatus</th><th class="border-0">Archivo</th><th class="text-end pe-3 border-0">Fecha</th></tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        var dc = doc.Status switch { "APPROVED" => "status-aceptado", "PENDING" or "SUBMITTED" => "status-pendiente", "REJECTED" => "status-rechazado", _ => "status-pendiente" };
                        <tr>
                            <td class="ps-3 fw-bold txt-title text-truncate" style="max-width:200px;" title="@doc.Title">@doc.Title</td>
                            <td class="text-xs">@doc.StudentName</td>
                            <td><span class="badge bg-primary-100 txt-primary-dark" style="font-size:10px;">@doc.DocumentType</span></td>
                            <td class="text-muted text-xs text-truncate" style="max-width:160px;" title="@doc.ProgramName">@doc.ProgramName</td>
                            <td class="text-center"><span class="badge badge-status @dc shadow-sm">@doc.Status</span></td>
                            <td class="font-monospace text-muted" style="font-size:11px; max-width:120px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@doc.FileName">@doc.FileName</td>
                            <td class="text-end pe-3 text-muted text-xs">@doc.UploadDate.ToString("dd/MMM/yy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <script>
        Chart.register(ChartDataLabels); Chart.defaults.color = '#6B7280'; Chart.defaults.font.family = "'Montserrat', sans-serif";

        @if (Model.ByProgramType.Any())
        {
                <text>new Chart(document.getElementById('chartType'), { type: 'bar', data: { labels: [@Html.Raw(string.Join(",", Model.ByProgramType.Select(t => $"'{t.Status}'")))], datasets: [{ data: [@string.Join(",", Model.ByProgramType.Select(t => t.Count))], backgroundColor: '#13322B', borderRadius: 4, maxBarThickness: 55 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, datalabels: { anchor: 'end', align: 'top', color: '#13322B', font: { weight: '800', size: 10 }, offset: 4 } }, scales: { x: { grid: { display: false } }, y: { grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { precision: 0 } } } } });</text>
        }

        @if (Model.ByStatus.Any())
        {
                <text>new Chart(document.getElementById('chartStatus'), { type: 'doughnut', data: { labels: [@Html.Raw(string.Join(",", Model.ByStatus.Select(s => $"'{s.Status}'")))], datasets: [{ data: [@string.Join(",", Model.ByStatus.Select(s => s.Count))], backgroundColor: ['#13322B', '#D4C19C', '#204A40', '#991B1B', '#A67C52'], borderWidth: 2, borderColor: '#ffffff' }] }, options: { responsive: true, maintainAspectRatio: false, cutout: '75%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 15, font: { size: 10, weight: '600' } } }, datalabels: { display: false } } } });</text>
        }

        function filterTableByColumn(value, tableId, colIndex) { var table = document.getElementById(tableId); if (!table) return; if (!window._filters) window._filters = {}; if (!window._filters[tableId]) window._filters[tableId] = {}; if (value) window._filters[tableId][colIndex] = value; else delete window._filters[tableId][colIndex]; var rows = table.querySelectorAll('tbody tr'); var visible = 0; rows.forEach(function(row) { var show = true; for (var ci in window._filters[tableId]) { var fv = window._filters[tableId][ci]; var cell = row.cells[parseInt(ci)]; if (cell && cell.textContent.trim().indexOf(fv) === -1) { show = false; break; } } row.style.display = show ? '' : 'none'; if (show) visible++; }); var countEl = document.getElementById(tableId + 'Count'); if (countEl) countEl.textContent = 'Mostrando 1 a ' + visible + ' registros'; }
        function exportTableToCSV(tid, fn) { var t = document.getElementById(tid); var r = t.querySelectorAll('tr'); var c = []; r.forEach(function(row) { if (row.style.display === 'none') return; var cols = row.querySelectorAll('th,td'); var d = []; cols.forEach(function(col) { d.push('"' + col.textContent.trim().replace(/\n/g,' ').replace(/"/g,'""') + '"'); }); c.push(d.join(',')); }); var b = new Blob(['\uFEFF' + c.join('\n')], { type: 'text/csv;charset=utf-8;' }); var l = document.createElement('a'); l.href = URL.createObjectURL(b); l.download = fn; l.click(); }
    </script>
}
