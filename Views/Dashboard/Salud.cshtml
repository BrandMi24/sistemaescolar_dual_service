@model ControlEscolar.Models.Dashboard.MedicalViewModel
@{
    ViewData["Title"] = "Servicios Médicos — Salud Integral";
    Layout = "_LayoutDashboard";
    var cuatNames = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center mb-4 text-sm">
        <i class="bi bi-exclamation-triangle-fill fs-5 me-3"></i>
        <div><strong>Error:</strong> @ViewBag.Error</div>
    </div>
}

<div class="admin-card-white p-3 mb-4 shadow-sm border-0">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">AÑO</label>
            <select name="year" class="form-select bg-app border-0 text-sm fw-bold">
                @foreach (var y in Model.AvailableYears)
                {
                    if (y == Model.SelectedYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">CUATRIMESTRE</label>
            <select name="cuatrimestre" class="form-select bg-app border-0 text-sm fw-bold">
                @{
                    var cuatOptions = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
                }
                @foreach (var opt in cuatOptions)
                {
                    if (opt.Key == Model.SelectedCuatrimestre)
                    {
                        <option value="@opt.Key" selected>@opt.Value</option>
                    }
                    else
                    {
                        <option value="@opt.Key">@opt.Value</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-dark text-xs px-4 fw-bold shadow-sm">
                <i class="bi bi-funnel-fill me-2"></i> APLICAR
            </button>
            <a href="@Url.Action("Salud", "Dashboard")" class="btn btn-light border text-xs px-4 fw-bold">
                LIMPIAR
            </a>
        </div>
    </form>
</div>

@if (Model.SelectedCuatrimestre > 0)
{
    <div class="badge bg-dark mb-4 px-3 py-2 fw-normal text-xs shadow-sm">
        <i class="bi bi-filter-circle me-1"></i> Filtro activo: Año @Model.SelectedYear, @cuatNames[Model.SelectedCuatrimestre]
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Consultas Médicas</div>
                <div class="fs-2 fw-bold txt-title" style="color: #0d9e7a;">@Model.TotalVisitas</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-bandaid fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Atención Psicológica</div>
                <div class="fs-2 fw-bold txt-title text-primary">@Model.TotalPsicologicas</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-person-heart fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Edad Promedio</div>
                <div class="fs-2 fw-bold txt-title text-info">@Model.PromedioEdad <span class="text-sm text-muted">años</span></div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-calendar3 fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">IMC Promedio</div>
                <div class="fs-2 fw-bold txt-title text-warning">@Model.PromedioIMC</div>
                <div class="text-xxs text-muted mt-1">Temp. promedio: @Model.PromedioTemperatura°C</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-activity fs-3"></i></div>
        </div>
    </div>
</div>

<div class="row g-3 mb-5">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-3 h-100 shadow-sm border-0 d-flex align-items-center gap-3">
            <div class="icon-circle-lg bg-app text-danger"><i class="bi bi-exclamation-triangle-fill fs-4"></i></div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase mb-1">Con Alergias</div>
                <div class="fs-4 fw-bold txt-title text-danger">@Model.ConAlergias</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-3 h-100 shadow-sm border-0 d-flex align-items-center gap-3">
            <div class="icon-circle-lg bg-app text-warning"><i class="bi bi-clipboard2-pulse-fill fs-4"></i></div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase mb-1">Enf. Crónicas</div>
                <div class="fs-4 fw-bold txt-title text-warning">@Model.ConEnfermedadesCronicas</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-3 h-100 shadow-sm border-0 d-flex align-items-center gap-3">
            <div class="icon-circle-lg bg-app text-primary"><i class="bi bi-arrow-return-left fs-4"></i></div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase mb-1">Terapia Previa</div>
                <div class="fs-4 fw-bold txt-title">@Model.ConTerapiaPrevia</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-3 h-100 shadow-sm border-0 d-flex align-items-center gap-3">
            <div class="icon-circle-lg bg-app text-info"><i class="bi bi-capsule fs-4"></i></div>
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase mb-1">Con Medicación</div>
                <div class="fs-4 fw-bold txt-title">@Model.ConMedicacion</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-bar-chart-fill text-muted me-2"></i>Top 10 Motivos de Consulta Médica</h6>
            @if (Model.TopDiagnosticos.Any())
            {
                <div style="position: relative; height: 280px; width: 100%;">
                    <canvas id="chartDiag"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos para este periodo</div>
            }
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-pie-chart-fill text-muted me-2"></i>Distribución por Edad</h6>
            @if (Model.ByEdad.Any())
            {
                <div style="position: relative; height: 260px; width: 100%;">
                    <canvas id="chartEdad"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos para este periodo</div>
            }
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    @if (Model.TopDiagnosticos.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-clipboard2-check me-2"></i>Diagnósticos Médicos</h6>
                    <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblDiag','diagnosticos_medicos.csv')">
                        <i class="bi bi-download"></i> CSV
                    </button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 300px;">
                    <table class="table table-hover align-middle text-sm mb-0" id="tblDiag">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th class="ps-3 border-0 rounded-start">#</th>
                                <th class="border-0">Diagnóstico</th>
                                <th class="text-center border-0">Casos</th>
                                <th class="text-center pe-3 border-0 rounded-end">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var rk = 1;
                            }
                            @foreach (var d in Model.TopDiagnosticos)
                            {
                                <tr>
                                    <td class="ps-3 text-muted fw-bold">@rk</td>
                                    <td class="fw-bold txt-title text-xs">@d.Status</td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">@d.Count</span></td>
                                    <td class="text-center pe-3 text-muted">@d.Percentage%</td>
                                </tr>
                                rk++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.TopMotivosPsicologicos.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-3">
                    <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-chat-heart me-2"></i>Motivos Psicológicos</h6>
                    <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblPsico','motivos_psicologicos.csv')">
                        <i class="bi bi-download"></i> CSV
                    </button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 300px;">
                    <table class="table table-hover align-middle text-sm mb-0" id="tblPsico">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr>
                                <th class="ps-3 border-0 rounded-start">#</th>
                                <th class="border-0">Motivo</th>
                                <th class="text-center border-0">Casos</th>
                                <th class="text-center pe-3 border-0 rounded-end">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var rk2 = 1;
                            }
                            @foreach (var m in Model.TopMotivosPsicologicos)
                            {
                                var mc = m.Status.Contains("suicida") || m.Status.Contains("Violencia") ? "bg-danger" : m.Status.Contains("Ansiedad") || m.Status.Contains("Depresión") ? "bg-warning text-dark" : "bg-light text-dark border";
                                <tr>
                                    <td class="ps-3 text-muted fw-bold">@rk2</td>
                                    <td class="fw-bold txt-title text-xs">@m.Status</td>
                                    <td class="text-center"><span class="badge @mc">@m.Count</span></td>
                                    <td class="text-center pe-3 text-muted">@m.Percentage%</td>
                                </tr>
                                rk2++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<div class="row g-4 mb-5">
    @if (Model.ByEdad.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2">Distribución por Edad</h6>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Rango</th><th class="text-center pe-3 border-0">Total</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.ByEdad)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold txt-body">@e.Range</td>
                                    <td class="text-center pe-3"><span class="badge bg-light text-dark border">@e.Count</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    
    <div class="col-12 col-lg-6">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2">Resumen de Signos Vitales</h6>
            <div class="table-responsive custom-scroll" style="max-height: 250px;">
                <table class="table table-hover align-middle text-sm mb-0">
                    <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                        <tr><th class="ps-3 border-0">Indicador</th><th class="text-center pe-3 border-0">Valor Promedio</th></tr>
                    </thead>
                    <tbody>
                        <tr><td class="ps-3 fw-bold txt-title">Temperatura</td><td class="text-center pe-3"><span class="badge @(Model.PromedioTemperatura > 37.5m ? "bg-danger" : "bg-success")">@Model.PromedioTemperatura °C</span></td></tr>
                        <tr><td class="ps-3 fw-bold txt-title">IMC</td><td class="text-center pe-3"><span class="badge @(Model.PromedioIMC > 25 ? "bg-warning text-dark" : "bg-success")">@Model.PromedioIMC</span></td></tr>
                        <tr><td class="ps-3 fw-bold txt-title">Edad Promedio</td><td class="text-center pe-3"><span class="badge bg-info text-dark">@Model.PromedioEdad años</span></td></tr>
                        <tr><td class="ps-3 fw-bold txt-title">Pacientes con Alergias</td><td class="text-center pe-3"><span class="badge bg-danger">@Model.ConAlergias</span></td></tr>
                        <tr><td class="ps-3 fw-bold txt-title">Enfermedades Crónicas</td><td class="text-center pe-3"><span class="badge bg-warning text-dark">@Model.ConEnfermedadesCronicas</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (Model.RecentVisitas.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4" style="border-left: 4px solid #0d9e7a !important;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0"><i class="bi bi-file-medical me-2"></i>Bitácora de Atención Médica</h6>
            <div class="d-flex gap-2 flex-wrap">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value,'tblVisitas',4)">
                    <option value="">Diagnóstico (Todos)</option>
                    @foreach (var d in Model.TopDiagnosticos.Take(10))
                    {
                        <option value="@d.Status">@d.Status</option>
                    }
                </select>
                <button class="btn btn-dark text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblVisitas','bitacora_medica.csv')">
                    <i class="bi bi-download me-1"></i> DESCARGAR
                </button>
            </div>
        </div>

        <div class="text-xxs text-muted mb-2 fw-bold" id="tblVisitasCount">Mostrando 1 a @Model.RecentVisitas.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblVisitas">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Matrícula</th>
                        <th class="border-0">Fecha</th>
                        <th class="text-center border-0">Edad</th>
                        <th class="text-center border-0">Temp.</th>
                        <th class="border-0">Diagnóstico</th>
                        <th class="text-center border-0">P/A</th>
                        <th class="text-center border-0">Sat.</th>
                        <th class="text-center pe-3 border-0">Alergias</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.RecentVisitas)
                    {
                        <tr>
                            <td class="ps-3 fw-bold" style="color: var(--primary-900);">@v.Matricula</td>
                            <td class="text-muted text-xs">@v.FechaVisita.ToString("dd/MMM/yyyy")</td>
                            <td class="text-center text-xs">@v.Edad</td>
                            <td class="text-center"><span class="badge @(v.Temperatura != "—" && decimal.TryParse(v.Temperatura, out var temp) && temp > 37.5m ? "bg-danger" : "bg-light text-dark border")">@v.Temperatura°</span></td>
                            <td class="fw-bold txt-title text-xs text-truncate" style="max-width: 150px;" title="@v.Diagnostico">@v.Diagnostico</td>
                            <td class="text-center text-xs">@v.PresionArterial</td>
                            <td class="text-center text-xs">@v.Saturacion</td>
                            <td class="text-center pe-3">
                                @if (v.TieneAlergias)
                                {
                                    <span class="badge bg-danger" title="@v.Alergias">Sí</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.RecentPsicologicas.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-5" style="border-left: 4px solid #8b5cf6 !important;">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0" style="color: #8b5cf6;"><i class="bi bi-journal-medical me-2"></i>Bitácora Psicológica</h6>
            <div class="d-flex gap-2 flex-wrap">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value,'tblPsicoVisitas',4)">
                    <option value="">Motivo (Todos)</option>
                    @foreach (var m in Model.TopMotivosPsicologicos.Take(10))
                    {
                        <option value="@m.Status">@m.Status</option>
                    }
                </select>
                <button class="btn btn-dark text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblPsicoVisitas','bitacora_psicologica.csv')">
                    <i class="bi bi-download me-1"></i> DESCARGAR
                </button>
            </div>
        </div>

        <div class="text-xxs text-muted mb-2 fw-bold" id="tblPsicoVisitasCount">Mostrando 1 a @Model.RecentPsicologicas.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 400px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblPsicoVisitas">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Matrícula</th>
                        <th class="border-0">Fecha</th>
                        <th class="text-center border-0">Edad</th>
                        <th class="text-center border-0">Terapia Previa</th>
                        <th class="border-0">Motivo de Consulta</th>
                        <th class="pe-3 border-0">Medicación</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.RecentPsicologicas)
                    {
                        <tr>
                            <td class="ps-3 fw-bold" style="color: #8b5cf6;">@p.Matricula</td>
                            <td class="text-muted text-xs">@p.FechaVisita.ToString("dd/MMM/yyyy")</td>
                            <td class="text-center text-xs">@p.Edad</td>
                            <td class="text-center">
                                @if (p.TerapiaPrevia)
                                {
                                    <span class="badge bg-warning text-dark">Sí</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="fw-bold txt-title text-xs text-truncate" style="max-width: 200px;" title="@p.MotivoConsulta">@p.MotivoConsulta</td>
                            <td class="text-xs text-muted text-truncate pe-3" style="max-width: 150px;">@(string.IsNullOrEmpty(p.Medicacion) ? "—" : p.Medicacion)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    
    <script>
        Chart.register(ChartDataLabels);
        Chart.defaults.color = '#6c757d';
        Chart.defaults.borderColor = 'rgba(0,0,0,0.05)';
        Chart.defaults.font.family = "'Plus Jakarta Sans', system-ui, sans-serif";
        Chart.defaults.font.size = 12;

        var palette = ['#0d9e7a', '#E83E8C', '#F39C12', '#2C3E50', '#8b5cf6', '#3498DB', '#E74C3C', '#1ABC9C', '#95A5A6', '#D35400'];

        @if (Model.TopDiagnosticos.Any())
        {
            <text>
                new Chart(document.getElementById('chartDiag'), {
                type: 'bar',
                data: {
                labels: [@Html.Raw(string.Join(",", Model.TopDiagnosticos.Take(10).Select(d => $"'{d.Status}'")))],
                datasets: [{
                data: [@string.Join(",", Model.TopDiagnosticos.Take(10).Select(d => d.Count))],
                backgroundColor: '#2C3E50',
                borderRadius: 6,
                maxBarThickness: 36
                }]
                },
                options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                legend: { display: false },
                datalabels: { anchor: 'end', align: 'right', color: '#212529', font: { weight: 'bold', size: 12 }, offset: 4 }
                },
                scales: {
                x: { display: false, grid: { display: false } },
                y: { grid: { display: false } }
                },
                layout: { padding: { right: 40 } }
                }
                });
            </text>
        }

        @if (Model.ByEdad.Any())
        {
            <text>
                new Chart(document.getElementById('chartEdad'), {
                type: 'doughnut',
                data: {
                labels: [@Html.Raw(string.Join(",", Model.ByEdad.Select(e => $"'{e.Range}'")))],
                datasets: [{
                data: [@string.Join(",", Model.ByEdad.Select(e => e.Count))],
                backgroundColor: palette,
                borderWidth: 0
                }]
                },
                options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, boxWidth: 8, font: { size: 11 } } },
                datalabels: {
                color: '#fff',
                font: { weight: 'bold', size: 13 },
                formatter: function(v, ctx) {
                var t = ctx.dataset.data.reduce((a, b) => a + b, 0);
                var p = t > 0 ? Math.round(v / t * 100) : 0;
                return p > 5 ? p + '%' : '';
                }
                }
                }
                }
                });
            </text>
        }

        // Funciones de filtrado y exportación unificadas
        function filterTableByColumn(value, tableId, colIndex) {
        var table = document.getElementById(tableId);
        if (!table) return;
        if (!window._filters) window._filters = {};
        if (!window._filters[tableId]) window._filters[tableId] = {};
            
        if (value) window._filters[tableId][colIndex] = value;
        else delete window._filters[tableId][colIndex];
            
        var rows = table.querySelectorAll('tbody tr');
        var visible = 0;
        rows.forEach(function(row) {
        var show = true;
        for (var ci in window._filters[tableId]) {
        var filterVal = window._filters[tableId][ci];
        var cell = row.cells[parseInt(ci)];
        if (cell && cell.textContent.trim().indexOf(filterVal) === -1) { show = false; break; }
        }
        row.style.display = show ? '' : 'none';
        if (show) visible++;
        });
            
        var countEl = document.getElementById(tableId + 'Count');
        if (countEl) countEl.textContent = 'Mostrando 1 a ' + visible + ' registros';
        }

        function exportTableToCSV(tid, fn) {
        var t = document.getElementById(tid);
        var r = t.querySelectorAll('tr');
        var c = [];
        r.forEach(function(row) {
        if (row.style.display === 'none') return;
        var cols = row.querySelectorAll('th,td');
        var d = [];
        cols.forEach(function(col) { d.push('"' + col.textContent.trim().replace(/\n/g,' ').replace(/"/g,'""') + '"'); });
        c.push(d.join(','));
        });
        var b = new Blob(['\uFEFF' + c.join('\n')], { type: 'text/csv;charset=utf-8;' });
        var l = document.createElement('a');
        l.href = URL.createObjectURL(b);
        l.download = fn;
        l.click();
        }
    </script>
}