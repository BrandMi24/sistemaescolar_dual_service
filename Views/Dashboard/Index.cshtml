    }
    @if (Model.PreinscripcionesByCareer.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white h-100">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                    <h6 class="txt-title fw-bold text-xs text-uppercase tracking-wide mb-0">Preinscripciones Recientes</h6>
                    <button class="btn btn-sm btn-light border text-xxs fw-bold px-3 py-1" onclick="exportTableToCSV('tblPreCarreras', 'preinscripciones_carrera.csv')"><i class="bi bi-download"></i></button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0 table-borderless" id="tblPreCarreras">
                        <thead class="bg-app text-xxs fw-bold text-muted" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Carrera</th><th class="text-center border-0">Total</th><th class="text-center border-0">%</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.PreinscripcionesByCareer)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold txt-title text-xs">@c.CareerName</td>
                                    <td class="text-center"><span class="badge bg-primary-100 txt-primary-dark px-3 py-1">@c.Count</span></td>
                                    <td class="text-center text-muted text-xs">@c.Percentage%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

