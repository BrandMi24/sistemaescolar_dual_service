@model ControlEscolar.Models.Dashboard.RectorateViewModel
@{
    ViewData["Title"] = "Inicio — Vista General (Rectoría)";
    Layout = "_LayoutDashboard";
    
    var totalGender = Model.MaleCount + Model.FemaleCount + Model.OtherGenderCount;
    var cuatNames = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center mb-4 text-sm">
        <i class="bi bi-exclamation-triangle-fill fs-5 me-3"></i>
        <div><strong>Error:</strong> @ViewBag.Error</div>
    </div>
}

<div class="admin-card-white p-3 mb-4 shadow-sm border-0">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">AÑO</label>
            <select name="year" id="filterYear" class="form-select bg-app border-0 text-sm fw-bold">
                @foreach (var y in Model.AvailableYears)
                {
                    if (y == Model.SelectedYear)
                    {
                        <option value="@y" selected>@y</option>
                    }
                    else
                    {
                        <option value="@y">@y</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label text-xs fw-bold text-muted mb-1">CUATRIMESTRE</label>
            <select name="cuatrimestre" id="filterCuat" class="form-select bg-app border-0 text-sm fw-bold">
                @{
                    var cuatOptions = new Dictionary<int, string> { { 0, "Todo el año" }, { 1, "Ene — Abr" }, { 2, "May — Ago" }, { 3, "Sep — Dic" } };
                }
                @foreach (var opt in cuatOptions)
                {
                    if (opt.Key == Model.SelectedCuatrimestre)
                    {
                        <option value="@opt.Key" selected>@opt.Value</option>
                    }
                    else
                    {
                        <option value="@opt.Key">@opt.Value</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-6 d-flex gap-2">
            <button type="submit" class="btn btn-dark text-xs px-4 fw-bold shadow-sm">
                <i class="bi bi-funnel-fill me-2"></i> APLICAR
            </button>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-light border text-xs px-4 fw-bold">
                LIMPIAR
            </a>
        </div>
    </form>
</div>

@if (Model.SelectedCuatrimestre > 0)
{
    <div class="badge bg-dark mb-4 px-3 py-2 fw-normal text-xs shadow-sm">
        <i class="bi bi-filter-circle me-1"></i> Filtro activo: Año @Model.SelectedYear, @cuatNames[Model.SelectedCuatrimestre]
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Estudiantes Registrados</div>
                <div class="fs-2 fw-bold txt-title" style="color: #0d9e7a;">@Model.TotalStudents</div>
                <div class="text-xxs text-muted mt-1">@Model.ActiveStudents activos · @Model.TotalPreinscripciones preins.</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-people fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Carreras</div>
                <div class="fs-2 fw-bold txt-title text-success">@Model.TotalCareers</div>
                <div class="text-xxs text-muted mt-1">@Model.TotalGroups grupos en curso</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-journal-album fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Cuerpo Docente</div>
                <div class="fs-2 fw-bold txt-title text-primary">@Model.TotalTeachers</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-person-video3 fs-3"></i></div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0 d-flex justify-content-between align-items-center">
            <div>
                <div class="text-xs fw-bold text-muted text-uppercase tracking-wide mb-1">Trámites Pendientes</div>
                <div class="fs-2 fw-bold txt-title text-warning">@Model.TotalTramitesPendientes</div>
                <div class="text-xxs text-muted mt-1">@Model.TotalVisitasMedicas atenciones salud</div>
            </div>
            <div class="icon-circle-lg bg-app text-dark"><i class="bi bi-inboxes fs-3"></i></div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-bar-chart-fill text-muted me-2"></i>Estudiantes por Carrera</h6>
            @if (Model.StudentsByCareer.Any())
            {
                <div style="position: relative; height: 280px; width: 100%;">
                    <canvas id="chartCareers"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos poblacionales para este periodo</div>
            }
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="admin-card-white p-4 h-100 shadow-sm border-0">
            <h6 class="txt-title fw-bold text-uppercase mb-4 text-sm"><i class="bi bi-pie-chart-fill text-muted me-2"></i>Distribución de Género</h6>
            @if (totalGender > 0)
            {
                <div style="position: relative; height: 260px; width: 100%;">
                    <canvas id="chartGender"></canvas>
                </div>
            }
            else
            {
                <div class="text-center text-muted p-5 bg-app rounded-3 text-sm">Sin datos para este periodo</div>
            }
        </div>
    </div>
</div>

@if (Model.CareersOverview.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-mortarboard-fill me-2"></i>Estadísticas por Carrera</h6>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value, 'tblCarreras', 0)">
                    <option value="">Todas las carreras</option>
                    @foreach (var c in Model.CareersOverview)
                    {
                        <option value="@c.CareerName">@c.CareerName</option>
                    }
                </select>
                <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblCarreras', 'estadisticas_por_carrera.csv')">
                    <i class="bi bi-download me-1"></i> CSV
                </button>
            </div>
        </div>

        <div class="text-xxs text-muted mb-2 fw-bold" id="tblCarrerasCount">Mostrando 1 a @Model.CareersOverview.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 350px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblCarreras">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Carrera</th>
                        <th class="text-center border-0">Total</th>
                        <th class="text-center border-0">Inscritos</th>
                        <th class="text-center border-0">Preinscritos</th>
                        <th class="text-center border-0">Bajas</th>
                        <th class="text-center border-0">Grupos</th>
                        <th class="text-center pe-3 border-0">%</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.CareersOverview)
                    {
                        <tr>
                            <td class="ps-3 fw-bold txt-title">@c.CareerName</td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@c.TotalStudents</span></td>
                            <td class="text-center text-success fw-bold">@c.Inscritos</td>
                            <td class="text-center text-warning fw-bold">@c.Preinscritos</td>
                            <td class="text-center @(c.Bajas > 0 ? "text-danger fw-bold" : "text-muted")">@c.Bajas</td>
                            <td class="text-center"><span class="badge bg-primary">@c.Groups</span></td>
                            <td class="text-center pe-3 text-muted">@c.Percentage%</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (Model.GroupsOverview.Any())
{
    <div class="admin-card-white p-4 shadow-sm border-0 mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-3 mb-3 gap-3">
            <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm"><i class="bi bi-grid-3x3-gap-fill me-2"></i>Estadísticas por Grupo</h6>
            <div class="d-flex gap-2 flex-wrap">
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value, 'tblGrupos', 1)">
                    <option value="">Carrera (Todas)</option>
                    @foreach (var c in Model.CareersOverview.Where(c => c.TotalStudents > 0))
                    {
                        <option value="@c.CareerName">@c.CareerName</option>
                    }
                </select>
                <select class="form-select form-select-sm bg-app border-0 text-xs fw-bold" style="width: auto;" onchange="filterTableByColumn(this.value, 'tblGrupos', 2)">
                    <option value="">Turno (Todos)</option>
                    <option value="Matutino">Matutino</option>
                    <option value="Vespertino">Vespertino</option>
                </select>
                <button class="btn btn-light border text-xs fw-bold px-3 py-1" onclick="exportTableToCSV('tblGrupos', 'estadisticas_por_grupo.csv')">
                    <i class="bi bi-download me-1"></i> CSV
                </button>
            </div>
        </div>

        <div class="text-xxs text-muted mb-2 fw-bold" id="tblGruposCount">Mostrando 1 a @Model.GroupsOverview.Count registros</div>

        <div class="table-responsive custom-scroll" style="max-height: 350px;">
            <table class="table table-hover align-middle text-sm mb-0" id="tblGrupos">
                <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-3 border-0">Grupo</th>
                        <th class="border-0">Carrera</th>
                        <th class="border-0">Turno</th>
                        <th class="text-center border-0">Cuat.</th>
                        <th class="text-center pe-3 border-0">Estudiantes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.GroupsOverview)
                    {
                        var bc = g.StudentCount > 12 ? "bg-success" : g.StudentCount > 5 ? "bg-warning text-dark" : "bg-danger";
                        var cuatNum = new string(g.GroupCode.TakeWhile(char.IsDigit).ToArray());
                        <tr>
                            <td class="ps-3"><span class="badge fw-bold px-3 py-2 text-dark" style="background-color: #e9ecef; border-radius: 6px;">@g.GroupCode</span></td>
                            <td class="fw-bold txt-title text-xs">@g.CareerName</td>
                            <td class="text-muted text-xs">@g.Shift</td>
                            <td class="text-center"><span class="badge bg-light text-dark border">@cuatNum</span></td>
                            <td class="text-center pe-3"><span class="badge @bc">@g.StudentCount</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="row g-4 mb-4">
    @if (Model.StudentsByStatus.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <h6 class="txt-title fw-bold text-uppercase mb-3 text-sm border-bottom pb-2">Estudiantes por Estatus</h6>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Estatus</th><th class="text-center border-0">Total</th><th class="text-center border-0">%</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var s in Model.StudentsByStatus)
                            {
                                var sc = s.Status switch { "INSCRITO" => "bg-success", "PREINSCRITO" => "bg-warning text-dark", "BAJA" => "bg-danger", _ => "bg-secondary" };
                                <tr>
                                    <td class="ps-3 fw-bold txt-body">@s.Status</td>
                                    <td class="text-center"><span class="badge @sc">@s.Count</span></td>
                                    <td class="text-center text-muted">@s.Percentage%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    @if (Model.PreinscripcionesByCareer.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm">Preinscripciones Recientes</h6>
                    <button class="btn btn-light border text-xs fw-bold px-2 py-1" onclick="exportTableToCSV('tblPreCarreras', 'preinscripciones_carrera.csv')"><i class="bi bi-download"></i></button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 250px;">
                    <table class="table table-hover align-middle text-sm mb-0" id="tblPreCarreras">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Carrera</th><th class="text-center border-0">Total</th><th class="text-center border-0">%</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.PreinscripcionesByCareer)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold txt-body text-xs">@c.CareerName</td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">@c.Count</span></td>
                                    <td class="text-center text-muted">@c.Percentage%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<h6 class="txt-title fw-bold text-uppercase mb-3 mt-5"><i class="bi bi-clock-history me-2"></i>Historial de Movimientos</h6>
<div class="row g-4 mb-5">
    @if (Model.CareerChanges.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0" style="border-top: 4px solid #0d9e7a !important;">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm">Cambios de Carrera</h6>
                    <button class="btn btn-light border text-xs fw-bold px-2 py-1" onclick="exportTableToCSV('tblCareerHistory','historial_cambio_carrera.csv')"><i class="bi bi-download"></i></button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 300px;">
                    <table class="table table-hover align-middle text-sm mb-0" id="tblCareerHistory">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Alumno</th><th class="border-0">Destino</th><th class="text-end pe-3 border-0">Fecha</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model.CareerChanges)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-bold txt-title">@h.StudentName</div>
                                        <div class="text-xxs text-muted">@h.Matricula</div>
                                    </td>
                                    <td><span class="badge bg-primary text-wrap text-start" style="max-width: 120px;">@h.CareerName</span></td>
                                    <td class="text-end pe-3 text-muted text-xs">@h.StartDate.ToString("dd/MMM/yy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    @if (Model.GroupChanges.Any())
    {
        <div class="col-12 col-lg-6">
            <div class="admin-card-white p-4 h-100 shadow-sm border-0" style="border-top: 4px solid #f59e0b !important;">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
                    <h6 class="txt-title fw-bold text-uppercase mb-0 text-sm">Cambios de Grupo</h6>
                    <button class="btn btn-light border text-xs fw-bold px-2 py-1" onclick="exportTableToCSV('tblGroupHistory','historial_cambio_grupo.csv')"><i class="bi bi-download"></i></button>
                </div>
                <div class="table-responsive custom-scroll" style="max-height: 300px;">
                    <table class="table table-hover align-middle text-sm mb-0" id="tblGroupHistory">
                        <thead class="bg-app text-muted text-xs" style="position: sticky; top: 0; z-index: 1;">
                            <tr><th class="ps-3 border-0">Alumno</th><th class="border-0">Nuevo Grupo</th><th class="text-end pe-3 border-0">Fecha</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model.GroupChanges)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="fw-bold txt-title">@h.StudentName</div>
                                        <div class="text-xxs text-muted">@h.Matricula</div>
                                    </td>
                                    <td><span class="badge fw-bold px-2 py-1 text-dark" style="background-color: #e9ecef;">@h.GroupCode</span></td>
                                    <td class="text-end pe-3 text-muted text-xs">@h.StartDate.ToString("dd/MMM/yy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    
    <script>
        Chart.register(ChartDataLabels);
        Chart.defaults.color = '#6c757d';
        Chart.defaults.borderColor = 'rgba(0,0,0,0.05)';
        Chart.defaults.font.family = "'Plus Jakarta Sans', system-ui, sans-serif";
        Chart.defaults.font.size = 12;

        @if (Model.StudentsByCareer.Any())
        {
            <text>
                new Chart(document.getElementById('chartCareers'), {
                type: 'bar',
                data: {
                labels: [@Html.Raw(string.Join(",", Model.StudentsByCareer.Select(c => $"'{c.CareerName}'")))],
                datasets: [{
                data: [@string.Join(",", Model.StudentsByCareer.Select(c => c.Count))],
                backgroundColor: '#2C3E50', // Color oscuro corporativo
                borderRadius: 6,
                maxBarThickness: 36
                }]
                },
                options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                legend: { display: false },
                datalabels: { anchor: 'end', align: 'right', color: '#212529', font: { weight: 'bold', size: 12 }, offset: 4 }
                },
                scales: {
                x: { display: false, grid: { display: false } },
                y: { grid: { display: false } }
                },
                layout: { padding: { right: 40 } }
                }
                });
            </text>
        }

        @if (totalGender > 0)
        {
            <text>
                new Chart(document.getElementById('chartGender'), {
                type: 'doughnut',
                data: {
                labels: ['Masculino','Femenino'@(Model.OtherGenderCount > 0 ? ",'Otro'" : "")],
                datasets: [{
                data: [@Model.MaleCount,@Model.FemaleCount@(Model.OtherGenderCount > 0 ? $",{Model.OtherGenderCount}" : "")],
                backgroundColor: ['#3498DB', '#E83E8C'@(Model.OtherGenderCount > 0 ? ",'#95A5A6'" : "")],
                borderWidth: 0
                }]
                },
                options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, boxWidth: 8, font: { size: 11 } } },
                datalabels: {
                color: '#fff',
                font: { weight: 'bold', size: 13 },
                formatter: function(v, ctx) {
                var t = ctx.dataset.data.reduce((a, b) => a + b, 0);
                var p = t > 0 ? Math.round(v / t * 100) : 0;
                return p > 5 ? p + '%' : '';
                }
                }
                }
                }
                });
            </text>
        }

        // Funciones de filtrado y exportación unificadas
        function filterTableByColumn(value, tableId, colIndex) {
        var table = document.getElementById(tableId);
        if (!table) return;
        if (!window._filters) window._filters = {};
        if (!window._filters[tableId]) window._filters[tableId] = {};
            
        if (value) window._filters[tableId][colIndex] = value;
        else delete window._filters[tableId][colIndex];
            
        var rows = table.querySelectorAll('tbody tr');
        var visible = 0;
        rows.forEach(function(row) {
        var show = true;
        for (var ci in window._filters[tableId]) {
        var filterVal = window._filters[tableId][ci];
        var cell = row.cells[parseInt(ci)];
        if (cell && cell.textContent.trim().indexOf(filterVal) === -1) { show = false; break; }
        }
        row.style.display = show ? '' : 'none';
        if (show) visible++;
        });
            
        var countEl = document.getElementById(tableId + 'Count');
        if (countEl) countEl.textContent = 'Mostrando 1 a ' + visible + ' registros';
        }

        function exportTableToCSV(tid, fn) {
        var t = document.getElementById(tid);
        var r = t.querySelectorAll('tr');
        var c = [];
        r.forEach(function(row) {
        if (row.style.display === 'none') return;
        var cols = row.querySelectorAll('th,td');
        var d = [];
        cols.forEach(function(col) { d.push('"' + col.textContent.trim().replace(/\n/g,' ').replace(/"/g,'""') + '"'); });
        c.push(d.join(','));
        });
        var b = new Blob(['\uFEFF' + c.join('\n')], { type: 'text/csv;charset=utf-8;' });
        var l = document.createElement('a');
        l.href = URL.createObjectURL(b);
        l.download = fn;
        l.click();
        }
    </script>
}