@{
    ViewData["Title"] = "Documentos enviados";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int inscripcionId = ViewBag.InscripcionId;
    string nombre = ViewBag.Nombre;
    string matricula = ViewBag.Matricula;
}

<div class="container py-5" style="max-width: 560px;">

    <!-- Icono animado de éxito -->
    <div class="text-center mb-4">
        <div class="mx-auto mb-4" style="
            width: 80px; height: 80px;
            background: linear-gradient(135deg, #48bb78, #38a169);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 8px 30px rgba(72,187,120,0.4);
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;">
            <i class="bi bi-check-lg" style="font-size: 2.5rem; color: white;"></i>
        </div>
        <h1 class="fw-bold text-dark mb-2" style="font-size: 1.5rem; letter-spacing: -0.5px;">
            ¡Documentos enviados correctamente!
        </h1>
        <p class="text-muted fw-medium" style="font-size: 0.9rem;">
            Control Escolar revisará tus documentos y te notificará por correo electrónico cuando sean validados.
        </p>
    </div>

    <!-- Card de resumen -->
    <div class="bg-white rounded-4 shadow-sm border border-light p-4 mb-4">
        <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
            <div style="width:44px;height:44px;background:#f0fff4;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-person-check-fill" style="color:#38a169;font-size:1.2rem;"></i>
            </div>
            <div>
                <p class="fw-bold mb-0 text-dark" style="font-size:0.9rem;">@nombre</p>
                <p class="text-muted mb-0" style="font-size:0.75rem;">Matrícula: <strong>@matricula</strong></p>
            </div>
        </div>

        <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
            <li class="d-flex align-items-center gap-2 text-sm">
                <i class="bi bi-check-circle-fill text-success"></i>
                <span class="text-muted fw-medium">Archivos recibidos y guardados</span>
            </li>
            <li class="d-flex align-items-center gap-2 text-sm">
                <i class="bi bi-clock-history" style="color:#d69e2e;"></i>
                <span class="text-muted fw-medium">Revisión pendiente por Control Escolar</span>
            </li>
            <li class="d-flex align-items-center gap-2 text-sm">
                <i class="bi bi-envelope-check" style="color:#4299e1;"></i>
                <span class="text-muted fw-medium">Recibirás un correo cuando sean validados</span>
            </li>
        </ul>
    </div>

    <!-- Botones de acción -->
    <div class="d-flex flex-column gap-3">
        <a asp-controller="Aspirantes" asp-action="DescargarFicha" asp-route-id="@inscripcionId"
           class="btn py-3 fw-bold text-xxs tracking-widest rounded-3"
           style="background:#13322B; color:white; border:none;">
            <i class="bi bi-file-earmark-arrow-down me-2"></i>
            REIMPRIMIR MI FICHA DE INSCRIPCIÓN
        </a>

        <a asp-controller="Home" asp-action="Index"
           class="btn btn-light py-3 fw-bold text-xxs tracking-widest rounded-3 border">
            <i class="bi bi-house me-2"></i>
            VOLVER AL PORTAL PRINCIPAL
        </a>
    </div>

    <p class="text-center text-muted mt-4" style="font-size: 0.7rem; opacity: 0.65;">
        <i class="bi bi-shield-lock me-1"></i>
        Tus documentos están protegidos — conexión segura con el servidor institucional
    </p>
</div>

<style>
    .text-xxs { font-size: 0.65rem; }
    .tracking-widest { letter-spacing: 0.15em; }
    .text-sm { font-size: 0.85rem; }

    @@keyframes popIn {
        0%   { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1);   opacity: 1; }
    }
</style>
