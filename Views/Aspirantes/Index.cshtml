@using ControlEscolar.Enums
@model IEnumerable<ControlEscolar.Models.Aspirante>

@{
    ViewData["Title"] = "Lista de Inscripciones";
}

<div class="main-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Lista de Inscripciones</h2>
        <a asp-action="Create" class="btn btn-primary">Nueva Inscripción</a>
    </div>

    <div class="table-responsive">
        <table class="table table-modern align-middle">
            <thead>
                <tr>
                    <th>Folio</th>
                    <th>Nombre</th>
                    <th>Apellido Paterno</th>
                    <th>Carrera</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Fecha Registro</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold">@item.Id</td>
                        <td>@item.Nombre @item.ApellidoPaterno @item.ApellidoMaterno</td>
                        <td>@item.ApellidoPaterno</td>
                        <td class="text-truncate" style="max-width:220px;">@item.CarreraSolicitada</td>
                        <td class="text-truncate" style="max-width:200px;"><a href="mailto:@item.Email">@item.Email</a></td>
                        <td>
                            @await Html.PartialAsync("_StatusBadge", null, new ViewDataDictionary(ViewData) { { "StatusValue", item.EstadoRegistro.ToString() }, { "StatusType", "registro" } })
                        </td>
                        <td>@item.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Ver</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
