@model ControlEscolar.Models.CorreccionDocumentosViewModel

@{
    ViewData["Title"] = "Corrección de Documentos";
    Layout = null; // Vista independiente, sin layout institucional de admin
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Corrección de Documentos — ITC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #13322B;
            --primary-light: #1a4a3e;
            --accent: #2ecc71;
            --danger-soft: #fff5f5;
            --danger-border: #feb2b2;
            --warning-soft: #fffaf0;
            --warning-border: #fbd38d;
            --surface: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #1a202c;
            --text-muted: #718096;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f2922 0%, #1a4a3e 50%, #13322B 100%);
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .correction-wrapper {
            width: 100%;
            max-width: 680px;
        }

        /* Header institucional */
        .itc-header {
            text-align: center;
            margin-bottom: 1.5rem;
            color: white;
        }

        .itc-header .itc-logo-circle {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }

        .itc-header h1 {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
            letter-spacing: -0.025em;
        }

        .itc-header p {
            font-size: 0.8rem;
            opacity: 0.75;
            margin: 0;
        }

        /* Card principal */
        .correction-card {
            background: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0,0,0,0.3);
        }

        /* Banda de alerta superior */
        .error-banner {
            background: linear-gradient(90deg, #fc8181, #f56565);
            color: white;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .error-banner i {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .error-banner .banner-title {
            font-size: 0.875rem;
            font-weight: 700;
            margin: 0;
        }

        .error-banner .banner-sub {
            font-size: 0.75rem;
            opacity: 0.9;
            margin: 0;
        }

        /* Info del alumno */
        .student-info {
            padding: 1.25rem 1.5rem;
            background: var(--surface);
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .student-avatar {
            width: 44px;
            height: 44px;
            background: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .student-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
            margin: 0;
        }

        .student-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin: 0;
        }

        /* Body de la card */
        .correction-body {
            padding: 1.5rem;
        }

        /* Sección de un documento */
        .doc-section {
            border: 2px solid var(--danger-border);
            background: var(--danger-soft);
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            transition: border-color 0.2s, background 0.2s;
        }

        .doc-section.doc-uploading {
            border-color: #68d391;
            background: #f0fff4;
        }

        .doc-section-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1rem;
        }

        .doc-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: #fed7d7;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #c53030;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .doc-section.doc-uploading .doc-icon {
            background: #c6f6d5;
            color: #276749;
        }

        .doc-title {
            font-size: 0.875rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0;
        }

        .doc-badge {
            font-size: 0.65rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 100px;
            background: #fed7d7;
            color: #c53030;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .motivo-box {
            font-size: 0.75rem;
            color: #744210;
            background: var(--warning-soft);
            border: 1px solid var(--warning-border);
            border-radius: 8px;
            padding: 0.5rem 0.75rem;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: flex-start;
            gap: 0.5rem;
        }

        /* File input personalizado */
        .file-input-wrapper {
            position: relative;
        }

        .file-input-label {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border: 2px dashed #fc8181;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s;
            background: white;
        }

        .file-input-label:hover {
            border-color: var(--primary);
            background: #f0fff4;
        }

        .file-input-label.has-file {
            border-color: #68d391;
            border-style: solid;
            background: #f0fff4;
        }

        .file-real {
            display: none;
        }

        .file-label-text {
            font-size: 0.8rem;
            color: var(--text-muted);
            flex: 1;
        }

        .file-label-text.has-file {
            color: #276749;
            font-weight: 600;
        }

        /* Éxito */
        .success-banner {
            background: linear-gradient(90deg, #48bb78, #38a169);
            color: white;
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .success-banner i { font-size: 2rem; flex-shrink: 0; }

        /* Botón de envío */
        .btn-submit {
            width: 100%;
            padding: 0.875rem;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 0.875rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn-submit:hover {
            background: var(--primary-light);
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(19,50,43,0.4);
        }

        .btn-submit:active { transform: translateY(0); }

        .footer-note {
            text-align: center;
            font-size: 0.7rem;
            color: rgba(255,255,255,0.5);
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <div class="correction-wrapper">

        <!-- Header institucional -->
        <div class="itc-header">
            <div class="itc-logo-circle">
                <i class="bi bi-mortarboard-fill" style="font-size:1.75rem; color:white;"></i>
            </div>
            <h1>Instituto Tecnológico</h1>
            <p>Sistema de Control Escolar — Corrección de Documentos</p>
        </div>

        <div class="correction-card">

            @if (TempData["CorreccionExitosa"] != null)
            {
                <!-- Mensaje de éxito después de redirigir -->
                <div class="p-4">
                    <div class="success-banner">
                        <i class="bi bi-check-circle-fill"></i>
                        <div>
                            <p style="font-weight:700; font-size:0.95rem; margin:0;">¡Documentos enviados correctamente!</p>
                            <p style="font-size:0.8rem; opacity:0.9; margin:0;">Sus documentos han sido recibidos y serán revisados por Control Escolar a la brevedad.</p>
                        </div>
                    </div>
                    <p style="font-size:0.8rem; color:#718096; text-align:center; margin-top:1rem;">
                        <i class="bi bi-clock me-1"></i>
                        Recibirá una notificación por correo electrónico cuando su documentación sea validada.
                    </p>
                </div>
            }
            else
            {
                <!-- Banda de alerta -->
                <div class="error-banner">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <div>
                        <p class="banner-title">Documentos con error — Acción requerida</p>
                        <p class="banner-sub">Solo los documentos marcados requieren corrección. Los demás ya están validados.</p>
                    </div>
                </div>

                <!-- Info del alumno -->
                <div class="student-info">
                    <div class="student-avatar">
                        @(Model.NombreCompleto.Length > 0 ? Model.NombreCompleto[0].ToString().ToUpper() : "A")
                    </div>
                    <div>
                        <p class="student-name">@Model.NombreCompleto</p>
                        <p class="student-meta">
                            Matrícula: <strong>@Model.Matricula</strong> &nbsp;·&nbsp;
                            Folio: <strong>@Model.Folio</strong>
                        </p>
                    </div>
                </div>

                <!-- Formulario de corrección -->
                <div class="correction-body">
                    @if (!Model.ActaConError && !Model.CurpConError && !Model.BoletaConError)
                    {
                        <div class="alert alert-success text-center py-4">
                            <i class="bi bi-check2-circle fs-1 d-block mb-2"></i>
                            <strong>No hay documentos pendientes de corrección.</strong><br />
                            <span style="font-size:0.8rem;">Todos sus documentos han sido enviados correctamente.</span>
                        </div>
                    }
                    else
                    {
                        <p style="font-size:0.8rem; color:#718096; margin-bottom:1.25rem;">
                            <i class="bi bi-info-circle me-1"></i>
                            Por favor suba únicamente los documentos indicados abajo en formato <strong>PDF</strong> (máx. 5 MB cada uno).
                        </p>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger text-sm py-2 mb-3">
                                <i class="bi bi-exclamation-circle me-1"></i>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    @error.ErrorMessage
                                }
                            </div>
                        }

                        <form method="post"
                              asp-action="CorregirDocumentos"
                              asp-controller="Aspirantes"
                              enctype="multipart/form-data"
                              id="formCorreccion">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="InscripcionId" value="@Model.InscripcionId" />
                            <input type="hidden" name="Folio" value="@Model.Folio" />
                            <input type="hidden" name="Curp" value="@Model.Curp" />
                            <input type="hidden" name="NombreCompleto" value="@Model.NombreCompleto" />
                            <input type="hidden" name="Matricula" value="@Model.Matricula" />
                            <input type="hidden" name="ActaConError" value="@Model.ActaConError.ToString().ToLower()" />
                            <input type="hidden" name="CurpConError" value="@Model.CurpConError.ToString().ToLower()" />
                            <input type="hidden" name="BoletaConError" value="@Model.BoletaConError.ToString().ToLower()" />

                            @if (Model.ActaConError)
                            {
                                <div class="doc-section" id="section-acta">
                                    <div class="doc-section-header">
                                        <div class="doc-icon">
                                            <i class="bi bi-file-earmark-person-fill"></i>
                                        </div>
                                        <div style="flex:1;">
                                            <p class="doc-title">Acta de Nacimiento</p>
                                            <span class="doc-badge">Requiere corrección</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.MotivoError))
                                    {
                                        <div class="motivo-box">
                                            <i class="bi bi-chat-left-text-fill" style="flex-shrink:0; margin-top:1px;"></i>
                                            <span>Motivo indicado por Control Escolar: <strong>@Model.MotivoError</strong></span>
                                        </div>
                                    }
                                    <div class="file-input-wrapper">
                                        <label class="file-input-label" for="actaFile" id="labelActa">
                                            <i class="bi bi-cloud-arrow-up-fill fs-5" style="color:#fc8181;"></i>
                                            <span class="file-label-text" id="textActa">Seleccionar PDF del Acta de Nacimiento...</span>
                                        </label>
                                        <input type="file" id="actaFile" name="ActaNacimientoFile"
                                               class="file-real" accept=".pdf"
                                               onchange="updateFileLabel(this, 'labelActa', 'textActa', 'section-acta')" />
                                    </div>
                                </div>
                            }

                            @if (Model.CurpConError)
                            {
                                <div class="doc-section" id="section-curp">
                                    <div class="doc-section-header">
                                        <div class="doc-icon">
                                            <i class="bi bi-card-text"></i>
                                        </div>
                                        <div style="flex:1;">
                                            <p class="doc-title">CURP</p>
                                            <span class="doc-badge">Requiere corrección</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.MotivoError))
                                    {
                                        <div class="motivo-box">
                                            <i class="bi bi-chat-left-text-fill" style="flex-shrink:0; margin-top:1px;"></i>
                                            <span>Motivo indicado por Control Escolar: <strong>@Model.MotivoError</strong></span>
                                        </div>
                                    }
                                    <div class="file-input-wrapper">
                                        <label class="file-input-label" for="curpFile" id="labelCurp">
                                            <i class="bi bi-cloud-arrow-up-fill fs-5" style="color:#fc8181;"></i>
                                            <span class="file-label-text" id="textCurp">Seleccionar PDF del CURP...</span>
                                        </label>
                                        <input type="file" id="curpFile" name="CurpPdfFile"
                                               class="file-real" accept=".pdf"
                                               onchange="updateFileLabel(this, 'labelCurp', 'textCurp', 'section-curp')" />
                                    </div>
                                </div>
                            }

                            @if (Model.BoletaConError)
                            {
                                <div class="doc-section" id="section-boleta">
                                    <div class="doc-section-header">
                                        <div class="doc-icon">
                                            <i class="bi bi-journal-text"></i>
                                        </div>
                                        <div style="flex:1;">
                                            <p class="doc-title">Boleta / Certificado de Estudios</p>
                                            <span class="doc-badge">Requiere corrección</span>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.MotivoError))
                                    {
                                        <div class="motivo-box">
                                            <i class="bi bi-chat-left-text-fill" style="flex-shrink:0; margin-top:1px;"></i>
                                            <span>Motivo indicado por Control Escolar: <strong>@Model.MotivoError</strong></span>
                                        </div>
                                    }
                                    <div class="file-input-wrapper">
                                        <label class="file-input-label" for="boletaFile" id="labelBoleta">
                                            <i class="bi bi-cloud-arrow-up-fill fs-5" style="color:#fc8181;"></i>
                                            <span class="file-label-text" id="textBoleta">Seleccionar PDF de la Boleta o Certificado...</span>
                                        </label>
                                        <input type="file" id="boletaFile" name="BoletaPdfFile"
                                               class="file-real" accept=".pdf"
                                               onchange="updateFileLabel(this, 'labelBoleta', 'textBoleta', 'section-boleta')" />
                                    </div>
                                </div>
                            }

                            <button type="submit" class="btn-submit mt-3" id="btnEnviar">
                                <i class="bi bi-send-fill"></i>
                                Enviar Documentos Corregidos
                            </button>
                        </form>
                    }
                </div>
            }
        </div>

        <p class="footer-note">
            <i class="bi bi-shield-lock me-1"></i>
            Conexión segura — Datos protegidos por el servidor institucional
        </p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function updateFileLabel(input, labelId, textId, sectionId) {
            const label = document.getElementById(labelId);
            const textSpan = document.getElementById(textId);
            const section = document.getElementById(sectionId);
            const icon = label.querySelector('i');

            if (input.files && input.files.length > 0) {
                const file = input.files[0];
                const sizeMB = (file.size / 1024 / 1024).toFixed(2);

                textSpan.textContent = `${file.name} (${sizeMB} MB)`;
                textSpan.classList.add('has-file');
                label.classList.add('has-file');
                icon.style.color = '#48bb78';
                section.classList.add('doc-uploading');
            } else {
                textSpan.classList.remove('has-file');
                label.classList.remove('has-file');
                icon.style.color = '#fc8181';
                section.classList.remove('doc-uploading');
            }
        }

        // Validación antes de enviar
        document.getElementById('formCorreccion')?.addEventListener('submit', function (e) {
            const btn = document.getElementById('btnEnviar');
            const actaError = @Model.ActaConError.ToString().ToLower();
            const curpError = @Model.CurpConError.ToString().ToLower();
            const boletaError = @Model.BoletaConError.ToString().ToLower();

            const actaFile = document.getElementById('actaFile');
            const curpFile = document.getElementById('curpFile');
            const boletaFile = document.getElementById('boletaFile');

            let valido = true;

            if (actaError && (!actaFile || actaFile.files.length === 0)) {
                document.getElementById('section-acta')?.style.setProperty('border-color', '#f56565', 'important');
                valido = false;
            }
            if (curpError && (!curpFile || curpFile.files.length === 0)) {
                document.getElementById('section-curp')?.style.setProperty('border-color', '#f56565', 'important');
                valido = false;
            }
            if (boletaError && (!boletaFile || boletaFile.files.length === 0)) {
                document.getElementById('section-boleta')?.style.setProperty('border-color', '#f56565', 'important');
                valido = false;
            }

            if (!valido) {
                e.preventDefault();
                alert('Por favor seleccione un archivo PDF para cada documento marcado con error.');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Enviando documentos...';
        });
    </script>
</body>
</html>
