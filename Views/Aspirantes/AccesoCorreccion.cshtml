@{
    ViewData["Title"] = "Corrección de Documentos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="text-center py-5 mb-2 mt-3 fade-in">
    <h1 class="display-5 fw-bold mb-3 text-dark text-uppercase" style="letter-spacing:-1px;">
        Corrección de Documentos
    </h1>
    <p class="fs-6 mx-auto text-muted fw-medium" style="max-width:560px;line-height:1.6;">
        Ingresa tu <strong>Folio de preinscripción</strong> y tu <strong>CURP</strong> para acceder
        a tus documentos pendientes de corrección.
    </p>
</div>

<div class="container pb-5" style="max-width:480px;">

    @if (TempData["AccesoError"] != null)
    {
        <div class="alert d-flex align-items-center gap-3 rounded-3 mb-4 py-3"
             style="background:#fff5f5;border:1px solid #feb2b2;color:#c53030;">
            <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
            <span class="text-sm fw-medium">@TempData["AccesoError"]</span>
        </div>
    }

    <div class="bg-white rounded-4 shadow-sm border border-light p-4 p-lg-5">
        <div class="d-flex align-items-center gap-3 mb-4">
            <div style="width:48px;height:48px;background:#fff5f5;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <i class="bi bi-shield-lock-fill" style="color:#c53030;font-size:1.25rem;"></i>
            </div>
            <div>
                <p class="fw-bold mb-0 text-dark" style="font-size:0.9rem;">Acceso seguro</p>
                <p class="text-muted mb-0" style="font-size:0.75rem;">Tus datos no se comparten en la URL</p>
            </div>
        </div>

        <form asp-controller="Aspirantes" asp-action="AccesoCorreccion" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label fw-bold text-xxs tracking-widest text-muted uppercase mb-1">
                    FOLIO DE PREINSCRIPCIÓN *
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-hash text-muted"></i>
                    </span>
                    <input type="text"
                           name="folio"
                           id="inputFolio"
                           class="form-control border-start-0 ps-0 fw-medium"
                           placeholder="Ej: PRE-2026-00001"
                           autocomplete="off"
                           required />
                </div>
                <div class="form-text text-xs">El folio lo recibiste al completar tu preinscripción.</div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-xxs tracking-widest text-muted uppercase mb-1">
                    CURP *
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-person-vcard text-muted"></i>
                    </span>
                    <input type="text"
                           name="curp"
                           id="inputCurp"
                           class="form-control border-start-0 ps-0 fw-medium text-uppercase"
                           placeholder="18 caracteres"
                           maxlength="18"
                           autocomplete="off"
                           required />
                </div>
                <div class="form-text text-xs">Ingresa tu CURP tal como aparece en tu constancia oficial.</div>
            </div>

            <button type="submit"
                    class="btn w-100 py-3 fw-bold text-xxs tracking-widest rounded-3"
                    style="background:#13322B;color:white;border:none;">
                <i class="bi bi-search me-2"></i>BUSCAR MIS DOCUMENTOS
            </button>
        </form>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="Index"
           class="text-muted text-xs fw-medium text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i>Volver al portal principal
        </a>
    </div>
</div>

<style>
    .text-xxs { font-size: 0.65rem; }
    .tracking-widest { letter-spacing: 0.15em; }
    .uppercase { text-transform: uppercase; }

    .form-control:focus { border-color: #13322B; box-shadow: 0 0 0 0.2rem rgba(19,50,43,0.15); }
    .input-group-text { border-color: #dee2e6; }
    .input-group:focus-within .input-group-text { border-color: #13322B; }
</style>
