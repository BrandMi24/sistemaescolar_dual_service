@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <h1 class="h3 mb-3">No tienes permiso para acceder a esta sección</h1>
                    <p class="text-muted mb-4">
                        Tu usuario no cuenta con el rol necesario para abrir esta ruta.
                        Si crees que es un error, solicita validación de permisos al administrador.
                    </p>

                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Ir al inicio</a>
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary">Iniciar sesión con otra cuenta</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
