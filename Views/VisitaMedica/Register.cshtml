@model ControlEscolar.Models.VisitaMedica
@{
    ViewData["Title"] = "Registro de Visita Médica";
    Layout = "_LayoutSalud";
}

<div class="row g-4 align-items-start mx-auto fade-in" style="max-width: 1200px;">
    
    <div class="col-12 col-lg-4 col-xl-3 position-lg-sticky" style="top: 20px;">
        <div class="bg-white p-4 rounded-4 shadow-sm border border-light d-flex flex-column gap-4">
            
            <div class="text-center pb-3 border-bottom border-light">
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 60px; height: 60px;">
                    <i class="bi bi-heart-pulse-fill text-dark fs-3"></i>
                </div>
                <h6 class="fw-bold mb-1 text-dark">Nueva Consulta</h6>
                <p class="text-muted text-xs mb-0">Área de Enfermería</p>
                
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-xs fw-bold text-muted">Progreso</span>
                        <span id="progressText" class="text-xs fw-bold text-dark">33%</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 6px;">
                        <div id="progressBar" class="progress-bar bg-dark" role="progressbar" style="width: 33%;"></div>
                    </div>
                </div>
            </div>

            <ul class="nav flex-column nav-pills-custom" id="medicoTabs" role="tablist">
                <li class="nav-item mb-2" role="presentation">
                    <button class="nav-link w-100 active d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso1" type="button" onclick="updateProgress(33)">
                        <span><i class="bi bi-person-badge me-2"></i> 1. Identificación</span>
                        <i class="bi bi-check-circle-fill text-success text-xs d-none" id="icon-step1"></i>
                    </button>
                </li>
                <li class="nav-item mb-2" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso2" type="button" onclick="updateProgress(66)">
                        <span><i class="bi bi-activity me-2"></i> 2. Signos Vitales</span>
                        <i class="bi bi-check-circle-fill text-success text-xs d-none" id="icon-step2"></i>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link w-100 d-flex justify-content-between align-items-center" data-bs-toggle="pill" data-bs-target="#paso3" type="button" onclick="updateProgress(100)">
                        <span><i class="bi bi-clipboard-check me-2"></i> 3. Diagnóstico</span>
                    </button>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-12 col-lg-8 col-xl-9">
        <form asp-action="Register" method="post" id="formRegistro">
            <div class="tab-content bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light">
                
                <div class="tab-pane fade show active" id="paso1" role="tabpanel">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h4 class="fw-bold text-dark mb-1">1. Datos del Estudiante</h4>
                        <p class="text-muted text-sm mb-0">Información básica y académica del paciente.</p>
                    </div>

                    <div class="bg-light p-4 rounded-3 border border-light mb-4">
                        <h6 class="fw-bold text-dark text-sm mb-3"><i class="bi bi-search me-2"></i>Búsqueda en Sistema</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Matrícula</label>
                                <input asp-for="Matricula" class="form-control fw-bold" id="Matricula" placeholder="Ingrese matrícula..." />
                                <span asp-validation-for="Matricula" class="text-danger text-xs"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Fecha de Visita</label>
                                <input asp-for="FechaVisita" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-dark text-sm mb-3"><i class="bi bi-person-lines-fill me-2"></i>Información Personal</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-12">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Nombre Completo</label>
                            <input asp-for="NombreCompleto" class="form-control" id="NombreCompleto" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Carrera / Programa Educativo</label>
                            <input asp-for="Carrera" class="form-control" id="Carrera" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Fecha de Nacimiento</label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control" id="fechaNacimiento" onchange="calcularEdad()" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Edad</label>
                            <input asp-for="Edad" class="form-control bg-light fw-bold" id="edad" readonly />
                        </div>
                    </div>

                    <div class="mt-4 text-end border-top pt-4">
                        <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm" onclick="showTab('#paso2', 66)">
                            Siguiente Paso <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="tab-pane fade" id="paso2" role="tabpanel">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h4 class="fw-bold text-dark mb-1">2. Signos Vitales y Físico</h4>
                        <p class="text-muted text-sm mb-0">Información clínica recopilada durante la exploración.</p>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Talla (cm)</label>
                            <input asp-for="Talla" type="number" step="0.1" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Peso (kg)</label>
                            <input asp-for="Peso" type="number" step="0.1" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Temperatura (°C)</label>
                            <input asp-for="Temperatura" type="number" step="0.1" class="form-control" />
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Frec. Cardíaca</label>
                            <input asp-for="FrecuenciaCardiaca" class="form-control" placeholder="lpm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Frec. Respiratoria</label>
                            <input asp-for="FrecuenciaRespiratoria" class="form-control" placeholder="rpm" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Saturación O2 (%)</label>
                            <input asp-for="Saturacion" class="form-control" placeholder="%" />
                        </div>
                        <div class="col-12">
                            <label class="form-label text-xs fw-bold text-muted text-uppercase mb-1">Presión Arterial</label>
                            <input asp-for="PresionArterial" class="form-control" placeholder="Ej. 120/80" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between border-top pt-4">
                        <button type="button" class="btn btn-outline-dark fw-bold px-4 shadow-sm" onclick="showTab('#paso1', 33)">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="button" class="btn btn-dark px-4 fw-bold shadow-sm" onclick="showTab('#paso3', 100)">
                            Siguiente Paso <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </div>

                <div class="tab-pane fade" id="paso3" role="tabpanel">
                    <div class="mb-4 pb-3 border-bottom border-light">
                        <h4 class="fw-bold text-dark mb-1">3. Evaluación y Diagnóstico</h4>
                        <p class="text-muted text-sm mb-0">Detalles finales y antecedentes relevantes.</p>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded-3 border border-light h-100">
                                <label class="form-label text-xs fw-bold text-dark text-uppercase mb-3">Alergias Conocidas</label>
                                <div class="form-check form-switch mb-2">
                                    <input asp-for="TieneAlergias" class="form-check-input" type="checkbox" id="checkAlergias" onchange="toggleAlergias()">
                                    <label class="form-check-label text-xs fw-bold text-muted ms-2" for="checkAlergias">¿Presenta alergias?</label>
                                </div>
                                <div id="campoEspecificarAlergia" class="d-none mt-3">
                                    <input asp-for="EspecificarAlergia" class="form-control" id="inputAlergia" placeholder="Especifique cuáles..." />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="bg-light p-3 rounded-3 border border-light h-100">
                                <label class="form-label text-xs fw-bold text-dark text-uppercase mb-2">Enfermedades Crónicas</label>
                                <input asp-for="EnfermedadesCronicas" class="form-control" placeholder="Reporte de enfermedades..." />
                            </div>
                        </div>
                        <div class="col-12 mt-4">
                            <label class="form-label text-xs fw-bold text-dark text-uppercase mb-2">Diagnóstico y Tratamiento *</label>
                            <textarea asp-for="Diagnostico" class="form-control" rows="6" required placeholder="Escriba el diagnóstico y tratamiento..."></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between border-top pt-4">
                        <button type="button" class="btn btn-outline-dark fw-bold px-4 shadow-sm" onclick="showTab('#paso2', 66)">
                            <i class="bi bi-arrow-left me-2"></i> Anterior
                        </button>
                        <button type="submit" class="btn btn-dark px-5 fw-bold shadow-sm">
                            Guardar Expediente <i class="bi bi-save ms-2"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    /* Forzar estilo oscuro en los tabs para eliminar el azul de Bootstrap */
    .nav-pills-custom .nav-link {
        color: #495057;
        font-weight: 600;
        border-radius: 8px;
        padding: 12px 16px;
        transition: all 0.2s;
    }
    .nav-pills-custom .nav-link:hover {
        background-color: #f8f9fa; 
    }
    .nav-pills-custom .nav-link.active {
        background-color: #212529 !important; 
        color: #ffffff !important;
    }
    
    /* Inputs genéricos limpios */
    .form-control {
        border: 1px solid #dee2e6;
        border-radius: 6px;
        padding: 10px 12px;
        box-shadow: none !important;
    }
    .form-control:focus {
        border-color: #212529;
    }
</style>

@section Scripts {
    <script>
        function showTab(target, progress) {
            // Mostrar la pestaña
            const triggerEl = document.querySelector(`button[data-bs-target="${target}"]`);
            bootstrap.Tab.getOrCreateInstance(triggerEl).show();
            
            // Actualizar progreso
            updateProgress(progress);
            
            // Mostrar la palomita verde de "completado" en el paso anterior
            if(progress === 66) {
                document.getElementById('icon-step1').classList.remove('d-none');
            } else if(progress === 100) {
                document.getElementById('icon-step1').classList.remove('d-none');
                document.getElementById('icon-step2').classList.remove('d-none');
            }

            window.scrollTo(0, 0);
        }

        function updateProgress(value) {
            document.getElementById('progressBar').style.width = value + '%';
            document.getElementById('progressText').innerText = value + '%';
        }

        function toggleAlergias() {
            const check = document.getElementById('checkAlergias');
            const contenedor = document.getElementById('campoEspecificarAlergia');
            const input = document.getElementById('inputAlergia');
            if (check.checked) {
                contenedor.classList.remove('d-none');
                input.focus();
            } else {
                contenedor.classList.add('d-none');
                input.value = "";
            }
        }

        function calcularEdad() {
            const fechaNac = document.getElementById('fechaNacimiento').value;
            if (fechaNac) {
                const hoy = new Date();
                const cumpleanos = new Date(fechaNac);
                let edad = hoy.getFullYear() - cumpleanos.getFullYear();
                const m = hoy.getMonth() - cumpleanos.getMonth();
                if (m < 0 || (m === 0 && hoy.getDate() < cumpleanos.getDate())) {
                    edad--;
                }
                document.getElementById('edad').value = edad;
            }
        }

        document.getElementById('Matricula').addEventListener('blur', function() {
            const matricula = this.value.trim();
            if (matricula) {
                fetch(`/VisitaMedica/ObtenerDatosAlumno?matricula=${matricula}`)
                    .then(response => {
                        if(!response.ok) throw new Error("No encontrado");
                        return response.json();
                    })
                    .then(data => {
                        document.getElementById('NombreCompleto').value = data.nombreCompleto;
                        document.getElementById('Carrera').value = data.carrera;
                        if(data.fechaNacimiento) {
                            document.getElementById('fechaNacimiento').value = data.fechaNacimiento;
                            calcularEdad();
                        }
                    })
                    .catch(error => console.log("Datos no encontrados en sistema central."));
            }
        });
    </script>
}