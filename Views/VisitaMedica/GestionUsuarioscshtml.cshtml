@model ControlEscolar.Models.UsuariosViewModel
@{
    ViewData["Title"] = "Gestión de Personal";
    Layout = "_LayoutSalud";
}

<div class="admin-card-white p-0 rounded-4 border-theme shadow-sm overflow-hidden fade-in">
    <div class="bg-surface p-4 border-bottom border-theme d-flex justify-content-between align-items-center">
        <h6 class="txt-title fw-bold mb-0">Control de Accesos Salud</h6>
    </div>
    <div class="table-responsive">
        <table class="table table-borderless align-middle mb-0">
            <thead class="admin-table-header">
                <tr>
                    <th class="py-3 px-4">Personal</th>
                    <th class="py-3">Correo</th>
                    <th class="py-3 text-center">Rol</th>
                    <th class="py-3 text-end px-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users)
                {
                    <tr class="border-bottom border-theme hover-bg-app">
                        <td class="px-4 py-3 fw-bold txt-title text-sm">@u.Nombre</td>
                        <td class="text-xs text-muted">@u.Email</td>
                        <td class="text-center"><span class="badge @(u.Rol.Contains("Jefe") ? "bg-error-100 txt-error" : "status-aceptado") px-3 text-xxs">@u.Rol.ToUpper()</span></td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-ghost-sep border-theme text-primary fw-bold" onclick="openR(@u.Id, '@u.Nombre')">EDITAR ROL</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>