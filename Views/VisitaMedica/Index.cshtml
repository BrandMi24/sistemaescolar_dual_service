@model IEnumerable<ControlEscolar.Models.VisitaMedica>
@{
    ViewData["Title"] = "Directorio Médico";
    Layout = "_LayoutSalud";
}

<div class="d-flex flex-column gap-4 fade-in" style="min-height: 82vh;">

    <div class="bg-surface p-4 rounded-4 border border-light shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1" style="max-width: 750px;">
            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
                <input type="text" id="searchInput" class="form-control border-0 bg-app py-2 ps-5 text-sm fw-medium shadow-none" placeholder="Buscar por nombre o matrícula...">
            </div>

            <select id="statusFilter" class="form-select border-0 bg-app txt-title fw-bold text-xs shadow-none" style="width: auto; min-width: 180px; cursor: pointer;">
                <option value="">TODOS LOS ESTADOS</option>
                <option value="SEGUIMIENTO">EN SEGUIMIENTO</option>
                <option value="CONCLUIDO">CONCLUIDOS</option>
            </select>
        </div>

        <a asp-action="Register" class="btn-primary-sep border-0 d-flex align-items-center gap-2 shadow-sm text-decoration-none py-2 px-4 text-xs fw-bold tracking-widest">
            <i class="bi bi-plus-lg"></i> REGISTRAR CONSULTA
        </a>
    </div>

    <div class="bg-surface p-0 rounded-4 border border-light shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
        <div class="table-responsive flex-grow-1">
            <table class="table table-borderless align-middle mb-0">
                <thead class="bg-app sticky-top" style="z-index: 5;">
                    <tr>
                        <th class="py-3 px-4 text-xxs fw-bold text-uppercase tracking-wider">Estudiante</th>
                        <th class="py-3 text-center text-xxs fw-bold text-uppercase tracking-wider">Matrícula</th>
                        <th class="py-3 text-xxs fw-bold text-uppercase tracking-wider">Programa / Carrera</th>
                        <th class="py-3 text-center text-xxs fw-bold text-uppercase tracking-wider">Estado</th>
                        <th class="py-3 text-end px-4 text-xxs fw-bold text-uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody id="medicoBody">
                    @foreach (var alumno in Model)
                    {
                        // Nota: Mantengo tu lógica de estatus actual
                        var esSeguimiento = true; 
                        var estadoTexto = esSeguimiento ? "SEGUIMIENTO" : "CONCLUIDO";
                        var estadoClase = esSeguimiento ? "bg-warning bg-opacity-10 text-warning border-warning" : "status-aceptado";

                        <tr class="border-bottom border-light hover-bg-app data-row" 
                            data-estado="@estadoTexto" 
                            data-search="@(alumno.NombreCompleto + " " + alumno.Matricula)">
                            <td class="px-4 py-3">
                                <div class="txt-title fw-bold text-xs text-uppercase mb-0">@alumno.NombreCompleto</div>
                                <div class="text-muted fw-bold text-xxs tracking-tighter opacity-75">
                                    ÚLTIMA ATENCIÓN: @alumno.FechaVisita.ToString("dd/MM/yyyy")
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-app text-secondary border border-light px-3 py-2 text-xxs fw-bold" style="font-family: monospace; letter-spacing: 1px;">
                                    @alumno.Matricula
                                </span>
                            </td>
                            <td>
                                <div class="text-xxs fw-bold text-secondary text-uppercase tracking-tight">@alumno.Carrera</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold border @estadoClase">
                                    @estadoTexto
                                </span>
                            </td>
                            <td class="text-end px-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="History" asp-route-id="@alumno.Matricula" 
                                       class="btn btn-sm border-0 bg-primary-100 txt-primary-dark rounded-2 py-1 px-2">
                                        <i class="bi bi-folder2-open fs-6"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem;">Mostrar:</span>
                <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs shadow-none" style="width: 70px; cursor: pointer;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                </select>
                <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
            </div>

            <nav aria-label="Navegación">
                <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                </ul>
            </nav>
        </div>
    </div>
</div>

<style>
    /* Estilos para que los botones de navegación sean visibles */
    .page-link-custom {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 12px;
        font-size: 0.7rem;
        font-weight: 700;
        border-radius: 8px !important;
        border: 1px solid #e2e8f0 !important;
        background-color: #f1f5f9 !important; /* Fondo bg-app */
        color: #1a2b6b !important; /* Texto primary-dark */
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .page-link-custom:hover {
        background-color: #e2e8f0 !important;
        color: #1a2b6b !important;
    }

    .page-item.active .page-link-custom {
        background-color: #1a2b6b !important; /* Fondo primary-dark */
        border-color: #1a2b6b !important;
        color: #ffffff !important; /* Texto blanco */
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .page-item.disabled .page-link-custom {
        opacity: 0.4;
        cursor: not-allowed;
        background-color: #f8fafc !important;
    }

    /* Utilidades de tabla */
    .hover-bg-app:hover { background-color: rgba(0,0,0,0.02) !important; }
    .badge { border-radius: 50px; padding: 6px 14px; font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .status-aceptado { background-color: #E1F7E7; color: #15803D; border: 1px solid rgba(21, 128, 61, 0.1); }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentPage = 1;

            function updateTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let statusFilter = $('#statusFilter').val();
                let rowsPerPage = parseInt($('#rowsPerPage').val());

                let $allRows = $('.data-row');
                let filteredRows = [];

                $allRows.each(function () {
                    let rowSearchData = $(this).data('search').toLowerCase();
                    let rowStatus = $(this).data('estado');

                    let matchesSearch = rowSearchData.includes(searchTerm);
                    let matchesStatus = (!statusFilter) || (rowStatus === statusFilter);

                    if (matchesSearch && matchesStatus) {
                        filteredRows.push($(this));
                    }
                    $(this).hide();
                });

                let totalRecords = filteredRows.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                
                if (currentPage > totalPages) currentPage = totalPages;

                let startIndex = (currentPage - 1) * rowsPerPage;
                let endIndex = Math.min(startIndex + rowsPerPage, totalRecords);

                for (let i = startIndex; i < endIndex; i++) {
                    filteredRows[i].show();
                }

                $('#tableInfo').text(totalRecords === 0 ? '0 REGISTROS' : `${startIndex + 1} - ${endIndex} DE ${totalRecords}`);
                renderPagination(totalPages);
            }

            function renderPagination(totalPages) {
                let html = '';
                
                // Anterior
                html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link page-link-custom" href="#" data-page="${currentPage - 1}">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>`;

                // Páginas
                for (let i = 1; i <= totalPages; i++) {
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                        <a class="page-link page-link-custom" href="#" data-page="${i}">${i}</a>
                    </li>`;
                }

                // Siguiente
                html += `<li class="page-item ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}">
                    <a class="page-link page-link-custom" href="#" data-page="${currentPage + 1}">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>`;

                $('#paginationControls').html(html);
            }

            $('#searchInput, #statusFilter, #rowsPerPage').on('input change', function() {
                currentPage = 1;
                updateTable();
            });

            $('#paginationControls').on('click', '.page-link', function(e) {
                e.preventDefault();
                let page = parseInt($(this).data('page'));
                if (page && !$(this).parent().hasClass('disabled')) {
                    currentPage = page;
                    updateTable();
                }
            });

            updateTable();
        });
    </script>
}