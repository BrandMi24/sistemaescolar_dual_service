@model ControlEscolar.Models.UsuariosViewModel
@{
    ViewData["Title"] = "Gestión de Personal Médico";
    Layout = "_LayoutSalud";
}

<div class="d-flex flex-column gap-4 fade-in" style="min-height: 82vh;">

    <div class="bg-surface p-4 rounded-4 border border-light shadow-sm d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div class="d-flex flex-column flex-md-row gap-3 flex-grow-1" style="max-width: 750px;">
            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-secondary"></i>
                <input type="text" id="searchInput" class="form-control border-0 bg-app py-2 ps-5 text-sm fw-medium shadow-none" placeholder="Buscar personal por nombre o correo...">
            </div>

            <select id="statusFilter" class="form-select border-0 bg-app txt-title fw-bold text-xs shadow-none" style="width: auto; min-width: 200px; cursor: pointer;">
                <option value="">TODOS LOS ROLES</option>
                <option value="HEAD NURSE">JEFE DE ENFERMERÍA</option>
                <option value="NURSE">ENFERMERÍA</option>
                <option value="PSYCHOLOGIST">PSICOLOGÍA</option>
                <option value="SIN ROL">SIN ASIGNACIÓN</option>
            </select>
        </div>
    </div>

    <div class="bg-surface p-0 rounded-4 border border-light shadow-sm overflow-hidden d-flex flex-column flex-grow-1">
        <div class="table-responsive flex-grow-1">
            <table class="table table-borderless align-middle mb-0">
                <thead class="bg-app sticky-top" style="z-index: 5;">
                    <tr>
                        <th class="py-3 px-4 text-xxs fw-bold text-uppercase tracking-wider">Nombre del Personal</th>
                        <th class="py-3 text-xxs fw-bold text-uppercase tracking-wider">Correo Institucional</th>
                        <th class="py-3 text-center text-xxs fw-bold text-uppercase tracking-wider">Rol Actual</th>
                        <th class="py-3 text-end px-4 text-xxs fw-bold text-uppercase tracking-wider">Acciones</th>
                    </tr>
                </thead>
                <tbody id="usuariosBody">
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        @foreach (var usuario in Model.Users)
                        {
                            var tieneRolSalud = usuario.Rol == "Nurse" || usuario.Rol == "Head Nurse" || usuario.Rol == "Psychologist";
                            var rolLimpio = string.IsNullOrEmpty(usuario.Rol) ? "SIN ROL" : usuario.Rol.ToUpper();
                            
                            // Mapeo de colores del Design System
                            var statusClass = "bg-app text-secondary border"; // Default
                            if (rolLimpio.Contains("HEAD")) statusClass = "status-aceptado";
                            else if (rolLimpio.Contains("NURSE") || rolLimpio.Contains("PSYCH")) statusClass = "status-pendiente";
                            else if (rolLimpio.Contains("SIN")) statusClass = "status-rechazado";

                            <tr class="border-bottom border-light hover-bg-app data-row" 
                                data-estado="@rolLimpio" 
                                data-search="@(usuario.Nombre + " " + usuario.Email)">
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="user-initial-avatar shadow-sm" style="width:35px; height:35px; font-size: 0.75rem; background-color: var(--accent-100); color: var(--primary-900);">
                                            @(string.IsNullOrEmpty(usuario.Nombre) ? "?" : usuario.Nombre.Substring(0, 1).ToUpper())
                                        </div>
                                        <div class="txt-title fw-bold text-xs text-uppercase">@usuario.Nombre</div>
                                    </div>
                                </td>
                                <td class="text-secondary fw-medium text-xs">@usuario.Email</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill px-3 py-2 text-xxs fw-bold border @statusClass">
                                        @rolLimpio
                                    </span>
                                </td>
                                <td class="text-end px-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-sm border-0 bg-primary-100 txt-primary-dark rounded-2 py-1 px-3 text-xxs fw-bold tracking-widest"
                                                onclick="abrirModalRol(@usuario.Id, '@usuario.Nombre')">
                                            EDITAR ROL
                                        </button>
                                        @if (tieneRolSalud)
                                        {
                                            <button type="button" class="btn btn-sm border-0 bg-error-100 text-danger rounded-2 py-1 px-2"
                                                    onclick="confirmarQuitarRol(@usuario.Id, '@usuario.Nombre', '@usuario.Rol')">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem;">Mostrar:</span>
                <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs shadow-none" style="width: 70px; cursor: pointer;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                </select>
                <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
            </div>

            <nav aria-label="Navegación de usuarios">
                <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                </ul>
            </nav>
        </div>
    </div>
</div>

@* MODAL EDITAR ROL (ESTILO LIMPIO) *@
<div class="modal fade" id="modalRol" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-primary-dark text-white p-4 border-0">
                <h6 class="modal-title fw-bold text-uppercase tracking-widest text-white">Actualizar Perfil de Acceso</h6>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-app">
                <div class="bg-white p-3 rounded-3 border border-light mb-4 d-flex align-items-center gap-3 shadow-sm">
                    <i class="bi bi-info-circle-fill fs-4 txt-primary-dark"></i>
                    <div class="text-xxs fw-bold text-secondary text-uppercase tracking-tighter">
                        Modificando permisos para:<br />
                        <span id="modalUserName" class="txt-title text-xs"></span>
                    </div>
                </div>
                <input type="hidden" id="inputUsuarioId" />
                <div class="px-1">
                    <label class="text-xxs fw-bold text-muted text-uppercase tracking-widest mb-2 d-block">Nueva Asignación de Rol</label>
                    <select id="selectRolId" class="form-select border-0 py-2 fw-bold text-sm txt-primary-dark shadow-sm">
                        <option value="5">ENFERMERA(O)</option>
                        <option value="6">PSICÓLOGA(O)</option>
                        <option value="4">JEFE DE ENFERMERÍA</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer bg-white border-top border-light p-3 d-flex justify-content-between">
                <span id="modalMsg" class="text-xxs fw-bold"></span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm bg-app text-secondary border-0 px-4 py-2 text-xxs fw-bold tracking-widest" data-bs-dismiss="modal">CANCELAR</button>
                    <button type="button" class="btn-primary-sep border-0 px-4 py-2 text-xxs fw-bold tracking-widest shadow-sm" id="btnGuardarRol" onclick="guardarCambioRol()">
                        GUARDAR CAMBIOS
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@* MODAL CONFIRMAR QUITAR *@
<div class="modal fade" id="modalQuitarRol" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-body p-4 text-center">
                <div class="bg-error-100 text-danger rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-exclamation-triangle fs-2"></i>
                </div>
                <h6 class="txt-title fw-bold text-uppercase tracking-wide">Revocar Acceso</h6>
                <p class="text-xs text-muted mb-4">
                    ¿Seguro que deseas quitar el rol de <strong id="quitarRolNombre"></strong> a <strong id="quitarRolUsuario"></strong>? 
                    Esta acción es inmediata.
                </p>
                <div class="d-grid gap-2">
                    <button type="button" class="btn btn-danger py-2 text-xxs fw-bold tracking-widest shadow-sm" onclick="ejecutarQuitarRol()" id="btnConfirmarQuitar">CONFIRMAR REVOCACIÓN</button>
                    <button type="button" class="btn btn-ghost-sep border-0 py-2 text-xxs fw-bold tracking-widest" data-bs-dismiss="modal">CANCELAR</button>
                </div>
                <div id="modalQuitarMsg" class="mt-2 text-xxs fw-bold"></div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Clases de utilidad para igualar el sistema de Ciclos */
    .hover-bg-app:hover { background-color: rgba(0,0,0,0.02) !important; }
    .user-initial-avatar { display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; }
    
    /* Botones de Paginación Visibles */
    .page-link-custom {
        display: flex; align-items: center; justify-content: center;
        min-width: 32px; height: 32px; padding: 0 12px;
        font-size: 0.7rem; font-weight: 700; border-radius: 8px !important;
        border: 1px solid var(--border-color); background-color: #f1f5f9; color: var(--primary-900);
        text-decoration: none; transition: all 0.2s;
    }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900) !important;
        border-color: var(--primary-900) !important;
        color: white !important;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
</style>

@section Scripts {
    <script>
        let currentPage = 1;
        let usuarioIdQuitar = null;

        $(document).ready(function () {
            // Lógica de Tabla (Filtro y Paginación)
            function updateTable() {
                let searchTerm = $('#searchInput').val().toLowerCase();
                let statusFilter = $('#statusFilter').val();
                let rowsPerPage = parseInt($('#rowsPerPage').val());

                let $allRows = $('.data-row');
                let filteredRows = [];

                $allRows.each(function () {
                    let rowData = $(this).data('search').toLowerCase();
                    let rowEstado = $(this).data('estado');

                    let matchesSearch = rowData.includes(searchTerm);
                    let matchesStatus = (!statusFilter) || (rowEstado.includes(statusFilter));

                    if (matchesSearch && matchesStatus) {
                        filteredRows.push($(this));
                    }
                    $(this).hide();
                });

                let totalRecords = filteredRows.length;
                let totalPages = Math.ceil(totalRecords / rowsPerPage) || 1;
                if (currentPage > totalPages) currentPage = totalPages;

                let start = (currentPage - 1) * rowsPerPage;
                let end = Math.min(start + rowsPerPage, totalRecords);

                for (let i = start; i < end; i++) {
                    filteredRows[i].show();
                }

                $('#tableInfo').text(totalRecords === 0 ? '0 REGISTROS' : `${start + 1} - ${end} DE ${totalRecords}`);
                renderPager(totalPages);
            }

            function renderPager(pages) {
                let html = `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}"><a class="page-link page-link-custom" href="#" data-page="${currentPage - 1}"><i class="bi bi-chevron-left"></i></a></li>`;
                for (let i = 1; i <= pages; i++) {
                    html += `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link page-link-custom" href="#" data-page="${i}">${i}</a></li>`;
                }
                html += `<li class="page-item ${currentPage === pages || pages === 0 ? 'disabled' : ''}"><a class="page-link page-link-custom" href="#" data-page="${currentPage + 1}"><i class="bi bi-chevron-right"></i></a></li>`;
                $('#paginationControls').html(html);
            }

            $('#searchInput, #statusFilter, #rowsPerPage').on('input change', function() {
                currentPage = 1;
                updateTable();
            });

            $(document).on('click', '.page-link', function(e) {
                e.preventDefault();
                let p = parseInt($(this).data('page'));
                if (p && p !== currentPage) { currentPage = p; updateTable(); }
            });

            updateTable();
        });

        // FUNCIONES DE MODAL
        function abrirModalRol(id, nombre) {
            $('#inputUsuarioId').val(id);
            $('#modalUserName').text(nombre);
            $('#modalMsg').text('');
            new bootstrap.Modal('#modalRol').show();
        }

        async function guardarCambioRol() {
            const $btn = $('#btnGuardarRol');
            const userId = $('#inputUsuarioId').val();
            const rolId = $('#selectRolId').val();

            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> GUARDANDO...');

            try {
                const response = await fetch('@Url.Action("AsignarRol", "VisitaMedica")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: parseInt(userId), rolId: parseInt(rolId) })
                });
                const result = await response.json();
                if (result.success) location.reload();
                else {
                    $('#modalMsg').text(result.message).addClass('text-danger');
                    $btn.prop('disabled', false).text('GUARDAR CAMBIOS');
                }
            } catch {
                $('#modalMsg').text('Error de conexión.').addClass('text-danger');
                $btn.prop('disabled', false).text('GUARDAR CAMBIOS');
            }
        }

        function confirmarQuitarRol(userId, nombre, rol) {
            usuarioIdQuitar = userId;
            $('#quitarRolUsuario').text(nombre);
            $('#quitarRolNombre').text(rol.toUpperCase());
            new bootstrap.Modal('#modalQuitarRol').show();
        }

        async function ejecutarQuitarRol() {
            const $btn = $('#btnConfirmarQuitar');
            $btn.prop('disabled', true).text('PROCESANDO...');

            try {
                const response = await fetch('/VisitaMedica/QuitarRol', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId: usuarioIdQuitar })
                });
                const data = await response.json();
                if (data.success) {
                    $('#modalQuitarMsg').text('Revocado con éxito').addClass('text-success');
                    setTimeout(() => location.reload(), 800);
                } else {
                    alert(data.message);
                    $btn.prop('disabled', false).text('CONFIRMAR REVOCACIÓN');
                }
            } catch {
                alert('Error de conexión');
                $btn.prop('disabled', false).text('CONFIRMAR REVOCACIÓN');
            }
        }
    </script>
}