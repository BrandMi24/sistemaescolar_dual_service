@model ControlEscolar.Models.UsuariosViewModel
@{
    ViewData["Title"] = "Gestión de Personal Médico";
    Layout = "_LayoutSalud";
}

<div class="admin-card-white shadow-sm border-0 p-0 rounded-4 overflow-hidden fade-in mb-5">

    @* ── Cabecera ── *@
    <div class="bg-surface p-4 border-bottom border-theme d-flex flex-column gap-3">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h5 class="txt-primary-dark fw-bold mb-1">
                    <i class="bi bi-person-gear me-2"></i>Control de Accesos Médicos
                </h5>
                <p class="text-muted text-xxs text-uppercase tracking-wide mb-0">
                    Administración de permisos para Enfermería y Psicología
                </p>
            </div>
            <div class="position-relative" style="max-width: 320px; width: 100%;">
                <i class="bi bi-search position-absolute text-muted" style="top: 50%; left: 14px; transform: translateY(-50%); pointer-events:none;"></i>
                <input type="text" id="searchInput" class="form-control ps-5"
                       placeholder="Buscar por nombre..."
                       style="height: 40px; border-radius: 8px; border: 1px solid var(--border-color); box-shadow: none; background-color: var(--app-bg);">
            </div>
        </div>
        <div class="d-flex align-items-center gap-3">
            <button id="btnSort" class="btn btn-sm d-flex align-items-center gap-2 fw-bold px-3"
                    style="height: 36px; border-radius: 8px; border: 1.5px solid var(--border-color); background-color: var(--app-bg);">
                <i class="bi bi-sort-alpha-down" id="sortIcon"></i>
                <span id="sortLabel">A → Z</span>
            </button>
        </div>
    </div>

    @* ── Tabla ── *@
    <div class="table-responsive custom-scroll">
        <table class="table table-hover align-middle table-borderless mb-0">
            <thead class="admin-table-header text-xxs">
                <tr>
                    <th class="ps-4 py-3">NOMBRE DEL PERSONAL</th>
                    <th>CORREO INSTITUCIONAL</th>
                    <th class="text-center">ROL ACTUAL</th>
                    <th class="text-end pe-4">ACCIONES</th>
                </tr>
            </thead>
            <tbody id="tbodyUsuarios">
                @if (Model.Users != null && Model.Users.Any())
                {
                    @foreach (var usuario in Model.Users)
                    {
                        var tieneRolSalud = usuario.Rol.Contains("Nurse") || usuario.Rol.Contains("Head Nurse") || usuario.Rol.Contains("Physicologyst");
                        var statusClass = "status-pendiente";
                        if (usuario.Rol.Contains("Head") || usuario.Rol.Contains("Jefe"))
                            statusClass = "status-aceptado";
                        else if (usuario.Rol.Contains("Sin") || string.IsNullOrEmpty(usuario.Rol))
                            statusClass = "status-rechazado";

                        <tr class="border-bottom border-theme hover-bg-app fila-usuario"
                            data-nombre="@usuario.Nombre.ToLower()"
                            data-id="@usuario.Id"
                            data-nombre-safe="@Uri.EscapeDataString(usuario.Nombre)"
                            data-rol="@usuario.Rol"
                            data-tiene-rol-salud="@tieneRolSalud.ToString().ToLower()">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-sm bg-primary-100 txt-primary-dark fw-bold d-flex align-items-center justify-content-center rounded-circle">
                                        @(string.IsNullOrEmpty(usuario.Nombre) ? "?" : usuario.Nombre.Substring(0, 1).ToUpper())
                                    </div>
                                    <span class="fw-semibold txt-title nombre-celda">@usuario.Nombre</span>
                                </div>
                            </td>
                            <td class="text-muted text-xs">@usuario.Email</td>
                            <td class="text-center">
                                <span class="badge badge-status @statusClass shadow-sm px-3 text-xxs">
                                    @(string.IsNullOrEmpty(usuario.Rol) ? "SIN ROL" : usuario.Rol.ToUpper())
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-ghost-sep border-theme text-primary fw-bold text-xxs py-2 btn-editar-rol">
                                    <i class="bi bi-pencil-square me-1"></i> EDITAR ROL
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center py-5 text-muted">No se encontraron usuarios activos.</td></tr>
                }
            </tbody>
        </table>
        <div id="sinResultados" class="text-center py-5 text-muted d-none">
            <i class="bi bi-search fs-3 mb-2 d-block"></i>
            <span class="text-sm fw-bold">No se encontraron resultados</span>
        </div>

        <div class="bg-white p-3 border-top border-light d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="text-secondary fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem;">Mostrar:</span>
                <select id="rowsPerPage" class="form-select form-select-sm border-0 bg-app fw-bold text-xs shadow-none" style="width: 70px; cursor: pointer;">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                </select>
                <div id="tableInfo" class="txt-primary-dark fw-bold text-uppercase tracking-tighter" style="font-size: 0.65rem; opacity: 0.8;"></div>
            </div>

            <nav aria-label="Navegación de usuarios">
                <ul class="pagination pagination-sm mb-0 gap-1" id="paginationControls">
                </ul>
            </nav>
        </div>
    </div>
</div>

@* ── Modal ── *@
<div class="modal fade" id="modalRol" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 ps-4 pt-4">
                <h5 class="txt-primary-dark fw-bold mb-0">Actualizar Perfil Médico</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-app">
                <div class="bg-white p-3 rounded-3 border border-light mb-4 d-flex align-items-center gap-3 shadow-sm">
                    <i class="bi bi-info-circle-fill fs-4 txt-primary-dark"></i>
                    <div class="text-xs">
                        Modificando permisos de:<br />
                        <strong id="modalUserName" class="txt-title text-sm"></strong>
                    </div>
                </div>

                <input type="hidden" id="inputUsuarioId" />

                <div class="mb-4">
                    <label class="text-muted mb-2 d-block text-xxs fw-bold">NUEVA ASIGNACIÓN</label>
                    <select id="selectRolId" class="form-select form-select-lg fw-semibold text-sm border-theme">
                        <option value="5">ENFERMERA(O)</option>
                        <option value="6">PSICÓLOGA(O)</option>
                        <option value="4">JEFE DE ENFERMERÍA</option>
                    </select>
                </div>

                <div id="seccionQuitarRol" class="d-none border-top border-theme pt-4 mt-2">
                    <p class="text-xs text-muted fw-bold text-uppercase mb-2">Zona de riesgo</p>
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3"
                         style="background-color:#fff5f5; border:1px solid #fecaca;">
                        <div>
                            <p class="text-sm fw-bold mb-0" style="color:#dc2626;">Quitar rol asignado</p>
                            <p class="text-xs text-muted mb-0">Revoca el acceso al módulo correspondiente.</p>
                        </div>
                        <button type="button" id="btnQuitarRol" class="btn btn-sm fw-bold text-xxs px-3"
                                style="background-color:#dc2626; color:white; border-radius:6px;">
                            <i class="bi bi-x-lg me-1"></i> QUITAR ROL
                        </button>
                    </div>
                    <div id="confirmacionQuitar" class="d-none mt-3 p-3 rounded-3"
                         style="background-color:#fef2f2; border:1px solid #fca5a5;">
                        <p class="text-sm fw-semibold mb-3" style="color:#dc2626;">
                            ¿Confirmas quitar el rol a <span id="confirmarNombreUsuario"></span>?
                        </p>
                        <div class="d-flex gap-2">
                            <button type="button" id="btnCancelarQuitar"
                                    class="btn btn-sm btn-ghost-sep border-theme fw-bold text-xxs px-3">
                                CANCELAR
                            </button>
                            <button type="button" id="btnConfirmarQuitar"
                                    class="btn btn-sm fw-bold text-xxs px-3"
                                    style="background-color:#dc2626; color:white; border-radius:6px;">
                                <i class="bi bi-check-lg me-1"></i> SÍ, QUITAR
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 d-flex justify-content-between align-items-center">
                <span id="modalMsg" class="text-xs fw-bold"></span>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-ghost-sep text-xxs px-4 fw-bold" data-bs-dismiss="modal">CANCELAR</button>
                    <button type="button" id="btnGuardarRol" class="btn btn-primary-sep text-xxs px-4 fw-bold">
                        <i class="bi bi-check-lg me-1"></i> GUARDAR CAMBIOS
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Clases de utilidad para igualar el sistema de Ciclos */
    .hover-bg-app:hover { background-color: rgba(0,0,0,0.02) !important; }
    .user-initial-avatar { display: flex; align-items: center; justify-content: center; border-radius: 50%; font-weight: 800; }
    
    /* Botones de Paginación Visibles */
    .page-link-custom {
        display: flex; align-items: center; justify-content: center;
        min-width: 32px; height: 32px; padding: 0 12px;
        font-size: 0.7rem; font-weight: 700; border-radius: 8px !important;
        border: 1px solid var(--border-color); background-color: #f1f5f9; color: var(--primary-900);
        text-decoration: none; transition: all 0.2s;
    }

    .page-item.active .page-link-custom {
        background-color: var(--primary-900) !important;
        border-color: var(--primary-900) !important;
        color: white !important;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
</style>

@section Scripts {
    <script>
        $(function () {
            var urlAsignar   = '@Url.Action("AsignarRol", "VisitaMedica")';
            var urlQuitarRol = '@Url.Action("QuitarRol", "VisitaMedica")';
            var sortDir      = 'asc';

            // ── Buscador ─────────────────────────────────────────────────────────────
            $('#searchInput').on('input', function () {
                var term = $(this).val().toLowerCase().trim();
                var visibles = 0;
                $('#tbodyUsuarios tr.fila-usuario').each(function () {
                    var nombre = $(this).find('.nombre-celda').text().toLowerCase();
                    var ok = nombre.indexOf(term) >= 0;
                    $(this).toggle(ok);
                    if (ok) visibles++;
                });
                $('#sinResultados').toggleClass('d-none', visibles > 0);
            });

            // ── Ordenar ───────────────────────────────────────────────────────────────
            $('#btnSort').on('click', function () {
                sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                $('#sortIcon').attr('class', sortDir === 'asc' ? 'bi bi-sort-alpha-down' : 'bi bi-sort-alpha-down-alt');
                $('#sortLabel').text(sortDir === 'asc' ? 'A → Z' : 'Z → A');
                var filas = $('#tbodyUsuarios tr.fila-usuario').get();
                filas.sort(function (a, b) {
                    var na = $(a).data('nombre') || '';
                    var nb = $(b).data('nombre') || '';
                    return sortDir === 'asc' ? na.localeCompare(nb, 'es') : nb.localeCompare(na, 'es');
                });
                $.each(filas, function (i, f) { $('#tbodyUsuarios').append(f); });
            });

            // ── Abrir modal ───────────────────────────────────────────────────────────
            $('#tbodyUsuarios').on('click', '.btn-editar-rol', function () {
                var fila         = $(this).closest('tr');
                var id           = fila.data('id');
                var nombreSafe   = fila.data('nombre-safe');
                var nombre       = decodeURIComponent(nombreSafe);
                var tieneRol     = fila.data('tiene-rol-salud') === true || fila.data('tiene-rol-salud') === 'true';

                $('#inputUsuarioId').val(id);
                $('#modalUserName').text(nombre);
                $('#confirmarNombreUsuario').text(nombre);
                $('#modalMsg').text('').attr('class', 'text-xs fw-bold');
                $('#btnGuardarRol').prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> GUARDAR CAMBIOS');
                $('#confirmacionQuitar').addClass('d-none');
                $('#btnQuitarRol').prop('disabled', false).html('<i class="bi bi-x-lg me-1"></i> QUITAR ROL').removeClass('d-none');

                if (tieneRol) {
                    $('#seccionQuitarRol').removeClass('d-none');
                } else {
                    $('#seccionQuitarRol').addClass('d-none');
                }

                $('#modalRol').modal('show');
            });

            // ── Guardar rol ───────────────────────────────────────────────────────────
            $('#btnGuardarRol').on('click', function () {
                var userId = parseInt($('#inputUsuarioId').val());
                var rolId  = parseInt($('#selectRolId').val());
                var $btn   = $(this);

                if (!userId) return;

                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> PROCESANDO...');

                $.ajax({
                    url:         urlAsignar,
                    type:        'POST',
                    contentType: 'application/json',
                    data:        JSON.stringify({ userId: userId, rolId: rolId }),
                    success: function (data) {
                        if (data.success) {
                            $('#modalMsg').text('✓ Rol asignado correctamente.').attr('class', 'text-xs fw-bold text-success');
                            setTimeout(function () { location.reload(); }, 900);
                        } else {
                            $('#modalMsg').text(data.message || 'Error al asignar el rol.').attr('class', 'text-xs fw-bold text-danger');
                            $btn.prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> GUARDAR CAMBIOS');
                        }
                    },
                    error: function () {
                        $('#modalMsg').text('Error de conexión.').attr('class', 'text-xs fw-bold text-danger');
                        $btn.prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> GUARDAR CAMBIOS');
                    }
                });
            });

            // ── Quitar rol: mostrar confirmación ──────────────────────────────────────
            $('#btnQuitarRol').on('click', function () {
                $('#confirmacionQuitar').removeClass('d-none');
                $(this).addClass('d-none');
            });

            $('#btnCancelarQuitar').on('click', function () {
                $('#confirmacionQuitar').addClass('d-none');
                $('#btnQuitarRol').prop('disabled', false)
                                 .html('<i class="bi bi-x-lg me-1"></i> QUITAR ROL')
                                 .removeClass('d-none');
            });

            // ── Quitar rol: confirmar ─────────────────────────────────────────────────
            $('#btnConfirmarQuitar').on('click', function () {
                var userId = parseInt($('#inputUsuarioId').val());
                var $btn   = $(this);

                if (!userId) return;

                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Quitando...');

                $.ajax({
                    url:         urlQuitarRol,
                    type:        'POST',
                    contentType: 'application/json',
                    data:        JSON.stringify({ userId: userId }),
                    success: function (data) {
                        if (data.success) {
                            $('#modalMsg').text('✓ Rol eliminado correctamente.').attr('class', 'text-xs fw-bold text-success');
                            setTimeout(function () { location.reload(); }, 900);
                        } else {
                            $('#modalMsg').text(data.message || 'Error al quitar el rol.').attr('class', 'text-xs fw-bold text-danger');
                            $btn.prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> SÍ, QUITAR');
                        }
                    },
                    error: function () {
                        $('#modalMsg').text('Error de conexión.').attr('class', 'text-xs fw-bold text-danger');
                        $btn.prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i> SÍ, QUITAR');
                    }
                });
            });
        });
    </script>
}